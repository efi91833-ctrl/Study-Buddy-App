// ── Custom label storage (user-drawn boxes override built-in placeholders) ──
function getCustomLabels() {
  try { return JSON.parse(localStorage.getItem('anatomy_custom_labels') || '{}'); }
  catch { return {}; }
}
// On startup: load labels.json from disk and merge into localStorage
// (runs once; localStorage takes priority so in-session edits are not overwritten)
(function loadLabelsFromDisk() {
  fetch('/labels.json')
    .then(r => r.ok ? r.json() : null)
    .then(disk => {
      if (!disk) return;
      const local = getCustomLabels();
      // Merge: disk entries fill in any slides missing from localStorage
      let changed = false;
      Object.keys(disk).forEach(k => {
        if (!local[k] || local[k].length === 0) {
          local[k] = disk[k];
          changed = true;
        }
      });
      if (changed) localStorage.setItem('anatomy_custom_labels', JSON.stringify(local));
    })
    .catch(() => {});
})();
function saveCustomLabelsForSlide(slideId, labels) {
  const all = getCustomLabels();
  all[slideId] = labels;
  const json = JSON.stringify(all);
  localStorage.setItem('anatomy_custom_labels', json);
  // Also persist to labels.json on disk so boxes survive browser clears
  fetch('/save-labels', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: json,
  }).catch(() => {}); // silent if server not running
}
// Returns user-drawn boxes for this slide (from localStorage), then built-in defaults
function getLabelsForSlide(slideId) {
  const custom = getCustomLabels();
  if (custom[slideId] && custom[slideId].length > 0) return custom[slideId];
  for (const test of ANATOMY_SLIDE_TESTS) {
    const slide = test.slides.find(s => s.slideId === slideId);
    if (slide) return slide.labels;
  }
  return [];
}


// ─────────────────────────────────────────────────────────────
// QUESTION BANK  (add new subjects/questions here only)
// ─────────────────────────────────────────────────────────────
const QUESTION_BANK = {
  Histology: {
    color: '#888',
    icon: '',
    description: 'Microscopic structure of tissues',
    exams: [
      { name: 'Histo 1',  questions: [
  {id:"histo1-001",topic:"Skin",subtopic:"Epidermal barrier",difficulty:"Hard",question:"Which epidermal structure is most directly responsible for forming the water barrier?",options:{A:"Keratohyaline granules",B:"Lamellar granules",C:"Melanosomes",D:"Desmosomes"},correct:"B",explanation:"Lamellar granules release lipids into intercellular spaces, forming the epidermal water barrier."},
  {id:"histo1-002",topic:"Skin",subtopic:"Melanocytes",difficulty:"Hard",question:"Which statement about melanocytes is correct?",options:{A:"They are joined to keratinocytes by desmosomes",B:"They originate from mesoderm",C:"They transfer melanosomes to keratinocytes",D:"Their number differs mainly by race"},correct:"C",explanation:"Melanocytes are neural crest-derived cells that transfer melanosomes to keratinocytes by cytocrine secretion."},
  {id:"histo1-003",topic:"Skin",subtopic:"Thick vs thin skin",difficulty:"Medium",question:"Which feature is typical of thick skin?",options:{A:"Absence of hair follicles and sebaceous glands",B:"Absence of stratum corneum",C:"Presence of only four epidermal layers",D:"Presence of abundant hair follicles"},correct:"A",explanation:"Thick skin has five epidermal layers, including stratum lucidum, and lacks hair follicles and sebaceous glands."},
  {id:"histo1-004",topic:"GIT",subtopic:"Enteric plexuses",difficulty:"Hard",question:"Which pairing is correct?",options:{A:"Meissner plexus — between circular and longitudinal muscle",B:"Auerbach plexus — in lamina propria",C:"Meissner plexus — controls mainly skeletal muscle",D:"Auerbach plexus — between muscle layers of tunica muscularis"},correct:"D",explanation:"Auerbach myenteric plexus lies between the circular and longitudinal muscle layers and regulates motility."},
  {id:"histo1-005",topic:"GIT",subtopic:"Esophagus",difficulty:"Hard",question:"The esophageal epithelium is best described as:",options:{A:"Stratified squamous non-keratinized epithelium",B:"Simple columnar mucus-secreting epithelium",C:"Pseudostratified ciliated columnar epithelium",D:"Transitional epithelium"},correct:"A",explanation:"The esophagus is lined by stratified squamous non-keratinized epithelium for mechanical protection."},
  {id:"histo1-006",topic:"GIT",subtopic:"Stomach",difficulty:"Very hard",question:"Which stomach region has deep gastric pits and coiled mucous glands?",options:{A:"Fundus",B:"Pylorus",C:"Corpus",D:"Esophagus"},correct:"B",explanation:"The pyloric region has narrow deep pits and branched coiled mucous glands."},
  {id:"histo1-007",topic:"Liver",subtopic:"Sinusoids",difficulty:"Very hard",question:"Which structure is located between hepatocytes and sinusoidal endothelium?",options:{A:"Canal of Hering",B:"Portal tract",C:"Space of Disse",D:"Central vein"},correct:"C",explanation:"The space of Disse lies between hepatocytes and fenestrated sinusoidal endothelium."},
  {id:"histo1-008",topic:"Liver",subtopic:"Portal triad",difficulty:"Hard",question:"Which combination belongs to the portal triad?",options:{A:"Central vein, hepatic artery, bile canaliculus",B:"Portal vein, central vein, lymphatic vessel",C:"Sinusoid, bile canaliculus, Kupffer cell",D:"Interlobular vein, interlobular artery, interlobular bile duct"},correct:"D",explanation:"The portal triad contains branches of portal vein, hepatic artery, and bile duct."},
  {id:"histo1-009",topic:"Respiratory",subtopic:"Conducting epithelium",difficulty:"Hard",question:"The physiological ratio of goblet cells to ciliated cells in conducting epithelium is approximately:",options:{A:"1:1",B:"1:5",C:"5:1",D:"1:20"},correct:"B",explanation:"In normal conducting respiratory epithelium, goblet cells are fewer than ciliated cells, about 1:5."},
  {id:"histo1-010",topic:"Respiratory",subtopic:"Epiglottis",difficulty:"Very hard",question:"Which statement about the epiglottis is correct?",options:{A:"It contains elastic cartilage and different epithelia on its two surfaces",B:"It contains hyaline cartilage only",C:"Both surfaces are lined by keratinized stratified squamous epithelium",D:"It has no glands in the lamina propria"},correct:"A",explanation:"The epiglottis has elastic cartilage; the lingual surface is stratified squamous, while the laryngeal surface is respiratory epithelium."},
  {id:"histo1-011",topic:"Urinary",subtopic:"Nephron location",difficulty:"Medium",question:"Which nephron component is always located in the renal cortex?",options:{A:"Thin descending limb",B:"Papillary duct",C:"Renal corpuscle",D:"Loop of Henle bend"},correct:"C",explanation:"Renal corpuscles are always located in the cortex."},
  {id:"histo1-012",topic:"Urinary",subtopic:"Juxtamedullary nephrons",difficulty:"Hard",question:"Juxtamedullary nephrons are characterized by:",options:{A:"Renal corpuscles high in the cortex and short loops",B:"Absence of thin limbs",C:"Loops restricted to cortex",D:"Renal corpuscles near the medulla and long loops of Henle"},correct:"D",explanation:"Juxtamedullary nephrons have corpuscles near the medulla and long loops of Henle."},
  {id:"histo1-013",topic:"Endocrine",subtopic:"Adenohypophysis",difficulty:"Very hard",question:"Which adenohypophyseal cells are acidophils?",options:{A:"Somatotrophs and lactotrophs",B:"Corticotrophs and thyrotrophs",C:"Gonadotrophs and corticotrophs",D:"Chromophobes and thyrotrophs"},correct:"A",explanation:"Somatotrophs produce GH and lactotrophs produce prolactin; both are acidophils."},
  {id:"histo1-014",topic:"Endocrine",subtopic:"Hormone receptors",difficulty:"Very hard",question:"Which hormones bind intracellular receptors?",options:{A:"Peptide hormones and catecholamines",B:"Steroid hormones and thyroid hormones",C:"Only glycoprotein hormones",D:"Only catecholamines"},correct:"B",explanation:"Steroid and thyroid hormones are lipophilic and bind intracellular receptors."},
  {id:"histo1-015",topic:"Male reproductive",subtopic:"Blood-testis barrier",difficulty:"Very hard",question:"Which cells form the blood-testis barrier?",options:{A:"Leydig cells",B:"Myoid cells",C:"Sertoli cells",D:"Spermatogonia"},correct:"C",explanation:"The blood-testis barrier is formed by tight junctions between Sertoli cells."},
  {id:"histo1-016",topic:"Male reproductive",subtopic:"Spermatogenesis",difficulty:"Very hard",question:"Which cell is haploid but still contains chromosomes with two chromatids?",options:{A:"Type B spermatogonium",B:"Primary spermatocyte",C:"Spermatid",D:"Secondary spermatocyte"},correct:"D",explanation:"Secondary spermatocytes are haploid with 23 chromosomes, each still composed of two chromatids."},
  {id:"histo1-017",topic:"Female reproductive",subtopic:"Oogenesis",difficulty:"Very hard",question:"A primary oocyte in a primordial follicle is arrested in:",options:{A:"Diplotene stage of prophase I",B:"Metaphase II",C:"Anaphase I",D:"Telophase II"},correct:"A",explanation:"Primary oocytes begin meiosis prenatally and arrest in diplotene of prophase I."},
  {id:"histo1-018",topic:"Female reproductive",subtopic:"Follicles",difficulty:"Hard",question:"Which feature defines a unilaminar primary follicle?",options:{A:"Multiple granulosa layers and an antrum",B:"A single layer of cuboidal follicular cells around a primary oocyte",C:"Secondary oocyte in metaphase II",D:"Corpus luteum formation"},correct:"B",explanation:"A unilaminar primary follicle has one layer of cuboidal follicular cells and a growing primary oocyte."},
  {id:"histo1-019",topic:"Tooth development",subtopic:"Dental lamina",difficulty:"Hard",question:"Dental lamina develops from:",options:{A:"Neural tube",B:"Mesoderm",C:"Oral ectoderm",D:"Endoderm"},correct:"C",explanation:"Dental lamina forms from the epithelial lining of the oral cavity, which is ectodermal."},
  {id:"histo1-020",topic:"Tooth development",subtopic:"Cap stage",difficulty:"Very hard",question:"Which structures together form the enamel organ in the cap stage?",options:{A:"Dental papilla, dental sac, odontoblasts",B:"Dental lamina, dental sac, pulp",C:"Odontoblasts, cementoblasts, dental pulp",D:"Outer enamel epithelium, inner enamel epithelium, stellate reticulum"},correct:"D",explanation:"The enamel organ consists of outer enamel epithelium, inner enamel epithelium, and stellate reticulum."},
  {id:"histo1-021",topic:"Lymphatic",subtopic:"Lymph node cortex",difficulty:"Hard",question:"Which region of a lymph node is B-cell dependent?",options:{A:"Medullary sinus",B:"Cortex with lymphoid follicles",C:"Paracortex",D:"Hilum"},correct:"B",explanation:"Lymphoid follicles in the cortex are B-dependent areas."},
  {id:"histo1-022",topic:"Lymphatic",subtopic:"Paracortex",difficulty:"Very hard",question:"Which structure is typical of the paracortex of a lymph node?",options:{A:"High endothelial venules",B:"Hassall corpuscles",C:"Red pulp cords",D:"Central artery"},correct:"A",explanation:"The paracortex is T-cell dependent and contains high endothelial venules."},
  {id:"histo1-023",topic:"Cardiovascular",subtopic:"Endothelium",difficulty:"Hard",question:"Weibel-Palade bodies store:",options:{A:"Collagen type II and elastin",B:"Hemoglobin and ferritin",C:"von Willebrand factor and P-selectin",D:"Renin and erythropoietin"},correct:"C",explanation:"Weibel-Palade bodies contain von Willebrand factor and P-selectin."},
  {id:"histo1-024",topic:"Cardiovascular",subtopic:"Myocardium",difficulty:"Medium",question:"Which junctions are found in intercalated discs?",options:{A:"Only tight junctions",B:"Only hemidesmosomes",C:"Only synapses",D:"Fascia adherens, desmosomes, and gap junctions"},correct:"D",explanation:"Intercalated discs contain fascia adherens, desmosomes, and nexus/gap junctions."},
  {id:"histo1-025",topic:"Nervous system",subtopic:"Blood-brain barrier",difficulty:"Very hard",question:"Which site normally lacks a typical blood-brain barrier?",options:{A:"Cerebral cortex",B:"Spinal cord white matter",C:"Neurohypophysis",D:"Cerebellar cortex"},correct:"C",explanation:"The BBB is absent in regions such as the neurohypophysis, hypothalamus, and choroid plexus."},
  {id:"histo1-026",topic:"Nervous system",subtopic:"CNS gray vs white matter",difficulty:"Hard",question:"Which statement best describes white matter?",options:{A:"It contains mainly neuronal perikarya",B:"It contains myelinated axons organized into tracts",C:"It lacks glial cells",D:"It consists mainly of synaptic neuropil"},correct:"B",explanation:"White matter contains mainly myelinated axons running in parallel tracts, with oligodendrocytes and other glia."},
  {id:"histo1-027",topic:"Oral cavity",subtopic:"Lip",difficulty:"Very hard",question:"Which statement about the vermilion zone of the lip is correct?",options:{A:"It has keratinized stratified squamous epithelium and highly vascularized connective tissue",B:"It contains abundant eccrine sweat glands",C:"It is lined by respiratory epithelium",D:"It contains no sebaceous glands"},correct:"A",explanation:"The vermilion zone has keratinized stratified squamous epithelium and highly vascular connective tissue; it lacks sweat and salivary glands."},
  {id:"histo1-028",topic:"Oral cavity",subtopic:"Tongue papillae",difficulty:"Hard",question:"Which papillae are the most numerous and mainly mechanical?",options:{A:"Vallate papillae",B:"Foliate papillae",C:"Fungiform papillae",D:"Filiform papillae"},correct:"D",explanation:"Filiform papillae are the most numerous, keratinized, and help mechanically move food."},
  {id:"histo1-029",topic:"Respiratory",subtopic:"Conducting portion cells",difficulty:"Very hard",question:"Small granule cells of the conducting respiratory epithelium are:",options:{A:"Neuroendocrine DNES cells",B:"Stem cells responsible for epithelial regeneration",C:"Mucus-producing cells",D:"Cells with 250–300 cilia"},correct:"A",explanation:"Small granule/Kulchitsky cells are neuroendocrine cells belonging to DNES."},
  {id:"histo1-030",topic:"Integration",subtopic:"Correct/incorrect pairings",difficulty:"Very hard",question:"Which pairing is incorrect?",options:{A:"Ito cell — vitamin A storage",B:"Kupffer cell — bile production",C:"Type II pneumocyte — surfactant",D:"Sertoli cell — inhibin"},correct:"B",explanation:"Kupffer cells are macrophages; bile is produced by hepatocytes."},
] },
      { name: 'Histo 2',  questions: [
  {id:"histo2-001",topic:"Skin",subtopic:"Keratinization",difficulty:"Very hard",question:"Which protein is directly responsible for aggregation of keratin filaments?",options:{A:"Filaggrin",B:"Desmoglein",C:"Involucrin",D:"Keratin"},correct:"A",explanation:"Filaggrin aggregates keratin filaments in the stratum granulosum."},
  {id:"histo2-002",topic:"Skin",subtopic:"Merkel cells",difficulty:"Hard",question:"Merkel cells are best described as:",options:{A:"Dendritic antigen-presenting cells",B:"Mechanoreceptors associated with nerve endings",C:"Pigment-producing cells",D:"Stem cells"},correct:"B",explanation:"Merkel cells are tactile receptors connected to sensory nerve endings."},
  {id:"histo2-003",topic:"GIT",subtopic:"Small intestine",difficulty:"Very hard",question:"Which feature is unique to the ileum?",options:{A:"Brunner glands",B:"Plicae circulares",C:"Peyer patches",D:"Gastric pits"},correct:"C",explanation:"Peyer patches are lymphoid aggregates specific to the ileum."},
  {id:"histo2-004",topic:"GIT",subtopic:"Stomach cells",difficulty:"Very hard",question:"Which cell produces intrinsic factor?",options:{A:"Chief cell",B:"Parietal cell",C:"Mucous neck cell",D:"Enteroendocrine cell"},correct:"B",explanation:"Parietal cells produce HCl and intrinsic factor."},
  {id:"histo2-005",topic:"Liver",subtopic:"Kupffer cells",difficulty:"Hard",question:"Kupffer cells originate from:",options:{A:"Endoderm",B:"Mesoderm (monocyte lineage)",C:"Neural crest",D:"Ectoderm"},correct:"B",explanation:"Kupffer cells are macrophages derived from monocytes."},
  {id:"histo2-006",topic:"Liver",subtopic:"Zonation",difficulty:"Very hard",question:"Which zone is most susceptible to hypoxia?",options:{A:"Zone I",B:"Zone II",C:"Zone III",D:"Portal area"},correct:"C",explanation:"Zone III is farthest from oxygen supply."},
  {id:"histo2-007",topic:"Respiratory",subtopic:"Alveoli",difficulty:"Very hard",question:"Which cell type regenerates alveolar epithelium?",options:{A:"Type I pneumocyte",B:"Type II pneumocyte",C:"Macrophage",D:"Endothelial cell"},correct:"B",explanation:"Type II cells proliferate and differentiate into type I cells."},
  {id:"histo2-008",topic:"Respiratory",subtopic:"Bronchioles",difficulty:"Very hard",question:"Which feature distinguishes bronchioles from bronchi?",options:{A:"Presence of cartilage",B:"Presence of smooth muscle",C:"Absence of cartilage",D:"Presence of goblet cells"},correct:"C",explanation:"Bronchioles lack cartilage."},
  {id:"histo2-009",topic:"Urinary",subtopic:"Filtration barrier",difficulty:"Very hard",question:"Which layer is most selective in filtration?",options:{A:"Endothelium",B:"Basement membrane",C:"Slit diaphragm",D:"Mesangium"},correct:"C",explanation:"Slit diaphragm is the final filtration barrier."},
  {id:"histo2-010",topic:"Urinary",subtopic:"Macula densa",difficulty:"Hard",question:"Macula densa senses:",options:{A:"Glucose levels",B:"NaCl concentration",C:"pH",D:"Oxygen"},correct:"B",explanation:"It detects NaCl for renin regulation."},
  {id:"histo2-011",topic:"Endocrine",subtopic:"Thyroid",difficulty:"Very hard",question:"Colloid mainly contains:",options:{A:"Thyroxine",B:"Thyroglobulin",C:"Calcitonin",D:"TSH"},correct:"B",explanation:"Thyroglobulin stores thyroid hormone precursors."},
  {id:"histo2-012",topic:"Endocrine",subtopic:"Adrenal gland",difficulty:"Very hard",question:"Which layer produces androgens?",options:{A:"Zona glomerulosa",B:"Zona fasciculata",C:"Zona reticularis",D:"Medulla"},correct:"C",explanation:"Zona reticularis produces weak androgens."},
  {id:"histo2-013",topic:"Nervous",subtopic:"Glial cells",difficulty:"Very hard",question:"Which cell is phagocytic in CNS?",options:{A:"Astrocyte",B:"Oligodendrocyte",C:"Microglia",D:"Ependymal"},correct:"C",explanation:"Microglia act as macrophages."},
  {id:"histo2-014",topic:"Nervous",subtopic:"Synapse",difficulty:"Hard",question:"Neurotransmitter release occurs at:",options:{A:"Dendrite",B:"Synaptic cleft",C:"Axon terminal",D:"Cell body"},correct:"C",explanation:"Release from presynaptic terminal."},
  {id:"histo2-015",topic:"Male repro",subtopic:"Leydig cells",difficulty:"Hard",question:"Leydig cells are stimulated by:",options:{A:"FSH",B:"LH",C:"Testosterone",D:"Inhibin"},correct:"B",explanation:"LH stimulates testosterone production."},
  {id:"histo2-016",topic:"Male repro",subtopic:"Seminiferous tubules",difficulty:"Very hard",question:"Which cells provide nutrients to spermatogenic cells?",options:{A:"Leydig",B:"Sertoli",C:"Peritubular",D:"Stem cells"},correct:"B",explanation:"Sertoli cells support germ cells."},
  {id:"histo2-017",topic:"Female repro",subtopic:"Ovulation",difficulty:"Very hard",question:"Ovulation releases:",options:{A:"Primary oocyte",B:"Secondary oocyte",C:"Oogonium",D:"Zygote"},correct:"B",explanation:"Secondary oocyte is released."},
  {id:"histo2-018",topic:"Female repro",subtopic:"Corpus luteum",difficulty:"Hard",question:"Corpus luteum secretes mainly:",options:{A:"Estrogen",B:"Progesterone",C:"FSH",D:"LH"},correct:"B",explanation:"Progesterone maintains endometrium."},
  {id:"histo2-019",topic:"Tooth",subtopic:"Dentin",difficulty:"Very hard",question:"Dentin is produced by:",options:{A:"Ameloblasts",B:"Odontoblasts",C:"Cementoblasts",D:"Fibroblasts"},correct:"B",explanation:"Odontoblasts form dentin."},
  {id:"histo2-020",topic:"Tooth",subtopic:"Enamel",difficulty:"Hard",question:"Enamel is derived from:",options:{A:"Mesoderm",B:"Neural crest",C:"Ectoderm",D:"Endoderm"},correct:"C",explanation:"Ameloblasts are ectodermal."},
  {id:"histo2-021",topic:"Lymphatic",subtopic:"Spleen",difficulty:"Very hard",question:"White pulp surrounds:",options:{A:"Central artery",B:"Vein",C:"Sinusoid",D:"Capsule"},correct:"A",explanation:"White pulp surrounds central artery."},
  {id:"histo2-022",topic:"Lymphatic",subtopic:"Thymus",difficulty:"Hard",question:"Which feature is unique to thymus?",options:{A:"Germinal centers",B:"Hassall corpuscles",C:"Sinusoids",D:"Follicles"},correct:"B",explanation:"Only thymus has Hassall corpuscles."},
  {id:"histo2-023",topic:"Cardio",subtopic:"Capillaries",difficulty:"Very hard",question:"Which capillary type is most permeable?",options:{A:"Continuous",B:"Fenestrated",C:"Sinusoidal",D:"Elastic"},correct:"C",explanation:"Sinusoidal have large gaps."},
  {id:"histo2-024",topic:"Cardio",subtopic:"Heart conduction",difficulty:"Hard",question:"Which cells initiate heartbeat?",options:{A:"Purkinje",B:"SA node cells",C:"AV node",D:"Bundle fibers"},correct:"B",explanation:"SA node is pacemaker."},
  {id:"histo2-025",topic:"Epithelium",subtopic:"General",difficulty:"Very hard",question:"Which epithelium has highest regenerative capacity?",options:{A:"Simple squamous",B:"Stratified squamous",C:"Cuboidal",D:"Transitional"},correct:"B",explanation:"High turnover due to stem cells."},
  {id:"histo2-026",topic:"Epithelium",subtopic:"Specializations",difficulty:"Very hard",question:"Microvilli increase:",options:{A:"Secretion",B:"Surface area",C:"Motility",D:"Attachment"},correct:"B",explanation:"Brush border for absorption."},
  {id:"histo2-027",topic:"Integration",subtopic:"Incorrect pairings",difficulty:"Very hard",question:"Which pairing is INCORRECT?",options:{A:"Astrocyte–BBB",B:"Podocyte–filtration",C:"Sertoli–estrogen",D:"Kupffer–phagocytosis"},correct:"C",explanation:"Sertoli produce inhibin, not estrogen."},
  {id:"histo2-028",topic:"Integration",subtopic:"Correct pairings",difficulty:"Very hard",question:"Which pairing is correct?",options:{A:"Type I pneumocyte–surfactant",B:"Type II pneumocyte–regeneration",C:"Macrophage–gas exchange",D:"Goblet–cilia"},correct:"B",explanation:"Type II cells regenerate alveoli."},
  {id:"histo2-029",topic:"Embryology",subtopic:"Neural crest",difficulty:"Very hard",question:"Neural crest contributes to:",options:{A:"Epidermis",B:"Melanocytes",C:"Muscle",D:"Endothelium"},correct:"B",explanation:"Melanocytes are neural crest derived."},
  {id:"histo2-030",topic:"Embryology",subtopic:"Germ layers",difficulty:"Very hard",question:"Which germ layer forms epithelium of GIT?",options:{A:"Ectoderm",B:"Mesoderm",C:"Endoderm",D:"Neural crest"},correct:"C",explanation:"Endoderm forms lining epithelium."},
] },
      { name: 'Histo 3',  questions: [
  {id:"histo3-001",topic:"GIT",subtopic:"Esophagus",difficulty:"Very hard",question:"Which statement about the esophagus is correct?",options:{A:"Its mucosa is lined by stratified squamous non-keratinized epithelium",B:"Its submucosa contains Brunner glands",C:"Its entire muscularis externa is smooth muscle",D:"Its abdominal portion is covered by adventitia"},correct:"A",explanation:"The esophagus has stratified squamous non-keratinized epithelium; abdominal esophagus has serosa, not adventitia."},
  {id:"histo3-002",topic:"GIT",subtopic:"Stomach",difficulty:"Hard",question:"Which cell type secretes pepsinogen?",options:{A:"Parietal cell",B:"Chief cell",C:"Mucous neck cell",D:"Enteroendocrine cell"},correct:"B",explanation:"Chief cells secrete pepsinogen, the inactive precursor of pepsin."},
  {id:"histo3-003",topic:"GIT",subtopic:"Duodenum",difficulty:"Very hard",question:"A section of intestine shows villi and glands in the submucosa. The most likely organ is:",options:{A:"Jejunum",B:"Ileum",C:"Duodenum",D:"Colon"},correct:"C",explanation:"Duodenum has villi and Brunner glands in the submucosa."},
  {id:"histo3-004",topic:"Liver",subtopic:"Functional units",difficulty:"Very hard",question:"The classical hepatic lobule is centered on the:",options:{A:"Portal triad",B:"Bile duct",C:"Hepatic artery",D:"Central vein"},correct:"D",explanation:"The classical hepatic lobule is organized around the central vein."},
  {id:"histo3-005",topic:"Liver",subtopic:"Space of Disse",difficulty:"Very hard",question:"Which cells store vitamin A in the liver?",options:{A:"Ito cells",B:"Kupffer cells",C:"Cholangiocytes",D:"Endothelial cells"},correct:"A",explanation:"Hepatic stellate cells/Ito cells in the space of Disse store vitamin A."},
  {id:"histo3-006",topic:"Pancreas",subtopic:"Exocrine pancreas",difficulty:"Hard",question:"Which feature helps distinguish pancreas from salivary glands?",options:{A:"Serous acini",B:"Centroacinar cells",C:"Intercalated ducts",D:"Secretory granules"},correct:"B",explanation:"Centroacinar cells are characteristic of the pancreas."},
  {id:"histo3-007",topic:"Respiratory",subtopic:"Bronchi",difficulty:"Very hard",question:"Which structure disappears when bronchi become bronchioles?",options:{A:"Smooth muscle",B:"Epithelium",C:"Cartilage",D:"Elastic fibers"},correct:"C",explanation:"Bronchioles lack cartilage and submucosal glands."},
  {id:"histo3-008",topic:"Respiratory",subtopic:"Alveolar septum",difficulty:"Very hard",question:"Which component is part of the blood-air barrier?",options:{A:"Goblet cell mucus",B:"Fused basal laminae of pneumocyte and capillary endothelium",C:"Cartilage plate",D:"Smooth muscle layer"},correct:"B",explanation:"The thin blood-air barrier includes type I pneumocyte, fused basal laminae, and capillary endothelium."},
  {id:"histo3-009",topic:"Urinary",subtopic:"Renal corpuscle",difficulty:"Very hard",question:"Which cells support glomerular capillaries and can contract?",options:{A:"Podocytes",B:"Macula densa cells",C:"Mesangial cells",D:"Principal cells"},correct:"C",explanation:"Mesangial cells support capillary loops and regulate filtration by contraction."},
  {id:"histo3-010",topic:"Urinary",subtopic:"Tubules",difficulty:"Hard",question:"Which tubule segment has a prominent brush border?",options:{A:"Proximal convoluted tubule",B:"Distal convoluted tubule",C:"Collecting duct",D:"Thin limb of Henle"},correct:"A",explanation:"PCT cells have abundant microvilli forming a brush border."},
  {id:"histo3-011",topic:"Endocrine",subtopic:"Adrenal cortex",difficulty:"Very hard",question:"Which pairing is correct?",options:{A:"Zona glomerulosa — cortisol",B:"Zona fasciculata — glucocorticoids",C:"Zona reticularis — aldosterone",D:"Adrenal medulla — steroid hormones"},correct:"B",explanation:"Zona fasciculata produces glucocorticoids, mainly cortisol."},
  {id:"histo3-012",topic:"Endocrine",subtopic:"Pituitary",difficulty:"Very hard",question:"Which cells are PAS-positive basophils?",options:{A:"Somatotrophs and lactotrophs",B:"Chromophobes only",C:"Gonadotrophs, thyrotrophs, and corticotrophs",D:"Pituicytes"},correct:"C",explanation:"Basophils include gonadotrophs, thyrotrophs, and corticotrophs."},
  {id:"histo3-013",topic:"Nervous system",subtopic:"Meninges",difficulty:"Very hard",question:"CSF is found in the:",options:{A:"Epidural space",B:"Subdural space",C:"Subarachnoid space",D:"Endoneurium"},correct:"C",explanation:"The subarachnoid space contains cerebrospinal fluid."},
  {id:"histo3-014",topic:"Nervous system",subtopic:"Cerebral cortex",difficulty:"Hard",question:"Neocortex is characterized by:",options:{A:"Three neuronal layers",B:"Six neuronal layers",C:"Absence of pyramidal neurons",D:"Only white matter"},correct:"B",explanation:"Neocortex/isocortex has six neuronal layers."},
  {id:"histo3-015",topic:"Skin",subtopic:"Epidermis",difficulty:"Very hard",question:"Which statement about stratum granulosum is correct?",options:{A:"It contains keratohyaline and lamellar granules",B:"It is found only in thin skin",C:"It contains living melanocytes only",D:"It is the deepest mitotic layer"},correct:"A",explanation:"Stratum granulosum contains keratohyaline granules and lamellar bodies."},
  {id:"histo3-016",topic:"Skin",subtopic:"Langerhans cells",difficulty:"Hard",question:"Langerhans cells are mainly:",options:{A:"Mechanoreceptors",B:"Pigment-producing cells",C:"Antigen-presenting dendritic cells",D:"Keratin-producing cells"},correct:"C",explanation:"Langerhans cells are immune antigen-presenting cells."},
  {id:"histo3-017",topic:"Male reproductive",subtopic:"Sertoli cells",difficulty:"Very hard",question:"Which is NOT a function of Sertoli cells?",options:{A:"Formation of blood-testis barrier",B:"Secretion of inhibin",C:"Phagocytosis of residual bodies",D:"Secretion of testosterone"},correct:"D",explanation:"Testosterone is secreted by Leydig cells, not Sertoli cells."},
  {id:"histo3-018",topic:"Male reproductive",subtopic:"Spermatogenesis",difficulty:"Very hard",question:"Primary spermatocytes are:",options:{A:"Haploid with 1N DNA",B:"Diploid with 4N DNA",C:"Haploid with 2N DNA",D:"Mature spermatozoa"},correct:"B",explanation:"Primary spermatocytes are diploid and have duplicated DNA before meiosis I."},
  {id:"histo3-019",topic:"Female reproductive",subtopic:"Follicles",difficulty:"Very hard",question:"The zona pellucida first appears in the:",options:{A:"Primordial follicle",B:"Unilaminar primary follicle",C:"Corpus luteum",D:"Corpus albicans"},correct:"B",explanation:"Zona pellucida appears during the primary follicle stage."},
  {id:"histo3-020",topic:"Female reproductive",subtopic:"Endometrium",difficulty:"Hard",question:"Which layer regenerates the endometrium after menstruation?",options:{A:"Stratum functionale",B:"Myometrium",C:"Stratum basale",D:"Perimetrium"},correct:"C",explanation:"Stratum basale remains and regenerates the functional layer."},
  {id:"histo3-021",topic:"Lymphatic",subtopic:"Thymus",difficulty:"Very hard",question:"Which statement about thymus is correct?",options:{A:"It has lymphoid follicles with germinal centers",B:"Its stroma is reticular epithelium",C:"It filters lymph via afferent lymphatics",D:"It is a B-cell maturation organ"},correct:"B",explanation:"The thymus is lymphoepithelial; its stroma is epithelial reticular cells."},
  {id:"histo3-022",topic:"Lymphatic",subtopic:"Spleen",difficulty:"Very hard",question:"Which structure belongs to red pulp?",options:{A:"PALS",B:"Malpighian follicle",C:"Splenic cords and sinusoids",D:"Hassall corpuscles"},correct:"C",explanation:"Red pulp consists of splenic cords and venous sinusoids."},
  {id:"histo3-023",topic:"Cardiovascular",subtopic:"Endocardium",difficulty:"Hard",question:"Purkinje fibers are located mainly in the:",options:{A:"Epicardium",B:"Myocardial intercalated discs",C:"Subendocardial layer",D:"Tunica adventitia"},correct:"C",explanation:"Purkinje fibers are located in the subendocardial layer."},
  {id:"histo3-024",topic:"Cardiovascular",subtopic:"Vessels",difficulty:"Very hard",question:"Which vessel type has the most prominent tunica media relative to its wall?",options:{A:"Large vein",B:"Muscular artery",C:"Lymphatic capillary",D:"Venule"},correct:"B",explanation:"Muscular arteries have a very prominent tunica media of smooth muscle."},
  {id:"histo3-025",topic:"Tooth development",subtopic:"Bell stage",difficulty:"Very hard",question:"Odontoblasts differentiate from:",options:{A:"Inner enamel epithelium",B:"Outer enamel epithelium",C:"Dental papilla mesenchyme",D:"Stellate reticulum"},correct:"C",explanation:"Odontoblasts arise from neural crest-derived dental papilla mesenchyme."},
  {id:"histo3-026",topic:"Tooth development",subtopic:"Enamel",difficulty:"Very hard",question:"Which cells produce enamel?",options:{A:"Odontoblasts",B:"Cementoblasts",C:"Osteoblasts",D:"Inner ameloblasts"},correct:"D",explanation:"Inner enamel epithelium differentiates into ameloblasts that produce enamel."},
  {id:"histo3-027",topic:"Oral cavity",subtopic:"Tongue",difficulty:"Hard",question:"Which papillae lack taste buds and are mainly mechanical?",options:{A:"Filiform papillae",B:"Fungiform papillae",C:"Vallate papillae",D:"Foliate papillae"},correct:"A",explanation:"Filiform papillae are keratinized mechanical papillae and lack taste buds."},
  {id:"histo3-028",topic:"Oral cavity",subtopic:"Lip",difficulty:"Very hard",question:"Which lip zone lacks sweat glands and salivary glands but may contain sebaceous glands?",options:{A:"Mucous surface",B:"Vermilion zone",C:"Skin surface",D:"Orbicularis oris"},correct:"B",explanation:"The vermilion zone lacks sweat and salivary glands; sebaceous glands may open directly to the surface."},
  {id:"histo3-029",topic:"Embryology",subtopic:"Face development",difficulty:"Very hard",question:"Failure of fusion between the maxillary prominence and medial nasal prominence causes:",options:{A:"Cleft palate only",B:"Spina bifida",C:"Cleft lip",D:"Tracheoesophageal fistula"},correct:"C",explanation:"Cleft lip results from failed fusion of maxillary and medial nasal prominences."},
