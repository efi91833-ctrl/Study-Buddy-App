<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Study Buddy</title>

  <!-- PWA: installable as iPad home screen app -->
  <link rel="manifest" href="manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="Study Buddy" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="theme-color" content="#1976d2" />
  <link rel="apple-touch-icon" href="icons/icon-192.png" />

  <script src="vendor/react.min.js"></script>
  <script src="vendor/react-dom.min.js"></script>
  <script src="vendor/babel.min.js"></script>
  <script src="vendor/pdf.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #ffffff;
      color: #1a1a1a;
      min-height: 100vh;
      position: relative;
    }

    /* ── Persistent background (all screens) ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: url('Wound-man,_16th_Century_Wellcome_L0010200.webp') center/45% no-repeat;
      filter: grayscale(1);
      opacity: 0.07;
      z-index: -1;
      pointer-events: none;
      -webkit-mask-image: radial-gradient(ellipse 45% 65% at center, black 30%, transparent 75%);
      mask-image: radial-gradient(ellipse 45% 65% at center, black 30%, transparent 75%);
    }
    body::after { display: none; }

    /* ── Layout ── */
    .app { min-height: 100vh; display: flex; flex-direction: column; }

    .topbar {
      display: flex; align-items: center; gap: 12px;
      padding: 16px 28px;
      background: rgba(242,237,232,0.85);
      border-bottom: 1px solid #ccc;
    }
    .topbar-back {
      margin-left: auto;
      background: none; border: 1px solid #999; border-radius: 8px;
      color: #555; cursor: pointer; padding: 6px 14px; font-size: 14px;
      transition: all .15s;
    }
    .topbar-back:hover { border-color: #333; color: #000; }

    .content { flex: 1; padding: 36px 24px; max-width: 860px; margin: 0 auto; width: 100%; }

    /* ── Home Screen ── */
    .home-screen {
      position: relative;
      flex: 1;
      display: flex;
      overflow: hidden;
      min-height: 100vh;
    }
    .home-bg {
      position: absolute;
      inset: 0;
      background: url('Wound-man,_16th_Century_Wellcome_L0010200.webp') center/contain no-repeat;
      filter: grayscale(100%);
      z-index: 0;
    }
    .home-overlay {
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0.45);
      z-index: 1;
    }
    .home-sidebar {
      position: relative;
      z-index: 2;
      width: 260px;
      flex-shrink: 0;
      background: rgba(160,160,160,0.25);
      border-right: 1px solid rgba(0,0,0,0.08);
      padding: 36px 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      overflow-y: auto;
    }
    .sidebar-label {
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 6px;
    }
    .sidebar-subject-card {
      background: rgba(255,255,255,0.6);
      border: 1px solid rgba(0,0,0,0.1);
      border-radius: 12px;
      padding: 16px 16px;
      cursor: pointer;
      transition: all .18s;
    }
    .sidebar-subject-card:hover {
      background: rgba(255,255,255,0.9);
      border-color: rgba(0,0,0,0.25);
    }
    .sidebar-subject-name {
      font-size: 15px;
      font-weight: 700;
      color: #1a1a1a;
      margin-bottom: 3px;
    }
    .sidebar-subject-desc {
      font-size: 12px;
      color: #777;
      margin-bottom: 10px;
    }
    .sidebar-stats { display: flex; gap: 6px; flex-wrap: wrap; }
    .sidebar-stat {
      font-size: 11px; padding: 2px 8px;
      border-radius: 10px;
      background: rgba(0,0,0,0.05);
      color: #777;
      border: 1px solid rgba(0,0,0,0.1);
    }
    .sidebar-stat.weak   { border-color: #aaa; color: #555; }
    .sidebar-stat.mastered { border-color: #888; color: #333; }

    /* ── Bookshelf ── */
    .bookshelf-section {
      margin-top: auto;
      padding-top: 20px;
      border-top: 1px solid rgba(0,0,0,0.08);
    }
    .bookshelf-label {
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 12px;
    }
    .bookshelf-shelf {
      display: flex;
      align-items: flex-end;
      gap: 5px;
      min-height: 90px;
      padding-bottom: 6px;
      border-bottom: 1.5px solid rgba(0,0,0,0.15);
    }
    .book-spine {
      width: 28px;
      height: 80px;
      border-radius: 2px 4px 4px 2px;
      border-left: 3px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.18);
      backdrop-filter: blur(4px);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .2s;
      position: relative;
      overflow: hidden;
    }
    .book-spine:hover {
      height: 88px;
      background: rgba(255,255,255,0.35);
      border-left-color: rgba(0,0,0,0.35);
    }
    .book-spine.active {
      background: rgba(0,0,0,0.08);
      border-left-color: rgba(0,0,0,0.5);
    }
    .book-spine-title {
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: 9px;
      color: rgba(255,255,255,0.7);
      letter-spacing: 0.06em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-height: 72px;
      padding: 0 4px;
    }
    .book-add-btn {
      width: 28px;
      height: 80px;
      border-radius: 4px;
      border: 1.5px dashed rgba(0,0,0,0.18);
      background: transparent;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(0,0,0,0.25);
      font-size: 18px;
      transition: all .2s;
    }
    .book-add-btn:hover {
      border-color: rgba(0,0,0,0.4);
      color: rgba(0,0,0,0.5);
    }
    .book-processing {
      font-size: 10px;
      color: #aaa;
      margin-top: 6px;
      font-style: italic;
    }

    .home-center {
      position: relative;
      z-index: 2;
      flex: 1;
      display: flex;
      align-items: flex-end;
      justify-content: flex-end;
      padding: 0 52px 48px 0;
    }
    .home-main-title {
      font-size: 52px;
      font-weight: 300;
      color: rgba(0,0,0,0.25);
      letter-spacing: 0.18em;
      text-align: right;
      text-transform: uppercase;
      font-family: Georgia, 'Times New Roman', serif;
      user-select: none;
    }

    /* kept for exam screen stat badges */
    .stat-badge {
      font-size: 12px; padding: 3px 10px;
      border-radius: 20px;
      background: #1e1e2e;
      color: #aaa;
      border: 1px solid #2a2a2a;
    }
    .stat-badge.weak { border-color: #666; color: #bbb; }
    .stat-badge.mastered { border-color: #888; color: #ddd; }

    /* ── Exam Screen ── */
    .exam-header { margin-bottom: 28px; }
    .exam-subject-label {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 13px; color: #666;
      background: rgba(255,255,255,0.7); border-radius: 20px; padding: 4px 14px;
      border: 1px solid #ccc;
      margin-bottom: 12px;
    }
    .exam-title { font-size: 22px; font-weight: 700; margin-bottom: 6px; color: #1a1a1a; }
    .exam-meta { font-size: 13px; color: #888; }

    .question-list { display: flex; flex-direction: column; gap: 24px; }

    .question-card {
      background: rgba(255,255,255,0.75);
      border: 1px solid #ddd;
      border-radius: 16px;
      padding: 24px;
    }

    .question-num {
      font-size: 12px; color: #999; margin-bottom: 10px;
      text-transform: uppercase; letter-spacing: .05em;
    }
    .question-topic-tag {
      display: inline-block;
      font-size: 11px; padding: 2px 9px;
      border-radius: 10px;
      background: rgba(0,0,0,0.06);
      color: #777;
      margin-bottom: 10px;
      border: 1px solid #ddd;
    }
    .question-text {
      font-size: 16px; font-weight: 600; line-height: 1.5;
      margin-bottom: 18px; color: #111;
    }

    .options-grid { display: flex; flex-direction: column; gap: 10px; }

    .option-btn {
      display: flex; align-items: center; gap: 12px;
      width: 100%;
      background: rgba(255,255,255,0.6);
      border: 1.5px solid #ccc;
      border-radius: 10px;
      padding: 12px 16px;
      cursor: pointer;
      text-align: left;
      color: #222;
      font-size: 14px;
      transition: all .15s;
    }
    .option-btn:hover:not(:disabled) {
      border-color: #888;
      background: rgba(255,255,255,0.9);
    }
    .option-btn:disabled { cursor: default; }

    .option-letter {
      width: 28px; height: 28px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700;
      background: #e0dbd6;
      color: #555;
      flex-shrink: 0;
    }

    /* Selected (pre-submit) */
    .option-btn.selected { border-color: #555; background: rgba(0,0,0,0.06); }
    .option-btn.selected .option-letter { background: #555; color: #fff; }

    /* Post-submit states */
    .option-btn.correct { border-color: #4a7c6a; background: rgba(74,124,106,0.1); }
    .option-btn.correct .option-letter { background: #4a7c6a; color: #fff; }

    .option-btn.wrong { border-color: #7c4a4a; background: rgba(124,74,74,0.1); }
    .option-btn.wrong .option-letter { background: #7c4a4a; color: #fff; }

    .option-btn.revealed { border-color: #ccc; background: rgba(0,0,0,0.03); opacity: .75; }
    .option-btn.revealed .option-letter { background: #ccc; color: #888; }

    .option-btn.reveal-correct { border-color: #4a7c6a; background: rgba(74,124,106,0.1); opacity: .85; }
    .option-btn.reveal-correct .option-letter { background: #4a7c6a; color: #fff; }

    .explanation-box {
      margin-top: 16px;
      background: rgba(0,0,0,0.04);
      border: 1px solid #ddd;
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 13.5px;
      color: #555;
      line-height: 1.6;
    }
    .explanation-box strong { color: #222; }

    .unanswered-note {
      margin-top: 10px;
      font-size: 12px;
      color: #999;
      font-style: italic;
    }

    /* ── Submit / Actions ── */
    .exam-actions {
      margin-top: 32px;
      display: flex; gap: 14px; align-items: center; flex-wrap: wrap;
    }

    .btn-primary {
      background: #333;
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 13px 28px;
      font-size: 15px; font-weight: 600;
      cursor: pointer;
      transition: all .15s;
    }
    .btn-primary:hover { background: #111; transform: translateY(-1px); }
    .btn-primary:disabled { background: #bbb; color: #888; cursor: default; transform: none; }

    .btn-secondary {
      background: none;
      color: #666;
      border: 1px solid #ccc;
      border-radius: 10px;
      padding: 13px 28px;
      font-size: 15px; font-weight: 600;
      cursor: pointer;
      transition: all .15s;
    }
    .btn-secondary:hover { border-color: #333; color: #000; }

    /* ── Results Banner ── */
    .results-banner {
      background: rgba(255,255,255,0.75);
      border: 1px solid #ddd;
      border-radius: 16px;
      padding: 28px 32px;
      margin-bottom: 28px;
      display: flex; align-items: center; gap: 28px; flex-wrap: wrap;
    }
    .score-ring {
      width: 90px; height: 90px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-direction: column;
      font-size: 26px; font-weight: 800;
      flex-shrink: 0;
    }
    .score-ring .score-label { font-size: 11px; font-weight: 500; opacity: .7; }

    .score-great { background: rgba(74,124,106,0.1); border: 3px solid #4a7c6a; color: #3a6b57; }
    .score-ok    { background: rgba(180,140,60,0.1); border: 3px solid #9a8040; color: #7a6030; }
    .score-poor  { background: rgba(124,74,74,0.1);  border: 3px solid #7c4a4a; color: #6b3a3a; }

    .results-detail { flex: 1; }
    .results-detail h2 { font-size: 20px; font-weight: 700; margin-bottom: 6px; color: #1a1a1a; }
    .results-detail p  { font-size: 14px; color: #888; }

    .weak-areas-box {
      background: rgba(255,255,255,0.75);
      border: 1px solid #ddd;
      border-radius: 12px;
      padding: 18px 20px;
      margin-top: 24px;
    }
    .weak-areas-box h3 { font-size: 14px; font-weight: 600; color: #555; margin-bottom: 12px; }
    .weak-tag {
      display: inline-block;
      font-size: 12px; padding: 3px 10px;
      border-radius: 10px;
      background: rgba(0,0,0,0.05); color: #666;
      border: 1px solid #ccc;
      margin: 3px;
    }

    .progress-info {
      font-size: 13px; color: #888; margin-top: 6px;
    }

    /* ── Search Widget ── */
    .search-widget {
      position: fixed;
      top: 18px;
      right: 24px;
      z-index: 1000;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
    }
    .search-input-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(0,0,0,0.18);
      border-radius: 0;
      padding: 4px 2px;
    }
    .search-input-wrap input {
      border: none;
      outline: none;
      background: transparent;
      font-size: 13px;
      color: #333;
      width: 150px;
      letter-spacing: 0.03em;
    }
    .search-input-wrap input::placeholder { color: #bbb; font-style: italic; }
    .search-icon { font-size: 11px; color: #bbb; }

    .search-panel {
      margin-top: 8px;
      width: 300px;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 14px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.12);
      overflow: hidden;
    }
    .search-results-list {
      max-height: 200px;
      overflow-y: auto;
      border-bottom: 1px solid #eee;
    }
    .search-result-item {
      padding: 9px 14px;
      cursor: pointer;
      font-size: 13px;
      color: #333;
      border-bottom: 1px solid #f0f0f0;
      transition: background .1s;
    }
    .search-result-item:hover { background: #f5f5f5; }
    .search-result-item .result-topic {
      font-size: 11px;
      color: #aaa;
      margin-top: 2px;
    }
    .search-result-item.active { background: #f0f0f0; }

    .search-definition {
      padding: 14px 16px;
    }
    .search-definition .def-term {
      font-size: 13px;
      font-weight: 700;
      color: #111;
      margin-bottom: 6px;
    }
    .search-definition .def-text {
      font-size: 12.5px;
      color: #555;
      line-height: 1.6;
    }
    .search-no-results {
      padding: 14px 16px;
      font-size: 13px;
      color: #aaa;
      text-align: center;
    }

    /* ── Book Reader (fullscreen modal) ── */
    .book-reader-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.82);
      z-index: 1999;
    }
    .book-reader {
      position: fixed;
      inset: 0;
      z-index: 2000;
      display: flex;
      flex-direction: column;
      pointer-events: none;
    }
    .book-reader-inner {
      margin: auto;
      width: 780px;
      max-width: 96vw;
      max-height: 92vh;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 24px 80px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      pointer-events: all;
    }
    .book-reader-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 18px;
      border-bottom: 1px solid #eee;
      background: #fafafa;
      flex-shrink: 0;
    }
    .book-reader-title {
      font-size: 13px;
      font-weight: 600;
      color: #222;
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      font-family: Georgia, serif;
      letter-spacing: 0.02em;
    }
    .book-reader-nav {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: #555;
      flex-shrink: 0;
    }
    .book-reader-nav button {
      background: none;
      border: 1px solid #ddd;
      border-radius: 6px;
      width: 32px; height: 32px;
      cursor: pointer;
      font-size: 18px;
      color: #444;
      display: flex; align-items: center; justify-content: center;
      transition: all .15s;
    }
    .book-reader-nav button:hover:not(:disabled) { border-color: #888; color: #000; }
    .book-reader-nav button:disabled { opacity: .25; cursor: default; }
    .book-reader-close {
      background: none;
      border: 1px solid #ddd;
      cursor: pointer;
      font-size: 14px;
      color: #888;
      padding: 4px 10px;
      border-radius: 6px;
      transition: all .15s;
      flex-shrink: 0;
    }
    .book-reader-close:hover { color: #000; border-color: #888; }

    .book-reader-body canvas {
      box-shadow: 0 4px 24px rgba(0,0,0,0.2);
      border-radius: 2px;
      max-width: 100%;
      height: auto;
    }
    .book-reader-loading {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      font-size: 14px;
      color: #999;
      font-style: italic;
    }

    .book-reader-search-btn {
      background: none;
      border: 1px solid #ddd;
      border-radius: 6px;
      width: 32px; height: 32px;
      cursor: pointer;
      font-size: 16px;
      color: #666;
      display: flex; align-items: center; justify-content: center;
      transition: all .15s;
      flex-shrink: 0;
    }
    .book-reader-search-btn:hover { border-color: #888; color: #000; }

    .book-search-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 18px;
      border-bottom: 1px solid #eee;
      background: #fafafa;
      flex-shrink: 0;
    }
    .book-search-bar input {
      flex: 1;
      border: none;
      border-bottom: 1px solid #ccc;
      outline: none;
      background: transparent;
      font-size: 13px;
      color: #222;
      padding: 2px 0;
    }
    .book-search-bar input::placeholder { color: #bbb; font-style: italic; }
    .book-search-count {
      font-size: 11px;
      color: #aaa;
      white-space: nowrap;
    }
    .book-search-results {
      max-height: 200px;
      overflow-y: auto;
      border-bottom: 1px solid #eee;
      flex-shrink: 0;
    }
    .book-search-result {
      display: flex;
      align-items: baseline;
      gap: 10px;
      padding: 8px 18px;
      cursor: pointer;
      border-bottom: 1px solid #f5f5f5;
      transition: background .1s;
    }
    .book-search-result:hover { background: #f5f5f5; }
    .book-search-page {
      font-size: 11px;
      font-weight: 700;
      color: #888;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .book-search-snippet {
      font-size: 12px;
      color: #555;
      line-height: 1.4;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .book-search-empty {
      padding: 12px 18px;
      font-size: 12px;
      color: #aaa;
      font-style: italic;
      border-bottom: 1px solid #eee;
    }

    .book-reader-toc-btn {
      background: none; border: 1px solid #ddd; border-radius: 6px;
      width: 32px; height: 32px; cursor: pointer; font-size: 14px; color: #666;
      display: flex; align-items: center; justify-content: center;
      transition: all .15s; flex-shrink: 0;
    }
    .book-reader-toc-btn:hover { border-color: #888; color: #000; }

    .book-reader-body {
      flex: 1; display: flex; overflow: hidden; background: #e8e8e8;
    }
    .book-toc-sidebar {
      width: 220px; flex-shrink: 0;
      background: #fff; border-right: 1px solid #eee;
      overflow-y: auto; padding: 12px 0;
    }
    .book-toc-label {
      font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
      color: #aaa; padding: 0 14px 8px; border-bottom: 1px solid #f0f0f0;
      margin-bottom: 6px;
    }
    .book-toc-item {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 6px; padding: 6px 14px 6px 12px;
      cursor: pointer; transition: background .1s;
    }
    .book-toc-item:hover { background: #f5f5f5; }
    .book-toc-item.active { background: #f0f0f0; }
    .book-toc-title {
      font-size: 12px; color: #333; flex: 1;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .book-toc-item.active .book-toc-title { font-weight: 600; color: #111; }
    .book-toc-page { font-size: 11px; color: #aaa; flex-shrink: 0; }

    .book-canvas-wrap {
      flex: 1; overflow-y: auto; overflow-x: hidden;
      display: flex; justify-content: center; padding: 20px;
    }
    .book-canvas-wrap canvas {
      box-shadow: 0 4px 24px rgba(0,0,0,0.2);
      border-radius: 2px; max-width: 100%; height: auto;
    }

    /* ── Anatomy Slide Test ── */
    .anatomy-slide-wrap {
      position: relative; width: 100%; border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.18);
      display: inline-block;
    }
    .anatomy-slide-img {
      width: 100%; display: block; border-radius: 10px;
    }
    .cover-box {
  position: absolute;
  background: black;
  opacity: 0.9;
  border: 2px solid white;
  border-radius: 6px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: clamp(10px, 1.4vw, 14px);
  font-weight: 700;
  color: transparent;
  transition: opacity .25s, background .2s;
  box-sizing: border-box;

    }
   .cover-box:hover { border-color: black; }
    .cover-box.revealed {
  background: transparent;
  border: 2px dashed black;
  opacity: 1;
  color: transparent;
}

    .anatomy-sidebar-card {
      background: rgba(30,30,30,0.85);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 12px; padding: 14px 16px;
      cursor: pointer; color: #fff; margin-top: 6px;
      transition: background .15s;
    }
    .anatomy-sidebar-card:hover { background: rgba(20,20,20,0.95); }
    .anatomy-progress-bar {
      height: 4px; background: rgba(255,255,255,0.15);
      border-radius: 2px; margin-top: 8px; overflow: hidden;
    }
    .anatomy-progress-fill {
      height: 100%; background: #aaa; border-radius: 2px; transition: width .4s;
    }

    /* ── iPad / mobile responsive fixes ── */
    @media (max-width: 900px) {
      .content { padding: 20px 14px; }
    }

    /* iOS: prevent double-tap zoom on buttons and images */
    button, img { touch-action: manipulation; }

    /* Smooth scrolling on iOS */
    body { -webkit-overflow-scrolling: touch; }

    /* Safe area insets for iPhone X+ notch / iPad home bar */
    .app {
      padding-bottom: env(safe-area-inset-bottom);
      padding-left:   env(safe-area-inset-left);
      padding-right:  env(safe-area-inset-right);
    }

    /* Prevent text size adjustment on orientation change */
    html { -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }

    /* ── Czech Credit Test — black & white ── */
    .czech-header{background:#1a1a1a;color:#fff;border-radius:14px;padding:20px 24px;margin-bottom:20px;}
    .czech-header h2{font-size:1.15rem;font-weight:700;margin-bottom:4px;}
    .czech-header .back-btn{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.3);color:#fff;border-radius:8px;padding:6px 14px;cursor:pointer;font-size:.85rem;margin-bottom:14px;}
    .czech-header .back-btn:hover{background:rgba(255,255,255,.22);}
    .cz-test-tab{padding:6px 22px;border-radius:9px;border:2px solid rgba(255,255,255,.3);background:transparent;color:#fff;cursor:pointer;font-size:.92rem;font-weight:600;transition:all .15s;}
    .cz-test-tab.cz-tab-active{background:#fff;color:#1a1a1a;border-color:#fff;}
    .cz-test-tab:hover:not(.cz-tab-active){border-color:#fff;}
    .czech-section-card{background:#fff;border-radius:12px;padding:20px;margin-bottom:14px;box-shadow:0 1px 4px rgba(0,0,0,.08);}
    .czech-section-title{font-size:.9rem;font-weight:700;color:#1a1a1a;margin-bottom:14px;padding-bottom:10px;border-bottom:2px solid #e8e8e8;line-height:1.4;}
    .cz-match-wrap{position:relative;}
    .cz-match-cols{display:flex;gap:0;align-items:flex-start;}
    .cz-match-col{flex:1;display:flex;flex-direction:column;gap:7px;}
    .cz-match-gap{width:72px;flex-shrink:0;}
    .cz-match-item{padding:10px 13px;border-radius:9px;border:2px solid #ddd;cursor:pointer;font-size:.9rem;line-height:1.3;transition:border .12s,background .12s;user-select:none;background:#fff;}
    .cz-match-item:hover{border-color:#666;}
    .cz-match-item.cz-selected{border-color:#1a1a1a!important;background:#f0f0f0!important;font-weight:600;}
    .cz-match-svg{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;}
    .cz-label-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px;}
    .cz-label-cell{display:flex;flex-direction:column;gap:4px;}
    .cz-label-prompt{font-size:.75rem;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.04em;}
    .cz-text-field{padding:8px 11px;border-radius:8px;border:1.5px solid #ddd;font-size:.9rem;outline:none;width:100%;transition:border .12s;background:#fafafa;}
    .cz-text-field:focus{border-color:#1a1a1a;background:#fff;}
    .cz-text-field:disabled{background:#f5f5f5;color:#555;cursor:default;}
    .cz-write-list{display:flex;flex-direction:column;gap:10px;}
    .cz-write-row{display:flex;align-items:flex-start;gap:10px;}
    .cz-write-num{font-size:.78rem;font-weight:700;color:#aaa;min-width:22px;padding-top:10px;}
    .cz-write-prompt{font-size:.88rem;color:#555;flex:1;min-width:0;padding-top:9px;line-height:1.5;}
    .cz-write-input{flex:1.2;min-width:0;}
    .cz-mcq-story{font-style:italic;color:#555;margin-bottom:16px;padding:11px 14px;background:#f5f5f5;border-radius:9px;font-size:.88rem;line-height:1.5;}
    .cz-mcq-list{display:flex;flex-direction:column;gap:14px;}
    .cz-mcq-q{font-size:.9rem;font-weight:500;margin-bottom:7px;line-height:1.4;}
    .cz-mcq-opts{display:flex;flex-wrap:wrap;gap:7px;}
    .cz-mcq-opt{padding:7px 12px;border-radius:8px;border:1.5px solid #ddd;cursor:pointer;font-size:.87rem;transition:all .12s;user-select:none;}
    .cz-mcq-opt:hover{border-color:#555;background:#f5f5f5;}
    .cz-mcq-opt.cz-active{border-color:#1a1a1a;background:#f0f0f0;font-weight:600;}
    .cz-tf-story{font-size:.87rem;font-style:italic;color:#555;margin-bottom:14px;padding:10px 13px;background:#f5f5f5;border-radius:9px;line-height:1.5;}
    .cz-tf-list{display:flex;flex-direction:column;gap:8px;}
    .cz-tf-row{display:flex;align-items:flex-start;gap:10px;}
    .cz-tf-idx{font-size:.75rem;font-weight:700;color:#bbb;min-width:20px;padding-top:9px;}
    .cz-tf-stmt{font-size:.88rem;flex:1;line-height:1.45;padding-top:7px;}
    .cz-tf-btns{display:flex;gap:6px;flex-shrink:0;padding-top:2px;}
    .cz-tf-btn{padding:6px 14px;border-radius:8px;border:1.5px solid #ddd;cursor:pointer;font-size:.85rem;font-weight:600;background:#fff;transition:all .12s;}
    .cz-tf-btn.on{border-color:#1a1a1a;background:#1a1a1a;color:#fff;}
    .cz-tf-btn:hover:not(.on){background:#f5f5f5;}
    .cz-choose-wrap{font-size:.95rem;line-height:2.2;color:#333;}
    .cz-choice-toggle{display:inline-flex;border-radius:7px;border:1.5px solid #555;overflow:hidden;margin:0 2px;font-size:.88rem;cursor:pointer;user-select:none;vertical-align:middle;}
    .cz-choice-opt{padding:2px 9px;transition:all .12s;}
    .cz-choice-opt.on{background:#1a1a1a;color:#fff;font-weight:600;}
    .cz-choice-opt.off{background:#f0f0f0;color:#555;}
    .cz-submit-row{display:flex;justify-content:center;padding:8px 0 4px;}
    .cz-submit-btn{padding:14px 52px;border-radius:12px;background:#1a1a1a;color:#fff;border:none;cursor:pointer;font-size:1rem;font-weight:700;letter-spacing:.02em;transition:opacity .15s;}
    .cz-submit-btn:hover{opacity:.82;}
    /* Feedback after submit */
    .cz-fb-row{display:flex;align-items:flex-start;gap:10px;padding:6px 0;border-bottom:1px solid #f0f0f0;font-size:.88rem;flex-wrap:wrap;}
    .cz-fb-q{color:#555;flex:1;min-width:120px;line-height:1.4;}
    .cz-fb-right{font-weight:700;color:#1a1a1a;}
    .cz-fb-wrong{font-weight:700;text-decoration:line-through;color:#999;}
    .cz-fb-correct{font-weight:700;color:#1a1a1a;margin-left:6px;}
    .cz-fb-explanation{font-size:.8rem;color:#666;margin-top:5px;padding:6px 10px;background:#f5f5f5;border-radius:7px;line-height:1.5;width:100%;}
    .cz-fb-open{color:#888;font-style:italic;}
    .cz-fb-match-ok{font-weight:600;}
    .cz-fb-match-miss{color:#888;text-decoration:line-through;}
    @media(max-width:480px){
      .cz-match-gap{width:36px;}
      .cz-match-item{padding:8px 10px;font-size:.85rem;}
      .cz-label-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr));}
      .cz-mcq-opts{flex-direction:column;}
      .cz-tf-row{flex-wrap:wrap;}
      .cz-tf-btns{margin-left:30px;}
      .cz-write-row{flex-wrap:wrap;}
      .cz-write-prompt{flex:0 0 100%;}
    }
  </style>
</head>
<body>
<div id="root"></div>

<script src="histology-questions.js"></script>
<script src="anatomy-questions.js"></script>
<script src="czech-questions.js"></script>
<script src="czechQuestionBanks.js"></script>
<script src="muscle-bank.js"></script>
