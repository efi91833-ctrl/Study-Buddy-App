  {id:"histo10-017",topic:"Male repro",subtopic:"Spermatogenesis",difficulty:"Very hard",question:"Which stage is diploid?",options:{A:"Spermatid",B:"Spermatozoa",C:"Primary spermatocyte",D:"Secondary spermatocyte"},correct:"C",explanation:"Before meiosis I."},
  {id:"histo10-018",topic:"Female repro",subtopic:"Ovary",difficulty:"Very hard",question:"Which cells surround oocyte?",options:{A:"Theca",B:"Granulosa",C:"Leydig",D:"Sertoli"},correct:"B",explanation:"Follicular cells."},
  {id:"histo10-019",topic:"Female repro",subtopic:"Uterus",difficulty:"Very hard",question:"Which layer contracts during labor?",options:{A:"Endometrium",B:"Myometrium",C:"Perimetrium",D:"Basalis"},correct:"B",explanation:"Smooth muscle layer."},
  {id:"histo10-020",topic:"Lymphatic",subtopic:"Lymph node",difficulty:"Very hard",question:"Germinal centers contain:",options:{A:"T cells",B:"B cells",C:"Macrophages only",D:"Fibroblasts"},correct:"B",explanation:"B-cell proliferation."},
  {id:"histo10-021",topic:"Lymphatic",subtopic:"Spleen",difficulty:"Very hard",question:"Red pulp function:",options:{A:"Immune response",B:"Filter old RBCs",C:"Hormone secretion",D:"Gas exchange"},correct:"B",explanation:"Remove damaged RBCs."},
  {id:"histo10-022",topic:"Cardio",subtopic:"Heart",difficulty:"Very hard",question:"Purkinje fibers are specialized for:",options:{A:"Contraction",B:"Conduction",C:"Secretion",D:"Support"},correct:"B",explanation:"Rapid conduction."},
  {id:"histo10-023",topic:"Cardio",subtopic:"Arteries",difficulty:"Very hard",question:"Elastic arteries contain:",options:{A:"Collagen only",B:"Elastic lamellae",C:"Bone",D:"Cartilage"},correct:"B",explanation:"Allow stretch."},
  {id:"histo10-024",topic:"Tooth",subtopic:"Enamel",difficulty:"Very hard",question:"Enamel is:",options:{A:"Living tissue",B:"Dead mineralized tissue",C:"Cartilage",D:"Bone-like"},correct:"B",explanation:"No cells."},
  {id:"histo10-025",topic:"Tooth",subtopic:"Pulp",difficulty:"Very hard",question:"Pulp contains:",options:{A:"Blood vessels",B:"Nerves",C:"Connective tissue",D:"All"},correct:"D",explanation:"Highly vascularized CT."},
  {id:"histo10-026",topic:"Oral cavity",subtopic:"Salivary glands",difficulty:"Very hard",question:"Mucous cells secrete:",options:{A:"Watery fluid",B:"Mucus",C:"Hormones",D:"Enzymes only"},correct:"B",explanation:"Viscous secretion."},
  {id:"histo10-027",topic:"Oral cavity",subtopic:"Tongue",difficulty:"Very hard",question:"Filiform papillae function:",options:{A:"Taste",B:"Mechanical",C:"Secretion",D:"Absorption"},correct:"B",explanation:"No taste buds."},
  {id:"histo10-028",topic:"Embryology",subtopic:"Gastrulation",difficulty:"Very hard",question:"Ectoderm gives rise to:",options:{A:"Muscle",B:"Skin epidermis",C:"Bone",D:"Blood"},correct:"B",explanation:"Surface ectoderm."},
  {id:"histo10-029",topic:"Embryology",subtopic:"Neural crest",difficulty:"Very hard",question:"Neural crest forms:",options:{A:"CNS neurons",B:"PNS structures",C:"Endothelium",D:"Muscle"},correct:"B",explanation:"Peripheral nervous system."},
  {id:"histo10-030",topic:"Integration",subtopic:"Incorrect pairing",difficulty:"Very hard",question:"Which pairing is incorrect?",options:{A:"Type I pneumocyte–gas exchange",B:"Podocyte–filtration",C:"Goblet cell–enzymes",D:"Beta cell–insulin"},correct:"C",explanation:"Goblet cells secrete mucus, not enzymes."},
] },
    ...(window.histoExtraExams || []),
    ],
    // Computed flat list — keeps progress tracking, search index, and totalCount working
    get questions() { return this.exams.flatMap(e => e.questions); },
  },

  Anatomy: {
    color: '#888',
    icon: '',
    description: 'Structure of the human body',
    exams: [
      ...(window.anatExtraExams || []),
