  {id:"histo7-009",topic:"Urinary",subtopic:"Loop",difficulty:"Very hard",question:"Thick ascending limb actively transports:",options:{A:"Water",B:"NaCl",C:"Glucose",D:"Urea"},correct:"B",explanation:"Important for concentration gradient."},
  {id:"histo7-010",topic:"Endocrine",subtopic:"Pituitary",difficulty:"Very hard",question:"Which is NOT secreted by anterior pituitary?",options:{A:"GH",B:"TSH",C:"Oxytocin",D:"ACTH"},correct:"C",explanation:"Oxytocin stored in posterior."},
  {id:"histo7-011",topic:"Endocrine",subtopic:"Adrenal medulla",difficulty:"Very hard",question:"Chromaffin cells release:",options:{A:"Cortisol",B:"Aldosterone",C:"Catecholamines",D:"Thyroxine"},correct:"C",explanation:"Epinephrine/norepinephrine."},
  {id:"histo7-012",topic:"Nervous",subtopic:"Gray vs white matter",difficulty:"Very hard",question:"Gray matter contains:",options:{A:"Myelinated axons only",B:"Neuron cell bodies",C:"Only glia",D:"No synapses"},correct:"B",explanation:"Perikarya + synapses."},
  {id:"histo7-013",topic:"Nervous",subtopic:"Glia",difficulty:"Very hard",question:"Which CNS cell regulates extracellular ions?",options:{A:"Astrocyte",B:"Microglia",C:"Oligodendrocyte",D:"Ependymal"},correct:"A",explanation:"Astrocytes maintain environment."},
  {id:"histo7-014",topic:"Skin",subtopic:"Epidermis",difficulty:"Very hard",question:"Which layer first shows keratinization?",options:{A:"Basale",B:"Spinosum",C:"Granulosum",D:"Corneum"},correct:"C",explanation:"Keratohyalin granules appear."},
  {id:"histo7-015",topic:"Skin",subtopic:"Sweat glands",difficulty:"Very hard",question:"Eccrine glands open into:",options:{A:"Hair follicle",B:"Skin surface",C:"Sebaceous duct",D:"Dermis"},correct:"B",explanation:"Direct to surface."},
  {id:"histo7-016",topic:"Male repro",subtopic:"Seminiferous tubules",difficulty:"Very hard",question:"Which cells nourish germ cells?",options:{A:"Leydig",B:"Sertoli",C:"Peritubular",D:"Spermatogonia"},correct:"B",explanation:"Support and nutrition."},
  {id:"histo7-017",topic:"Male repro",subtopic:"Epididymis",difficulty:"Very hard",question:"Function of stereocilia:",options:{A:"Motility",B:"Absorption",C:"Secretion only",D:"Protection"},correct:"B",explanation:"Absorptive surface."},
  {id:"histo7-018",topic:"Female repro",subtopic:"Follicles",difficulty:"Very hard",question:"Zona pellucida is:",options:{A:"Cell layer",B:"Glycoprotein layer",C:"Basement membrane",D:"Hormone"},correct:"B",explanation:"Surrounds oocyte."},
  {id:"histo7-019",topic:"Female repro",subtopic:"Uterus",difficulty:"Very hard",question:"Which layer regenerates after menstruation?",options:{A:"Functional",B:"Basal",C:"Myometrium",D:"Serosa"},correct:"B",explanation:"Basal layer remains."},
  {id:"histo7-020",topic:"Lymphatic",subtopic:"Node structure",difficulty:"Very hard",question:"Paracortex contains mainly:",options:{A:"B cells",B:"T cells",C:"Macrophages",D:"Plasma cells"},correct:"B",explanation:"T-cell zone."},
  {id:"histo7-021",topic:"Lymphatic",subtopic:"Spleen",difficulty:"Very hard",question:"Red pulp function:",options:{A:"Lymphocyte maturation",B:"Filtration of RBCs",C:"Antibody production only",D:"Hormone secretion"},correct:"B",explanation:"Removes old RBCs."},
  {id:"histo7-022",topic:"Cardio",subtopic:"Layers",difficulty:"Very hard",question:"Endocardium resembles:",options:{A:"Epithelium",B:"Endothelium",C:"Muscle",D:"Cartilage"},correct:"B",explanation:"Simple squamous endothelium."},
  {id:"histo7-023",topic:"Cardio",subtopic:"Arteries",difficulty:"Very hard",question:"Elastic arteries contain:",options:{A:"Collagen only",B:"Elastic lamellae",C:"No muscle",D:"Valves"},correct:"B",explanation:"Allow recoil."},
  {id:"histo7-024",topic:"Tooth",subtopic:"Development",difficulty:"Very hard",question:"Dental papilla gives rise to:",options:{A:"Enamel",B:"Dentin and pulp",C:"Cementum",D:"Periodontal ligament"},correct:"B",explanation:"Odontoblast lineage."},
  {id:"histo7-025",topic:"Tooth",subtopic:"Periodontium",difficulty:"Very hard",question:"Periodontal ligament contains:",options:{A:"Cartilage",B:"Dense CT fibers",C:"Bone marrow",D:"Epithelial cells only"},correct:"B",explanation:"Collagen fibers anchor tooth."},
  {id:"histo7-026",topic:"Oral",subtopic:"Glands",difficulty:"Very hard",question:"Sublingual gland secretion is mainly:",options:{A:"Serous",B:"Mucous",C:"Mixed equal",D:"Endocrine"},correct:"B",explanation:"Mostly mucous."},
  {id:"histo7-027",topic:"Oral",subtopic:"Taste",difficulty:"Very hard",question:"Taste buds connect to:",options:{A:"Blood vessels",B:"Nerve fibers",C:"Muscle fibers",D:"Ducts"},correct:"B",explanation:"Sensory transduction."},
  {id:"histo7-028",topic:"Embryology",subtopic:"Pharyngeal arches",difficulty:"Very hard",question:"First arch forms:",options:{A:"Maxilla and mandible",B:"Hyoid",C:"Larynx",D:"Trachea"},correct:"A",explanation:"Meckel cartilage derivatives."},
  {id:"histo7-029",topic:"Embryology",subtopic:"Placenta",difficulty:"Very hard",question:"Which layer contacts maternal blood?",options:{A:"Cytotrophoblast",B:"Syncytiotrophoblast",C:"Amnion",D:"Decidua"},correct:"B",explanation:"Direct exchange surface."},
  {id:"histo7-030",topic:"Integration",subtopic:"Trap",difficulty:"Very hard",question:"Which pairing is INCORRECT?",options:{A:"Astrocyte–BBB",B:"Type II–surfactant",C:"Leydig–inhibin",D:"Mesangial–support"},correct:"C",explanation:"Inhibin = Sertoli, not Leydig."},
] },
      { name: 'Histo 8',  questions: [
  {id:"histo8-001",topic:"GIT",subtopic:"Colon",difficulty:"Very hard",question:"Which feature best distinguishes colon from small intestine?",options:{A:"Absence of villi",B:"Presence of enterocytes",C:"Presence of goblet cells",D:"Lamina propria"},correct:"A",explanation:"Colon has crypts but no villi; goblet cells are abundant but not unique."},
  {id:"histo8-002",topic:"GIT",subtopic:"Small intestine",difficulty:"Very hard",question:"Lacteals are mainly responsible for absorption of:",options:{A:"Amino acids",B:"Lipids",C:"Glucose",D:"Water"},correct:"B",explanation:"Lacteals absorb chylomicrons from intestinal villi."},
  {id:"histo8-003",topic:"Liver",subtopic:"Portal lobule",difficulty:"Very hard",question:"Portal lobule is centered around:",options:{A:"Central vein",B:"Hepatic sinusoid",C:"Portal triad",D:"Hepatic artery only"},correct:"C",explanation:"Portal lobule emphasizes bile drainage toward the bile duct in the portal area."},
  {id:"histo8-004",topic:"Liver",subtopic:"Hepatic acinus",difficulty:"Very hard",question:"Which hepatic acinus zone is first exposed to toxins arriving from portal blood?",options:{A:"Zone 1",B:"Zone 2",C:"Zone 3",D:"Central vein zone"},correct:"A",explanation:"Zone 1 is closest to portal blood supply, so it receives oxygen and toxins first."},
  {id:"histo8-005",topic:"Pancreas",subtopic:"Duct system",difficulty:"Very hard",question:"Which duct component is absent in pancreas compared with many salivary glands?",options:{A:"Intercalated duct",B:"Striated duct",C:"Centroacinar cell",D:"Main duct"},correct:"B",explanation:"The pancreas lacks striated ducts; centroacinar cells are characteristic."},
  {id:"histo8-006",topic:"Respiratory",subtopic:"Conducting portion",difficulty:"Very hard",question:"Which cell is a stem/progenitor cell in conducting respiratory epithelium?",options:{A:"Goblet cell",B:"Brush cell",C:"Basal cell",D:"Small granule cell"},correct:"C",explanation:"Basal cells regenerate the conducting epithelium."},
  {id:"histo8-007",topic:"Respiratory",subtopic:"Epiglottis",difficulty:"Very hard",question:"The lingual surface of the epiglottis is typically lined by:",options:{A:"Pseudostratified ciliated epithelium",B:"Simple squamous epithelium",C:"Transitional epithelium",D:"Non-keratinized stratified squamous epithelium"},correct:"D",explanation:"The lingual surface faces the oral cavity and is lined by non-keratinized stratified squamous epithelium."},
  {id:"histo8-008",topic:"Urinary",subtopic:"Renal corpuscle",difficulty:"Very hard",question:"The visceral layer of Bowman capsule is formed by:",options:{A:"Podocytes",B:"Simple squamous parietal cells",C:"Mesangial cells",D:"Macula densa cells"},correct:"A",explanation:"Podocytes form the visceral layer and filtration slits."},
  {id:"histo8-009",topic:"Urinary",subtopic:"JGA",difficulty:"Very hard",question:"Renin is secreted mainly by:",options:{A:"Macula densa cells",B:"Podocytes",C:"Juxtaglomerular granular cells",D:"Principal cells"},correct:"C",explanation:"Modified smooth muscle cells of the afferent arteriole release renin."},
  {id:"histo8-010",topic:"Endocrine",subtopic:"Parathyroid",difficulty:"Very hard",question:"The chief cells of parathyroid gland secrete:",options:{A:"Calcitonin",B:"Parathyroid hormone",C:"Thyroxine",D:"Aldosterone"},correct:"B",explanation:"Chief cells produce PTH, which regulates calcium metabolism."},
  {id:"histo8-011",topic:"Endocrine",subtopic:"Thyroid",difficulty:"Very hard",question:"Which statement is correct about thyroid follicles?",options:{A:"They store hormone extracellularly as colloid",B:"They contain only basophils",C:"They secrete insulin",D:"They lack epithelial lining"},correct:"A",explanation:"Thyroid follicles uniquely store hormone precursor extracellularly in colloid."},
  {id:"histo8-012",topic:"Nervous",subtopic:"Meninges",difficulty:"Very hard",question:"Arachnoid villi function mainly in:",options:{A:"CSF production",B:"CSF resorption into venous sinuses",C:"Blood-brain barrier formation",D:"Myelin production"},correct:"B",explanation:"Arachnoid villi resorb CSF into dural venous sinuses."},
  {id:"histo8-013",topic:"Nervous",subtopic:"BBB",difficulty:"Very hard",question:"Which structure is NOT a normal component of the blood-brain barrier?",options:{A:"Continuous capillary endothelium",B:"Endothelial basement membrane",C:"Astrocytic end-feet",D:"Fenestrated sinusoidal endothelium"},correct:"D",explanation:"BBB capillaries are continuous and non-fenestrated."},
  {id:"histo8-014",topic:"Skin",subtopic:"Melanin",difficulty:"Very hard",question:"Differences in skin color are mainly due to differences in:",options:{A:"Number of melanocytes",B:"Number/distribution of melanosomes in keratinocytes",C:"Number of Langerhans cells",D:"Thickness of dermis only"},correct:"B",explanation:"Melanocyte number is similar; melanosome amount and distribution differ."},
  {id:"histo8-015",topic:"Skin",subtopic:"Stratum corneum",difficulty:"Very hard",question:"Desquamation of superficial keratinocytes depends mainly on degradation of:",options:{A:"Gap junctions",B:"Hemidesmosomes",C:"Desmosomes",D:"Basal lamina"},correct:"C",explanation:"Proteolytic cleavage of desmosomes allows desquamation."},
  {id:"histo8-016",topic:"Male reproductive",subtopic:"Spermiogenesis",difficulty:"Very hard",question:"The acrosome is derived from:",options:{A:"Golgi apparatus",B:"Mitochondria",C:"Smooth ER",D:"Nucleus"},correct:"A",explanation:"Proacrosomal vesicles form from the Golgi apparatus."},
  {id:"histo8-017",topic:"Male reproductive",subtopic:"Seminiferous epithelium",difficulty:"Very hard",question:"Which cell type is normally located in the basal compartment?",options:{A:"Primary spermatocyte",B:"Spermatid",C:"Spermatogonium",D:"Spermatozoon"},correct:"C",explanation:"Spermatogonia remain basal; meiotic cells enter the adluminal compartment."},
  {id:"histo8-018",topic:"Female reproductive",subtopic:"Oogenesis",difficulty:"Very hard",question:"The secondary oocyte is arrested in:",options:{A:"Prophase I",B:"Metaphase II",C:"Anaphase II",D:"Telophase I"},correct:"B",explanation:"The ovulated secondary oocyte remains arrested in metaphase II until fertilization."},
  {id:"histo8-019",topic:"Female reproductive",subtopic:"Ovary surface",difficulty:"Hard",question:"The surface of the ovary is covered by:",options:{A:"Stratified squamous epithelium",B:"Pseudostratified ciliated epithelium",C:"Simple cuboidal epithelium",D:"Transitional epithelium"},correct:"C",explanation:"The ovarian surface is covered by simple cuboidal epithelium with tunica albuginea beneath."},
  {id:"histo8-020",topic:"Lymphatic",subtopic:"Lymph node flow",difficulty:"Very hard",question:"Correct lymph flow through a lymph node is:",options:{A:"Efferent → subcapsular sinus → afferent",B:"Afferent → subcapsular sinus → cortical sinuses → medullary sinuses → efferent",C:"Artery → follicle → vein",D:"Medulla → cortex → capsule"},correct:"B",explanation:"Lymph enters via afferent vessels and exits at the hilum through efferent lymphatics."},
  {id:"histo8-021",topic:"Lymphatic",subtopic:"Thymus",difficulty:"Very hard",question:"Which feature is absent in thymus?",options:{A:"Cortex",B:"Medulla",C:"Hassall corpuscles",D:"Germinal centers"},correct:"D",explanation:"Thymus lacks lymphoid follicles and germinal centers."},
  {id:"histo8-022",topic:"Cardiovascular",subtopic:"Endothelium",difficulty:"Very hard",question:"Endothelial cells promote leukocyte adhesion using:",options:{A:"Actin only",B:"P-selectin and adhesion molecules",C:"Keratin filaments",D:"Surfactant proteins"},correct:"B",explanation:"Endothelial Weibel-Palade bodies contain P-selectin; endothelial cells also express adhesion molecules."},
  {id:"histo8-023",topic:"Cardiovascular",subtopic:"Heart",difficulty:"Very hard",question:"Atrial cardiomyocytes are endocrine because they produce:",options:{A:"Renin",B:"Erythropoietin",C:"Atrial natriuretic peptide precursor",D:"Calcitonin"},correct:"C",explanation:"Atrial cardiomyocytes synthesize ANP precursor."},
  {id:"histo8-024",topic:"Tooth development",subtopic:"Cap stage",difficulty:"Very hard",question:"Stellate reticulum is located:",options:{A:"Between outer and inner enamel epithelium",B:"Inside dental papilla",C:"Inside dental pulp",D:"Between dentin and cementum"},correct:"A",explanation:"Stellate reticulum lies between the inner and outer enamel epithelium of the enamel organ."},
  {id:"histo8-025",topic:"Tooth development",subtopic:"Dental sac",difficulty:"Very hard",question:"Dental sac is best described as:",options:{A:"Oral ectoderm forming enamel",B:"Condensed mesenchyme surrounding dental buds",C:"Inner enamel epithelium",D:"Developing ameloblast layer"},correct:"B",explanation:"Dental sac is condensed mesenchyme surrounding dental buds and contributes supporting tissues."},
  {id:"histo8-026",topic:"Oral cavity",subtopic:"Tongue",difficulty:"Very hard",question:"The root of the tongue is characterized by:",options:{A:"Filiform papillae only",B:"Lingual tonsil",C:"No lymphoid tissue",D:"Respiratory epithelium"},correct:"B",explanation:"The root contains lingual tonsil; papillae are on the body/apex."},
  {id:"histo8-027",topic:"Oral cavity",subtopic:"Lip",difficulty:"Very hard",question:"The mucous surface of the lip is lined by:",options:{A:"Keratinized stratified squamous epithelium",B:"Respiratory epithelium",C:"Non-keratinized stratified squamous epithelium",D:"Simple columnar epithelium"},correct:"C",explanation:"The mucous surface has non-keratinized stratified squamous epithelium and labial glands."},
  {id:"histo8-028",topic:"Embryology",subtopic:"Face development",difficulty:"Very hard",question:"Primary palate is derived from:",options:{A:"Intermaxillary segment",B:"Lateral palatine shelves only",C:"Mandibular prominence",D:"Second pharyngeal arch"},correct:"A",explanation:"The intermaxillary segment contributes to the primary palate."},
  {id:"histo8-029",topic:"Embryology",subtopic:"Neural crest",difficulty:"Very hard",question:"Which cell is neural crest-derived?",options:{A:"Keratinocyte",B:"Melanocyte",C:"Hepatocyte",D:"Enterocyte"},correct:"B",explanation:"Melanocytes are derived from neural crest."},
  {id:"histo8-030",topic:"Integration",subtopic:"Incorrect pairings",difficulty:"Very hard",question:"Which pairing is incorrect?",options:{A:"Parafollicular cell — calcitonin",B:"Chief parathyroid cell — PTH",C:"Alpha pancreatic cell — insulin",D:"Chromaffin cell — catecholamines"},correct:"C",explanation:"Alpha cells secrete glucagon; beta cells secrete insulin."},
] },
      { name: 'Histo 9',  questions: [
  {id:"histo9-001",topic:"GIT",subtopic:"Esophagus",difficulty:"Very hard",question:"Upper third of esophagus contains which muscle type?",options:{A:"Smooth only",B:"Skeletal only",C:"Mixed skeletal and smooth",D:"Cardiac muscle"},correct:"B",explanation:"Upper third is skeletal muscle, middle mixed, lower smooth."},
  {id:"histo9-002",topic:"GIT",subtopic:"Stomach",difficulty:"Very hard",question:"Which cell produces intrinsic factor?",options:{A:"Chief cell",B:"Parietal cell",C:"Mucous neck cell",D:"Enteroendocrine cell"},correct:"B",explanation:"Parietal cells produce HCl and intrinsic factor."},
  {id:"histo9-003",topic:"Liver",subtopic:"Kupffer cells",difficulty:"Very hard",question:"Kupffer cells are best described as:",options:{A:"Hepatocytes",B:"Endothelial cells",C:"Resident macrophages",D:"Fibroblasts"},correct:"C",explanation:"Kupffer cells are macrophages lining sinusoids."},
  {id:"histo9-004",topic:"Liver",subtopic:"Sinusoids",difficulty:"Very hard",question:"Hepatic sinusoids are characterized by:",options:{A:"Continuous endothelium",B:"Fenestrated discontinuous endothelium",C:"Stratified lining",D:"Thick basement membrane"},correct:"B",explanation:"Sinusoids are discontinuous and fenestrated."},
  {id:"histo9-005",topic:"Pancreas",subtopic:"Endocrine",difficulty:"Very hard",question:"Which cell type secretes glucagon?",options:{A:"Alpha cells",B:"Beta cells",C:"Delta cells",D:"PP cells"},correct:"A",explanation:"Alpha cells produce glucagon."},
  {id:"histo9-006",topic:"Respiratory",subtopic:"Alveoli",difficulty:"Very hard",question:"Type I pneumocytes are specialized for:",options:{A:"Surfactant production",B:"Gas exchange",C:"Immune defense",D:"Mucus secretion"},correct:"B",explanation:"Thin cells for diffusion."},
  {id:"histo9-007",topic:"Respiratory",subtopic:"Bronchi",difficulty:"Very hard",question:"Which structure is present in bronchi but absent in bronchioles?",options:{A:"Smooth muscle",B:"Goblet cells",C:"Cartilage plates",D:"Elastic fibers"},correct:"C",explanation:"Cartilage disappears in bronchioles."},
  {id:"histo9-008",topic:"Urinary",subtopic:"Loop of Henle",difficulty:"Very hard",question:"Thin descending limb is permeable mainly to:",options:{A:"Sodium",B:"Water",C:"Urea only",D:"Proteins"},correct:"B",explanation:"Water leaves passively."},
  {id:"histo9-009",topic:"Urinary",subtopic:"Collecting duct",difficulty:"Very hard",question:"Which hormone increases water permeability in collecting duct?",options:{A:"Aldosterone",B:"ADH",C:"Renin",D:"ANP"},correct:"B",explanation:"ADH inserts aquaporins."},
  {id:"histo9-010",topic:"Endocrine",subtopic:"Adrenal gland",difficulty:"Very hard",question:"Which zone produces aldosterone?",options:{A:"Zona reticularis",B:"Zona fasciculata",C:"Zona glomerulosa",D:"Medulla"},correct:"C",explanation:"Glomerulosa → mineralocorticoids."},
  {id:"histo9-011",topic:"Endocrine",subtopic:"Pituitary",difficulty:"Very hard",question:"Posterior pituitary stores hormones produced in:",options:{A:"Anterior pituitary",B:"Hypothalamus",C:"Adrenal cortex",D:"Thyroid"},correct:"B",explanation:"ADH and oxytocin from hypothalamus."},
  {id:"histo9-012",topic:"Nervous",subtopic:"Neuron types",difficulty:"Very hard",question:"Which neuron type is typical for dorsal root ganglion?",options:{A:"Multipolar",B:"Bipolar",C:"Pseudounipolar",D:"Anaxonic"},correct:"C",explanation:"Sensory ganglia have pseudounipolar neurons."},
  {id:"histo9-013",topic:"Nervous",subtopic:"Glia",difficulty:"Very hard",question:"Microglia originate from:",options:{A:"Neuroectoderm",B:"Neural crest",C:"Mesoderm",D:"Endoderm"},correct:"C",explanation:"Derived from monocytes."},
  {id:"histo9-014",topic:"Skin",subtopic:"Epidermis",difficulty:"Very hard",question:"Which layer undergoes mitosis?",options:{A:"Corneum",B:"Granulosum",C:"Spinosum",D:"Basale"},correct:"D",explanation:"Stem cells in stratum basale."},
  {id:"histo9-015",topic:"Skin",subtopic:"Dermis",difficulty:"Very hard",question:"Which layer contains Meissner corpuscles?",options:{A:"Reticular dermis",B:"Papillary dermis",C:"Hypodermis",D:"Epidermis"},correct:"B",explanation:"Light touch receptors in papillary dermis."},
  {id:"histo9-016",topic:"Male repro",subtopic:"Testis",difficulty:"Very hard",question:"Which cell forms blood-testis barrier?",options:{A:"Leydig",B:"Sertoli",C:"Spermatogonia",D:"Peritubular"},correct:"B",explanation:"Tight junctions between Sertoli cells."},
  {id:"histo9-017",topic:"Male repro",subtopic:"Epididymis",difficulty:"Very hard",question:"Epithelium of epididymis is:",options:{A:"Simple cuboidal",B:"Stratified squamous",C:"Pseudostratified with stereocilia",D:"Transitional"},correct:"C",explanation:"Important for sperm maturation."},
  {id:"histo9-018",topic:"Female repro",subtopic:"Uterus",difficulty:"Very hard",question:"Which layer sheds during menstruation?",options:{A:"Basalis",B:"Functionalis",C:"Myometrium",D:"Perimetrium"},correct:"B",explanation:"Functional layer is shed."},
  {id:"histo9-019",topic:"Female repro",subtopic:"Placenta",difficulty:"Very hard",question:"Which layer directly contacts maternal blood?",options:{A:"Cytotrophoblast",B:"Syncytiotrophoblast",C:"Mesoderm",D:"Endothelium"},correct:"B",explanation:"Syncytiotrophoblast is outer invasive layer."},
  {id:"histo9-020",topic:"Lymphatic",subtopic:"Spleen",difficulty:"Very hard",question:"White pulp consists mainly of:",options:{A:"RBCs",B:"Adipose tissue",C:"Lymphocytes",D:"Fibroblasts"},correct:"C",explanation:"Immune function."},
  {id:"histo9-021",topic:"Lymphatic",subtopic:"Tonsils",difficulty:"Very hard",question:"Palatine tonsils are lined by:",options:{A:"Simple squamous",B:"Stratified squamous",C:"Respiratory epithelium",D:"Transitional"},correct:"B",explanation:"Protective epithelium."},
  {id:"histo9-022",topic:"Cardio",subtopic:"Capillaries",difficulty:"Very hard",question:"Which capillary type is found in kidney glomerulus?",options:{A:"Continuous",B:"Fenestrated",C:"Sinusoidal",D:"Lymphatic"},correct:"B",explanation:"Fenestrated without diaphragms."},
  {id:"histo9-023",topic:"Cardio",subtopic:"Heart",difficulty:"Very hard",question:"Which structure anchors AV valves?",options:{A:"Trabeculae carneae",B:"Chordae tendineae",C:"Moderator band",D:"Purkinje fibers"},correct:"B",explanation:"Connect valves to papillary muscles."},
  {id:"histo9-024",topic:"Tooth",subtopic:"Enamel",difficulty:"Very hard",question:"Enamel is produced by:",options:{A:"Odontoblasts",B:"Ameloblasts",C:"Cementoblasts",D:"Fibroblasts"},correct:"B",explanation:"Ameloblasts form enamel."},
  {id:"histo9-025",topic:"Tooth",subtopic:"Dentin",difficulty:"Very hard",question:"Dentin is secreted by:",options:{A:"Ameloblasts",B:"Odontoblasts",C:"Osteoblasts",D:"Cementoblasts"},correct:"B",explanation:"Odontoblasts line pulp."},
  {id:"histo9-026",topic:"Oral cavity",subtopic:"Salivary glands",difficulty:"Very hard",question:"Which gland is purely serous?",options:{A:"Parotid",B:"Submandibular",C:"Sublingual",D:"Minor glands"},correct:"A",explanation:"Parotid = serous."},
  {id:"histo9-027",topic:"Oral cavity",subtopic:"Tongue",difficulty:"Very hard",question:"Taste buds are found in:",options:{A:"Filiform papillae",B:"Fungiform and circumvallate",C:"All papillae",D:"None"},correct:"B",explanation:"Filiform lack taste buds."},
  {id:"histo9-028",topic:"Embryology",subtopic:"Placenta",difficulty:"Very hard",question:"Chorionic villi originate from:",options:{A:"Mesoderm only",B:"Ectoderm only",C:"Trophoblast",D:"Endoderm"},correct:"C",explanation:"Trophoblast forms villi."},
  {id:"histo9-029",topic:"Embryology",subtopic:"Neurulation",difficulty:"Very hard",question:"Neural tube gives rise to:",options:{A:"Peripheral nerves",B:"CNS",C:"Bone",D:"Muscle"},correct:"B",explanation:"Brain and spinal cord."},
  {id:"histo9-030",topic:"Integration",subtopic:"Incorrect pair",difficulty:"Very hard",question:"Which pairing is incorrect?",options:{A:"Beta cell–insulin",B:"Alpha cell–glucagon",C:"Delta cell–somatostatin",D:"PP cell–gastrin"},correct:"D",explanation:"PP cells secrete pancreatic polypeptide, not gastrin."},
] },
      { name: 'Histo 10', questions: [
  {id:"histo10-001",topic:"GIT",subtopic:"Small intestine",difficulty:"Very hard",question:"Which structure increases absorptive surface MOST?",options:{A:"Plicae circulares",B:"Villi",C:"Microvilli",D:"All equally"},correct:"C",explanation:"Microvilli provide the largest increase (brush border)."},
  {id:"histo10-002",topic:"GIT",subtopic:"Esophagus",difficulty:"Very hard",question:"Which epithelium lines the esophagus?",options:{A:"Simple columnar",B:"Stratified squamous non-keratinized",C:"Transitional",D:"Pseudostratified"},correct:"B",explanation:"Protection against abrasion."},
  {id:"histo10-003",topic:"Liver",subtopic:"Lobule",difficulty:"Very hard",question:"Blood flows in hepatic lobule:",options:{A:"Central → portal",B:"Portal → central",C:"Bidirectional",D:"Random"},correct:"B",explanation:"From portal triad to central vein."},
  {id:"histo10-004",topic:"Liver",subtopic:"Space of Disse",difficulty:"Very hard",question:"Space of Disse contains:",options:{A:"Blood cells",B:"Lymph",C:"Plasma between hepatocytes and endothelium",D:"Bile"},correct:"C",explanation:"Exchange zone."},
  {id:"histo10-005",topic:"Pancreas",subtopic:"Islets",difficulty:"Very hard",question:"Which cells produce insulin?",options:{A:"Alpha",B:"Beta",C:"Delta",D:"PP"},correct:"B",explanation:"Beta cells → insulin."},
  {id:"histo10-006",topic:"Respiratory",subtopic:"Alveoli",difficulty:"Very hard",question:"Type II pneumocytes function:",options:{A:"Gas exchange",B:"Surfactant production",C:"Phagocytosis",D:"Mucus secretion"},correct:"B",explanation:"Reduce surface tension."},
  {id:"histo10-007",topic:"Respiratory",subtopic:"Trachea",difficulty:"Very hard",question:"Trachea contains:",options:{A:"Smooth muscle only",B:"Cartilage rings",C:"Bone",D:"Striated muscle"},correct:"B",explanation:"C-shaped hyaline cartilage."},
  {id:"histo10-008",topic:"Urinary",subtopic:"Kidney",difficulty:"Very hard",question:"Which structure detects NaCl concentration?",options:{A:"Podocytes",B:"Macula densa",C:"Mesangial cells",D:"PCT cells"},correct:"B",explanation:"Part of JGA."},
  {id:"histo10-009",topic:"Urinary",subtopic:"Nephron",difficulty:"Very hard",question:"Most reabsorption occurs in:",options:{A:"Loop",B:"PCT",C:"DCT",D:"Collecting duct"},correct:"B",explanation:"~65% reabsorption."},
  {id:"histo10-010",topic:"Endocrine",subtopic:"Thyroid",difficulty:"Very hard",question:"Thyroid follicles store:",options:{A:"Hormone intracellularly",B:"Colloid extracellularly",C:"In blood",D:"In vesicles only"},correct:"B",explanation:"Unique extracellular storage."},
