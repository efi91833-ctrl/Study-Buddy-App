};

// ─────────────────────────────────────────────────────────────
// STORAGE HELPERS
// ─────────────────────────────────────────────────────────────
const STORAGE_KEY = 'studybuddy_v1';

function loadProgress() {
  try {
    return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {};
  } catch {
    return {};
  }
}

function saveProgress(data) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
}

function getSubjectProgress(subject) {
  const all = loadProgress();
  return all[subject] || { masteredIds: [], weakAreas: {} };
}

function updateSubjectProgress(subject, { newMastered = [], weakUpdates = {} }) {
  const all = loadProgress();
  const sp = all[subject] || { masteredIds: [], weakAreas: {} };

  const masteredSet = new Set(sp.masteredIds);
  newMastered.forEach(id => masteredSet.add(id));
  sp.masteredIds = [...masteredSet];

  Object.entries(weakUpdates).forEach(([topic, subs]) => {
    if (!sp.weakAreas[topic]) sp.weakAreas[topic] = {};
    Object.entries(subs).forEach(([subtopic, delta]) => {
      sp.weakAreas[topic][subtopic] = (sp.weakAreas[topic][subtopic] || 0) + delta;
    });
  });

  all[subject] = sp;
  saveProgress(all);
}

// ─────────────────────────────────────────────────────────────
// EXAM BUILDER
// ─────────────────────────────────────────────────────────────
function buildExam(subject, examIndex) {
  const sp = getSubjectProgress(subject);
  const masteredSet = new Set(sp.masteredIds);
  const weakAreas = sp.weakAreas || {};
  const meta = QUESTION_BANK[subject];

  // Use the specific exam's questions if available, otherwise the full flat list
  const source = (examIndex != null && meta.exams)
    ? meta.exams[examIndex].questions
    : meta.questions;

  let pool = source.filter(q => !masteredSet.has(q.id));

  if (pool.length === 0) {
    pool = [...source];
  }

  pool.sort((a, b) => {
    const wA = (weakAreas[a.topic]?.[a.subtopic] || 0);
    const wB = (weakAreas[b.topic]?.[b.subtopic] || 0);
    return wB - wA;
  });

  return pool;
}

// ─────────────────────────────────────────────────────────────
// COMPONENTS
// ─────────────────────────────────────────────────────────────

function OptionButton({ letter, text, state, onClick, disabled }) {
  return (
    <button
      className={`option-btn ${state}`}
      onClick={onClick}
      disabled={disabled}
    >
      <span className="option-letter">{letter}</span>
      <span>{text}</span>
    </button>
  );
}

function QuestionCard({ question, index, answer, onSelect, submitted }) {
  const { id, topic, subtopic, question: qText, options, correct, explanation } = question;

  function getState(letter) {
    if (!submitted) {
      return answer === letter ? 'selected' : '';
    }
    if (letter === correct) {
      return answer ? 'correct' : 'reveal-correct';
    }
    if (letter === answer) {
      return 'wrong';
    }
    if (!answer) return 'revealed';
    return '';
  }

  const unanswered = submitted && !answer;

  return (
    <div className="question-card">
      <div className="question-num">Question {index + 1}</div>
      <div className="question-topic-tag">{topic} › {subtopic}</div>
      <p className="question-text">{qText}</p>
      <div className="options-grid">
        {Object.entries(options).map(([letter, text]) => (
          <OptionButton
            key={letter}
            letter={letter}
            text={text}
            state={getState(letter)}
            onClick={() => onSelect(id, letter)}
            disabled={submitted}
          />
        ))}
      </div>
      {unanswered && (
        <p className="unanswered-note">Not answered — correct answer revealed above (not counted as wrong)</p>
      )}
      {submitted && (
        <div className="explanation-box">
          <strong>Explanation: </strong>{explanation}
        </div>
      )}
    </div>
  );
}

function ResultsBanner({ questions, answers, subject, onNext, onHome }) {
  const answered = questions.filter(q => answers[q.id]);
  const correct  = answered.filter(q => answers[q.id] === q.correct);
  const pct = answered.length ? Math.round((correct.length / answered.length) * 100) : 0;

  const ringClass = pct >= 80 ? 'score-great' : pct >= 50 ? 'score-ok' : 'score-poor';

  const wrongBySubtopic = {};
  questions.forEach(q => {
    if (answers[q.id] && answers[q.id] !== q.correct) {
      if (!wrongBySubtopic[q.subtopic]) wrongBySubtopic[q.subtopic] = 0;
      wrongBySubtopic[q.subtopic]++;
    }
  });
  const weakList = Object.keys(wrongBySubtopic);

  return (
    <div>
      <div className="results-banner">
        <div className={`score-ring ${ringClass}`}>
          <span>{pct}%</span>
          <span className="score-label">score</span>
        </div>
        <div className="results-detail">
          <h2>
            {pct >= 80 ? 'Great work!' : pct >= 50 ? 'Keep it up!' : 'Keep studying!'}
          </h2>
          <p>
            {correct.length} / {answered.length} answered correctly
            {questions.length - answered.length > 0 &&
              ` · ${questions.length - answered.length} skipped`}
          </p>
        </div>
      </div>

      {weakList.length > 0 && (
        <div className="weak-areas-box">
          <h3>Weak areas to focus on next time</h3>
          {weakList.map(sub => (
            <span key={sub} className="weak-tag">{sub}</span>
          ))}
        </div>
      )}

      <div className="exam-actions" style={{ marginTop: 28 }}>
        <button className="btn-primary" onClick={onNext}>Next Exam →</button>
        <button className="btn-secondary" onClick={onHome}>Back to Subjects</button>
      </div>
    </div>
  );
}

function ExamScreen({ subject, examIndex, onBack }) {
  const [questions]  = useState(() => buildExam(subject, examIndex));
  const [answers, setAnswers] = useState({});
  const [submitted, setSubmitted] = useState(false);
  const [showResults, setShowResults] = useState(false);

  const meta   = QUESTION_BANK[subject];
  const source = (examIndex != null && meta.exams) ? meta.exams[examIndex].questions : meta.questions;
  const sp     = getSubjectProgress(subject);
  const allMastered = source.length > 0 && source.every(q => sp.masteredIds.includes(q.id));

  function handleSelect(id, letter) {
    if (submitted) return;
    setAnswers(prev => ({ ...prev, [id]: letter }));
  }

  function handleSubmit() {
    const newMastered  = [];
    const weakUpdates  = {};

    questions.forEach(q => {
      const ans = answers[q.id];
      if (!ans) return;
      if (ans === q.correct) {
        newMastered.push(q.id);
      } else {
        if (!weakUpdates[q.topic]) weakUpdates[q.topic] = {};
        weakUpdates[q.topic][q.subtopic] = (weakUpdates[q.topic][q.subtopic] || 0) + 1;
      }
    });

    updateSubjectProgress(subject, { newMastered, weakUpdates });
    setSubmitted(true);
    setShowResults(true);
  }

  function handleNext() {
    window.location.reload();
  }

  const answeredCount = Object.keys(answers).length;
  const sp2 = getSubjectProgress(subject);
  const masteredCount = sp2.masteredIds.filter(id => source.some(q => q.id === id)).length;
  const totalCount = source.length;

  return (
    <div className="content">
      <div className="exam-header">
        <button className="topbar-back" style={{ marginBottom: 16 }} onClick={onBack}>← Subjects</button>
        <div className="exam-subject-label">
          <span>{subject}{examIndex != null && meta.exams ? ` · ${meta.exams[examIndex].name}` : ''}</span>
        </div>
        <h1 className="exam-title">
          {allMastered ? 'Full Review (all mastered!)' : 'Exam'}
        </h1>
        <p className="exam-meta">
          {questions.length} question{questions.length !== 1 ? 's' : ''}
          {masteredCount > 0 && ` · ${masteredCount}/${totalCount} mastered`}
          {!submitted && answeredCount > 0 && ` · ${answeredCount} answered`}
        </p>
      </div>

      <div className="question-list">
        {questions.map((q, i) => (
          <QuestionCard
            key={q.id}
            question={q}
            index={i}
            answer={answers[q.id]}
            onSelect={handleSelect}
            submitted={submitted}
          />
        ))}
      </div>

      {!submitted && (
        <div className="exam-actions">
          <button className="btn-primary" onClick={handleSubmit}>
            Submit Exam
          </button>
          <span style={{ fontSize: 13, color: '#666' }}>
            {answeredCount}/{questions.length} answered
          </span>
        </div>
      )}

      {showResults && (
        <ResultsBanner
          questions={questions}
          answers={answers}
          subject={subject}
          onNext={handleNext}
          onHome={onBack}
        />
      )}
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
// CZECH CREDIT TEST COMPONENTS
// ─────────────────────────────────────────────────────────────
function czShuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function parseCzChoose(text) {
  const parts = [];
  const re = /([^\s/]+)\/([^\s]+)/g;
  let last = 0, m;
  while ((m = re.exec(text)) !== null) {
    if (m.index > last) parts.push({ type: 'text', value: text.slice(last, m.index) });
    let o1 = m[1], o2 = m[2], trail = '';
    const pm = o2.match(/^(.*?)([.,;:!?]+)$/);
    if (pm) { o2 = pm[1]; trail = pm[2]; }
    parts.push({ type: 'choice', options: [o1, o2] });
    if (trail) parts.push({ type: 'text', value: trail });
    last = m.index + m[0].length;
  }
  if (last < text.length) parts.push({ type: 'text', value: text.slice(last) });
  return parts;
}

/* ── Match ── */
function CzMatchSection({ section, value = {}, onChange, submitted }) {
  const [shuffledRight] = useState(() => czShuffle(section.right));
  const [selected, setSelected] = useState(null);
  const [connLR, setConnLR] = useState({});
  const [connRL, setConnRL] = useState({});
  const [lines, setLines] = useState([]);
  const containerRef = useRef(null);
  const leftRefs = useRef({});
  const rightRefs = useRef({});

  const recalc = () => {
    if (!containerRef.current) return;
    const cr = containerRef.current.getBoundingClientRect();
    const nl = [];
    Object.entries(connLR).forEach(([li, ri]) => {
      const le = leftRefs.current[li], re = rightRefs.current[ri];
      if (!le || !re) return;
      const lr = le.getBoundingClientRect(), rr = re.getBoundingClientRect();
      nl.push({ x1: lr.right-cr.left, y1: lr.top+lr.height/2-cr.top,
                x2: rr.left-cr.left,  y2: rr.top+rr.height/2-cr.top });
    });
    setLines(nl);
  };
  useEffect(() => {
    recalc();
    const h = () => recalc();
    window.addEventListener('resize', h);
    window.addEventListener('scroll', h, true);
    return () => { window.removeEventListener('resize', h); window.removeEventListener('scroll', h, true); };
  }, [connLR]);

  const buildResult = (lr) => {
    const res = {};
    Object.entries(lr).forEach(([li, ri]) => { res[section.left[li]] = shuffledRight[ri]; });
    return res;
  };
  const clickLeft = (i) => {
    if (submitted) return;
    if (connLR[i] !== undefined) {
      const n1 = {...connLR}, n2 = {...connRL};
      delete n2[n1[i]]; delete n1[i];
      setConnLR(n1); setConnRL(n2); setSelected(null);
      onChange(buildResult(n1)); return;
    }
    setSelected(s => s === i ? null : i);
  };
  const clickRight = (j) => {
    if (submitted) return;
    if (selected === null) {
      if (connRL[j] !== undefined) {
        const n1 = {...connLR}, n2 = {...connRL};
        delete n1[n2[j]]; delete n2[j];
        setConnLR(n1); setConnRL(n2); onChange(buildResult(n1));
      }
      return;
    }
    const n1 = {...connLR}, n2 = {...connRL};
    if (n1[selected] !== undefined) { delete n2[n1[selected]]; }
    if (n2[j] !== undefined) { delete n1[n2[j]]; }
    n1[selected] = j; n2[j] = selected;
    setConnLR(n1); setConnRL(n2); setSelected(null);
    onChange(buildResult(n1));
  };
  const isConnected = (i) => connLR[i] !== undefined;

  if (submitted) {
    // Show feedback: left[i] should match right[i]
    return (
      <div>
        {section.left.map((lItem, i) => {
          const correctRight = section.right[i];
          const userRight = value[lItem];
          const correct = userRight === correctRight;
          return (
            <div key={i} className="cz-fb-row">
              <span className="cz-fb-q">{lItem}</span>
              {userRight
                ? correct
                  ? <span className="cz-fb-right">→ {userRight} ✓</span>
                  : <><span className="cz-fb-wrong">→ {userRight}</span><span className="cz-fb-correct"> correct: {correctRight}</span></>
                : <span className="cz-fb-open">— not matched (correct: {correctRight})</span>
              }
            </div>
          );
        })}
      </div>
    );
  }

  return (
    <div className="cz-match-wrap" ref={containerRef}>
      <svg className="cz-match-svg">
        {lines.map((l, k) => (
          <line key={k} x1={l.x1} y1={l.y1} x2={l.x2} y2={l.y2}
            stroke="#555" strokeWidth="2" strokeDasharray="5 3" strokeLinecap="round"/>
        ))}
      </svg>
      <div className="cz-match-cols">
        <div className="cz-match-col">
          {section.left.map((item, i) => (
            <div key={i} ref={el => leftRefs.current[i] = el}
              className={`cz-match-item${selected === i ? ' cz-selected' : ''}`}
              onClick={() => clickLeft(i)}
              style={isConnected(i) && selected !== i ? {borderColor:'#555',background:'#f0f0f0'} : {}}>
              {item}
            </div>
          ))}
        </div>
        <div className="cz-match-gap"/>
        <div className="cz-match-col">
          {shuffledRight.map((item, j) => (
            <div key={j} ref={el => rightRefs.current[j] = el}
              className="cz-match-item"
              onClick={() => clickRight(j)}
              style={connRL[j] !== undefined ? {borderColor:'#555',background:'#f0f0f0'} : {}}>
              {item}
            </div>
          ))}
        </div>
      </div>
      {selected !== null && (
        <p style={{fontSize:'.78rem',color:'#555',marginTop:8,textAlign:'center'}}>
          "{section.left[selected]}" selected — tap a word on the right
        </p>
      )}
    </div>
  );
}

/* ── Label ── */
function CzLabelSection({ section, value = {}, onChange, submitted }) {
  return (
    <div className="cz-label-grid">
      {section.prompts.map((p, i) => (
        <div key={i} className="cz-label-cell">
          <span className="cz-label-prompt">{i+1}. {p}</span>
          {submitted
            ? <div style={{fontSize:'.9rem',padding:'6px 0',color: value[i] ? '#1a1a1a' : '#aaa',fontStyle: value[i] ? 'normal' : 'italic'}}>
                {value[i] || '—'}
              </div>
            : <input className="cz-text-field" placeholder="Czech…"
                value={value[i] || ''} onChange={e => onChange({...value, [i]: e.target.value})}/>
          }
        </div>
      ))}
    </div>
  );
}

/* ── Write ── */
function CzWriteSection({ section, value = {}, onChange, submitted }) {
  return (
    <div className="cz-write-list">
      {section.prompts.map((p, i) => (
        <div key={i} className="cz-write-row">
          <span className="cz-write-num">{i+1}.</span>
          <span className="cz-write-prompt">{p}</span>
          {submitted
            ? <div style={{flex:1.2,fontSize:'.9rem',padding:'6px 0',color: value[i] ? '#1a1a1a' : '#aaa',fontStyle: value[i] ? 'normal' : 'italic'}}>
                {value[i] || '—'}
              </div>
            : <input className="cz-text-field cz-write-input" placeholder="Answer…"
                value={value[i] || ''} onChange={e => onChange({...value, [i]: e.target.value})}/>
          }
        </div>
      ))}
    </div>
  );
}

/* ── MCQ ── */
function CzMCQSection({ section, value = {}, onChange, submitted }) {
  return (
    <div>
      {section.text && <p className="cz-mcq-story">{section.text}</p>}
      <div className="cz-mcq-list">
        {section.questions.map((q, qi) => {
          const chosen = value[qi];
          const correctOpt = q.correct !== undefined ? q.options[q.correct] : null;
          const isCorrect = chosen === correctOpt;
          return (
            <div key={qi} style={{paddingBottom: submitted ? 2 : 0}}>
              <p className="cz-mcq-q">{qi+1}. {q.q}</p>
              {submitted ? (
                <div>
                  <div className="cz-fb-row" style={{borderBottom:'none',paddingBottom:0}}>
                    <span className="cz-fb-q">Your answer:</span>
                    {chosen
                      ? isCorrect
                        ? <span className="cz-fb-right">{chosen} ✓</span>
                        : <><span className="cz-fb-wrong">{chosen}</span><span className="cz-fb-correct"> {correctOpt}</span></>
                      : <span className="cz-fb-open">not answered{correctOpt ? ` — correct: ${correctOpt}` : ''}</span>
                    }
                  </div>
                  {!isCorrect && q.explanation && (
                    <div className="cz-fb-explanation">{q.explanation}</div>
                  )}
                </div>
              ) : (
                <div className="cz-mcq-opts">
                  {q.options.map((opt, oi) => (
                    <span key={oi} className={`cz-mcq-opt${chosen === opt ? ' cz-active' : ''}`}
                      onClick={() => onChange({...value, [qi]: opt})}>
                      {opt}
                    </span>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
}

/* ── True / False ── */
function CzTrueFalseSection({ section, value = {}, onChange, submitted }) {
  const toggle = (i, v) => onChange({...value, [i]: value[i] === v ? null : v});

  if (submitted) {
    return (
      <div>
        {section.text && <p className="cz-tf-story">{section.text}</p>}
        <div style={{display:'flex',flexDirection:'column',gap:6}}>
          {section.statements.map((stmt, i) => {
            const chosen = value[i];
            const correctAns = section.correct ? section.correct[i] : null;
            const isCorrect = correctAns ? chosen === correctAns : null;
            return (
              <div key={i} className="cz-fb-row">
                <span className="cz-fb-q">{i+1}. {stmt}</span>
                <span style={{flexShrink:0,whiteSpace:'nowrap'}}>
                  {!chosen
                    ? <span className="cz-fb-open">— {correctAns ? `correct: ${correctAns}` : ''}</span>
                    : isCorrect === true
                      ? <span className="cz-fb-right">{chosen} ✓</span>
                      : isCorrect === false
                        ? <><span className="cz-fb-wrong">{chosen}</span><span className="cz-fb-correct"> {correctAns}</span></>
                        : <span className="cz-fb-right">{chosen}</span>
                  }
                </span>
              </div>
            );
          })}
        </div>
      </div>
    );
  }

  return (
    <div>
      {section.text && <p className="cz-tf-story">{section.text}</p>}
      <div className="cz-tf-list">
        {section.statements.map((stmt, i) => (
          <div key={i} className="cz-tf-row">
            <span className="cz-tf-idx">{i+1}.</span>
            <span className="cz-tf-stmt">{stmt}</span>
            <div className="cz-tf-btns">
              <button className={`cz-tf-btn${value[i] === 'Ano' ? ' on' : ''}`}
                onClick={() => toggle(i, 'Ano')}>Ano</button>
              <button className={`cz-tf-btn${value[i] === 'Ne' ? ' on' : ''}`}
                onClick={() => toggle(i, 'Ne')}>Ne</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}

/* ── Choose Form ── */
function CzChooseFormSection({ section, value = {}, onChange, submitted }) {
  const parts = parseCzChoose(section.text);
  let ci = 0;

  if (submitted) {
    // Render inline with correct/wrong indicator per choice
    let fi = 0;
    return (
      <div className="cz-choose-wrap">
        {parts.map((part, pi) => {
          if (part.type === 'text') return <span key={pi}>{part.value}</span>;
          const idx = fi++;
          const sel = value[idx] !== undefined ? value[idx] : 0;
          const correctIdx = section.correct ? section.correct[idx] : null;
          const isOk = correctIdx === null || sel === correctIdx;
          const chosenWord = part.options[sel];
          const correctWord = correctIdx !== null ? part.options[correctIdx] : null;
          return (
            <span key={pi} style={{display:'inline-flex',alignItems:'baseline',margin:'0 2px',gap:2}}>
              {isOk
                ? <strong style={{borderBottom:'2px solid #1a1a1a'}}>{chosenWord} ✓</strong>
                : <><s style={{color:'#999'}}>{chosenWord}</s><strong style={{borderBottom:'2px solid #1a1a1a',marginLeft:4}}>{correctWord}</strong></>
              }
            </span>
          );
        })}
      </div>
    );
  }

  return (
    <div className="cz-choose-wrap">
      {parts.map((part, pi) => {
        if (part.type === 'text') return <span key={pi}>{part.value}</span>;
        const idx = ci++;
        const sel = value[idx] !== undefined ? value[idx] : 0;
        return (
          <span key={pi} className="cz-choice-toggle"
            onClick={() => onChange({...value, [idx]: sel === 0 ? 1 : 0})}>
            <span className={`cz-choice-opt ${sel === 0 ? 'on' : 'off'}`}>{part.options[0]}</span>
            <span className={`cz-choice-opt ${sel === 1 ? 'on' : 'off'}`}>{part.options[1]}</span>
          </span>
        );
      })}
    </div>
  );
}

/* ── Section wrapper ── */
function CzSection({ section, sIdx, answers, setAnswer, submitted }) {
  const val = answers[sIdx] || {};
  const upd = (v) => setAnswer(sIdx, v);
  return (
    <div className="czech-section-card">
      <div className="czech-section-title">{section.title}</div>
      {section.type === 'match'      && <CzMatchSection      section={section} value={val} onChange={upd} submitted={submitted}/>}
      {section.type === 'label'      && <CzLabelSection      section={section} value={val} onChange={upd} submitted={submitted}/>}
      {section.type === 'write'      && <CzWriteSection      section={section} value={val} onChange={upd} submitted={submitted}/>}
      {section.type === 'mcq'        && <CzMCQSection        section={section} value={val} onChange={upd} submitted={submitted}/>}
      {section.type === 'trueFalse'  && <CzTrueFalseSection  section={section} value={val} onChange={upd} submitted={submitted}/>}
      {section.type === 'chooseForm' && <CzChooseFormSection section={section} value={val} onChange={upd} submitted={submitted}/>}
    </div>
  );
}

/* ── Main Czech Credit Test ── */
function CzechCreditTest({ testKey: initialKey, onBack }) {
  const bank = window.czechCreditTests || {};
  const [testKey, setTestKey] = useState(initialKey || 'A');
  const [answers, setAnswers] = useState({});
  const [submitted, setSubmitted] = useState(false);
  const test = bank[testKey];

  const switchTest = (k) => { setTestKey(k); setAnswers({}); setSubmitted(false); };
  const setAnswer = (si, val) => setAnswers(prev => ({...prev, [si]: val}));

  if (!test) return <div style={{padding:40,textAlign:'center',color:'#888'}}>Czech test data not loaded.</div>;

  return (
    <div style={{maxWidth:760,margin:'0 auto',padding:'16px 12px 40px'}}>
      <div className="czech-header">
        <button className="back-btn" onClick={onBack}>← Back to Czech</button>
        <h2>{test.title}</h2>
        <div style={{display:'flex',gap:8,marginTop:12}}>
          {['A','B','C'].map(k => (
            <button key={k} className={`cz-test-tab${testKey===k ? ' cz-tab-active' : ''}`}
              onClick={() => switchTest(k)}>Test {k}</button>
          ))}
        </div>
      </div>

      {test.sections.map((section, si) => (
        <CzSection key={`${testKey}-${si}`} section={section} sIdx={si}
          answers={answers} setAnswer={setAnswer} submitted={submitted}/>
      ))}

      <div className="cz-submit-row">
        {!submitted
          ? <button className="cz-submit-btn" onClick={() => { setSubmitted(true); window.scrollTo(0,0); }}>
              Submit Test
            </button>
          : <button className="cz-submit-btn" style={{background:'#555'}}
              onClick={() => { setAnswers({}); setSubmitted(false); window.scrollTo(0,0); }}>
              Retake Test
            </button>
        }
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
function ExamPicker({ subject, onSelectExam, onBack }) {
  const meta = QUESTION_BANK[subject];
  const cardStyle = {
    background: 'rgba(255,255,255,0.85)',
    border: '1px solid rgba(0,0,0,0.12)',
    borderRadius: 14,
    padding: '18px 16px',
    cursor: 'pointer',
    textAlign: 'left',
    fontSize: 15,
    fontWeight: 600,
    color: '#1a1a1a',
    boxShadow: '0 1px 4px rgba(0,0,0,0.06)',
    transition: 'all .15s',
  };
  return (
    <div className="content" style={{ maxWidth: 520 }}>
      <div className="exam-header">
        <button className="topbar-back" style={{ marginBottom: 16 }} onClick={onBack}>← Subjects</button>
        <div className="exam-subject-label"><span>{subject}</span></div>
        <h1 className="exam-title">Choose an Exam</h1>
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: 12, marginTop: 24 }}>
        {/* Anatomy Slides special card */}
        {subject === 'Anatomy' && (
          <button onClick={() => onSelectExam({ type: 'anatomy_slides' })}
            style={{ ...cardStyle, background: 'rgba(240,240,255,0.9)', gridColumn: '1 / -1' }}>
            Anatomy Slides
            <div style={{ fontSize: 12, fontWeight: 400, color: '#888', marginTop: 4 }}>
              {ANATOMY_SLIDE_TESTS.length} tests · label and study anatomy images
            </div>
          </button>
        )}
        {/* Muscle Lab special card */}
        {subject === 'Anatomy' && (
          <button onClick={() => onSelectExam({ type: 'muscle_lab' })}
            style={{ ...cardStyle, background: 'rgba(240,240,240,0.9)', gridColumn: '1 / -1' }}>
            Muscle Lab
            <div style={{ fontSize: 12, fontWeight: 400, color: '#888', marginTop: 4 }}>
              {(window.MUSCLE_BANK || []).length} muscles · origin, insertion, innervation, function
            </div>
          </button>
        )}
        {/* Peritoneal Game special card */}
        {subject === 'Anatomy' && (
          <button onClick={() => onSelectExam({ type: 'peritoneal_game' })}
            style={{ ...cardStyle, background: 'rgba(240,240,240,0.9)', gridColumn: '1 / -1' }}>
            Match the Organ — Peritoneal Relations
            <div style={{ fontSize: 12, fontWeight: 400, color: '#888', marginTop: 4 }}>
              26 organs · drag and drop into the correct peritoneal category
            </div>
          </button>
        )}
        {/* Group exams by type for cleaner layout */}
        {(() => {
          const subjectBanks = meta.exams.filter(e => e.type === 'czech_subject');
          const creditTests  = meta.exams.filter(e => e.type === 'czech_credit');
          const regularExams = meta.exams.filter(e => e.type !== 'czech_subject' && e.type !== 'czech_credit');

          return (
            <>
              {/* Subject banks section */}
              {subjectBanks.length > 0 && (
                <>
                  <div style={{ gridColumn: '1 / -1', fontSize: 11, fontWeight: 700, color: '#888', textTransform: 'uppercase', letterSpacing: '.06em', marginBottom: -4, marginTop: 4 }}>Subject Banks</div>
                  {subjectBanks.map((exam, i) => {
                    const bank = window.czechQuestionBanks?.[exam.bankKey];
                    const count = bank?.questions?.length || 0;
                    return (
                      <button key={'sub-'+i}
                        onClick={() => onSelectExam({ type: 'czech_subject', bankKey: exam.bankKey })}
                        style={{ ...cardStyle, background: 'rgba(245,245,245,0.95)', borderLeft: '3px solid #1a1a1a' }}>
                        {exam.name}
                        <div style={{ fontSize: 12, fontWeight: 400, color: '#555', marginTop: 4 }}>
                          {count > 0 ? `${count} questions · mixed types` : 'Loading…'}
                        </div>
                      </button>
                    );
                  })}
                </>
              )}

              {/* Credit tests section */}
              {creditTests.length > 0 && (
                <>
                  <div style={{ gridColumn: '1 / -1', fontSize: 11, fontWeight: 700, color: '#888', textTransform: 'uppercase', letterSpacing: '.06em', marginBottom: -4, marginTop: 8 }}>Credit Tests</div>
                  {creditTests.map((exam, i) => (
                    <button key={'cred-'+i}
                      onClick={() => onSelectExam({ type: 'czech_credit', testKey: exam.testKey })}
                      style={{ ...cardStyle, background: 'rgba(240,240,248,0.95)' }}>
                      {exam.name}
                      <div style={{ fontSize: 12, fontWeight: 400, color: '#555', marginTop: 4 }}>
                        Credit test · 7 sections
                      </div>
                    </button>
                  ))}
                </>
              )}

              {/* Regular MCQ exams */}
              {regularExams.map((exam, i) => {
                const sp = getSubjectProgress(subject);
                const done = exam.questions.length > 0 && exam.questions.every(q => sp.masteredIds.includes(q.id));
                return (
                  <button key={'reg-'+i} onClick={() => onSelectExam(meta.exams.indexOf(exam))}
                    style={{ ...cardStyle, background: done ? '#e8f5e9' : 'rgba(255,255,255,0.85)' }}>
                    {exam.name}
                    <div style={{ fontSize: 12, fontWeight: 400, color: '#888', marginTop: 4 }}>
                      {exam.questions.length === 0 ? 'Coming soon' : `${exam.questions.length} questions${done ? ' · mastered' : ''}`}
                    </div>
                  </button>
                );
              })}
            </>
          );
        })()}
      </div>
    </div>
  );
}

function AnatomyTest({ onBack }) {
  const [selectedTest, setSelectedTest] = React.useState(null);
  const [slideIdx, setSlideIdx]         = React.useState(0);
  const [revealedIds, setRevealedIds]   = React.useState({});

  // Edit/positioning state
  const [editMode, setEditMode]       = React.useState(false);
  const [drawing, setDrawing]         = React.useState(null);
  const [pendingBox, setPendingBox]   = React.useState(null);
  const [pendingTerm, setPendingTerm] = React.useState('');
  const [editLabels, setEditLabels]   = React.useState(null);
  const [, forceUpdate]               = React.useReducer(x => x + 1, 0);

  const wrapRef = React.useRef(null);
  const termRef = React.useRef(null);

  // ── All hooks must be before any early return ──────────────
  const slide  = selectedTest ? selectedTest.slides[slideIdx] : null;
  const labels = slide
    ? (editMode ? (editLabels || getLabelsForSlide(slide.slideId)) : getLabelsForSlide(slide.slideId))
    : [];

  React.useEffect(() => {
    if (!selectedTest || !slide) return;
    setRevealedIds({});
    setPendingBox(null);
    setDrawing(null);
    setPendingTerm('');
    if (editMode) setEditLabels(getLabelsForSlide(slide.slideId));
  }, [slideIdx, selectedTest]);

  React.useEffect(() => {
    if (pendingBox) setTimeout(() => termRef.current?.focus(), 60);
  }, [pendingBox]);

  // ── Test picker (early return after all hooks) ───────────
  if (!selectedTest) {
    return (
      <div style={{maxWidth:860, margin:'0 auto', padding:'24px 20px'}}>
        <div style={{display:'flex', alignItems:'center', gap:10, marginBottom:24}}>
          <button className="topbar-back" onClick={onBack}>← Back</button>
          <span style={{fontSize:16, fontWeight:700, color:'#222'}}>Anatomy Slide Tests</span>
        </div>
        <div style={{display:'grid', gridTemplateColumns:'repeat(auto-fill, minmax(190px, 1fr))', gap:12}}>
          {ANATOMY_SLIDE_TESTS.map(test => {
            let labelCount = 0;
            test.slides.forEach(s => { labelCount += getLabelsForSlide(s.slideId).length; });
            return (
              <div key={test.testId}
                onClick={() => { setSelectedTest(test); setSlideIdx(0); setRevealedIds({}); setEditMode(false); setEditLabels(null); }}
                style={{
                  background:'rgba(255,255,255,0.8)', border:'1px solid #ddd',
                  borderRadius:12, padding:'16px', cursor:'pointer', transition:'all .15s',
                }}>
                <div style={{fontSize:15, fontWeight:700, color:'#1a1a1a', marginBottom:4}}>{test.title}</div>
                <div style={{fontSize:12, color:'#888'}}>{test.slides.length} slide{test.slides.length !== 1 ? 's' : ''}</div>
                {labelCount > 0 && (
                  <div style={{fontSize:11, color:'#999', marginTop:3}}>{labelCount} label{labelCount !== 1 ? 's' : ''} drawn</div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    );
  }

  // ── Test view ────────────────────────────────────────────

  // Simple reveal — no rating
  function handleBoxClick(label) {
    setRevealedIds(prev => ({ ...prev, [label.id]: !prev[label.id] }));
  }

  /* ── Edit mode ── */
  function enterEdit() {
    setEditLabels(getLabelsForSlide(slide.slideId));
    setPendingBox(null); setPendingTerm(''); setDrawing(null);
    setEditMode(true);
  }
  function exitEdit() {
    if (editLabels !== null) saveCustomLabelsForSlide(slide.slideId, editLabels);
    setPendingBox(null); setPendingTerm(''); setDrawing(null);
    setEditMode(false); setEditLabels(null); forceUpdate();
  }
  function discardEdit() {
    setPendingBox(null); setDrawing(null); setEditMode(false); setEditLabels(null);
  }

  /* ── Draw new box (mouse + touch) ── */
  function getPoint(e) {
    // Works for both MouseEvent and TouchEvent
    const src = e.touches ? e.touches[0] : e;
    const r = wrapRef.current.getBoundingClientRect();
    return {
      x: Math.max(0, Math.min(100, ((src.clientX - r.left) / r.width)  * 100)),
      y: Math.max(0, Math.min(100, ((src.clientY - r.top)  / r.height) * 100)),
    };
  }
  function onMouseDown(e) {
    if (!editMode) return;
    e.preventDefault();
    const p = getPoint(e);
    setDrawing({ sx: p.x, sy: p.y, cx: p.x, cy: p.y });
    setPendingBox(null); setPendingTerm('');
  }
  function onMouseMove(e) {
    if (!drawing) return;
    const p = getPoint(e);
    setDrawing(d => ({ ...d, cx: p.x, cy: p.y }));
  }
  function onMouseUp(e) {
    if (!drawing) return;
    const p = getPoint(e);
    const x = Math.min(drawing.sx, p.x), y = Math.min(drawing.sy, p.y);
    const w = Math.abs(p.x - drawing.sx),  h = Math.abs(p.y - drawing.sy);
    setDrawing(null);
    if (w < 1 || h < 1) return;
    setPendingBox({ x, y, w, h });
  }
  // Touch equivalents
  function onTouchStart(e) {
    if (!editMode) return;
    e.preventDefault();
    const p = getPoint(e);
    setDrawing({ sx: p.x, sy: p.y, cx: p.x, cy: p.y });
    setPendingBox(null); setPendingTerm('');
  }
  function onTouchMove(e) {
    if (!drawing) return;
    e.preventDefault();
    const p = getPoint(e);
    setDrawing(d => ({ ...d, cx: p.x, cy: p.y }));
  }
  function onTouchEnd(e) {
    if (!drawing) return;
    const touch = e.changedTouches[0];
    const r = wrapRef.current.getBoundingClientRect();
    const px = Math.max(0, Math.min(100, ((touch.clientX - r.left) / r.width)  * 100));
    const py = Math.max(0, Math.min(100, ((touch.clientY - r.top)  / r.height) * 100));
    const x = Math.min(drawing.sx, px), y = Math.min(drawing.sy, py);
    const w = Math.abs(px - drawing.sx),  h = Math.abs(py - drawing.sy);
    setDrawing(null);
    if (w < 1 || h < 1) return;
    setPendingBox({ x, y, w, h });
  }
  function savePending() {
    if (!pendingBox) return;
    const newLabel = { id: 's' + slide.slideId + '-c' + Date.now(), term: pendingTerm.trim() || '?', ...pendingBox };
    setEditLabels(prev => [...(prev || []), newLabel]);
    setPendingBox(null); setPendingTerm('');
  }
  function deleteEditLabel(id) {
    setEditLabels(prev => (prev || []).filter(l => l.id !== id));
  }
  function clearSlide() { setEditLabels([]); }

  const drawRect = drawing ? {
    x: Math.min(drawing.sx, drawing.cx), y: Math.min(drawing.sy, drawing.cy),
    w: Math.abs(drawing.cx - drawing.sx), h: Math.abs(drawing.cy - drawing.sy),
  } : null;

  const coveredCount = Object.values(revealedIds).filter(Boolean).length;
  const allRevealed  = labels.length > 0 && labels.every(l => revealedIds[l.id]);

  return (
    <div style={{maxWidth:860, margin:'0 auto', padding:'16px 20px'}}>

      {/* ── Top bar ── */}
      <div style={{display:'flex', alignItems:'center', gap:8, marginBottom:14, flexWrap:'wrap'}}>
        <button className="topbar-back"
          onClick={() => { setSelectedTest(null); setEditMode(false); setEditLabels(null); setRevealedIds({}); }}>
          ← Tests
        </button>
        {!editMode ? (
          <>
            <span style={{fontSize:13, color:'#888'}}>
              {selectedTest.title}&nbsp;·&nbsp;{coveredCount} covered term{coveredCount !== 1 ? 's' : ''}
            </span>
            {allRevealed && (
              <button onClick={() => setRevealedIds({})}
                style={{padding:'5px 12px', borderRadius:8, fontSize:12, cursor:'pointer',
                  background:'#f5f5f5', color:'#333', border:'1px solid #ccc'}}>
                Reset
              </button>
            )}
            <button onClick={enterEdit}
              style={{marginLeft:'auto', padding:'5px 14px', borderRadius:8, fontSize:12,
                cursor:'pointer', background:'#f5f5f5', color:'#555', border:'1px solid #ccc'}}>
              ✏️ Position boxes
            </button>
          </>
        ) : (
          <>
            <span style={{fontSize:13, color:'#e65100', fontWeight:600}}>
              Edit mode — drag to draw boxes, click x to delete
            </span>
            <button onClick={clearSlide}
              style={{padding:'5px 10px', borderRadius:7, fontSize:12, cursor:'pointer',
                background:'#fff3e0', color:'#e65100', border:'1px solid #ffcc80'}}>
              Clear all
            </button>
            <button onClick={exitEdit}
              style={{marginLeft:'auto', padding:'5px 14px', borderRadius:8, fontSize:13,
                cursor:'pointer', background:'#1a1a1a', color:'#fff', border:'none', fontWeight:600}}>
              ✅ Save & done
            </button>
            <button onClick={discardEdit}
              style={{padding:'5px 10px', borderRadius:7, fontSize:12, cursor:'pointer',
                background:'#eee', color:'#666', border:'1px solid #ccc'}}>
              Cancel
            </button>
          </>
        )}
      </div>

      {/* ── Slide navigation ── */}
      <div style={{display:'flex', flexWrap:'wrap', gap:5, marginBottom:10}}>
        {selectedTest.slides.map((s, i) => (
          <button key={String(s.slideId)}
            onClick={() => { if (editMode) exitEdit(); setSlideIdx(i); }}
            style={{
              minWidth:34, height:34, padding:'0 10px', borderRadius:8, fontSize:12, fontWeight:600,
              cursor:'pointer', border:'1px solid',
              background:  i === slideIdx ? '#1a1a1a' : '#f5f5f5',
              color:       i === slideIdx ? '#fff'    : '#888',
              borderColor: i === slideIdx ? '#1a1a1a' : '#e0e0e0',
            }}>
            {i + 1}
          </button>
        ))}
      </div>

      {/* ── Slide title ── */}
      {slide.title && (
        <div style={{fontSize:13, color:'#888', marginBottom:8}}>{slide.title}</div>
      )}

      {/* ── Image + cover boxes ── */}
      <div
        ref={wrapRef}
        style={{
          position:'relative', width:'100%', display:'block',
          cursor: editMode ? 'crosshair' : 'default', userSelect:'none',
          touchAction: editMode ? 'none' : 'pan-y',
          WebkitUserSelect: 'none',
        }}
        onMouseDown={onMouseDown}
        onMouseMove={onMouseMove}
        onMouseUp={onMouseUp}
        onMouseLeave={() => drawing && setDrawing(null)}
        onTouchStart={onTouchStart}
        onTouchMove={onTouchMove}
        onTouchEnd={onTouchEnd}
      >
        <img
          src={slide.image}
          alt={slide.title || ('Slide ' + (slideIdx + 1))}
          draggable={false}
          style={{width:'100%', display:'block', borderRadius:10, border:'1px solid #ddd',
            boxShadow:'0 4px 20px rgba(0,0,0,0.12)', minHeight:200}}
          onError={e => { e.target.style.minHeight='200px'; e.target.style.background='#f5f5f5'; }}
        />

        {labels.map(label => {
          const revealed = !editMode && !!revealedIds[label.id];
          return (
            <div
              key={label.id}
              className={'cover-box' + (revealed ? ' revealed' : '')}
              onClick={() => !editMode && handleBoxClick(label)}
              onTouchEnd={e => { if (!editMode) { e.preventDefault(); handleBoxClick(label); } }}
              style={{
                left:`${label.x}%`, top:`${label.y}%`,
                width:`${label.w}%`, height:`${label.h}%`,
                cursor:      editMode ? 'default'                 : 'pointer',
                background:  editMode ? 'rgba(25,118,210,0.15)'  : revealed ? 'transparent' : '#888',
                borderColor: editMode ? '#1976d2'                 : revealed ? '#999'        : '#666',
                borderStyle: editMode ? 'dashed'                  : revealed ? 'dashed'      : 'solid',
                opacity:     1,
              }}>
              {editMode ? (
                <>
                  <span style={{fontSize:'clamp(8px,1vw,11px)', color:'#1976d2',
                    overflow:'hidden', textOverflow:'ellipsis', whiteSpace:'nowrap',
                    maxWidth:'90%', textAlign:'center'}}>
                    {label.term}
                  </span>
                  <button
                    onMouseDown={e => e.stopPropagation()}
                    onClick={e => { e.stopPropagation(); deleteEditLabel(label.id); }}
                    style={{position:'absolute', top:1, right:1, background:'#c62828', color:'#fff',
                      border:'none', borderRadius:3, fontSize:9, lineHeight:1, padding:'1px 3px',
                      cursor:'pointer', zIndex:5}}>
                    x
                  </button>
                </>
              ) : (
                !revealed && '?'
              )}
            </div>
          );
        })}

        {drawRect && (
          <div style={{position:'absolute', pointerEvents:'none',
            left:`${drawRect.x}%`, top:`${drawRect.y}%`,
            width:`${drawRect.w}%`, height:`${drawRect.h}%`,
            border:'2px dashed #e65100', background:'rgba(230,81,0,0.1)', borderRadius:4}}/>
        )}
      </div>

      {/* ── Pending box: name the term ── */}
      {editMode && pendingBox && (
        <div style={{marginTop:10, padding:'10px 16px', background:'#fff3e0', borderRadius:10,
          border:'1px solid #ffcc80', display:'flex', gap:8, alignItems:'center', flexWrap:'wrap'}}>
          <span style={{fontSize:13, color:'#b26000', fontWeight:600}}>Term name:</span>
          <input ref={termRef} type="text" value={pendingTerm}
            onChange={e => setPendingTerm(e.target.value)}
            onKeyDown={e => {
              if (e.key === 'Enter')  savePending();
              if (e.key === 'Escape') { setPendingBox(null); setPendingTerm(''); }
            }}
            placeholder="e.g. Femoral head (optional)"
            style={{flex:1, minWidth:150, padding:'6px 10px', border:'1px solid #ffcc80',
              borderRadius:7, fontSize:13}}/>
          <button onClick={savePending}
            style={{padding:'6px 14px', background:'#1a1a1a', color:'#fff', border:'none',
              borderRadius:7, fontSize:13, cursor:'pointer'}}>Save box</button>
          <button onClick={() => { setPendingBox(null); setPendingTerm(''); }}
            style={{padding:'6px 10px', background:'#eee', color:'#555', border:'1px solid #ccc',
              borderRadius:7, fontSize:13, cursor:'pointer'}}>Cancel</button>
        </div>
      )}
    </div>
  );
}

function HomeScreen({ onSelectSubject, onBooksChange, onOpenBook }) {
  return (
    <div className="home-screen">
      <div className="home-bg" />
      <div className="home-overlay" />

      <div className="home-sidebar">
        <div className="sidebar-label">Subjects</div>
        {Object.entries(QUESTION_BANK).map(([name, meta]) => {
          const sp = getSubjectProgress(name);
          const masteredCount = sp.masteredIds.length;
          const totalCount    = meta.questions.length;
          const weakCount     = Object.values(sp.weakAreas)
            .flatMap(subs => Object.values(subs))
            .filter(n => n > 0).length;
          const available = totalCount - masteredCount;

          return (
            <div
              key={name}
              className="sidebar-subject-card"
              onClick={() => onSelectSubject(name)}
            >
              <div className="sidebar-subject-name">{name}</div>
              <div className="sidebar-subject-desc">{meta.description}</div>
              <div className="sidebar-stats">
                <span className="sidebar-stat">{totalCount} Qs</span>
                {masteredCount > 0 && (
                  <span className="sidebar-stat mastered">{masteredCount} mastered</span>
                )}
                {weakCount > 0 && (
                  <span className="sidebar-stat weak">{weakCount} weak</span>
                )}
                {available === 0 && (
                  <span className="sidebar-stat mastered">All done!</span>
                )}
              </div>
            </div>
          );
        })}
        <BookShelf onBooksChange={onBooksChange} onOpenBook={onOpenBook} />
      </div>

      <div className="home-center">
        <h1 className="home-main-title">Study Buddy</h1>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
// ATLAS TERMS  (auto-generated from atlas_terms.xlsx)
// ─────────────────────────────────────────────────────────────
const ATLAS_TERMS = [{"t": "Skeleton axiale", "m": "Axial skeleton", "e": "skeleton (Gk. skeletos: dried up, from skellein = to dry) + axiale (L. axialis: of an axis, from axis = axle, pivot)", "p": 11}, {"t": "Columna vertebralis", "m": "Vertebral column", "e": "columna (L. columna: column, pillar) + vertebralis (L. vertebralis: of the vertebra, from vertere = to turn)", "p": 11}, {"t": "Canalis vertebralis", "m": "Vertebral canal — canal formed by the successive vertebral foramina", "e": "canalis (L. canalis: channel, canal) + vertebralis (L. vertebralis: of the vertebra, from vertere = to turn)", "p": 11}, {"t": "Corpus vertebrae", "m": "Body of vertebra", "e": "corpus (L. corpus: body) + vertebrae (L. vertebra: joint of the spine, from vertere = to turn)", "p": 11}, {"t": "Facies intervertebralis", "m": "The surface of a vertebra facing the adjacent vertebra", "e": "facies (L. facies: face, surface) + intervertebralis (L. inter = between + vertebralis = of the vertebra, from vertere = to turn)", "p": 11}, {"t": "Apophysis anularis", "m": "Ring apophysis (epiphysis) — ring of bone around the upper and lower surfaces of the vertebral body", "e": "apophysis (Gk. apophysis: offshoot, from apo = away + phyein = to grow) + anularis (L. anularis: ring-shaped, from anulus = ring)", "p": 11}, {"t": "Arcus vertebrae", "m": "Vertebral arch — forms the posterior and lateral boundaries of the vertebral foramen", "e": "arcus (L. arcus: arch, bow) + vertebrae (L. vertebra: joint of the spine, from vertere = to turn)", "p": 11}, {"t": "Pediculus arcus vertebrae", "m": "Pedicle — the portion of the vertebral arch situated anteriorly between the body and transverse process", "e": "pediculus (L. pediculus: little foot, stalk, from pes/pedis = foot) + arcus (L. arcus: arch, bow) + vertebrae (L. vertebra: joint of the spine, from vertere = to turn)", "p": 11}, {"t": "Lamina arcus vertebrae", "m": "Lamina — the portion of the vertebral arch situated posteriorly between the transverse process and the spinous process", "e": "lamina (L. lamina: thin plate, layer) + arcus (L. arcus: arch, bow) + vertebrae (L. vertebra: joint of the spine, from vertere = to turn)", "p": 11}, {"t": "Junctio neurocentralis", "m": "Neurocentral junction (synchondrosis) — cartilaginous joint between the left and right fetal neural arches and the centrum", "e": "junctio (L. junctio: joining, from jungere = to join) + neurocentralis (Gk. neuron = nerve + L. centralis = of the center, from centrum = center)", "p": 11}, {"t": "Foramen intervertebrale", "m": "Intervertebral foramen — opening for the passage of the spinal nerve and small vessels", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + intervertebrale (L. inter = between + vertebrale = of the vertebra, from vertere = to turn)", "p": 11}, {"t": "Incisura vertebralis superior", "m": "Superior vertebral notch — notch on the superior aspect of the pedicle", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + vertebralis (L. vertebralis: of the vertebra, from vertere = to turn) + superior (L. superior: upper, higher)", "p": 11}, {"t": "Incisura vertebralis inferior", "m": "Inferior vertebral notch — notch on the inferior aspect of the pedicle", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + vertebralis (L. vertebralis: of the vertebra, from vertere = to turn) + inferior (L. inferior: lower)", "p": 11}, {"t": "Foramen vertebrale", "m": "Vertebral foramen — space surrounded by the vertebral arch and body", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + vertebrale (L. vertebrale: of the vertebra, from vertere = to turn)", "p": 11}, {"t": "Processus spinosus", "m": "Spinous process — it is bifid in the upper four cervical vertebrae", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + spinosus (L. spinosus: spiny, thorny, from spina = spine, thorn)", "p": 11}, {"t": "Processus transversus", "m": "Transverse process", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + transversus (L. transversus: turned across, from trans = across + vertere = to turn)", "p": 11}, {"t": "Processus costalis", "m": "Costal process — the transverse process of a lumbar vertebra, corresponding to a rudimentary rib", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + costalis (L. costalis: of a rib, from costa = rib)", "p": 11}, {"t": "Processus articularis superior", "m": "Superior articular process (zygapophysis) — articular process on the superior aspect of the vertebral arch", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + articularis (L. articularis: of a joint, from articulus = joint) + superior (L. superior: upper, higher)", "p": 11}, {"t": "Zygapophysis superior", "m": "Superior articular process (zygapophysis) — articular process on the superior aspect of the vertebral arch", "e": "zygapophysis (Gk. zygon = yoke + apophysis = offshoot, from apo = away + phyein = to grow) + superior (L. superior: upper, higher)", "p": 11}, {"t": "Processus articularis inferior", "m": "Inferior articular process (zygapophysis) — articular process on the inferior aspect of the vertebral arch", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + articularis (L. articularis: of a joint, from articulus = joint) + inferior (L. inferior: lower)", "p": 11}, {"t": "Zygapophysis inferior", "m": "Inferior articular process (zygapophysis) — articular process on the inferior aspect of the vertebral arch", "e": "zygapophysis (Gk. zygon = yoke + apophysis = offshoot, from apo = away + phyein = to grow) + inferior (L. inferior: lower)", "p": 11}, {"t": "Vertebrae cervicales", "m": "Cervical vertebrae — the seven uppermost vertebrae (C1–7)", "e": "vertebrae (L. vertebra: joint of the spine, from vertere = to turn) + cervicales (L. cervicalis: of the neck, from cervix = neck)", "p": 11}, {"t": "Uncus corporis", "m": "Uncal process or uncus — upwardly projecting, hook-like process on either side of the cervical vertebrae", "e": "uncus (L. uncus: hook) + corporis (L. corpus/corporis: body)", "p": 11}, {"t": "Foramen transversarium", "m": "Foramen transversarium — hole in the transverse process of cervical vertebrae for the passage of the vertebral artery and vein", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + transversarium (L. transversarius: of the transverse, from transversus = turned across, from trans = across + vertere = to turn)", "p": 11}, {"t": "Tuberculum anterius", "m": "Anterior tubercle — anterior projection on the transverse processes of cervical vertebrae 2–7 for muscle attachment", "e": "tuberculum (L. tuberculum: small swelling, knob, from tuber = swelling) + anterius (L. anterius: more anterior, front, from ante = before)", "p": 11}, {"t": "Tuberculum posterius", "m": "Posterior tubercle — posterior projection on the transverse processes of cervical vertebrae 2–7 for muscle attachment", "e": "tuberculum (L. tuberculum: small swelling, knob, from tuber = swelling) + posterius (L. posterius: more posterior, behind, from post = after, behind)", "p": 11}, {"t": "Tuberculum caroticum", "m": "Carotid tubercle — well developed anterior tubercle of C6, against which the common carotid artery can be compressed", "e": "tuberculum (L. tuberculum: small swelling, knob, from tuber = swelling) + caroticum (Gk. karotikos: of the carotid, from karos = deep sleep, heavy sleep)", "p": 11}, {"t": "Sulcus n. spinalis", "m": "Groove for spinal nerve — groove on the transverse processes of C3–7 for the spinal nerves exiting from the intervertebral foramina", "e": "sulcus (L. sulcus: groove, furrow) + n. [nervus] (L. nervus: nerve, sinew) + spinalis (L. spinalis: of the spine, from spina = spine)", "p": 11}, {"t": "Vertebra prominens", "m": "Vertebra prominens (C7) — the seventh cervical vertebra, named for its especially well-developed spinous process", "e": "vertebra (L. vertebra: joint of the spine, from vertere = to turn) + prominens (L. prominens: projecting, prominent, from prominere = to jut out)", "p": 11}, {"t": "Vertebrae thoracicae", "m": "Thoracic vertebrae — the twelve vertebrae of the thorax (T1–12)", "e": "vertebrae (L. vertebra: joint of the spine, from vertere = to turn) + thoracicae (Gk. thorakikos: of the chest, from thorax = chest, breastplate)", "p": 11}, {"t": "Fovea costalis superior", "m": "Superior costal facet — fossa for articulation with the head of a rib, located near the root of the arch on the upper edge of the body of a vertebra", "e": "fovea (L. fovea: pit, small depression) + costalis (L. costalis: of a rib, from costa = rib) + superior (L. superior: upper, higher)", "p": 11}, {"t": "Fovea costalis inferior", "m": "Inferior costal facet — fossa for articulation with the head of a rib, located below the root of the arch on the lower edge of the body of a vertebra", "e": "fovea (L. fovea: pit, small depression) + costalis (L. costalis: of a rib, from costa = rib) + inferior (L. inferior: lower)", "p": 11}, {"t": "Fovea costalis processus transversi", "m": "Costal facet of transverse process — facet for articulation with the tubercle of a rib", "e": "fovea (L. fovea: pit, small depression) + costalis (L. costalis: of a rib, from costa = rib) + processus (L. processus: projection, from procedere = to go forward) + transversi (L. transversus: turned across, from trans = across + vertere = to turn)", "p": 11}, {"t": "Vertebrae lumbales", "m": "Lumbar vertebrae — the five vertebrae of the lumbar region (L1–5)", "e": "vertebrae (L. vertebra: joint of the spine, from vertere = to turn) + lumbales (L. lumbalis: of the loins, from lumbus = loin)", "p": 11}, {"t": "Processus accessorius", "m": "Accessory process — rudiment of the original lumbar transverse process, projecting posteriorly from the base of the costal process", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + accessorius (L. accessorius: additional, supplementary, from accedere = to come near, approach)", "p": 11}, {"t": "Processus mamillaris", "m": "Mamillary process — a blunt process projecting from the superior articular process of the lumbar vertebra", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + mamillaris (L. mamillaris: of or like a nipple, from mamilla = nipple, small breast, diminutive of mamma = breast)", "p": 11}, {"t": "Massa lateralis atlantis", "m": "Lateral mass of atlas — the thickened lateral part of the atlas which bears the skull for the lacking vertebra", "e": "massa (L. massa: mass, lump) + lateralis (L. laterālis: of the side, from latus = side) + atlantis (Gk. Atlās/atlantos: Atlas, the titan bearing the world, genitive of atlas)", "p": 13}, {"t": "Facies articularis superior", "m": "Superior articular facet — elliptical and concave facet", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint, from articulus = joint) + superior (L. superior: upper, higher)", "p": 13}, {"t": "Facies articularis inferior", "m": "Inferior articular facet — roundish and slightly concave surface lined with cartilage", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + inferior (L. inferior: lower)", "p": 13}, {"t": "Arcus anterior atlantis", "m": "Anterior arch of atlas", "e": "arcus (L. arcus: arch, bow) + anterior (L. anterior: front, from ante = before) + atlantis (Gk. atlantos: genitive of Atlas)", "p": 13}, {"t": "Fovea dentis atlantis", "m": "Dental fovea of atlas — facet for articulation with the dens of the axis on the inner surface of the anterior arch", "e": "fovea (L. fovea: pit, small depression) + dentis (L. dens/dentis: tooth, genitive singular) + atlantis (Gk. atlantos: genitive of Atlas)", "p": 13}, {"t": "Tuberculum anterius atlantis", "m": "Anterior tubercle of atlas", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = swelling) + anterius (L. anterius: neuter of anterior, front) + atlantis (Gk. atlantos: genitive of Atlas)", "p": 13}, {"t": "Arcus posterior atlantis", "m": "Posterior arch of atlas", "e": "arcus (L. arcus: arch, bow) + posterior (L. posterior: behind, from post = after) + atlantis (Gk. atlantos: genitive of Atlas)", "p": 13}, {"t": "Sulcus arteriae vertebralis", "m": "Groove for vertebral artery — groove for the vertebral artery located on the posterior arch of the atlas behind the articular surfaces", "e": "sulcus (L. sulcus: groove, furrow) + arteriae (L. arteria: artery, from Gk. artēria = windpipe, artery, genitive) + vertebralis (L. vertebrālis: of the vertebra, from vertere = to turn)", "p": 13}, {"t": "Dens axis", "m": "Dens of axis — odontoid process", "e": "dens (L. dens: tooth) + axis (L. axis: axle, pivot, from Gk. axōn = axle)", "p": 13}, {"t": "Apex dentis", "m": "Apex of dens — attachment site of the apical ligament of the dens", "e": "apex (L. apex: tip, summit) + dentis (L. dens/dentis: tooth, genitive singular)", "p": 13}, {"t": "Facies articularis anterior", "m": "Anterior articular surface of dens", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + anterior (L. anterior: front)", "p": 13}, {"t": "Facies articularis posterior", "m": "Posterior articular surface of dens", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + posterior (L. posterior: behind)", "p": 13}, {"t": "Basis ossis sacri", "m": "Base of sacrum — broad upper end of sacrum", "e": "basis (Gk./L. basis: base, foundation) + ossis (L. os/ossis: bone, genitive singular) + sacri (L. sacer/sacri: sacred, holy, genitive of sacrum)", "p": 13}, {"t": "Promontorium ossis sacri", "m": "Promontory of sacrum — prominent anterior margin of the body of the first sacral vertebra projecting into the pelvic inlet", "e": "promontorium (L. promontorium: promontory, headland, from prominere = to jut out) + ossis (L. os/ossis: bone, genitive) + sacri (L. sacer: sacred, genitive)", "p": 13}, {"t": "Ala sacralis", "m": "Ala of sacrum — part of the base of the sacrum situated lateral to the first sacral vertebra", "e": "ala (L. āla: wing) + sacralis (L. sacrālis: of the sacrum, from sacer = sacred)", "p": 13}, {"t": "Pars lateralis ossis sacri", "m": "Lateral part or mass of sacrum — the lateral part of the sacrum derived from the transverse processes and rudimentary ribs", "e": "pars (L. pars: part) + lateralis (L. laterālis: of the side) + ossis (L. os/ossis: bone, genitive) + sacri (L. sacer: sacred, genitive)", "p": 13}, {"t": "Facies auricularis", "m": "Auricular surface — ear-shaped articular surface for the ilium", "e": "facies (L. faciēs: face, surface) + auricularis (L. auriculāris: of the ear, from auricula = little ear, from auris = ear)", "p": 13}, {"t": "Tuberositas sacralis", "m": "Sacral tuberosity — rough area behind the auricular surface for the attachment of the sacroiliac ligaments", "e": "tuberositas (L. tuberōsitas: roughness, knobby quality, from tuberosus = full of lumps) + sacralis (L. sacrālis: of the sacrum)", "p": 13}, {"t": "Facies pelvica", "m": "Pelvic surface — anterior surface of the sacrum facing the pelvis", "e": "facies (L. faciēs: face, surface) + pelvica (L. pelvicus: of the pelvis, from pelvis = basin)", "p": 13}, {"t": "Lineae transversae", "m": "Transverse lines — four anteriorly situated fusion lines of the five sacral vertebral bodies", "e": "lineae (L. linea: line, plural) + transversae (L. transversus: crosswise, from trans = across + vertere = to turn, plural feminine)", "p": 13}, {"t": "Foramina intervertebralia", "m": "Intervertebral foramina — openings for passage of the sacral spinal nerves developing from the original superior and inferior notches", "e": "foramina (L. foramen: opening, hole, plural; from forare = to bore) + intervertebralia (L. intervertebrālis: between vertebrae, from inter = between + vertebra = vertebra, plural neuter)", "p": 13}, {"t": "Foramina sacralia anteriora", "m": "Anterior sacral foramina — anterior openings for nerves and vessels", "e": "foramina (L. foramen: opening, hole, plural) + sacralia (L. sacrālis: of the sacrum, plural neuter) + anteriora (L. anterior: front, plural neuter)", "p": 13}, {"t": "Facies dorsalis ossis sacri", "m": "Dorsal surface of sacrum", "e": "facies (L. faciēs: face, surface) + dorsalis (L. dorsālis: of the back, from dorsum = back) + ossis (L. os/ossis: bone, genitive) + sacri (L. sacer: sacred, genitive)", "p": 13}, {"t": "Crista sacralis mediana", "m": "Median sacral crest — median ridge formed by the remnants of the spinous processes of the sacral vertebrae", "e": "crista (L. crista: crest, ridge) + sacralis (L. sacrālis: of the sacrum) + mediana (L. mediānus: median, middle, from medius = middle)", "p": 13}, {"t": "Foramina sacralia posteriora", "m": "Posterior sacral foramina — posterior openings for nerves and vessels", "e": "foramina (L. foramen: opening, hole, plural) + sacralia (L. sacrālis: of the sacrum, plural neuter) + posteriora (L. posterior: behind, plural neuter)", "p": 13}, {"t": "Cristae sacralis intermedia", "m": "Intermediate sacral crests — remnants of the articular processes located on either side of the median sacral crest", "e": "cristae (L. crista: crest, plural) + sacralis (L. sacrālis: of the sacrum) + intermedia (L. intermedius: intermediate, between, from inter = between + medius = middle)", "p": 13}, {"t": "Crista sacralis lateralis", "m": "Lateral sacral crest — posterior bilateral series of rudimentary transverse processes", "e": "crista (L. crista: crest, ridge) + sacralis (L. sacrālis: of the sacrum) + lateralis (L. laterālis: of the side)", "p": 13}, {"t": "Cornu sacrale", "m": "Sacral cornu (horn) — hook-shaped processes that extend downward on either side of the sacral hiatus", "e": "cornu (L. cornū: horn) + sacrale (L. sacrālis: of the sacrum, neuter form)", "p": 13}, {"t": "Canalis sacralis", "m": "Sacral canal — inferior end of the vertebral canal", "e": "canalis (L. canālis: canal, channel, from canna = reed, pipe) + sacralis (L. sacrālis: of the sacrum)", "p": 13}, {"t": "Hiatus sacralis", "m": "Sacral hiatus — opening at the inferior end of the vertebral canal located usually at the level of vertebrae S3-4; emergence site of filum terminale and injection site for lower epidural anesthesia", "e": "hiatus (L. hiātus: gap, opening, from hiare = to gape) + sacralis (L. sacrālis: of the sacrum)", "p": 13}, {"t": "Apex ossis sacri", "m": "Apex of sacrum — inferior tip of sacrum which gives attachment to the coccyx", "e": "apex (L. apex: tip, summit) + ossis (L. os/ossis: bone, genitive) + sacri (L. sacer: sacred, genitive)", "p": 13}, {"t": "Os coccygis", "m": "Coccygeal vertebrae I-IV — bone that usually consists of four rudimentary vertebrae", "e": "os (L. os: bone) + coccygis (Gk. kokkyx/kokkygos: cuckoo, coccyx; genitive; named for resemblance to cuckoo's beak)", "p": 13}, {"t": "Cornu coccygeus", "m": "Coccygeal cornu (horn) — upwardly projecting process formed by the articular process", "e": "cornu (L. cornū: horn) + coccygeus (Gk. kokkyx: cuckoo, coccyx; adjectival form)", "p": 13}, {"t": "Ossa thoracis", "m": "Thoracic bones", "e": "ossa (L. os/ossa: bones) + thoracis (Gk. thōrax/thoracis: chest, breastplate)", "p": 15}, {"t": "Costae (I–XII)", "m": "Ribs", "e": "costae (L. costa/costae: ribs, sides)", "p": 15}, {"t": "Costae verae (I–VII)", "m": "True ribs (1–7)", "e": "costae (L. costa: rib) + verae (L. verus/vera: true, genuine)", "p": 15}, {"t": "Costae spuriae (VIII–XII)", "m": "False ribs (8–12)", "e": "costae (L. costa: rib) + spuriae (L. spurius/spuria: false, illegitimate)", "p": 15}, {"t": "Costae fluitantes (XI–XII)", "m": "Floating ribs (11–12)", "e": "costae (L. costa: rib) + fluitantes (L. fluitare: to float, to drift)", "p": 15}, {"t": "Cartilago costalis", "m": "Costal cartilage — cartilage at the anterior ends of the ribs", "e": "cartilago (L. cartilago: cartilage, gristle) + costalis (L. costa: rib + -alis: pertaining to)", "p": 15}, {"t": "Os costale (costa)", "m": "Bony rib — the bony cartilaginous segment of the rib", "e": "os (L. os: bone) + costale (L. costa: rib + -ale: pertaining to)", "p": 15}, {"t": "Caput costae", "m": "Head of rib — articulates with the vertebral column", "e": "caput (L. caput: head) + costae (L. costa: rib, genitive singular)", "p": 15}, {"t": "Facies articulares capitis costae", "m": "Articular surface on head of rib", "e": "facies (L. facies: face, surface) + articulares (L. articularis: of a joint, from articulus: joint) + capitis (L. caput: head, genitive) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Crista capitis costae", "m": "Interarticular crest on head of rib — small ridge separating the two articular facets", "e": "crista (L. crista: crest, ridge) + capitis (L. caput: head, genitive) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Collum costae", "m": "Neck of rib — lies lateral to the head of the rib", "e": "collum (L. collum: neck) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Crista colli costae", "m": "Crest of neck of rib — sharp ridge on the upper border of the neck of a rib", "e": "crista (L. crista: crest, ridge) + colli (L. collum: neck, genitive) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Corpus costae", "m": "Shaft (body) of rib — main part of rib adjacent to the neck", "e": "corpus (L. corpus: body, shaft) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Tuberculum costae", "m": "Costal tubercle — posterior elevation between the neck and shaft of the rib", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber: lump) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Facies articularis tuberculi costae", "m": "Articular facet of costal tubercle — surface for articulation with the transverse process of thoracic vertebrae", "e": "facies (L. facies: surface) + articularis (L. articularis: of a joint) + tuberculi (L. tuberculum: small swelling, genitive) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Angulus costae", "m": "Angle of rib — posteriorly situated bend in the axis of the rib", "e": "angulus (L. angulus: angle, corner) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Sulcus costae", "m": "Costal groove — groove for the intercostal artery, vein and nerve on the lower margin of the internal surface of the rib", "e": "sulcus (L. sulcus: groove, furrow) + costae (L. costa: rib, genitive)", "p": 15}, {"t": "Costa prima", "m": "First rib — the only rib bent only along the edge", "e": "costa (L. costa: rib) + prima (L. primus/prima: first)", "p": 15}, {"t": "Tuberculum musculi scaleni anterioris", "m": "Tubercle for anterior scalene muscle — small prominence on the upper surface of the first rib", "e": "tuberculum (L. tuberculum: small swelling) + musculi (L. musculus: muscle, genitive) + scaleni (Gk. skalenos: uneven, oblique; genitive) + anterioris (L. anterior: front, genitive)", "p": 15}, {"t": "Sulcus arteriae subclaviae", "m": "Groove for subclavian artery — groove on the first rib just posterior to the anterior scalene tubercle", "e": "sulcus (L. sulcus: groove) + arteriae (Gk. arteria: artery, genitive) + subclaviae (L. sub: under + clavis: key, clavicle; genitive)", "p": 15}, {"t": "Sulcus venae subclaviae", "m": "Groove for subclavian vein — groove on the first rib just anterior to the anterior scalene tubercle", "e": "sulcus (L. sulcus: groove) + venae (L. vena: vein, genitive) + subclaviae (L. sub: under + clavis: key, clavicle; genitive)", "p": 15}, {"t": "Costa secunda", "m": "Second rib — attaches to the sternal angle and can easily be identified in patients", "e": "costa (L. costa: rib) + secunda (L. secundus/secunda: second)", "p": 15}, {"t": "Tuberositas musculi serrati anterioris", "m": "Roughened area on the outer surface of the shaft of the second rib that gives attachment to the serratus anterior muscle", "e": "tuberositas (L. tuberositas: roughness, knobby prominence, from tuber: lump) + musculi (L. musculus: muscle, genitive) + serrati (L. serratus: saw-toothed, from serra: saw; genitive) + anterioris (L. anterior: front, genitive)", "p": 15}, {"t": "Costa cervicalis", "m": "Cervical rib — accessory rib at C7", "e": "costa (L. costa: rib) + cervicalis (L. cervix/cervicalis: of the neck, from cervix: neck)", "p": 15}, {"t": "Sternum", "m": "Sternum", "e": "sternum (Gk. sternon: chest, breastbone)", "p": 15}, {"t": "Manubrium sterni", "m": "Manubrium sterni — the portion of the sternum situated above the sternal angle", "e": "manubrium (L. manubrium: handle, from manus: hand) + sterni (Gk. sternon: breastbone, genitive)", "p": 15}, {"t": "Incisura clavicularis", "m": "Clavicular notch — indentation for the sternoclavicular joint", "e": "incisura (L. incisura: notch, cut, from incidere: to cut into) + clavicularis (L. clavicula: small key, clavicle + -aris: pertaining to)", "p": 15}, {"t": "Incisura jugularis", "m": "Jugular notch — concavity at the upper border of the manubrium", "e": "incisura (L. incisura: notch, cut) + jugularis (L. jugulum: throat, collarbone + -aris: pertaining to)", "p": 15}, {"t": "Angulus sterni (sternalis)", "m": "Sternal angle — angle between the body and manubrium of the sternum, palpable through the skin", "e": "angulus (L. angulus: angle, corner) + sterni (Gk. sternon: breastbone, genitive) + sternalis (Gk./L. sternalis: of the sternum)", "p": 15}, {"t": "Synchondroses sternales", "m": "Sternal synchondroses — the two synchondroses of the sternum", "e": "synchondroses (Gk. syn: together + chondros: cartilage + -osis: condition; plural) + sternales (Gk./L. sternalis: of the sternum, plural)", "p": 15}, {"t": "Synchondrosis manubriosternalis", "m": "Manubriosternal synchondrosis — cartilaginous joint between the manubrium and the body of the sternum", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + -osis: condition) + manubriosternalis (L. manubrium: handle + Gk. sternon: breastbone + -alis: pertaining to)", "p": 15}, {"t": "Synchondrosis xiphisternalis", "m": "Xiphisternal synchondrosis — cartilaginous joint between the body of the sternum and the xiphoid process", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + -osis: condition) + xiphisternalis (Gk. xiphos: sword + sternon: breastbone + L. -alis: pertaining to)", "p": 15}, {"t": "Corpus sterni", "m": "Body of sternum — situated between the manubrium and xiphoid process", "e": "corpus (L. corpus: body) + sterni (Gk. sternon: breastbone, genitive)", "p": 15}, {"t": "Processus xiphoideus", "m": "Xiphoid process — stout process at the lower end of the sternum", "e": "processus (L. processus: projection, going forward) + xiphoideus (Gk. xiphos: sword + -oeides: resembling, shaped like)", "p": 15}, {"t": "Incisurae costales", "m": "Costal notches — indentations for the costal cartilages", "e": "incisurae (L. incisura: notch, cut, plural) + costales (L. costa: rib + -ales: pertaining to, plural)", "p": 15}, {"t": "Ossa suprasternalia", "m": "Suprasternal bones — small osseous remnants of the earlier episternum occurring in the ligaments of the sternoclavicular joint", "e": "ossa (L. os/ossa: bones) + suprasternalia (L. supra: above + Gk. sternon: breastbone + L. -alia: pertaining to)", "p": 15}, {"t": "Compages thoracis", "m": "Thoracic skeleton", "e": "compages (L. compages: framework, structure, from compingere: to fasten together) + thoracis (Gk. thōrax/thoracis: chest, genitive)", "p": 15}, {"t": "Cavitas thoracis", "m": "Thoracic cavity — used to denote the chest and chest cavity", "e": "cavitas (L. cavitas: cavity, hollow, from cavus: hollow) + thoracis (Gk. thōrax/thoracis: chest, genitive)", "p": 15}, {"t": "Apertura thoracis superior", "m": "Superior thoracic aperture (thoracic inlet) — upper thoracic opening", "e": "apertura (L. apertura: opening, from aperire: to open) + thoracis (Gk. thōrax/thoracis: chest, genitive) + superior (L. superior: upper, higher)", "p": 15}, {"t": "Apertura thoracis inferior", "m": "Inferior thoracic aperture (thoracic outlet) — lower opening of thorax", "e": "apertura (L. apertura: opening) + thoracis (Gk. thōrax/thoracis: chest, genitive) + inferior (L. inferior: lower)", "p": 15}, {"t": "Sulcus pulmonalis thoracis", "m": "Pulmonary sulcus of thorax — either of two large vertical grooves on either side of the vertebral column occupied by the lungs", "e": "sulcus (L. sulcus: groove, furrow) + pulmonalis (L. pulmo/pulmonalis: of the lung, from pulmo: lung) + thoracis (Gk. thōrax/thoracis: chest, genitive)", "p": 15}, {"t": "Arcus costalis", "m": "Costal arch — arch of ribs formed by the cartilages of ribs 7–10", "e": "arcus (L. arcus: arch, bow) + costalis (L. costa: rib + -alis: pertaining to)", "p": 15}, {"t": "Spatium intercostale", "m": "Intercostal space — space between the ribs", "e": "spatium (L. spatium: space, interval) + intercostale (L. inter: between + costa: rib + -ale: pertaining to)", "p": 15}, {"t": "Angulus infrasternalis", "m": "Infrasternal angle — angle between the right and left costal arch", "e": "angulus (L. angulus: angle, corner) + infrasternalis (L. infra: below + Gk. sternon: breastbone + L. -alis: pertaining to)", "p": 15}, {"t": "Ossa cranii", "m": "Bones of the skull", "e": "ossa (L. os/ossa: bones) + cranii (L. cranium, from Gk. kranion: skull)", "p": 17}, {"t": "Neurocranium", "m": "Portion of the cranium that encloses the brain", "e": "neuro (Gk. neuron: nerve, brain) + cranium (Gk. kranion: skull)", "p": 17}, {"t": "Viscerocranium", "m": "Portion of the cranium that forms the face", "e": "viscero (L. viscera: internal organs, face region) + cranium (Gk. kranion: skull)", "p": 17}, {"t": "Chondrocranium", "m": "Cartilaginous part of embryological skull that later forms base of skull", "e": "chondro (Gk. khondros: cartilage) + cranium (Gk. kranion: skull)", "p": 17}, {"t": "Os occipitale", "m": "Occipital bone — lies between the sphenoid, temporal and parietal bones", "e": "os (L. os: bone) + occipitale (L. occiput: back of the head, from ob = against + caput = head)", "p": 17}, {"t": "Foramen magnum", "m": "Large opening in the occipital bone for passage of the medulla oblongata, vessels and nerves", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + magnum (L. magnus: large, great)", "p": 17}, {"t": "Basion", "m": "Midpoint of the anterior border of the foramen magnum", "e": "basion (Gk. basis: base, foundation)", "p": 17}, {"t": "Opisthion", "m": "Midpoint of the posterior border of the foramen magnum", "e": "opisthion (Gk. opisthen: behind, at the back)", "p": 17}, {"t": "Pars basilaris ossis occipitalis", "m": "Basilar part of occipital bone — portion of occipital bone that projects superiorly from foramen magnum to sphenoid bone", "e": "pars (L. pars: part) + basilaris (L. basilaris: of the base, from Gk. basis = base) + ossis (L. os/ossis: bone) + occipitalis (L. occiput: back of the head, from ob = against + caput = head)", "p": 17}, {"t": "Clivus", "m": "Part of the basioccipital bone that slopes upwardly from the foramen magnum to the dorsum sellae", "e": "clivus (L. clivus: slope, hill)", "p": 17}, {"t": "Sulcus sinus pertrosi inferioris ossis occipitalis", "m": "Groove for inferior petrosal sinus of occipital bone", "e": "sulcus (L. sulcus: groove, furrow) + sinus (L. sinus: cavity, bay) + petrosi (L. petrosus: rocky, stony, from petra = rock) + inferioris (L. inferior: lower) + ossis (L. os/ossis: bone) + occipitalis (L. occiput: back of the head)", "p": 17}, {"t": "Tuberculum pharyngeum", "m": "Pharyngeal tubercle — prominence on the inferior surface of the basioccipital bone for attachment of the pharyngeal raphe", "e": "tuberculum (L. tuberculum: small bump, from tuber = swelling) + pharyngeum (Gk. pharynx: throat)", "p": 17}, {"t": "Pars lateralis ossis occipitalis", "m": "Lateral (condylar) part of occipital bone — lies lateral to the foramen magnum", "e": "pars (L. pars: part) + lateralis (L. lateralis: of the side, from latus = side) + ossis (L. os/ossis: bone) + occipitalis (L. occiput: back of the head)", "p": 17}, {"t": "Squama occipitalis", "m": "Squamous part of occipital bone — area extending from the posterior edge of the foramen magnum", "e": "squama (L. squama: scale, thin plate) + occipitalis (L. occiput: back of the head)", "p": 17}, {"t": "Margo mastoideus", "m": "Mastoid margin — border of the occipital bone united with the temporal bone", "e": "margo (L. margo: border, margin) + mastoideus (Gk. mastos: breast + eidos: form, shape — breast-shaped)", "p": 17}, {"t": "Margo lambdoideus", "m": "Lambdoid margin — border of the occipital bone that articulates with the parietal bone", "e": "margo (L. margo: border, margin) + lambdoideus (Gk. lambda: Greek letter Λ + eidos: form — lambda-shaped)", "p": 17}, {"t": "Os interparietale", "m": "Interparietal bone — anatomic variant that forms when the upper half of the squama occipitalis is separated by a transverse suture", "e": "os (L. os: bone) + inter (L. inter: between) + parietale (L. parietalis: of the wall, from paries = wall)", "p": 17}, {"t": "Condylus occipitalis", "m": "Occipital condyle — process on the occipital bone for articulation with the atlas", "e": "condylus (Gk. kondylos: knuckle, rounded process) + occipitalis (L. occiput: back of the head)", "p": 17}, {"t": "Canalis condylaris", "m": "Condylar canal — passage located posterior to the occipital condyle for transmission of a vein from the sigmoid sinus", "e": "canalis (L. canalis: channel, canal) + condylaris (Gk. kondylos: knuckle, rounded process)", "p": 17}, {"t": "Canalis hypoglossalis", "m": "Hypoglossal canal — passage that originates from the lateral part of the occipital bone, transmits the twelfth cranial nerve", "e": "canalis (L. canalis: channel, canal) + hypo (Gk. hypo: under) + glossalis (Gk. glossa: tongue)", "p": 17}, {"t": "Fossa condylaris", "m": "Condylar fossa — depression posterior to the occipital condyle", "e": "fossa (L. fossa: pit, ditch) + condylaris (Gk. kondylos: knuckle, rounded process)", "p": 17}, {"t": "Tuberculum jugulare", "m": "Jugular tubercle — small eminence above the hypoglossal canal", "e": "tuberculum (L. tuberculum: small bump, from tuber = swelling) + jugulare (L. jugulum: throat, collarbone, from jugum = yoke)", "p": 17}, {"t": "Processus jugularis", "m": "Jugular process — externally and internally visible process that projects laterally from the jugular foramen", "e": "processus (L. processus: projection, going forward) + jugularis (L. jugulum: throat, from jugum = yoke)", "p": 17}, {"t": "Processus intrajugularis ossis occipitalis", "m": "Intrajugular process of occipital bone — occasionally divides the jugular foramen into a lateral portion for the internal jugular vein and a medial segment for nerves", "e": "processus (L. processus: projection) + intra (L. intra: within) + jugularis (L. jugulum: throat) + ossis (L. os/ossis: bone) + occipitalis (L. occiput: back of the head)", "p": 17}, {"t": "Protuberantia occipitalis externa", "m": "External occipital protuberance — readily palpable bony projection in the middle of the occipital bone", "e": "protuberantia (L. protuberantia: bulge, from pro = forward + tuber = swelling) + occipitalis (L. occiput: back of the head) + externa (L. externus: outer, external)", "p": 17}, {"t": "Inion", "m": "Anthropometric landmark indicating the most prominent point on the external occipital protuberance", "e": "inion (Gk. inion: back of the head, nape of the neck)", "p": 17}, {"t": "Crista occipitalis externa", "m": "External occipital crest — bony ridge occasionally present between the external occipital protuberance and the foramen magnum", "e": "crista (L. crista: crest, ridge) + occipitalis (L. occiput: back of the head) + externa (L. externus: outer, external)", "p": 17}, {"t": "Linea nuchalis suprema", "m": "Highest (supreme) nuchal line — line arching externally from the upper margin of the external occipital protuberance", "e": "linea (L. linea: line) + nuchalis (Medieval L. nucha: nape of the neck, from Arabic nukhā' = spinal marrow) + suprema (L. supremus: highest, topmost)", "p": 17}, {"t": "Linea nuchalis superior", "m": "Superior nuchal line — transverse ridge at the level of the external occipital protuberance", "e": "linea (L. linea: line) + nuchalis (Medieval L. nucha: nape of the neck) + superior (L. superior: upper, higher)", "p": 17}, {"t": "Linea nuchalis inferior", "m": "Inferior nuchal line — transverse ridge between the superior nuchal line and the foramen magnum", "e": "linea (L. linea: line) + nuchalis (Medieval L. nucha: nape of the neck) + inferior (L. inferior: lower)", "p": 17}, {"t": "Planum occipitale", "m": "Occipital plane — outer surface of the occipital bone located superior to the external occipital protuberance", "e": "planum (L. planum: flat surface, plane) + occipitale (L. occiput: back of the head)", "p": 17}, {"t": "Eminentia cruciformis", "m": "Cruciform eminence — cross-shaped bony prominence with the internal occipital protuberance at its center", "e": "eminentia (L. eminentia: prominence, projection, from eminere = to project) + cruciformis (L. crux/crucis: cross + forma: shape — cross-shaped)", "p": 17}, {"t": "Protuberantia occipitalis interna", "m": "Internal occipital protuberance — midpoint of the cruciform eminence", "e": "protuberantia (L. protuberantia: bulge, from pro = forward + tuber = swelling) + occipitalis (L. occiput: back of the head) + interna (L. internus: inner, internal)", "p": 17}, {"t": "Crista occipitalis interna", "m": "Internal occipital crest — thick bony ridge that occasionally extends from the internal occipital protuberance to the foramen magnum", "e": "crista (L. crista: crest, ridge) + occipitalis (L. occiput: back of the head) + interna (L. internus: inner, internal)", "p": 17}, {"t": "Sulcus sinus sagittalis superioris", "m": "Groove for superior sagittal sinus", "e": "sulcus (L. sulcus: groove, furrow) + sinus (L. sinus: cavity, bay) + sagittalis (L. sagitta: arrow — arrow-shaped) + superioris (L. superior: upper, higher)", "p": 17}, {"t": "Sulcus sinus transversi", "m": "Groove for transverse sinus", "e": "sulcus (L. sulcus: groove, furrow) + sinus (L. sinus: cavity, bay) + transversi (L. transversus: crosswise, from trans = across + vertere = to turn)", "p": 17}, {"t": "Sulcus sinus sigmoidei", "m": "Groove for the sigmoid sinus — groove that begins before the sigmoid sinus enters the jugular foramen", "e": "sulcus (L. sulcus: groove, furrow) + sinus (L. sinus: cavity, bay) + sigmoidei (Gk. sigma: Greek letter Σ + eidos: form — sigma-shaped)", "p": 17}, {"t": "Sulcus sinus occipitalis", "m": "Groove for occipital sinus", "e": "sulcus (L. sulcus: groove, furrow) + sinus (L. sinus: cavity, bay) + occipitalis (L. occiput: back of the head)", "p": 17}, {"t": "Processus paramastoideus", "m": "Paramastoid process — prominence that occasionally projects from the jugular process in the direction of the transverse process of the atlas", "e": "processus (L. processus: projection, going forward) + para (Gk. para: beside, alongside) + mastoideus (Gk. mastos: breast + eidos: form — breast-shaped)", "p": 17}, {"t": "Fossa cerebralis", "m": "Cerebral fossa — depression for the occipital lobes of the cerebrum", "e": "fossa (L. fossa: pit, ditch) + cerebralis (L. cerebrum: brain)", "p": 17}, {"t": "Fossa cerebellaris", "m": "Cerebellar fossa — depression for the cerebellum", "e": "fossa (L. fossa: pit, ditch) + cerebellaris (L. cerebellum: little brain, diminutive of cerebrum)", "p": 17}, {"t": "Os sphenoidale", "m": "Sphenoid bone — bone located between the frontal, occipital and temporal bones", "e": "os (L. os: bone) + sphenoidale (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Corpus ossis sphenoidalis", "m": "Body of sphenoid bone — part located between the winged processes of the sphenoid bone", "e": "corpus (L. corpus: body) + ossis (L. os/ossis: bone) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Jugum sphenoidale", "m": "Connects the lesser wings of the sphenoid", "e": "jugum (L. jugum: yoke, ridge) + sphenoidale (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Sulcus prechiasmatis", "m": "(Pre)chiasmatic groove — groove between the right and left optic canals", "e": "sulcus (L. sulcus: groove, furrow) + prechiasmatis (Gk. pre = before + chiasma: crossing, from chiazein = to mark with an X)", "p": 19}, {"t": "Sella turcica", "m": "Turkish saddle — lies above the sphenoidal sinus and contains the hypophysis", "e": "sella (L. sella: seat, saddle) + turcica (L. turcicus: Turkish)", "p": 19}, {"t": "Tuberculum sellae", "m": "Small process in front of the hypophysial fossa", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = lump) + sellae (L. sella: seat, saddle)", "p": 19}, {"t": "Processus clinoideus medius", "m": "Middle clinoid process — either of two small protuberances occasionally present, one on either side of the floor of the hypophysial fossa", "e": "processus (L. processus: projection, going forward) + clinoideus (Gk. kline: bed + eidos: form, resembling a bed-post) + medius (L. medius: middle)", "p": 19}, {"t": "Fossa hypophysialis", "m": "Hypophysial fossa — fossa occupied by the hypophysis", "e": "fossa (L. fossa: pit, ditch) + hypophysialis (Gk. hypo: under + phyein: to grow, referring to the hypophysis)", "p": 19}, {"t": "Dorsum sellae", "m": "Posterior wall of the hypophysial fossa", "e": "dorsum (L. dorsum: back) + sellae (L. sella: seat, saddle)", "p": 19}, {"t": "Processus clinoideus posterior", "m": "Posterior clinoid process — either of two processes that extend from either side of the dorsum sellae", "e": "processus (L. processus: projection, going forward) + clinoideus (Gk. kline: bed + eidos: form, resembling a bed-post) + posterior (L. posterior: behind, later)", "p": 19}, {"t": "Sulcus caroticus", "m": "Carotid groove — longitudinal groove lateral to the body of the sphenoid bone that lodges the internal carotid artery", "e": "sulcus (L. sulcus: groove, furrow) + caroticus (Gk. karotides: carotid arteries, from karoun = to stupefy)", "p": 19}, {"t": "Lingula sphenoidalis", "m": "Pointed process lateral to the entrance of the internal carotid artery into the cranial fossa", "e": "lingula (L. lingula: little tongue, diminutive of lingua = tongue) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Crista sphenoidalis", "m": "Sphenoidal crest — median bony ridge on the anterior surface of the body of the sphenoid bone that articulates with the perpendicular plate of the ethmoid", "e": "crista (L. crista: crest, ridge) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Rostrum sphenoidale", "m": "Sphenoidal rostrum — downward continuation of the sphenoidal crest that articulates with the vomer", "e": "rostrum (L. rostrum: beak, snout) + sphenoidale (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Sinus sphenoidalis", "m": "Sphenoidal sinus — either of the paired paranasal sphenoidal sinuses", "e": "sinus (L. sinus: curve, hollow, cavity) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Septum intersinuale sphenoidale", "m": "Septum of sphenoidal sinus — partition separating the sinus into right and left parts", "e": "septum (L. septum: partition, wall) + intersinuale (L. inter: between + sinus: cavity) + sphenoidale (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Apertura sinus sphenoidalis", "m": "Aperture of sphenoidal sinus — orifice that opens anteriorly into the spheno-ethmoidal recess", "e": "apertura (L. apertura: opening, from aperire = to open) + sinus (L. sinus: hollow, cavity) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Concha sphenoidalis", "m": "Sphenoidal concha — originally paired, concave bony plate which fuses with the body of the sphenoid and forms part of the anterior and inferior wall of the sphenoidal sinus and other structures", "e": "concha (L./Gk. konche: shell, conch) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Ala minor ossis sphenoidalis", "m": "Lesser wing of sphenoid", "e": "ala (L. ala: wing) + minor (L. minor: smaller, lesser) + ossis (L. os/ossis: bone) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Canalis opticus", "m": "Optic canal — canal for the optic nerve and the ophthalmic artery", "e": "canalis (L. canalis: channel, canal) + opticus (Gk. optikos: of sight, from ops = eye)", "p": 19}, {"t": "Processus clinoideus anterior", "m": "Anterior clinoid process — cone-like process on either side of the anterior part of the hypophysial fossa", "e": "processus (L. processus: projection, going forward) + clinoideus (Gk. kline: bed + eidos: form, resembling a bed-post) + anterior (L. anterior: in front, before)", "p": 19}, {"t": "Fissura orbitalis superior", "m": "Superior orbital fissure — cleft between the greater and lesser wings of the sphenoid for the passage of nerves and veins", "e": "fissura (L. fissura: cleft, crack, from findere = to split) + orbitalis (L. orbita: track, orbit of the eye) + superior (L. superior: upper, higher)", "p": 19}, {"t": "Ala major ossis sphenoidalis", "m": "Greater wing of sphenoid", "e": "ala (L. ala: wing) + major (L. major: greater, larger) + ossis (L. os/ossis: bone) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Facies cerebralis", "m": "Cerebral surface — surface of the greater wing facing the brain", "e": "facies (L. facies: face, surface) + cerebralis (L. cerebrum: brain)", "p": 19}, {"t": "Facies temporalis", "m": "Temporal surface — outward surface of the greater wing", "e": "facies (L. facies: face, surface) + temporalis (L. tempora: temples, from tempus = time/temple of the head)", "p": 19}, {"t": "Facies maxillaris", "m": "Maxillary surface — surface of the greater wing facing the maxilla; the foramen rotundum opens here", "e": "facies (L. facies: face, surface) + maxillaris (L. maxilla: jaw, from mala = cheekbone)", "p": 19}, {"t": "Facies orbitalis", "m": "Orbital surface — surface of the greater wing facing the orbit", "e": "facies (L. facies: face, surface) + orbitalis (L. orbita: track, orbit of the eye)", "p": 19}, {"t": "Margo zygomaticus", "m": "Zygomatic border — margin of the greater wing articulating with the zygomatic bone", "e": "margo (L. margo: border, margin, edge) + zygomaticus (Gk. zygon: yoke + -maticus: adjectival suffix, referring to the zygomatic bone)", "p": 19}, {"t": "Margo frontalis", "m": "Frontal border — margin of the greater wing fused with the frontal bone", "e": "margo (L. margo: border, margin, edge) + frontalis (L. frons/frontis: forehead, brow)", "p": 19}, {"t": "Margo parietalis", "m": "Parietal border — margin of the greater wing fused with the parietal bone", "e": "margo (L. margo: border, margin, edge) + parietalis (L. paries/parietis: wall)", "p": 19}, {"t": "Margo squamosus", "m": "Squamous border — squamous margin of the greater wing that articulates with the temporal bone", "e": "margo (L. margo: border, margin, edge) + squamosus (L. squama: scale + -osus: full of, scaly)", "p": 19}, {"t": "Crista infratemporalis", "m": "Infratemporal crest — bony ridge between the vertical temporal surface and the horizontally-oriented inferior surface of the greater wing of the sphenoid", "e": "crista (L. crista: crest, ridge) + infratemporalis (L. infra: below + temporalis: of the temple, from tempus = temple)", "p": 19}, {"t": "Foramen rotundum", "m": "Foramen rotundum — round opening in the great wing that extends anteriorly into the pterygopalatine fossa; transmits the maxillary nerve", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + rotundum (L. rotundus: round, circular)", "p": 19}, {"t": "Foramen ovale", "m": "Opening for passage of the mandibular nerve in the medial part of the great wing, located in front of the foramen spinosum", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + ovale (L. ovalis: oval, egg-shaped, from ovum = egg)", "p": 19}, {"t": "Foramen venosum", "m": "[Foramen venosum] — opening occasionally present medial to the foramen ovale for passage of an emissary vein from the cavernous sinus", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + venosum (L. venosus: of a vein, from vena = vein)", "p": 19}, {"t": "Foramen spinosum", "m": "Opening situated lateral to and behind the foramen ovale for passage of the middle meningeal artery", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + spinosum (L. spinosus: spiny, thorny, from spina = spine, thorn)", "p": 19}, {"t": "Foramen petrosum", "m": "[Foramen petrosum] — opening occasionally present between the foramen ovale and the foramen spinosum for transmission of the lesser petrosal nerve", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + petrosum (L. petrosus: rocky, stony, from Gk. petra = rock)", "p": 19}, {"t": "Canaliculus innominatus", "m": "[[Canaliculus innominatus]] — opening occasionally present between the foramen ovale and the foramen spinosum for transmission of the lesser petrosal nerve", "e": "canaliculus (L. canaliculus: small channel, diminutive of canalis = canal) + innominatus (L. innominatus: unnamed, from in = not + nomen = name)", "p": 19}, {"t": "Spina ossis sphenoidalis", "m": "Angular spine of sphenoid — sharp, bony spur that extends downward from the greater wing", "e": "spina (L. spina: spine, thorn, spur) + ossis (L. os/ossis: bone) + sphenoidalis (Gk. sphenoeides: wedge-shaped, from sphen = wedge + eidos = form)", "p": 19}, {"t": "Sulcus tubae auditivae", "m": "Groove for the cartilaginous part of the auditory tube — shallow groove on the underside of the greater wing lateral to the root of the pterygoid process", "e": "sulcus (L. sulcus: groove, furrow) + tubae (L. tuba: tube, trumpet) + auditivae (L. auditivus: of hearing, from audire = to hear)", "p": 19}, {"t": "Processus pterygoideus", "m": "Pterygoid process of the sphenoid bone", "e": "processus (L. prōcessus: projection, going forward) + pterygoideus (Gk. pteryx: wing + eidos: form, shape — wing-shaped)", "p": 21}, {"t": "Lamina lateralis [processus pterygoidei]", "m": "Lateral pterygoid plate", "e": "lamina (L. lamina: thin plate, layer) + lateralis (L. laterālis: of the side, from latus: side) + processus (L. prōcessus: projection) + pterygoidei (Gk. pteryx: wing + eidos: form)", "p": 21}, {"t": "Lamina medialis [processus pterygoidei]", "m": "Medial pterygoid plate", "e": "lamina (L. lamina: thin plate) + medialis (L. mediālis: of the middle, from medius: middle) + processus (L. prōcessus: projection) + pterygoidei (Gk. pteryx: wing + eidos: form)", "p": 21}, {"t": "Incisura pterygoidea", "m": "Pterygoid notch (fissure)", "e": "incisura (L. incīsūra: notch, cut, from incidere: to cut into) + pterygoidea (Gk. pteryx: wing + eidos: form)", "p": 21}, {"t": "Fossa pterygoidea", "m": "Pterygoid fossa — space between the lateral and medial pterygoid plates for the medial pterygoid muscle", "e": "fossa (L. fossa: pit, ditch, hollow) + pterygoidea (Gk. pteryx: wing + eidos: form)", "p": 21}, {"t": "Fossa scaphoidea", "m": "Scaphoid fossa — oblong depression at the root of the medial pterygoid plate", "e": "fossa (L. fossa: pit, hollow) + scaphoidea (Gk. skaphē: boat + eidos: form — boat-shaped)", "p": 21}, {"t": "Processus vaginalis", "m": "Vaginal process — small bony ridge medial to the root of the medial pterygoid plate", "e": "processus (L. prōcessus: projection) + vaginalis (L. vāgīnālis: sheath-like, from vāgīna: sheath)", "p": 21}, {"t": "Sulcus palatovaginalis", "m": "Palatovaginal groove — groove which joins the palatine bone to form the palatovaginal canal", "e": "sulcus (L. sulcus: groove, furrow) + palatovaginalis (L. palatum: palate + vāgīna: sheath — palate-sheath related)", "p": 21}, {"t": "Sulcus vomerovaginalis", "m": "Vomerovaginal groove — groove at the base of the pterygoid process", "e": "sulcus (L. sulcus: groove, furrow) + vomerovaginalis (L. vomer: plowshare bone + vāgīna: sheath)", "p": 21}, {"t": "Hamulus pterygoideus", "m": "Pterygoid hamulus — hook-like process at the inferior end of the medial pterygoid plate", "e": "hamulus (L. hāmulus: small hook, diminutive of hāmus: hook) + pterygoideus (Gk. pteryx: wing + eidos: form)", "p": 21}, {"t": "Sulcus hamuli pterygoidei", "m": "Sulcus of pterygoid hamulus — groove produced by a sharp bend in the hamulus", "e": "sulcus (L. sulcus: groove, furrow) + hamuli (L. hāmulus: small hook) + pterygoidei (Gk. pteryx: wing + eidos: form)", "p": 21}, {"t": "Canalis pterygoideus [canalis Vidii]", "m": "Pterygoid (vidian) canal — passage extending anteriorly in the base of the pterygoid process", "e": "canalis (L. canālis: channel, canal, from canna: reed) + pterygoideus (Gk. pteryx: wing + eidos: form) + Vidii (proper name: Guido Guidi/Vidius, 16th century anatomist)", "p": 21}, {"t": "Processus pterygospinosus", "m": "Pterygospinous process — sharp spine on the posterior edge of the lateral pterygoid plate", "e": "processus (L. prōcessus: projection) + pterygospinosus (Gk. pteryx: wing + L. spīnōsus: spiny, from spīna: spine, thorn)", "p": 21}, {"t": "Os temporale", "m": "Temporal bone — bone that lies between the occipital, sphenoid and parietal bones", "e": "os (L. os: bone) + temporale (L. temporālis: of the temple, from tempus: temple of the head, time)", "p": 21}, {"t": "Pars petrosa ossis temporalis", "m": "Petrous part (pyramid) of temporal bone — houses the inner ear", "e": "pars (L. pars: part) + petrosa (L. petrōsa: rocky, stony, from petra: rock) + ossis (L. os/ossis: bone) + temporalis (L. temporālis: of the temple)", "p": 21}, {"t": "Margo occipitalis", "m": "Occipital border — margin articulating with the occipital bone", "e": "margo (L. margo: margin, border, edge) + occipitalis (L. occipitālis: of the occiput, from ob: against + caput: head)", "p": 21}, {"t": "Processus mastoideus", "m": "Mastoid process — process located just posterior to the external acoustic meatus", "e": "processus (L. prōcessus: projection) + mastoideus (Gk. mastos: breast + eidos: form — breast-shaped)", "p": 21}, {"t": "Incisura mastoidea", "m": "Mastoid notch — medial notch on the inferior surface of the mastoid process", "e": "incisura (L. incīsūra: notch, cut) + mastoidea (Gk. mastos: breast + eidos: form)", "p": 21}, {"t": "Sulcus a. occipitalis", "m": "Groove for occipital artery — lies medial to the mastoid notch and proximal to the occipital margin", "e": "sulcus (L. sulcus: groove) + a. [arteria] (L. arteria: artery, from Gk. artēria: windpipe, artery) + occipitalis (L. occipitālis: of the occiput, from ob: against + caput: head)", "p": 21}, {"t": "Foramen mastoideum", "m": "Mastoid foramen — opening behind the mastoid process for additional venous drainage from the cranial cavity", "e": "foramen (L. forāmen: opening, hole, from forāre: to bore) + mastoideum (Gk. mastos: breast + eidos: form)", "p": 21}, {"t": "Canalis fascialis", "m": "Facial canal — canal for the facial nerve beginning at the opening of the internal acoustic meatus and ending at the stylomastoid foramen", "e": "canalis (L. canālis: channel, canal) + fascialis (L. faciālis: of the face, from faciēs: face)", "p": 21}, {"t": "Geniculum canalis facialis", "m": "Genu of facial canal — sharp bend in the facial canal just below the anterior wall of the petrous part", "e": "geniculum (L. geniculum: small knee, bend, diminutive of genu: knee) + canalis (L. canālis: channel) + facialis (L. faciālis: of the face)", "p": 21}, {"t": "Canaliculus chordae tympani nervi", "m": "Canaliculus of chorda tympani nerve — narrow passageway for the chorda tympani nerve between the facial canal and the tympanic cavity", "e": "canaliculus (L. canaliculus: small channel, diminutive of canālis) + chordae (Gk. khordē: string, cord) + tympani (Gk. tympanon: drum) + nervi (L. nervus: nerve, sinew)", "p": 21}, {"t": "Apex partis petrosae", "m": "Apex of petrous temporal bone — directed anteromedially", "e": "apex (L. apex: tip, summit, point) + partis (L. pars/partis: part) + petrosae (L. petrōsa: rocky, stony, from petra: rock)", "p": 21}, {"t": "Canalis caroticus", "m": "Carotid canal — canal for the internal carotid artery", "e": "canalis (L. canālis: channel, canal) + caroticus (Gk. karōtis: carotid artery, from karoun: to stupefy — pressure on it causes unconsciousness)", "p": 21}, {"t": "Canaliculi caroticotympanici", "m": "Caroticotympanic canaliculi — small channels in the wall of the carotid canal for arterial and nerve branches", "e": "canaliculi (L. canaliculus: small channel, diminutive of canālis) + caroticotympanici (Gk. karōtis: carotid + tympanon: drum — relating to carotid and tympanum)", "p": 21}, {"t": "Canalis musculotubarius", "m": "Musculotubal canal — double canal for the auditory tube and tensor tympani muscle", "e": "canalis (L. canālis: channel, canal) + musculotubarius (L. musculus: muscle + tuba: tube — relating to muscle and tube)", "p": 21}, {"t": "Semicanalis m. tensoris tympani", "m": "Semicanal for tensor tympani muscle", "e": "semicanalis (L. semi: half + canālis: channel) + m. [musculi] (L. musculus: muscle) + tensoris (L. tensor: that which stretches, from tendere: to stretch) + tympani (Gk. tympanon: drum)", "p": 21}, {"t": "Semicanalis tubae auditoriae (auditivae)", "m": "Semicanal for the auditory tube", "e": "semicanalis (L. semi: half + canālis: channel) + tubae (L. tuba: tube, trumpet) + auditoriae (L. audītōrius: of hearing, from audīre: to hear) + auditivae (L. audītīvus: of hearing, from audīre: to hear)", "p": 21}, {"t": "Septum canalis musculotubarii", "m": "Septum of musculotubal canal — bony partition between the above-mentioned semicanals", "e": "septum (L. septum: partition, wall, from saepīre: to enclose) + canalis (L. canālis: channel) + musculotubarii (L. musculus: muscle + tuba: tube)", "p": 21}, {"t": "Facies anterior partis petrosae", "m": "Anterior surface of petrous part of temporal bone", "e": "facies (L. faciēs: face, surface) + anterior (L. anterior: front, former) + partis (L. pars/partis: part) + petrosae (L. petrōsus: rocky, stony, from petra = rock)", "p": 23}, {"t": "Tegmen tympani", "m": "Roof of tympanic cavity", "e": "tegmen (L. tegmen: covering, roof, from tegere = to cover) + tympani (L. tympanum: drum, from Gk. tympanon = drum)", "p": 23}, {"t": "Eminentia arcuata", "m": "Arcuate eminence", "e": "eminentia (L. ēminentia: prominence, projection, from eminēre = to stand out) + arcuata (L. arcuātus: arched, bow-shaped, from arcus = arch/bow)", "p": 23}, {"t": "Hiatus canalis n. petrosi majoris", "m": "Hiatus of canal for greater petrosal nerve", "e": "hiatus (L. hiātus: gap, opening, from hiāre = to gape) + canalis (L. canālis: channel, canal) + n. = nervus (L. nervus: nerve, sinew) + petrosi (L. petrōsus: rocky, from petra = rock) + majoris (L. maior: greater, larger)", "p": 23}, {"t": "Hiatus canalis n. petrosi minoris", "m": "Hiatus of canal for lesser petrosal nerve", "e": "hiatus (L. hiātus: gap, opening) + canalis (L. canālis: channel, canal) + n. = nervus (L. nervus: nerve) + petrosi (L. petrōsus: rocky, from petra = rock) + minoris (L. minor: lesser, smaller)", "p": 23}, {"t": "Sulcus n. petrosi majoris", "m": "Groove for greater petrosal nerve", "e": "sulcus (L. sulcus: groove, furrow) + n. = nervus (L. nervus: nerve) + petrosi (L. petrōsus: rocky) + majoris (L. maior: greater)", "p": 23}, {"t": "Sulcus n. petrosi minoris", "m": "Groove for lesser petrosal nerve", "e": "sulcus (L. sulcus: groove, furrow) + n. = nervus (L. nervus: nerve) + petrosi (L. petrōsus: rocky) + minoris (L. minor: lesser)", "p": 23}, {"t": "Impressio trigeminalis", "m": "Trigeminal impression", "e": "impressio (L. impressiō: impression, indentation, from imprimere = to press into) + trigeminalis (L. trigeminus: threefold, triple, from tri- = three + geminus = twin/born together)", "p": 23}, {"t": "Margo superior partis petrosae", "m": "Superior border of petrous temporal bone", "e": "margo (L. margō: border, edge, margin) + superior (L. superior: upper, higher) + partis (L. pars/partis: part) + petrosae (L. petrōsus: rocky)", "p": 23}, {"t": "Sulcus sinus petrosi superioris", "m": "Groove for superior petrosal sinus", "e": "sulcus (L. sulcus: groove, furrow) + sinus (L. sinus: hollow, bay, curve) + petrosi (L. petrōsus: rocky) + superioris (L. superior: upper, higher)", "p": 23}, {"t": "Facies posterior partis petrosae", "m": "Posterior surface of petrous part of temporal bone", "e": "facies (L. faciēs: face, surface) + posterior (L. posterior: behind, back) + partis (L. pars/partis: part) + petrosae (L. petrōsus: rocky)", "p": 23}, {"t": "Porus acusticus internus", "m": "Opening of internal acoustic meatus on the posterior wall of the petrous part of the temporal bone", "e": "porus (L. porus, from Gk. poros: passage, pore) + acusticus (Gk. akoustikos: of hearing, from akouein = to hear) + internus (L. internus: internal, inner)", "p": 23}, {"t": "Meatus acusticus internus", "m": "Internal acoustic (auditory) meatus", "e": "meatus (L. meātus: passage, canal, from meare = to pass) + acusticus (Gk. akoustikos: of hearing) + internus (L. internus: internal, inner)", "p": 23}, {"t": "Fossa subarcuata", "m": "Subarcuate fossa", "e": "fossa (L. fossa: pit, ditch, from fodere = to dig) + subarcuata (L. sub-: under, below + arcuātus: arched, from arcus = arch)", "p": 23}, {"t": "Aqueductus vestibuli", "m": "Aqueduct of vestibule", "e": "aqueductus (L. aquaeductus: water channel, from aqua = water + ducere = to lead) + vestibuli (L. vestibulum: entrance chamber, antechamber)", "p": 23}, {"t": "Apertura externa aqueductus vestibuli", "m": "External opening of vestibular aqueduct", "e": "apertura (L. apertūra: opening, from aperire = to open) + externa (L. externus: external, outer) + aqueductus (L. aquaeductus: water channel) + vestibuli (L. vestibulum: entrance chamber)", "p": 23}, {"t": "Margo posterior partis petrosae", "m": "Posterior border of petrous part of the temporal bone", "e": "margo (L. margō: border, edge) + posterior (L. posterior: behind, back) + partis (L. pars/partis: part) + petrosae (L. petrōsus: rocky)", "p": 23}, {"t": "Sulcus sinus petrosi inferioris", "m": "Groove for inferior petrosal sinus", "e": "sulcus (L. sulcus: groove, furrow) + sinus (L. sinus: hollow, bay) + petrosi (L. petrōsus: rocky) + inferioris (L. inferior: lower)", "p": 23}, {"t": "Processus intrajugularis", "m": "Intrajugular process", "e": "processus (L. prōcessus: projection, from procedere = to go forward) + intrajugularis (L. intra-: within + jugulāris: of the jugular)", "p": 23}, {"t": "Canaliculus cochleae", "m": "Cochlear canaliculus — bony canal for the cochlear aqueduct", "e": "canaliculus (L. canaliculus: small channel, diminutive of canālis = canal) + cochleae (L. cochlea: snail shell, from Gk. kokhlias = snail with spiral shell)", "p": 23}, {"t": "Apertura externa canaliculi cochleae", "m": "External opening of cochlear canaliculus", "e": "apertura (L. apertūra: opening) + externa (L. externus: external) + canaliculi (L. canaliculus: small channel) + cochleae (L. cochlea: snail shell, cochlea)", "p": 23}, {"t": "Facies inferior partis petrosae", "m": "Inferior surface of petrous temporal bone", "e": "facies (L. faciēs: face, surface) + inferior (L. inferior: lower) + partis (L. pars/partis: part) + petrosae (L. petrōsus: rocky)", "p": 23}, {"t": "Fossa jugularis", "m": "Jugular fossa — enlargement of the jugular foramen for the superior bulb of the internal jugular vein", "e": "fossa (L. fossa: pit, hollow) + jugularis (L. jugulāris: of the throat/jugular)", "p": 23}, {"t": "Canaliculus mastoideus", "m": "Mastoid canaliculus — narrow canal for the auricular branch of the vagus nerve", "e": "canaliculus (L. canaliculus: small channel) + mastoideus (Gk. mastoeidēs: breast-shaped, from mastos = breast + eidos = form)", "p": 23}, {"t": "Processus styloideus", "m": "Styloid process — long process located laterally in front of the jugular fossa", "e": "processus (L. prōcessus: projection) + styloideus (Gk. stylos: pillar, stake + eidos: form/shape, thus pillar-shaped)", "p": 23}, {"t": "Foramen stylomastoideum", "m": "Stylomastoid foramen — external opening of the facial canal", "e": "foramen (L. forāmen: opening, hole, from forāre = to bore) + stylomastoideum (Gk. stylos: pillar + mastoeidēs: breast-shaped, from mastos = breast + eidos = form)", "p": 23}, {"t": "Canaliculus tympanicus", "m": "Tympanic canaliculus — minute canal in the petrosal fossula traversed by the tympanic nerve and inferior tympanic artery", "e": "canaliculus (L. canaliculus: small channel) + tympanicus (L. tympanicus, from Gk. tympanon = drum)", "p": 23}, {"t": "Fossula petrosa", "m": "Petrosal fossula — slight depression in the bony ridge between the carotid canal and the jugular fossa", "e": "fossula (L. fossula: small pit, diminutive of fossa = pit) + petrosa (L. petrōsus: rocky, stony)", "p": 23}, {"t": "Cavitas tympanica", "m": "Tympanic (middle ear) cavity — narrow air-filled space between the osseous labyrinth and the tympanic membrane", "e": "cavitas (L. cavitās: hollow, cavity, from cavus = hollow) + tympanica (L. tympanicus, from Gk. tympanon = drum)", "p": 23}, {"t": "Fissura petrotympanica", "m": "Petrotympanic fissure [glaserian fissure] — fissure situated dorsomedial to the fossa of the temporomandibular joint", "e": "fissura (L. fissūra: cleft, crack, from findere = to split) + petrotympanica (L. petrōsus: rocky + Gk. tympanon: drum)", "p": 23}, {"t": "Fissura petrosquamosa", "m": "Petrosquamous fissure — lies on the skull base in front of the petrotympanic fissure between the visible petrous strip and the squamous part of the temporal bone", "e": "fissura (L. fissūra: cleft, crack) + petrosquamosa (L. petrōsus: rocky + squāmōsus: scaly, from squāma = scale)", "p": 23}, {"t": "Fissura tympanosquamosa", "m": "Squamotympanic fissure — lateral continuation of the two above mentioned fissures after they unite", "e": "fissura (L. fissūra: cleft, crack) + tympanosquamosa (Gk. tympanon: drum + L. squāmōsus: scaly, from squāma = scale)", "p": 23}, {"t": "Fissura tympanomastoidea", "m": "Tympanomastoid fissure — suture between the tympanic part of the temporal bone and the mastoid process", "e": "fissura (L. fissūra: cleft, crack) + tympanomastoidea (Gk. tympanon: drum + Gk. mastoeidēs: breast-shaped, from mastos = breast + eidos = form)", "p": 23}, {"t": "Pars tympanica", "m": "Tympanic part of temporal bone", "e": "pars (L. pars: part, portion) + tympanica (Gk. tympanon: drum, kettledrum)", "p": 25}, {"t": "Meatus acusticus externus", "m": "External acoustic (auditory) meatus", "e": "meatus (L. meātus: passage, channel, from meare = to go) + acusticus (Gk. akoustikos: of hearing, from akouein = to hear) + externus (L. externus: external, outer)", "p": 25}, {"t": "Porus acusticus externus", "m": "Opening of external acoustic meatus", "e": "porus (Gk. poros: passage, pore) + acusticus (Gk. akoustikos: of hearing) + externus (L. externus: external, outer)", "p": 25}, {"t": "Spina tympanica major", "m": "Greater tympanic spine — anterior end of the tympanic ring formed by the tympanic part of the temporal bone", "e": "spina (L. spina: spine, thorn) + tympanica (Gk. tympanon: drum) + major (L. maior: greater, larger)", "p": 25}, {"t": "Spina tympanica minor", "m": "Lesser tympanic spine — posterior end of the ring formed by the tympanic part of the temporal bone", "e": "spina (L. spina: spine, thorn) + tympanica (Gk. tympanon: drum) + minor (L. minor: lesser, smaller)", "p": 25}, {"t": "Sulcus tympanicus", "m": "Tympanic groove — groove for attachment of the tympanic membrane", "e": "sulcus (L. sulcus: groove, furrow) + tympanicus (Gk. tympanon: drum)", "p": 25}, {"t": "Incisura tympanica", "m": "Tympanic notch — notch between the greater and lesser tympanic spines", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + tympanica (Gk. tympanon: drum)", "p": 25}, {"t": "Vagina processus styloidei", "m": "Sheath of styloid process — ridge formed by the tympanic part of the temporal bone partially enclosing the root of the styloid process", "e": "vagina (L. vagina: sheath, scabbard) + processus (L. prōcessus: projection, going forward) + styloidei (Gk. stylos: pillar, column + eidos: form, resemblance)", "p": 25}, {"t": "Pars squamosa", "m": "Squamous part — part of the temporal bone located between the sphenoid, parietal and occipital bones", "e": "pars (L. pars: part, portion) + squamosa (L. squama: scale, hence squamosus = scaly, scale-like)", "p": 25}, {"t": "Incisura parietalis", "m": "Parietal notch — indentation posteroinferior to the temporal line", "e": "incisura (L. incisura: notch, from incidere = to cut into) + parietalis (L. paries: wall)", "p": 25}, {"t": "Margo sphenoidalis", "m": "Sphenoidal border — anterior margin articulating with the sphenoid bone", "e": "margo (L. margo: border, margin) + sphenoidalis (Gk. sphen: wedge + eidos: form, resemblance)", "p": 25}, {"t": "Sulcus arteriae temporalis mediae", "m": "Groove for the middle temporal artery", "e": "sulcus (L. sulcus: groove, furrow) + arteriae (Gk. arteria: artery, from aer = air + terein = to keep) + temporalis (L. tempora: temples) + mediae (L. medius: middle)", "p": 25}, {"t": "Processus zygomaticus", "m": "Zygomatic process of temporal bone — contributes to the formation of the zygomatic arch", "e": "processus (L. prōcessus: projection, going forward) + zygomaticus (Gk. zygoma: yoke, from zygon = yoke, bar)", "p": 25}, {"t": "Crista supramastoidea", "m": "Supramastoid crest — ridge forming the posterior boundary of the field of attachment of the temporalis muscle", "e": "crista (L. crista: crest, ridge) + supra (L. supra: above, over) + mastoidea (Gk. mastos: breast + eidos: form, resemblance)", "p": 25}, {"t": "Foveola suprameatica", "m": "Suprameatal pit — small pit superior to the suprameatal spine and lateral to the mastoid antrum", "e": "foveola (L. foveola: small pit, diminutive of fovea = pit) + supra (L. supra: above) + meatica (L. meātus: passage, channel)", "p": 25}, {"t": "Spina suprameatica", "m": "Suprameatal spine — projection for attachment of the auricular cartilage", "e": "spina (L. spina: spine, thorn) + supra (L. supra: above) + meatica (L. meātus: passage, channel)", "p": 25}, {"t": "Fossa mandibularis", "m": "Mandibular fossa — depression for the head of the mandible", "e": "fossa (L. fossa: pit, ditch, hollow) + mandibularis (L. mandibula: jaw, from mandere = to chew)", "p": 25}, {"t": "Facies articularis", "m": "Surface for articulation with the temporomandibular joint", "e": "facies (L. facies: face, surface) + articularis (L. articulāris: of a joint, from articulus = joint)", "p": 25}, {"t": "Tuberculum articulare", "m": "Articular tubercle — cylindrical elevation in front of the mandibular fossa", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = swelling, knob) + articulare (L. articulāris: of a joint)", "p": 25}, {"t": "Os parietale", "m": "Parietal bone — located between the frontal, sphenoid and temporal bones", "e": "os (L. os: bone) + parietale (L. paries: wall, hence parietalis = of the wall)", "p": 25}, {"t": "Facies interna", "m": "Internal surface — the internal or cerebral surface of the parietal bone", "e": "facies (L. facies: face, surface) + interna (L. internus: internal, inner)", "p": 25}, {"t": "Sulcus arteriae meningeae mediae", "m": "Groove for middle meningeal artery", "e": "sulcus (L. sulcus: groove, furrow) + arteriae (Gk. arteria: artery) + meningeae (Gk. meninx: membrane, covering of the brain) + mediae (L. medius: middle)", "p": 25}, {"t": "Facies externa", "m": "External surface — the external surface of the parietal bone facing the scalp", "e": "facies (L. facies: face, surface) + externa (L. externus: external, outer)", "p": 25}, {"t": "Linea temporalis superior", "m": "Superior temporal line — curved line for attachment of the temporal fascia, forming the upper margins of the planum temporale", "e": "linea (L. linea: line) + temporalis (L. tempora: temples) + superior (L. superior: upper, higher)", "p": 25}, {"t": "Linea temporalis inferior", "m": "Inferior temporal line — curved line for attachment of the temporalis muscle", "e": "linea (L. linea: line) + temporalis (L. tempora: temples) + inferior (L. inferior: lower)", "p": 25}, {"t": "Tuber parietale", "m": "Parietal tuber — prominence located near the middle of the external surface of the parietal bone", "e": "tuber (L. tuber: swelling, knob, protuberance) + parietale (L. paries: wall)", "p": 25}, {"t": "Margo sagittalis", "m": "Sagittal border — upper edge of parietal bone that lies in the midsagittal plane", "e": "margo (L. margo: border, margin) + sagittalis (L. sagitta: arrow)", "p": 25}, {"t": "Angulus frontalis", "m": "Frontal angle — anterosuperior angle of the parietal bone", "e": "angulus (L. angulus: angle, corner) + frontalis (L. frons: forehead, brow)", "p": 25}, {"t": "Angulus occipitalis", "m": "Occipital angle — posterosuperior angle of the parietal bone", "e": "angulus (L. angulus: angle, corner) + occipitalis (L. occiput: back of the head)", "p": 25}, {"t": "Angulus sphenoidalis", "m": "Sphenoidal angle — anteroinferior angle of the parietal bone", "e": "angulus (L. angulus: angle, corner) + sphenoidalis (Gk. sphen: wedge + eidos: form, resemblance)", "p": 25}, {"t": "Angulus mastoideus", "m": "Mastoid angle — posteroinferior angle of the parietal bone", "e": "angulus (L. angulus: angle, corner) + mastoideus (Gk. mastos: breast + eidos: form, resemblance)", "p": 25}, {"t": "Foramen parietale", "m": "Parietal foramen — opening for an emissary vein from the cranial cavity, usually located in the posterosuperior part of the parietal bone", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + parietale (L. paries: wall)", "p": 25}, {"t": "Anulus tympanicus", "m": "Tympanic ring — bony ring which is the developmental precursor of the tympanic part of the temporal bone", "e": "anulus (L. anulus: ring, small ring) + tympanicus (Gk. tympanon: drum)", "p": 25}, {"t": "Os frontale", "m": "Frontal bone", "e": "os (L. os: bone) + frontale (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Squama frontalis", "m": "Squama of frontal bone", "e": "squama (L. squama: scale, flat plate) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Tuber frontale", "m": "Frontal tuber (tuberosity)", "e": "tuber (L. tuber: bump, swelling, protuberance) + frontale (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Eminentia frontalis", "m": "Frontal eminence", "e": "eminentia (L. eminentia: prominence, projection, from eminere = to stand out) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Arcus superciliaris", "m": "Superciliary arch", "e": "arcus (L. arcus: arch, bow) + superciliaris (L. superciliaris: of the eyebrow, from super = above + cilium = eyelid/brow)", "p": 27}, {"t": "Glabella", "m": "Landmark between the two superciliary arches", "e": "glabella (L. glabella: smooth area, diminutive of glaber = smooth, hairless)", "p": 27}, {"t": "Sutura frontalis", "m": "Frontal (metopic) suture", "e": "sutura (L. sutura: seam, suture, from suere = to sew) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Sutura frontalis metopica", "m": "Persistent frontal suture in the adult", "e": "sutura (L. sutura: seam, suture) + frontalis (L. frontalis: of the forehead) + metopica (Gk. metopikos: of the forehead, from metopon = forehead)", "p": 27}, {"t": "Margo supraorbitalis", "m": "Supraorbital border", "e": "margo (L. margo: margin, border, edge) + supra (L. supra: above) + orbitalis (L. orbitalis: of the orbit, from orbita = orbit, track)", "p": 27}, {"t": "Incisura supraorbitalis", "m": "Supraorbital notch or foramen", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + supra (L. supra: above) + orbitalis (L. orbitalis: of the orbit)", "p": 27}, {"t": "Foramen supraorbitale", "m": "Supraorbital foramen", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + supra (L. supra: above) + orbitale (L. orbitalis: of the orbit)", "p": 27}, {"t": "Incisura frontalis", "m": "Frontal notch or foramen", "e": "incisura (L. incisura: notch, from incidere = to cut into) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Foramen frontale", "m": "Frontal foramen", "e": "foramen (L. foramen: opening, hole) + frontale (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Linea temporalis ossis frontalis", "m": "Temporal line of frontal bone", "e": "linea (L. linea: line) + temporalis (L. temporalis: of the temple) + ossis (L. os/ossis: bone) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Processus zygomaticus ossis frontalis", "m": "Zygomatic process of frontal bone", "e": "processus (L. processus: projection, process, from procedere = to go forward) + zygomaticus (Gk. zygoma: yoke, cheekbone, from zygon = yoke) + ossis (L. os/ossis: bone) + frontalis (L. frontalis: of the forehead)", "p": 27}, {"t": "Crista frontalis", "m": "Frontal crest — a median ridge on the anterior internal surface of the frontal bone for attachment of the falx cerebri", "e": "crista (L. crista: crest, ridge) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Foramen caecum", "m": "Foramen cecum — canal behind the frontal crest", "e": "foramen (L. foramen: opening, hole) + caecum (L. caecus: blind, from caecus = blind)", "p": 27}, {"t": "Pars nasalis ossis frontalis", "m": "Nasal part of frontal bone — middle segment between the two orbital parts of the frontal bone", "e": "pars (L. pars: part, portion) + nasalis (L. nasalis: of the nose, from nasus = nose) + ossis (L. os/ossis: bone) + frontalis (L. frontalis: of the forehead)", "p": 27}, {"t": "Spina nasalis", "m": "Nasal spine — pointed median structure projecting from the pars nasalis", "e": "spina (L. spina: spine, thorn, pointed projection) + nasalis (L. nasalis: of the nose, from nasus = nose)", "p": 27}, {"t": "Margo nasalis", "m": "Nasal border — serrated lower margin of the nasal part of the frontal bone", "e": "margo (L. margo: margin, border) + nasalis (L. nasalis: of the nose, from nasus = nose)", "p": 27}, {"t": "Pars orbitalis", "m": "Orbital part — the part of the frontal bone forming the roof of the orbit", "e": "pars (L. pars: part, portion) + orbitalis (L. orbitalis: of the orbit, from orbita = orbit, track)", "p": 27}, {"t": "Spina trochlearis", "m": "Trochlear spine — small bony spicule occasionally present on the anterosuperior part of the medial angle of the orbit", "e": "spina (L. spina: spine, thorn, pointed projection) + trochlearis (Gk. trochlea: pulley, wheel, from trokhos = wheel)", "p": 27}, {"t": "Fovea trochlearis", "m": "Trochlear fovea — small depression for attachment of a cartilaginous sling (trochlea or pulley)", "e": "fovea (L. fovea: pit, small depression) + trochlearis (Gk. trochlea: pulley, from trokhos = wheel)", "p": 27}, {"t": "Foramina ethmoidalia", "m": "Ethmoidal foramina — openings for the ethmoidal vessels and nerves", "e": "foramina (L. foramen/foramina: openings, holes, plural of foramen) + ethmoidalia (Gk. ethmoeidēs: sieve-like, from ethmos = sieve + eidos = form)", "p": 27}, {"t": "Fossa glandulae lacrimalis", "m": "Fossa for lacrimal gland — depression for the lacrimal gland in the lateral angle of the orbit", "e": "fossa (L. fossa: pit, ditch, depression) + glandulae (L. glandula: small gland, diminutive of glans = acorn) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 27}, {"t": "Incisura ethmoidalis", "m": "Ethmoid notch — space between the right and left orbital parts of the frontal bone in which the ethmoid bone is lodged", "e": "incisura (L. incisura: notch, from incidere = to cut into) + ethmoidalis (Gk. ethmoeidēs: sieve-like, from ethmos = sieve + eidos = form)", "p": 27}, {"t": "Sinus frontalis", "m": "Frontal sinus — averages 3 cm high and 2.5 cm wide and often extends 1.8 cm posteriorly, forming a part of the orbital roof", "e": "sinus (L. sinus: hollow, cavity, sinus) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Apertura sinus frontalis", "m": "Opening of frontal sinus — medial opening on the floor of the frontal sinus for discharge of secretions into the nasal cavity", "e": "apertura (L. apertura: opening, from aperire = to open) + sinus (L. sinus: hollow, cavity) + frontalis (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Septum intersinuale frontale", "m": "Septum of frontal sinus — partition between the right and left frontal sinuses", "e": "septum (L. septum: partition, wall, from saepire = to enclose) + intersinuale (L. inter = between + sinuale, from sinus = hollow, cavity) + frontale (L. frontalis: of the forehead, from frons = forehead)", "p": 27}, {"t": "Os ethmoidale", "m": "Ethmoid bone — unpaired bone in the ethmoid notch of the frontal bone", "e": "os (L. os: bone) + ethmoidale (Gk. ēthmoeidēs: sieve-like, from ēthmos = sieve + eidos = form)", "p": 29}, {"t": "Lamina et foramina cribrosa", "m": "Cribriform plate and foramina — elongated horizontal plate occupying the median plane between the nasal cavity and the anterior cranial fossa", "e": "lamina (L. lamina: thin plate, layer) + et (L. et: and) + foramina (L. foramina: holes, plural of foramen) + cribrosa (L. cribrōsus: sieve-like, from cribrum = sieve)", "p": 29}, {"t": "Crista galli", "m": "Crista galli — small bony process that projects upward from the anterior cranial fossa and gives attachment to the falx cerebri", "e": "crista (L. crista: crest, ridge) + galli (L. gallus: cock/rooster, genitive = of the cock)", "p": 29}, {"t": "Ala cristae galli", "m": "Ala of crista galli — winglike, paired process for connection of the crista galli to the frontal crest", "e": "ala (L. ala: wing) + cristae (L. crista: crest, genitive = of the crest) + galli (L. gallus: cock/rooster, genitive = of the cock)", "p": 29}, {"t": "Lamina perpendicularis", "m": "Perpendicular plate — extends downward from the ethmoid bone and forms the upper part of the nasal septum", "e": "lamina (L. lamina: thin plate, layer) + perpendicularis (L. perpendiculāris: perpendicular, from perpendiculum = plumb line)", "p": 29}, {"t": "Labyrinthus ethmoidalis", "m": "Ethmoidal labyrinth — collective term for the ethmoidal air cells situated between the orbital and nasal cavities", "e": "labyrinthus (Gk. labyrinthos: labyrinth, maze) + ethmoidalis (Gk. ēthmoeidēs: sieve-like, from ēthmos = sieve + eidos = form)", "p": 29}, {"t": "Cellulae ethmoidales", "m": "Ethmoidal air cells", "e": "cellulae (L. cellula: small chamber, diminutive of cella = room) + ethmoidales (Gk. ēthmoeidēs: sieve-like, from ēthmos = sieve + eidos = form)", "p": 29}, {"t": "Infundibulum ethmoidale", "m": "Ethmoidal infundibulum — narrow, oblong canal below the middle nasal concha and between the uncinate process and ethmoidal bulla", "e": "infundibulum (L. infundibulum: funnel, from infundere = to pour into) + ethmoidale (Gk. ēthmoeidēs: sieve-like, from ēthmos = sieve + eidos = form)", "p": 29}, {"t": "Hiatus semilunaris", "m": "Hiatus semilunaris — opening of the infundibulum that faces the nose", "e": "hiatus (L. hiatus: gap, opening, from hiare = to gape) + semilunaris (L. semilunāris: half-moon shaped, from semi = half + luna = moon)", "p": 29}, {"t": "Bulla ethmoidalis", "m": "Bulla ethmoidalis — an anterior elevation formed by an especially large and wide ethmoidal air cell which compresses the ethmoidal infundibulum", "e": "bulla (L. bulla: bubble, rounded knob) + ethmoidalis (Gk. ēthmoeidēs: sieve-like, from ēthmos = sieve + eidos = form)", "p": 29}, {"t": "Lamina orbitalis", "m": "Orbital plate — a very thin bony plate which forms part of the medial wall of the orbit", "e": "lamina (L. lamina: thin plate, layer) + orbitalis (L. orbitālis: of the orbit, from orbita = track, circuit)", "p": 29}, {"t": "Lamina papyracea", "m": "Lamina papyracea — alternate term for orbital plate", "e": "lamina (L. lamina: thin plate, layer) + papyracea (L. papyraceus: paper-thin, from papyrus = paper)", "p": 29}, {"t": "Concha nasalis suprema", "m": "Highest, rudimentary nasal concha", "e": "concha (Gk. konchē: shell) + nasalis (L. nāsālis: of the nose, from nasus = nose) + suprema (L. suprēmus: highest, superlative of superus = above)", "p": 29}, {"t": "Concha nasalis superior", "m": "Superior nasal concha", "e": "concha (Gk. konchē: shell) + nasalis (L. nāsālis: of the nose, from nasus = nose) + superior (L. superior: upper, higher)", "p": 29}, {"t": "Concha nasalis media", "m": "Middle nasal concha", "e": "concha (Gk. konchē: shell) + nasalis (L. nāsālis: of the nose, from nasus = nose) + media (L. medius: middle)", "p": 29}, {"t": "Processus uncinatus", "m": "Uncinate process — hook-like process that extends posteriorly and inferiorly from the ethmoid bone", "e": "processus (L. prōcessus: projection, going forward, from procedere = to go forward) + uncinatus (L. uncinātus: hooked, from uncus = hook)", "p": 29}, {"t": "Concha nasalis inferior", "m": "Inferior nasal concha — independent lower nasal concha attached to the lateral nasal wall", "e": "concha (Gk. konchē: shell) + nasalis (L. nāsālis: of the nose, from nasus = nose) + inferior (L. inferior: lower)", "p": 29}, {"t": "Processus lacrimalis", "m": "Lacrimal process — process that projects anterosuperiorly from the inferior nasal concha", "e": "processus (L. prōcessus: projection, going forward) + lacrimalis (L. lacrimālis: of tears, from lacrima = tear)", "p": 29}, {"t": "Processus maxillaris", "m": "Maxillary process — lateral process which forms a part of the medial wall of the maxillary sinus", "e": "processus (L. prōcessus: projection, going forward) + maxillaris (L. maxillāris: of the jaw, from maxilla = jawbone)", "p": 29}, {"t": "Processus ethmoidalis", "m": "Ethmoidal process — united with the uncinate process of the ethmoid bone", "e": "processus (L. prōcessus: projection, going forward) + ethmoidalis (Gk. ēthmoeidēs: sieve-like, from ēthmos = sieve + eidos = form)", "p": 29}, {"t": "Os lacrimale", "m": "Lacrimal bone — bone in front of the orbital plate of the ethmoid bone", "e": "os (L. os: bone) + lacrimale (L. lacrimālis: of tears, from lacrima = tear)", "p": 29}, {"t": "Crista lacrimalis posterior", "m": "Posterior lacrimal crest — ridge forming the posterior border of the entrance into the nasolacrimal canal", "e": "crista (L. crista: crest, ridge) + lacrimalis (L. lacrimālis: of tears, from lacrima = tear) + posterior (L. posterior: behind, hinder)", "p": 29}, {"t": "Sulcus lacrimalis", "m": "Lacrimal sulcus of lacrimal bone — groove-like beginning of the nasolacrimal canal", "e": "sulcus (L. sulcus: groove, furrow) + lacrimalis (L. lacrimālis: of tears, from lacrima = tear)", "p": 29}, {"t": "Hamulus lacrimalis", "m": "Lacrimal hamulus — hook-like lower margin of the entrance into the nasolacrimal canal", "e": "hamulus (L. hamulus: small hook, diminutive of hamus = hook) + lacrimalis (L. lacrimālis: of tears, from lacrima = tear)", "p": 29}, {"t": "Fossa sacci lacrimalis", "m": "Fossa for lacrimal sac — enlarged area for the nasolacrimal sac located at the beginning of the nasolacrimal canal", "e": "fossa (L. fossa: pit, ditch, from fodere = to dig) + sacci (L. saccus: bag, sac, genitive = of the sac) + lacrimalis (L. lacrimālis: of tears, from lacrima = tear)", "p": 29}, {"t": "Os nasale", "m": "Nasal bone — bone between the right and left halves of the maxilla", "e": "os (L. os: bone) + nasale (L. nāsālis: of the nose, from nasus = nose)", "p": 29}, {"t": "Sulcus ethmoidalis", "m": "Ethmoidal sulcus — groove on the undersurface of the nasal bone for the external nasal branch of the anterior ethmoidal nerve", "e": "sulcus (L. sulcus: groove, furrow) + ethmoidalis (Gk. ēthmoeidēs: sieve-like, from ēthmos = sieve + eidos = form)", "p": 29}, {"t": "Foramina nasalia", "m": "Nasal foramina — inconstant opening for branches of the external nasal and anterior ethmoidal nerves and vessels", "e": "foramina (L. foramina: holes, plural of foramen, from forare = to bore) + nasalia (L. nāsālis: of the nose, from nasus = nose)", "p": 29}, {"t": "Vomer", "m": "Vomer — unpaired bone forming a part of the nasal septum and lying between the sphenoid, maxillary and palatine bones as well as the perpendicular plate of the ethmoid", "e": "vomer (L. vomer: plowshare, from its shape)", "p": 29}, {"t": "Ala vomeris", "m": "Ala of vomer — wing-like process for articulation with the sphenoid and palatine bones", "e": "ala (L. ala: wing) + vomeris (L. vomer: plowshare, genitive = of the vomer)", "p": 29}, {"t": "Sulcus vomeris", "m": "Sulcus vomeris — oblique groove for the nasopalatine nerve and its accompanying vessels", "e": "sulcus (L. sulcus: groove, furrow) + vomeris (L. vomer: plowshare, genitive = of the vomer)", "p": 29}, {"t": "Crista choanalis vomeris", "m": "Choanal crest of vomer — posterior edge of vomer separating the two choanae", "e": "crista (L. crista: crest, ridge) + choanalis (Gk. choanē: funnel, from chein = to pour) + vomeris (L. vomer: plowshare, genitive = of the vomer)", "p": 29}, {"t": "Pars cuneiformis vomeris", "m": "Cuneiform part of vomer — wedge-shaped part of vomer", "e": "pars (L. pars: part) + cuneiformis (L. cuneus: wedge + forma: shape) + vomeris (L. vomer: plowshare, genitive = of the vomer)", "p": 29}, {"t": "Lamina cribrosa", "m": "Cribriform plate", "e": "lamina (L. lamina: thin plate, layer) + cribrosa (L. cribrōsus: sieve-like, perforated, from cribrum = sieve)", "p": 30}, {"t": "Meatus nasi superior", "m": "Superior nasal meatus", "e": "meatus (L. meātus: passage, channel, from meare = to go, pass) + nasi (L. nāsus: nose, genitive = of the nose) + superior (L. superior: higher, upper)", "p": 30}, {"t": "Meatus nasi medius", "m": "Middle nasal meatus", "e": "meatus (L. meātus: passage, channel, from meare = to go, pass) + nasi (L. nāsus: nose, genitive = of the nose) + medius (L. medius: middle)", "p": 30}, {"t": "Meatus nasi inferior", "m": "Inferior nasal meatus", "e": "meatus (L. meātus: passage, channel) + nasi (L. nāsus: nose, genitive = of the nose) + inferior (L. inferior: lower)", "p": 30}, {"t": "Ossa faciei", "m": "Facial bones", "e": "ossa (L. os/ossis: bones) + faciei (L. facies: face, genitive form)", "p": 31}, {"t": "Corpus maxillae", "m": "Body of maxilla — central part of the maxilla enclosing the maxillary sinus", "e": "corpus (L. corpus: body) + maxillae (L. maxilla: upper jaw, genitive form, from magnus: great)", "p": 31}, {"t": "Canalis infraorbitalis", "m": "Infraorbital canal — canal for the infraorbital artery and nerve", "e": "canalis (L. canalis: canal, channel) + infra (L. infra: below, beneath) + orbitalis (L. orbitalis: of the orbit)", "p": 31}, {"t": "Sulcus infraorbitalis", "m": "Infraorbital groove — groove at the beginning of the infraorbital canal", "e": "sulcus (L. sulcus: groove, furrow) + infra (L. infra: below) + orbitalis (L. orbitalis: of the orbit)", "p": 31}, {"t": "Margo infraorbitalis", "m": "Infraorbital margin — lower margin of the orbit formed in part by the maxilla", "e": "margo (L. margo: margin, border, edge) + infra (L. infra: below) + orbitalis (L. orbitalis: of the orbit)", "p": 31}, {"t": "Facies anterior", "m": "Anterior surface", "e": "facies (L. facies: surface, face) + anterior (L. anterior: front, comparative of ante: before)", "p": 31}, {"t": "Foramen infraorbitale", "m": "Infraorbital foramen — opening of the infraorbital canal traversed by the infraorbital nerve and accompanying artery", "e": "foramen (L. foramen: opening, hole, from forare: to bore) + infra (L. infra: below) + orbitale (L. orbitalis: of the orbit)", "p": 31}, {"t": "Fossa canina", "m": "Canine fossa — depressed area below the infraorbital canal, site of origin of levator anguli oris muscle", "e": "fossa (L. fossa: pit, ditch, from fodere: to dig) + canina (L. caninus: of the dog, canine, from canis: dog)", "p": 31}, {"t": "Incisura nasalis", "m": "Nasal notch — curved margin of the bony anterior nasal (piriform) aperture", "e": "incisura (L. incisura: notch, incision, from incidere: to cut into) + nasalis (L. nasalis: of the nose, from nasus: nose)", "p": 31}, {"t": "Spina nasalis anterior", "m": "Anterior nasal spine — spinous projection at the lower boundary of the anterior nasal aperture, attachment site of the cartilaginous nasal septum", "e": "spina (L. spina: spine, thorn) + nasalis (L. nasalis: of the nose) + anterior (L. anterior: front, forward)", "p": 31}, {"t": "Sutura zygomaticomaxillaris", "m": "Zygomaticomaxillary suture — suture occasionally present from the infraorbital margin to the infraorbital foramen", "e": "sutura (L. sutura: seam, suture, from suere: to sew) + zygomatico (Gk. zygoma: yoke, cheekbone) + maxillaris (L. maxillaris: of the jaw, from maxilla: jaw)", "p": 31}, {"t": "Facies infratemporalis", "m": "Infratemporal surface — surface of the maxilla situated behind the zygomatic process", "e": "facies (L. facies: surface) + infra (L. infra: below) + temporalis (L. temporalis: of the temple, from tempora: temples of the head)", "p": 31}, {"t": "Foramina alveolaria", "m": "Alveolar foramina — small openings on the infratemporal surface for passage of nerves and vessels to the molars", "e": "foramina (L. foramina: openings, plural of foramen) + alveolaria (L. alveolaris: of the socket, from alveolus: small hollow, socket)", "p": 31}, {"t": "Canales alveolares", "m": "Alveolar canals — canals leading to the alveolar foramina for the transport of nerves and vessels for the teeth", "e": "canales (L. canales: canals, plural of canalis: channel) + alveolares (L. alveolares: of the sockets, from alveolus: small hollow)", "p": 31}, {"t": "Tuber maxillare", "m": "Tuber of maxilla — thin-walled tuberosity on the posterior wall of the maxillary sinus", "e": "tuber (L. tuber: swelling, bump, knob) + maxillare (L. maxillaris: of the jaw, from maxilla: jaw)", "p": 31}, {"t": "Facies nasalis", "m": "Nasal surface — medial surface of maxilla forming a portion of the lateral nasal wall", "e": "facies (L. facies: surface, face) + nasalis (L. nasalis: of the nose, from nasus: nose)", "p": 31}, {"t": "Crista conchalis", "m": "Conchal crest — oblique ridge for attachment of the inferior nasal concha", "e": "crista (L. crista: crest, ridge) + conchalis (L. conchalis: of the concha, from concha: shell)", "p": 31}, {"t": "Margo lacrimalis", "m": "Lacrimal margin — border of the maxilla articulating with the lacrimal bone", "e": "margo (L. margo: margin, border) + lacrimalis (L. lacrimalis: of tears, from lacrima: tear)", "p": 31}, {"t": "Hiatus maxillaris", "m": "Maxillary hiatus — large opening in the medial bony wall of the maxillary sinus", "e": "hiatus (L. hiatus: gap, opening, from hiare: to gape) + maxillaris (L. maxillaris: of the jaw, from maxilla: jaw)", "p": 31}, {"t": "Sulcus palatinus major", "m": "Greater palatine sulcus — groove at the posterior border of the maxilla combining with a similar groove on the palatine bone to form a canal for the greater palatine nerve and descending palatine artery", "e": "sulcus (L. sulcus: groove, furrow) + palatinus (L. palatinus: of the palate, from palatum: palate) + major (L. major: greater, larger)", "p": 31}, {"t": "Sulcus pterygopalatinus", "m": "Pterygopalatine sulcus — alternative name for the greater palatine sulcus", "e": "sulcus (L. sulcus: groove) + pterygo (Gk. pteryx/pterygo: wing) + palatinus (L. palatinus: of the palate)", "p": 31}, {"t": "Sinus maxillaris", "m": "Maxillary sinus — paranasal cavity within the body of the maxilla measuring over 3 cm vertically and sagittally and 2.5 cm in the frontal plane", "e": "sinus (L. sinus: cavity, bay, hollow) + maxillaris (L. maxillaris: of the jaw, from maxilla: jaw)", "p": 31}, {"t": "Processus frontalis", "m": "Frontal process of maxilla", "e": "processus (L. processus: projection, going forward, from procedere: to proceed) + frontalis (L. frontalis: of the forehead/front, from frons: forehead)", "p": 31}, {"t": "Crista lacrimalis anterior", "m": "Anterior lacrimal crest — bony ridge in front of the entrance to the nasolacrimal canal", "e": "crista (L. crista: crest, ridge) + lacrimalis (L. lacrimalis: of tears, from lacrima: tear) + anterior (L. anterior: front, forward)", "p": 31}, {"t": "Incisura lacrimalis", "m": "Lacrimal notch — crescent-shaped notch at the entrance to the nasolacrimal canal", "e": "incisura (L. incisura: notch, from incidere: to cut into) + lacrimalis (L. lacrimalis: of tears, from lacrima: tear)", "p": 31}, {"t": "Crista ethmoidalis", "m": "Ethmoidal crest — oblique ridge on the medial surface of the frontal process for the attachment of the middle nasal concha", "e": "crista (L. crista: crest, ridge) + ethmoidalis (Gk. ethmoeidēs: sieve-like, from ethmos: sieve + eidos: form)", "p": 31}, {"t": "Processus palatinus", "m": "Palatine process — horizontal plate which forms the largest part of the hard palate", "e": "processus (L. prōcessus: projection, going forward) + palatinus (L. palātīnus: of the palate, from palātum = palate)", "p": 33}, {"t": "Crista nasalis", "m": "Nasal crest — midline bony ridge for the attachment of the nasal septum", "e": "crista (L. crista: ridge, crest) + nasalis (L. nāsālis: of the nose, from nāsus = nose)", "p": 33}, {"t": "Os incisivum", "m": "Incisive bone (premaxilla) — separate fetal bone which becomes incorporated into the adult maxilla and houses the incisor teeth", "e": "os (L. os: bone) + incisivum (L. incīsīvus: cutting, from incīdere = to cut into)", "p": 33}, {"t": "Canalis incisivus", "m": "Incisive canal — paired canal from the floor of the nasal cavity that unites with the palate in the uniform fossa incisiva", "e": "canalis (L. canālis: channel, canal) + incisivus (L. incīsīvus: cutting, from incīdere = to cut into)", "p": 33}, {"t": "Fossa incisiva", "m": "Incisive fossa — uniform fossa where the incisive canal unites with the palate", "e": "fossa (L. fossa: pit, depression, from fodere = to dig) + incisiva (L. incīsīva: of cutting, from incīdere = to cut into)", "p": 33}, {"t": "Sutura incisiva", "m": "Incisive suture — suture between the premaxilla and the palatine process of the maxilla", "e": "sutura (L. sūtūra: seam, suture, from suere = to sew) + incisiva (L. incīsīva: of cutting, from incīdere = to cut into)", "p": 33}, {"t": "Spinae palatinae", "m": "Palatine spines — bony ridges along the palatine grooves", "e": "spinae (L. spīna: spine, thorn, ridge, plural) + palatinae (L. palātīnae: of the palate, plural, from palātum = palate)", "p": 33}, {"t": "Sulci palatini", "m": "Palatine grooves — grooves running from posterior to anterior along the inferior surface of the palate for passage of nerves and vessels from the greater palatine foramen", "e": "sulci (L. sulcus: groove, furrow, plural) + palatini (L. palātīnī: of the palate, plural, from palātum = palate)", "p": 33}, {"t": "Processus alveolaris", "m": "Alveolar process — crested process that bears the teeth", "e": "processus (L. prōcessus: projection, going forward) + alveolaris (L. alveolāris: of the socket, from alveus = hollow, cavity)", "p": 33}, {"t": "Arcus alveolaris", "m": "Alveolar arch — curved free border of the alveolar process", "e": "arcus (L. arcus: arch, bow) + alveolaris (L. alveolāris: of the socket, from alveus = hollow, cavity)", "p": 33}, {"t": "Alveoli dentales", "m": "Dental alveoli — sockets in the alveolar process that house the roots of the teeth", "e": "alveoli (L. alveolus: small hollow, socket, plural, diminutive of alveus = hollow) + dentales (L. dentāles: of the teeth, from dens/dentis = tooth)", "p": 33}, {"t": "Septa interalveolaria", "m": "Interalveolar septa — bony ridges between adjacent alveoli", "e": "septa (L. septum: partition, plural, from saepire = to enclose) + interalveolaria (L. inter = between + alveolāria: of the sockets, from alveus = hollow)", "p": 33}, {"t": "Septa interradicularia", "m": "Interradicular septa — bony partitions each forming compartments for the roots of a tooth", "e": "septa (L. septum: partition, plural) + interradicularia (L. inter = between + rādīcula: small root, diminutive of rādix = root)", "p": 33}, {"t": "Juga alveolaria", "m": "Alveolar juga — eminences on the external surface of the jaw produced by the protrusion of the tooth sockets", "e": "juga (L. jugum: ridge, yoke, plural) + alveolaria (L. alveolāria: of the sockets, from alveus = hollow)", "p": 33}, {"t": "Foramen incisivum", "m": "Incisive foramen — opening of the incisive canal into the oral cavity", "e": "foramen (L. forāmen: opening, hole, from forāre = to bore) + incisivum (L. incīsīvum: of cutting, from incīdere = to cut into)", "p": 33}, {"t": "Os palatinum", "m": "Palatine bone — bone forming the posterior continuation of the maxilla", "e": "os (L. os: bone) + palatinum (L. palātīnum: of the palate, from palātum = palate)", "p": 33}, {"t": "Incisura sphenopalatina", "m": "Sphenopalatine notch — part of the sphenopalatine foramen at the superior margin of the perpendicular plate", "e": "incisura (L. incīsūra: notch, incision, from incīdere = to cut into) + sphenopalatina (Gk. sphen = wedge + L. palātīna: of the palate)", "p": 33}, {"t": "Processus pyramidalis", "m": "Pyramidal process — process inserted into the pterygoid notch (fissure)", "e": "processus (L. prōcessus: projection, going forward) + pyramidalis (L. pyramidālis: pyramid-shaped, from Gk. pyramis = pyramid)", "p": 33}, {"t": "Canales palatini minores", "m": "Lesser palatine canals — canals in the pyramidal process for the lesser palatine arteries and nerves", "e": "canales (L. canālis: channel, canal, plural) + palatini (L. palātīnī: of the palate, plural) + minores (L. minōres: lesser, smaller, plural)", "p": 33}, {"t": "Processus orbitalis", "m": "Orbital process — process that projects forward and upward between the maxillary, ethmoid and sphenoid bones", "e": "processus (L. prōcessus: projection, going forward) + orbitalis (L. orbitālis: of the orbit, from orbita = track, orbit, eye socket)", "p": 33}, {"t": "Processus sphenoidalis", "m": "Sphenoidal process — process in the superior portion of the palatine bone behind the sphenopalatine notch", "e": "processus (L. prōcessus: projection, going forward) + sphenoidalis (Gk. sphen = wedge + eidos = form: wedge-shaped)", "p": 33}, {"t": "Lamina horizontalis", "m": "Horizontal plate — plate that forms the posterior portion of both the hard palate and the floor of the nasal cavity", "e": "lamina (L. lāmina: plate, layer, thin sheet) + horizontalis (L. horizontālis: horizontal, from Gk. horizōn = bounding circle, horizon)", "p": 33}, {"t": "Facies palatina", "m": "Palatine surface — surface facing the oral cavity", "e": "facies (L. faciēs: surface, face) + palatina (L. palātīna: of the palate, from palātum = palate)", "p": 33}, {"t": "Foramina palatina minora", "m": "Lesser palatine foramina — openings of the lesser palatine canals", "e": "foramina (L. forāmen: opening, hole, plural: forāmina) + palatina (L. palātīna: of the palate, plural) + minora (L. minōra: lesser, smaller, plural neuter)", "p": 33}, {"t": "Spina nasalis posterior", "m": "Posterior nasal spine — tip of the nasal crest along the median plane at the junction with the palatine bone of the opposite side", "e": "spina (L. spīna: spine, thorn, pointed projection) + nasalis (L. nāsālis: of the nose, from nāsus = nose) + posterior (L. posterior: behind, rear, from post = after)", "p": 33}, {"t": "Crista palatina", "m": "Palatine crest — ridge frequently present on the inferior surface of the horizontal plate behind its anterior margin", "e": "crista (L. crista: ridge, crest) + palatina (L. palātīna: of the palate, from palātum = palate)", "p": 33}, {"t": "Os zygomaticum", "m": "Zygomatic bone — forms a large part of the lateral wall of the orbit and a large part of the zygomatic arch", "e": "os (L. os: bone) + zygomaticum (Gk. zygōma: yoke, from zygon = yoke, bar)", "p": 35}, {"t": "Facies lateralis", "m": "Lateral surface", "e": "facies (L. faciēs: face, surface) + lateralis (L. laterālis: of the side, from latus = side)", "p": 35}, {"t": "Processus temporalis", "m": "Temporal process — posteriorly directed process which combines with the zygomatic process of the temporal bone to form the zygomatic arch", "e": "processus (L. prōcessus: projection, going forward) + temporalis (L. temporālis: of the temple, from tempora = temples)", "p": 35}, {"t": "Eminentia orbitalis", "m": "Orbital eminence — small tubercle just within the lateral margin of the orbit, gives attachment to the lateral palpebral ligament among others", "e": "eminentia (L. eminentia: prominence, projection, from eminēre = to stand out) + orbitalis (L. orbitālis: of the orbit, from orbita = track, circuit)", "p": 35}, {"t": "Tuberculum marginale", "m": "Marginal tubercle — prominence usually present on the posterior margin of the frontal process, attachment site of the temporalis muscle", "e": "tuberculum (L. tuberculum: small lump, diminutive of tuber = swelling) + marginale (L. marginālis: of the margin, from margo = edge, border)", "p": 35}, {"t": "Foramen zygomatico-orbitale", "m": "Zygomatico-orbital foramen — foramen on the orbital surface leading into a bony canal for the zygomatic nerve", "e": "foramen (L. forāmen: opening, hole, from forāre = to bore) + zygomatico (Gk. zygōma: yoke) + orbitale (L. orbitālis: of the orbit, from orbita = track)", "p": 35}, {"t": "Foramen zygomaticofaciale", "m": "Zygomaticofacial foramen — opening on the lateral surface for passage of the zygomaticofacial nerve", "e": "foramen (L. forāmen: opening, hole) + zygomatico (Gk. zygōma: yoke) + faciale (L. faciālis: of the face, from facies = face)", "p": 35}, {"t": "Foramen zygomaticotemporale", "m": "Zygomaticotemporal foramen — foramen on the temporal surface for passage of the zygomaticotemporal nerve", "e": "foramen (L. forāmen: opening, hole) + zygomatico (Gk. zygōma: yoke) + temporale (L. temporālis: of the temple, from tempora = temples)", "p": 35}, {"t": "Mandibula", "m": "Mandible — lower jaw bone", "e": "mandibula (L. mandibula: jaw, from mandere = to chew)", "p": 35}, {"t": "Corpus mandibulae", "m": "Body of mandible — horizontal part of the mandible to which the mandibular rami are attached", "e": "corpus (L. corpus: body) + mandibulae (L. mandibula: jaw, genitive form, from mandere = to chew)", "p": 35}, {"t": "Basis mandibulae", "m": "Base of mandible — lower portion of the body of the mandible minus the alveolar part", "e": "basis (Gk./L. basis: base, foundation) + mandibulae (L. mandibula: jaw, genitive form, from mandere = to chew)", "p": 35}, {"t": "Symphysis mandibulae", "m": "Symphysis menti — median connective tissue bridge between the right and left halves of the mandible, becomes ossified in the first postnatal year", "e": "symphysis (Gk. symphysis: growing together, from syn = together + physis = growth) + mandibulae (L. mandibula: jaw, genitive form)", "p": 35}, {"t": "Protuberantia mentalis", "m": "Mental protuberance — prominence of the chin", "e": "protuberantia (L. protuberantia: bulging out, from pro = forward + tuber = swelling) + mentalis (L. mentālis: of the chin, from mentum = chin)", "p": 35}, {"t": "Tuberculum mentale", "m": "Mental tubercle — prominence on either side of the mental protuberance", "e": "tuberculum (L. tuberculum: small lump, diminutive of tuber = swelling) + mentale (L. mentālis: of the chin, from mentum = chin)", "p": 35}, {"t": "Foramen mentale", "m": "Mental foramen — opening for the mental nerve below the second premolar, pressure point for the third division of the trigeminal nerve", "e": "foramen (L. forāmen: opening, hole, from forāre = to bore) + mentale (L. mentālis: of the chin, from mentum = chin)", "p": 35}, {"t": "Linea obliqua", "m": "Oblique line — oblique ridge extending from the mandibular ramus to the external surface of the body of the mandible", "e": "linea (L. līnea: line, from linum = thread) + obliqua (L. oblīquus: slanting, oblique)", "p": 35}, {"t": "Fossa digastrica", "m": "Digastric fossa — pea-to-bean-sized depression on the lower internal surface of the body of the mandible near the symphysis, for attachment of the digastric muscle", "e": "fossa (L. fossa: pit, ditch, from fodere = to dig) + digastrica (Gk. di = two + gaster = belly, referring to the two-bellied muscle)", "p": 35}, {"t": "Spina mentalis", "m": "Mental spine — bony elevation at the back of the symphysis projecting toward the tongue, origin of the genioglossus and geniohyoid muscles", "e": "spina (L. spīna: spine, thorn, pointed projection) + mentalis (L. mentālis: of the chin, from mentum = chin)", "p": 35}, {"t": "Linea mylohyoidea", "m": "Mylohyoid line — oblique ridge extending from the posterosuperior to anteroinferior aspect of the body of the mandible, origin of the mylohyoid muscle, posterior end is origin of mylopharyngeal part of the superior constrictor muscle of the pharynx", "e": "linea (L. līnea: line) + mylohyoidea (Gk. mylos = mill, molar + hyoeides = U-shaped, from letter upsilon)", "p": 35}, {"t": "Fovea sublingualis", "m": "Sublingual fovea — depression for the sublingual gland on the anterior part of the mandible above the mylohyoid line", "e": "fovea (L. fovea: small pit, depression) + sublingualis (L. sub = under + lingua = tongue)", "p": 35}, {"t": "Fovea submandibularis", "m": "Submandibular fovea — depression for the submandibular gland on the posterior half of the body of the mandible below the mylohyoid line", "e": "fovea (L. fovea: small pit, depression) + submandibularis (L. sub = under + mandibula = jaw)", "p": 35}, {"t": "Pars alveolaris", "m": "Alveolar part — pectinate process on the base of the mandible that houses the roots of the teeth", "e": "pars (L. pars: part, portion) + alveolaris (L. alveolāris: of a hollow, from alveolus = small hollow, diminutive of alveus = hollow)", "p": 35}, {"t": "Ramus mandibulae", "m": "Ramus of mandible — process that projects superiorly from the mandible", "e": "ramus (L. rāmus: branch) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Angulus mandibulae", "m": "Angle of mandible — angle between the body and ramus of the mandible", "e": "angulus (L. angulus: angle, corner) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Tuberositas masseterica", "m": "Masseteric tuberosity — roughened area on the external surface of the angle of the mandible", "e": "tuberositas (L. tuberōsitās: knobby projection, from tuber = swelling) + masseterica (Gk. massētēr: chewer, from massasthai = to chew)", "p": 37}, {"t": "Tuberositas pterygoidea", "m": "Pterygoid tuberosity — roughened area on the internal surface near the angle of the mandible", "e": "tuberositas (L. tuberōsitās: knobby projection, from tuber = swelling) + pterygoidea (Gk. pteryx: wing + eidos: form, shape)", "p": 37}, {"t": "Foramen mandibulae", "m": "Mandibular foramen — opening on the inner aspect of the mandibular ramus leading into the mandibular canal", "e": "foramen (L. forāmen: opening, hole, from forare = to bore) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Lingula mandibulae", "m": "Lingula of mandible — bony projection medial to the mandibular foramen", "e": "lingula (L. lingula: little tongue, diminutive of lingua = tongue) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Canalis mandibulae", "m": "Mandibular canal — bony canal within the mandible for passage of the inferior alveolar artery and nerve", "e": "canalis (L. canālis: channel, canal, from canna = reed, pipe) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Sulcus mylohyoideus", "m": "Mylohyoid groove — groove extending forward and downward from the mandibular foramen", "e": "sulcus (L. sulcus: furrow, groove) + mylohyoideus (Gk. mylos: mill, molar + hyoeides: U-shaped, from hy = upsilon letter + eidos = form)", "p": 37}, {"t": "Processus coronoideus", "m": "Coronoid process — muscular process separated from the posteriorly situated condylar process by the mandibular notch", "e": "processus (L. prōcessus: projection, going forward) + coronoideus (Gk. korōnē: crown, curved thing + eidos: form, shape)", "p": 37}, {"t": "Crista temporalis", "m": "Temporal crest — sharp bony ridge at the anterior margin of the coronoid process for attachment of the temporalis muscle", "e": "crista (L. crista: crest, ridge) + temporalis (L. temporālis: of the temple, from tempus = temple of the head)", "p": 37}, {"t": "Incisura mandibulae", "m": "Mandibular notch — indentation between the condylar and coronoid processes", "e": "incisura (L. incisūra: notch, incision, from incidere = to cut into) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Processus condylaris", "m": "Condylar process — articular process of the mandible", "e": "processus (L. prōcessus: projection, going forward) + condylaris (Gk. kondylos: knuckle, rounded prominence)", "p": 37}, {"t": "Caput mandibulae", "m": "Head of mandible — articular head of the mandible", "e": "caput (L. caput: head) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Collum mandibulae", "m": "Neck of mandible — narrow segment below the head of the mandible", "e": "collum (L. collum: neck) + mandibulae (L. mandibula: jaw, from mandere = to chew)", "p": 37}, {"t": "Fovea pterygoidea", "m": "Pterygoid fovea — anteromedial pit below the head of the mandible for attachment of the lateral pterygoid muscle", "e": "fovea (L. fovea: pit, small depression) + pterygoidea (Gk. pteryx: wing + eidos: form, shape)", "p": 37}, {"t": "Os hyoideum", "m": "Hyoid bone — starts to ossify before birth", "e": "os (L. os: bone) + hyoideum (Gk. hyoeides: U-shaped or upsilon-shaped, from hy = Greek letter upsilon + eidos = form)", "p": 37}, {"t": "Corpus ossis hyoidea", "m": "Body of hyoid — anterior segment between the right and left horns", "e": "corpus (L. corpus: body) + ossis (L. os, ossis: bone) + hyoidea (Gk. hyoeides: U-shaped, from hy = upsilon + eidos = form)", "p": 37}, {"t": "Cornu minus", "m": "Lesser horn (cornu) — lesser horn of the hyoid", "e": "cornu (L. cornu: horn) + minus (L. minus: lesser, smaller)", "p": 37}, {"t": "Cornu majus", "m": "Greater horn (cornu) — greater horn of the hyoid", "e": "cornu (L. cornu: horn) + majus (L. majus: greater, larger)", "p": 37}, {"t": "Cranium", "m": "Skull", "e": "cranium (Gk. kranion: skull, from kara = head)", "p": 37}, {"t": "Cavitas cranii", "m": "Cranial cavity", "e": "cavitas (L. cavitās: hollowness, cavity, from cavus = hollow) + cranii (Gk./L. cranium: skull)", "p": 37}, {"t": "Pericranium", "m": "Periosteum of the external skull surface", "e": "peri (Gk. peri: around) + cranium (Gk. kranion: skull)", "p": 37}, {"t": "Lamina externa", "m": "External table (lamina) — outer layer of bone comprising the skull cap (calvaria)", "e": "lamina (L. lamina: thin plate, layer) + externa (L. externus: outer, external)", "p": 37}, {"t": "Diploë", "m": "Diploë — layer of spongy bone between the external and internal tables, especially in the cranial bones", "e": "diploë (Gk. diploē: a fold, doubling, from diploos = double)", "p": 37}, {"t": "Canales diploici", "m": "Diploic canals — large venous canals in the diploë", "e": "canales (L. canālis: channel, canal, from canna = reed) + diploici (Gk. diploē: doubling, double layer)", "p": 37}, {"t": "Lamina interna", "m": "Internal table (lamina) — inner layer of bone comprising the skull cap", "e": "lamina (L. lamina: thin plate, layer) + interna (L. internus: inner, internal)", "p": 37}, {"t": "Foveolae granulares", "m": "Granular pits (pacchionian granulations) — small pits occupied by the arachnoid granulations", "e": "foveolae (L. foveola: small pit, diminutive of fovea = pit) + granulares (L. granulum: small grain, from granum = grain)", "p": 37}, {"t": "Norma verticalis", "m": "Norma verticalis (calvaria) — normal outline of skull cap as viewed from above", "e": "norma (L. norma: rule, pattern, outline) + verticalis (L. verticālis: vertical, from vertex = highest point, crown)", "p": 37}, {"t": "Calvaria", "m": "Calvaria — skull cap / normal outline of skull cap as viewed from above", "e": "calvaria (L. calvāria: skull, scalp, from calvus = bald)", "p": 37}, {"t": "Vertex", "m": "Crown of head — highest point of the vault of the skull", "e": "vertex (L. vertex: highest point, crown, from vertere = to turn)", "p": 37}, {"t": "Frons", "m": "Forehead — front of calvaria above the eyes", "e": "frons (L. frons: forehead, brow, front)", "p": 37}, {"t": "Norma facialis", "m": "Norma facialis — normal outline of skull as viewed from in front", "e": "norma (L. norma: rule, pattern, outline) + facialis (L. faciālis: of the face, from facies = face)", "p": 37}, {"t": "Norma lateralis", "m": "Lateral view of the skull (lateral norm)", "e": "norma (L. norma: rule, pattern, standard view) + lateralis (L. lateralis: of the side, from latus = side)", "p": 38}, {"t": "Gonion", "m": "The most lateral point on the mandibular angle", "e": "gonion (Gk. gōnia: angle, corner)", "p": 38}, {"t": "Pterygoid", "m": "Pterygoid — relating to the pterygoid process", "e": "pterygoid (Gk. pteryx: wing + eidos: form/shape — wing-shaped)", "p": 38}, {"t": "Basis cranii interna", "m": "Internal base of cranium — superior aspect of the skull base and its cranial cavities", "e": "basis (Gk. basis: base, foundation) + cranii (L. cranium, from Gk. kranion: skull) + interna (L. internus: inner, internal)", "p": 39}, {"t": "Fossa cranii anterior", "m": "Anterior cranial fossa — cranial cavity extending from the wall of the frontal bone to the lesser wing of the sphenoid", "e": "fossa (L. fossa: pit, ditch, from fodere = to dig) + cranii (L. cranium, from Gk. kranion: skull) + anterior (L. anterior: before, in front)", "p": 39}, {"t": "Fossa cranii media", "m": "Middle cranial fossa — cranial cavity extending from the lesser wing of the sphenoid to the petrous ridge of the temporal bone", "e": "fossa (L. fossa: pit, ditch) + cranii (L. cranium, from Gk. kranion: skull) + media (L. medius: middle)", "p": 39}, {"t": "Fossa cranii posterior", "m": "Posterior cranial fossa — cranial cavity extending from the petrous ridge to the posterior wall of the skull", "e": "fossa (L. fossa: pit, ditch) + cranii (L. cranium, from Gk. kranion: skull) + posterior (L. posterior: behind, later)", "p": 39}, {"t": "Impressiones digitatae", "m": "Digital impressions — flat indentations corresponding to the cerebral gyri which produce them", "e": "impressiones (L. impressio: impression, imprint, from imprimere = to press into) + digitatae (L. digitatus: finger-like, from digitus = finger)", "p": 39}, {"t": "Sulci venosi", "m": "Venous grooves — grooves for meningeal veins occasionally present on the inner wall of the parietal bone", "e": "sulci (L. sulcus: groove, furrow) + venosi (L. venosus: of veins, from vena = vein)", "p": 39}, {"t": "Sulci arteriales", "m": "Arterial grooves — grooves on the inner wall of the skull produced primarily by the middle meningeal artery and its branches", "e": "sulci (L. sulcus: groove, furrow) + arteriales (L. arterialis: of arteries, from arteria, from Gk. arteria = artery)", "p": 39}, {"t": "Ossa suturalia", "m": "Sutural (wormian) bones — bones occasionally present in cranial sutures", "e": "ossa (L. os: bone) + suturalia (L. suturalis: of a suture, from sutura = seam, from suere = to sew)", "p": 39}, {"t": "Fossa temporalis", "m": "Temporal fossa — area between the temporal line and the zygomatic arch", "e": "fossa (L. fossa: pit, ditch) + temporalis (L. temporalis: of the temple, from tempora = temples of the head)", "p": 39}, {"t": "Arcus zygomaticus", "m": "Zygomatic arch — bony arch formed by the union of the zygomatic process of the temporal bone with the temporal process of the zygomatic bone", "e": "arcus (L. arcus: arch, bow) + zygomaticus (Gk. zygoma: yoke, cheekbone, from zygon = yoke)", "p": 39}, {"t": "Fossa infratemporalis", "m": "Infratemporal fossa — inferior continuation of the temporal fossa located between the ramus of the mandible and the greater wing of the sphenoid", "e": "fossa (L. fossa: pit, ditch) + infratemporalis (L. infra = below + temporalis = of the temple)", "p": 39}, {"t": "Fossa pterygopalatina", "m": "Pterygopalatine fossa — the part of the infratemporal fossa just lateral to the sphenopalatine foramen and the perpendicular lamina of the palatine bone", "e": "fossa (L. fossa: pit, ditch) + pterygo- (Gk. pteryx: wing) + palatina (L. palatinus: of the palate, from palatum = palate)", "p": 39}, {"t": "Fissura pterygomaxillaris", "m": "Pterygomaxillary fissure — cleft located between the maxilla and the lateral pterygoid plate", "e": "fissura (L. fissura: cleft, crack, from findere = to split) + pterygo- (Gk. pteryx: wing) + maxillaris (L. maxillaris: of the jaw, from maxilla = jaw)", "p": 39}, {"t": "Norma basilaris", "m": "Normal outline of skull base as viewed from below — external base of cranium", "e": "norma (L. norma: rule, pattern, outline) + basilaris (L. basilaris: of the base, from basis, from Gk. basis = base)", "p": 39}, {"t": "Basis cranii externa", "m": "External base of cranium — normal outline of skull base as viewed from below", "e": "basis (Gk. basis: base, foundation) + cranii (L. cranium, from Gk. kranion: skull) + externa (L. externus: outer, external)", "p": 39}, {"t": "Canalis palatinus major", "m": "Greater palatine canal — canal formed by the palatine bone and maxilla for the descending palatine artery and the greater palatine nerve", "e": "canalis (L. canalis: channel, canal, from canna = reed, pipe) + palatinus (L. palatinus: of the palate) + major (L. major: greater, larger)", "p": 39}, {"t": "Foramen jugulare", "m": "Jugular foramen — fibrous, divided opening between the occipital and temporal bones; point where the sigmoid sinus and inferior petrosal sinus unite", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + jugulare (L. jugularis: of the throat/jugular, from jugulum = throat, collarbone)", "p": 39}, {"t": "Fissura sphenopetrosa", "m": "Sphenopetrosal fissure — medial continuation of the petrosquamous fissure", "e": "fissura (L. fissura: cleft, crack) + spheno- (Gk. sphen: wedge) + petrosa (L. petrosus: rocky, stony, from petra = rock)", "p": 39}, {"t": "Fissura petro-occipitalis", "m": "Petro-occipital fissure — cleft between the petrous temporal and occipital bones extending medially from the jugular foramen", "e": "fissura (L. fissura: cleft, crack) + petro- (L. petrosus: rocky, from petra = rock) + occipitalis (L. occipitalis: of the back of the head, from ob = against + caput = head)", "p": 39}, {"t": "Foramen lacerum", "m": "Foramen lacerum — irregular, fibrocartilage-covered opening in the middle cranial fossa between the apex of the petrous part of the temporal bone and the sphenoid bone", "e": "foramen (L. foramen: opening, hole) + lacerum (L. lacer: torn, jagged, from lacerare = to tear)", "p": 39}, {"t": "Palatum osseum", "m": "Bony (hard) palate", "e": "palatum (L. palatum: palate, roof of the mouth) + osseum (L. osseus: bony, of bone, from os = bone)", "p": 39}, {"t": "Foramen palatinum majus", "m": "Greater palatine foramen — opening of the greater palatine canal located near the posterior margin of the bony palate between the palatine bone and maxilla", "e": "foramen (L. foramen: opening, hole) + palatinum (L. palatinus: of the palate) + majus (L. major: greater, larger)", "p": 39}, {"t": "Foramina incisiva", "m": "Incisive foramina — two or four openings for the incisive canals", "e": "foramina (L. foramen, pl. foramina: openings, holes) + incisiva (L. incisivus: cutting, from incidere = to cut into)", "p": 39}, {"t": "Canalis palatovaginalis", "m": "Palatovaginal canal — small canal between the vaginal process of the sphenoid and palatine bone for branches of the maxillary artery and the pterygopalatine ganglion", "e": "canalis (L. canalis: channel, canal) + palato- (L. palatum: palate) + vaginalis (L. vaginalis: sheath-like, from vagina = sheath)", "p": 39}, {"t": "Canalis vomerovaginalis", "m": "Vomerovaginal canal — small canal occasionally present between the vomer and the vaginal process of the sphenoid for transmission of a branch of the sphenopalatine artery", "e": "canalis (L. canalis: channel, canal) + vomero- (L. vomer: plowshare, the vomer bone) + vaginalis (L. vaginalis: sheath-like, from vagina = sheath)", "p": 39}, {"t": "Canalis vomerorostralis", "m": "Vomerorostral canal — small canal between the vomer and sphenoidal rostrum", "e": "canalis (L. canalis: channel, canal) + vomero- (L. vomer: plowshare, the vomer bone) + rostralis (L. rostralis: of the beak/rostrum, from rostrum = beak, snout)", "p": 39}, {"t": "Cavitas nasi", "m": "Nasal cavity", "e": "cavitas (L. cavitās: hollowness, cavity, from cavus = hollow) + nasi (L. nasus, gen. nasi: nose)", "p": 41}, {"t": "Septum nasi osseum", "m": "Bony nasal septum — bony partition formed by the vomer and the perpendicular plate of the ethmoid", "e": "septum (L. septum: partition, fence, from saepire = to enclose) + nasi (L. nasus, gen. nasi: nose) + osseum (L. osseus: bony, of bone, from os = bone)", "p": 41}, {"t": "Apertura piriformis", "m": "Piriform aperture — pear-shaped anterior nasal opening in the bony skull", "e": "apertura (L. apertura: opening, from aperire = to open) + piriformis (L. pirum = pear + forma = shape; pear-shaped)", "p": 41}, {"t": "Nasalis anterior", "m": "Anterior nasal (opening)", "e": "nasalis (L. nasalis: of the nose, from nasus = nose) + anterior (L. anterior: front, forward, comparative of ante = before)", "p": 41}, {"t": "Meatus nasalis superior", "m": "Superior nasal meatus — space above the middle nasal concha", "e": "meatus (L. meātus: passage, channel, from meare = to go, pass) + nasalis (L. nasalis: of the nose) + superior (L. superior: upper, higher, comparative of superus = above)", "p": 41}, {"t": "Meatus nasalis medius", "m": "Middle nasal meatus — space between the middle and inferior nasal conchae", "e": "meatus (L. meātus: passage, channel) + nasalis (L. nasalis: of the nose) + medius (L. medius: middle, in the middle)", "p": 41}, {"t": "Meatus nasalis inferior", "m": "Inferior nasal meatus — space below the inferior nasal concha", "e": "meatus (L. meātus: passage, channel) + nasalis (L. nasalis: of the nose) + inferior (L. inferior: lower, comparative of inferus = below)", "p": 41}, {"t": "Canalis nasolacrimalis", "m": "Nasolacrimal canal — passageway for the nasolacrimal duct which opens beneath the inferior nasal concha", "e": "canalis (L. canālis: canal, channel, pipe) + naso- (L. nasus: nose) + lacrimalis (L. lacrima: tear; lacrimalis: of tears)", "p": 41}, {"t": "Recessus sphenoethmoidalis", "m": "Sphenoethmoidal recess — space above the superior nasal concha", "e": "recessus (L. recessus: recess, withdrawal, from recedere = to withdraw) + sphenoethmoidalis (Gk. sphen = wedge + Gk. ethmos = sieve; combined: sphenoid + ethmoid + -alis = pertaining to)", "p": 41}, {"t": "Meatus nasopharyngeus", "m": "Nasopharyngeal meatus — part of the nasal cavity that extends from the posterior margin of the conchae to the choana", "e": "meatus (L. meātus: passage, channel) + nasopharyngeus (L. nasus = nose + Gk. pharynx = throat; nasopharyngeal)", "p": 41}, {"t": "Choanae", "m": "Posterior apertures of the nose — bilateral openings between the nasal cavity and the nasopharynx", "e": "choanae (Gk. choanē: funnel; pl. choanae: funnel-shaped openings)", "p": 41}, {"t": "Foramen sphenopalatinum", "m": "Sphenopalatine foramen — superior opening in the pterygopalatine fossa leading into the nasal cavity", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + sphenopalatinum (Gk. sphen = wedge + L. palatum = palate; sphenopalatine)", "p": 41}, {"t": "Orbita", "m": "Orbit — bony cavity that contains the eyeball", "e": "orbita (L. orbita: track, orbit, path of a wheel, from orbis = circle, wheel)", "p": 41}, {"t": "Aditus orbitalis", "m": "Orbital aditus — anterior opening (base) of the orbit", "e": "aditus (L. aditus: entrance, approach, from adire = to go to) + orbitalis (L. orbitalis: of the orbit, from orbita = orbit)", "p": 41}, {"t": "Margo orbitalis", "m": "Orbital margin — bony margin of orbit", "e": "margo (L. margo: border, margin, edge) + orbitalis (L. orbitalis: of the orbit)", "p": 41}, {"t": "Margo lateralis", "m": "Lateral margin — lateral border of orbital aditus", "e": "margo (L. margo: border, margin) + lateralis (L. lateralis: of the side, from latus = side)", "p": 41}, {"t": "Margo medialis", "m": "Medial margin — medial border of orbital aditus", "e": "margo (L. margo: border, margin) + medialis (L. medialis: of the middle, from medius = middle)", "p": 41}, {"t": "Paries superior", "m": "Superior wall — roof of the orbit", "e": "paries (L. pariēs: wall) + superior (L. superior: upper, higher)", "p": 41}, {"t": "Paries inferior", "m": "Inferior wall — floor of the orbit", "e": "paries (L. pariēs: wall) + inferior (L. inferior: lower)", "p": 41}, {"t": "Paries lateralis", "m": "Lateral wall of orbit", "e": "paries (L. pariēs: wall) + lateralis (L. lateralis: of the side, from latus = side)", "p": 41}, {"t": "Paries medialis", "m": "Medial wall of orbit", "e": "paries (L. pariēs: wall) + medialis (L. medialis: of the middle, from medius = middle)", "p": 41}, {"t": "Foramen ethmoidale anterius", "m": "Anterior ethmoidal foramen — anterior opening in the medial wall of the orbit between the frontal and ethmoid bones for passage of the anterior ethmoidal nerve and vessels from the anterior cranial fossa", "e": "foramen (L. foramen: opening, hole) + ethmoidale (Gk. ethmos = sieve + -oeides = like; ethmoid) + anterius (L. anterius: more anterior, from ante = before)", "p": 41}, {"t": "Foramen ethmoidale posterius", "m": "Posterior ethmoidal foramen — posterior opening in the medial wall of the orbit between the frontal and ethmoid bones for passage of the posterior ethmoidal vessels and nerve", "e": "foramen (L. foramen: opening, hole) + ethmoidale (Gk. ethmos = sieve + -oeides = like; ethmoid) + posterius (L. posterius: more posterior, from post = behind, after)", "p": 41}, {"t": "Fissura orbitalis inferior", "m": "Inferior orbital fissure — cleft between the greater wing of the sphenoid and the orbital surface of the maxilla for passage of the zygomatic nerve and the infraorbital nerve and vessels", "e": "fissura (L. fissura: cleft, fissure, from findere = to split) + orbitalis (L. orbitalis: of the orbit) + inferior (L. inferior: lower)", "p": 41}, {"t": "Norma occipitalis", "m": "Normal outline of skull viewed from behind", "e": "norma (L. norma: rule, pattern, standard, outline view) + occipitalis (L. occiput, occipitis: back of the head; from ob = against + caput = head)", "p": 41}, {"t": "Lambda", "m": "Junction point of the lambdoid and sagittal sutures", "e": "lambda (Gk. lambda: the Greek letter Λ, used because the lambdoid suture resembles the shape of the letter)", "p": 41}, {"t": "Fonticuli cranii", "m": "Cranial fontanelles — membrane-covered gaps between the developing skull bones (fetal and infant)", "e": "fonticuli (L. fonticulus, pl. fonticuli: little fountain, diminutive of fons = spring, fountain) + cranii (L. cranium, gen. cranii: skull, from Gk. kranion = skull)", "p": 41}, {"t": "Fonticulus anterior", "m": "Anterior fontanelle — rhomboid, large space located anteriorly in the sagittal suture between the temporal and frontal anlagen; obliterated in the 2nd and 3rd postnatal year", "e": "fonticulus (L. fonticulus: little fountain, diminutive of fons = spring, source) + anterior (L. anterior: front, forward, comparative of ante = before)", "p": 41}, {"t": "Fonticulus posterior", "m": "Posterior fontanelle — small triangular gap at the junction of the sagittal and lamboid sutures, i.e., between the paired temporal bones and the occipital bone; closes within 3 months after birth", "e": "fonticulus (L. fonticulus: little fountain, diminutive of fons = spring, source) + posterior (L. posterior: behind, comparative of posterus = coming after, from post = behind)", "p": 41}, {"t": "Fonticulus sphenoidalis anterolateralis", "m": "Sphenoidal (anterolateral) fontanelle — lateral gap between the frontal, parietal, temporal and sphenoid bones, i.e., at the site of the pterion", "e": "fonticulus (L. fonticulus: little fountain) + sphenoidalis (Gk. sphen = wedge + -oeides = like; sphenoid) + anterolateralis (L. ante = before + latus = side; anterolateral)", "p": 41}, {"t": "Fonticulus mastoideus posterolateralis", "m": "Mastoid (posterolateral) fontanelle — lateral space between the parietal, occipital and temporal bones, i.e., at the site of the asterion", "e": "fonticulus (L. fonticulus: little fountain) + mastoideus (Gk. mastos = breast + -oeides = like; mastoid, breast-shaped) + posterolateralis (L. posterus = coming after + latus = side; posterolateral)", "p": 41}, {"t": "Skeleton appendiculare", "m": "Appendicular skeleton — bones of the limbs", "e": "skeleton (Gk. skeletos: dried up, dried body) + appendiculare (L. appendiculāris: relating to an appendage, from appendere = to hang upon)", "p": 43}, {"t": "Ossa membri superioris", "m": "Bones of the upper limb", "e": "ossa (L. os/ossa: bones) + membri (L. membrum: limb, member, genitive) + superioris (L. superior: upper, higher, genitive)", "p": 43}, {"t": "Cingulum membri superioris", "m": "Shoulder (pectoral) girdle", "e": "cingulum (L. cingulum: girdle, belt, from cingere = to gird) + membri (L. membrum: limb, genitive) + superioris (L. superior: upper, genitive)", "p": 43}, {"t": "Cingulum pectorale", "m": "Pectoral girdle", "e": "cingulum (L. cingulum: girdle, belt) + pectorale (L. pectorālis: of the chest, from pectus = chest)", "p": 43}, {"t": "Scapula", "m": "Shoulder blade", "e": "scapula (L. scapula: shoulder blade, possibly from Gk. skaptein = to dig, due to spade-like shape)", "p": 43}, {"t": "Facies costalis (anterior)", "m": "Costal (anterior) surface — scapular surface facing the ribs", "e": "facies (L. faciēs: face, surface, appearance) + costalis (L. costālis: of the ribs, from costa = rib) + anterior (L. anterior: front, fore, from ante = before)", "p": 43}, {"t": "Fossa subscapularis", "m": "Subscapular fossa — concavity on the costal surface", "e": "fossa (L. fossa: pit, ditch, hollow, from fodere = to dig) + subscapularis (L. sub = under + scapula = shoulder blade, so: beneath the scapula)", "p": 43}, {"t": "Facies posterior", "m": "Posterior surface — scapular surface facing the skin of the back", "e": "facies (L. faciēs: face, surface) + posterior (L. posterior: behind, back, from post = after, behind)", "p": 43}, {"t": "Spina scapulae", "m": "Spine of scapula — long bony ridge on the posterior scapular surface extending into the acromion", "e": "spina (L. spina: spine, thorn, ridge) + scapulae (L. scapula: shoulder blade, genitive)", "p": 43}, {"t": "Fossa supraspinata", "m": "Supraspinous fossa — fossa that extends from above the spinous process to the superior margin of the scapula", "e": "fossa (L. fossa: pit, hollow) + supraspinata (L. supra = above + spina = spine, so: above the spine)", "p": 43}, {"t": "Fossa supraspinosa", "m": "Supraspinous fossa (alternate Latin form)", "e": "fossa (L. fossa: pit, hollow) + supraspinosa (L. supra = above + spinosa from spina = spine)", "p": 43}, {"t": "Fossa infraspinata", "m": "Infraspinous fossa — fossa that extends from below the spinous process to the inferior angle of the scapula", "e": "fossa (L. fossa: pit, hollow) + infraspinata (L. infra = below + spina = spine, so: below the spine)", "p": 43}, {"t": "Fossa infraspinosa", "m": "Infraspinous fossa (alternate Latin form)", "e": "fossa (L. fossa: pit, hollow) + infraspinosa (L. infra = below + spinosa from spina = spine)", "p": 43}, {"t": "Acromion", "m": "Acromion — free end of the scapular spine projecting over the head of the humerus", "e": "acromion (Gk. akrōmion: tip of the shoulder, from akros = topmost, tip + ōmos = shoulder)", "p": 43}, {"t": "Facies articularis acromii", "m": "Acromial articular surface — articular facet for the clavicle", "e": "facies (L. faciēs: surface) + articularis (L. articulāris: of a joint, from articulus = joint) + acromii (Gk./L. acromion: tip of shoulder, genitive)", "p": 43}, {"t": "Angulus acromialis", "m": "Acromial angle — sharp bend at the site where the spine of the scapula becomes continuous with the lateral margin of the acromion", "e": "angulus (L. angulus: angle, corner) + acromialis (L./Gk. acromialis: of the acromion, from akros = tip + ōmos = shoulder)", "p": 43}, {"t": "Margo superior", "m": "Superior margin — upper border of the scapula", "e": "margo (L. margo: margin, border) + superior (L. superior: upper, higher)", "p": 43}, {"t": "Incisura scapulae", "m": "Scapular notch — indentation in the superior margin of the scapula just medial to the coracoid process", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + scapulae (L. scapula: shoulder blade, genitive)", "p": 43}, {"t": "Incisura scapularis", "m": "Scapular notch (alternate Latin form)", "e": "incisura (L. incisura: notch, cut) + scapularis (L. scapulāris: of the shoulder blade)", "p": 43}, {"t": "Angulus inferior", "m": "Inferior angle — lower angle of the scapula", "e": "angulus (L. angulus: angle, corner) + inferior (L. inferior: lower)", "p": 43}, {"t": "Angulus lateralis", "m": "Lateral angle — lateral angle of the scapula bearing the glenoid cavity", "e": "angulus (L. angulus: angle, corner) + lateralis (L. laterālis: of the side, lateral)", "p": 43}, {"t": "Angulus superior", "m": "Superior angle — upper medial angle of the scapula", "e": "angulus (L. angulus: angle, corner) + superior (L. superior: upper, higher)", "p": 43}, {"t": "Cavitas glenoidalis", "m": "Glenoid cavity — articular cavity of the shoulder", "e": "cavitas (L. cavitās: cavity, hollow, from cavus = hollow) + glenoidalis (Gk. glēnoeidēs: socket-shaped, from glēnē = socket, cavity + eidos = form, shape)", "p": 43}, {"t": "Tuberculum infraglenoidale", "m": "Infraglenoid tubercle — small tubercle at the inferior margin of the glenoid cavity for the origin of the long head of the triceps", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = swelling) + infraglenoidale (L. infra = below + Gk. glēnē = socket + L. -oidalis = resembling, so: below the glenoid)", "p": 43}, {"t": "Tuberculum supraglenoidale", "m": "Supraglenoid tubercle — small tubercle at the superior margin of the glenoid cavity for the origin of the long head of the biceps", "e": "tuberculum (L. tuberculum: small swelling) + supraglenoidale (L. supra = above + Gk. glēnē = socket + L. -oidalis = resembling, so: above the glenoid)", "p": 43}, {"t": "Collum scapulae", "m": "Neck of scapula — the portion of the scapula situated medial to the margin of the glenoid cavity", "e": "collum (L. collum: neck) + scapulae (L. scapula: shoulder blade, genitive)", "p": 43}, {"t": "Processus coracoideus", "m": "Coracoid process — hook-shaped process projecting anteriorly from the superior margin of the scapula just lateral to the scapular notch", "e": "processus (L. prōcessus: projection, going forward, from procedere = to go forward) + coracoideus (Gk. korakoeidēs: crow-shaped, from korax = crow + eidos = form, shape)", "p": 43}, {"t": "Clavicula", "m": "Clavicle — collar bone", "e": "clavicula (L. clāvicula: small key, little key, diminutive of clavis = key, from its rotation like a key)", "p": 43}, {"t": "Extremitas sternalis", "m": "Extremitas sternalis — sternal (medial) end of the clavicle facing the sternum", "e": "extremitas (L. extrēmitās: extremity, end, tip, from extremus = outermost) + sternalis (L. sternālis: of the sternum, from Gk. sternon = chest, breastbone)", "p": 43}, {"t": "Facies articularis sternalis", "m": "Sternal articular surface — articular surface on the medial end of clavicle for articulation with the sternum", "e": "facies (L. faciēs: surface) + articularis (L. articulāris: of a joint) + sternalis (L. sternālis: of the sternum, from Gk. sternon = breastbone)", "p": 43}, {"t": "Impressio ligamenti costoclavicularis", "m": "Impression for the costoclavicular ligament — roughened area on the inferior surface of the clavicle near the sternal end for attachment of the costoclavicular ligament", "e": "impressio (L. impressio: impression, indentation, from imprimere = to press into) + ligamenti (L. ligamentum: ligament, band, from ligare = to bind, genitive) + costoclavicularis (L. costa = rib + clavicula = clavicle, so: of the rib and clavicle)", "p": 43}, {"t": "Corpus claviculae", "m": "Body (shaft) of clavicle — middle portion of the clavicle", "e": "corpus (L. corpus: body, shaft) + claviculae (L. clāvicula: clavicle, genitive)", "p": 43}, {"t": "Corpus claviculare", "m": "Body of clavicle (alternate Latin form)", "e": "corpus (L. corpus: body) + claviculare (L. claviculāris: of the clavicle)", "p": 43}, {"t": "Sulcus musculi subclavii", "m": "Subclavian groove — elongated groove representing the deep attachment field of the subclavius muscle", "e": "sulcus (L. sulcus: groove, furrow) + musculi (L. musculus: muscle, genitive) + subclavii (L. sub = under + clavicula = clavicle, so: under the clavicle, genitive)", "p": 43}, {"t": "Extremitas acromialis", "m": "Acromial (lateral) end — end of the clavicle facing the acromion", "e": "extremitas (L. extrēmitās: extremity, end) + acromialis (Gk./L. acromialis: of the acromion, from akros = tip + ōmos = shoulder)", "p": 43}, {"t": "Tuberositas ligamenti coracoclavicularis", "m": "Tuberosity for the coracoclavicular ligament — roughened area for attachment of the two portions of the coracoclavicular ligament (conoid and trapezoid ligaments)", "e": "tuberositas (L. tuberositās: tuberosity, roughened prominence, from tuber = swelling) + ligamenti (L. ligamentum: ligament, genitive) + coracoclavicularis (Gk. korax = crow + L. clavicula = clavicle, so: of the coracoid and clavicle)", "p": 43}, {"t": "Facies articularis acromialis", "m": "Acromial articular surface — joint surface for the acromion", "e": "facies (L. faciēs: surface) + articularis (L. articulāris: of a joint) + acromialis (Gk./L.: of the acromion, from akros = tip + ōmos = shoulder)", "p": 43}, {"t": "Tuberculum conoideum", "m": "Conoid tubercle — small eminence on the inferior surface of the acromial end of the clavicle for attachment of the conoid ligament", "e": "tuberculum (L. tuberculum: small swelling) + conoideum (Gk. konoeidēs: cone-shaped, from konos = cone + eidos = form, shape)", "p": 43}, {"t": "Linea trapezoidea", "m": "Trapezoid line — attachment site for the trapezoid ligament on the inferior surface of the acromial end of the clavicle", "e": "linea (L. linea: line, from linum = flax, thread) + trapezoidea (Gk. trapezoeides: trapezoid-shaped, from trapeza = table + eidos = form, shape)", "p": 43}, {"t": "Pars libera membri superioris", "m": "Free part of upper limb — bones of the arm and hand", "e": "pars (L. pars: part) + libera (L. liber: free) + membri (L. membrum: limb, member) + superioris (L. superior: upper, higher)", "p": 45}, {"t": "Caput humeri", "m": "Head of humerus", "e": "caput (L. caput: head) + humeri (L. humerus: upper arm bone, shoulder)", "p": 45}, {"t": "Caput humerale", "m": "Head of humerus (alternate form)", "e": "caput (L. caput: head) + humerale (L. humeralis: of the humerus/shoulder)", "p": 45}, {"t": "Collum anatomicum", "m": "Anatomical neck — area between the head and the tubercles of the humerus", "e": "collum (L. collum: neck) + anatomicum (Gk. anatomē: dissection, from ana = up + temnein = to cut)", "p": 45}, {"t": "Collum chirurgicum", "m": "Surgical neck — tapering region distal to the tubercles and continuous with the shaft", "e": "collum (L. collum: neck) + chirurgicum (Gk. cheirourgikós: of surgery, from cheir = hand + ergon = work)", "p": 45}, {"t": "Tuberculum majus", "m": "Greater tubercle — large prominence at the posterolateral end of the humerus", "e": "tuberculum (L. tuberculum: small lump, diminutive of tuber = swelling) + majus (L. major: greater, larger)", "p": 45}, {"t": "Tuberculum minus", "m": "Lesser tubercle — smaller prominence on the anterior surface of the humerus", "e": "tuberculum (L. tuberculum: small lump, diminutive of tuber = swelling) + minus (L. minor: smaller, lesser)", "p": 45}, {"t": "Sulcus intertubercularis", "m": "Intertubercular groove — groove located between the two tubercles for passage of the tendon of the long head of the biceps", "e": "sulcus (L. sulcus: groove, furrow) + inter (L. inter: between) + tubercularis (L. tuberculum: small lump + -aris: relating to)", "p": 45}, {"t": "Crista tuberculi majoris", "m": "Crest of greater tubercle — bony ridge extending downward from the greater tubercle", "e": "crista (L. crista: crest, ridge) + tuberculi (L. tuberculum: small lump) + majoris (L. major: greater, larger)", "p": 45}, {"t": "Crista tuberculi minoris", "m": "Crest of lesser tubercle — bony ridge extending downward from the lesser tubercle", "e": "crista (L. crista: crest, ridge) + tuberculi (L. tuberculum: small lump) + minoris (L. minor: smaller, lesser)", "p": 45}, {"t": "Corpus humeri", "m": "Body of humerus — shaft between the two ends of the humerus", "e": "corpus (L. corpus: body, shaft) + humeri (L. humerus: upper arm bone)", "p": 45}, {"t": "Facies anterior medialis", "m": "Anteromedial surface — surface of the humerus lying medial to the prolongation of the crest of the greater tubercle", "e": "facies (L. facies: face, surface) + anterior (L. anterior: front, forward) + medialis (L. medialis: middle, from medius = middle)", "p": 45}, {"t": "Facies anteromedialis", "m": "Anteromedial surface (alternate form)", "e": "facies (L. facies: surface) + anteromedialis (L. antero = anterior/front + medialis = middle)", "p": 45}, {"t": "Facies anterior lateralis", "m": "Anterolateral surface — surface of the humerus located lateral to the prolongation of the crest of the greater tubercle", "e": "facies (L. facies: face, surface) + anterior (L. anterior: front) + lateralis (L. lateralis: of the side, from latus = side)", "p": 45}, {"t": "Facies anterolateralis", "m": "Anterolateral surface (alternate form)", "e": "facies (L. facies: surface) + anterolateralis (L. antero = front + lateralis = of the side)", "p": 45}, {"t": "Sulcus nervi radialis", "m": "Groove for radial nerve — oblique groove descending laterally on the posterior surface of the humerus", "e": "sulcus (L. sulcus: groove, furrow) + nervi (L. nervus: nerve, from Gk. neuron) + radialis (L. radius: spoke, ray + -alis: relating to)", "p": 45}, {"t": "Crista supracondylaris medialis", "m": "Medial supracondylar ridge — lower, sharp-edged end of the medial margin communicating with the medial epicondyle", "e": "crista (L. crista: crest, ridge) + supra (L. supra: above) + condylaris (Gk. kondylos: knuckle, rounded projection + L. -aris: relating to) + medialis (L. medialis: of the middle)", "p": 45}, {"t": "Processus supracondylaris", "m": "Supracondylar process — bony spur, phylogenetically conditioned, occasionally present at the medial margin of the distal humerus", "e": "processus (L. processus: projection, process, from procedere = to go forward) + supra (L. supra: above) + condylaris (Gk. kondylos: knuckle + L. -aris: relating to)", "p": 45}, {"t": "Crista supracondylaris lateralis", "m": "Lateral supracondylar ridge — lower, sharp-edged terminal portion of the lateral margin ending at the lateral epicondyle", "e": "crista (L. crista: crest, ridge) + supra (L. supra: above) + condylaris (Gk. kondylos: knuckle + L. -aris: relating to) + lateralis (L. lateralis: of the side)", "p": 45}, {"t": "Tuberositas deltoidea", "m": "Deltoid tuberosity — rough area on the anterolateral surface near the middle of the humerus for attachment of the deltoid muscle", "e": "tuberositas (L. tuberosus: full of lumps, from tuber = swelling + -itas: quality of) + deltoidea (Gk. delta: the letter Δ + eidos: shape, form; triangular)", "p": 45}, {"t": "Condylus humeri", "m": "Condyle of humerus — distal end of the humerus comprising the olecranon fossa, coronoid fossa, radial fossa and the articular surfaces", "e": "condylus (Gk. kondylos: knuckle, rounded projection) + humeri (L. humerus: upper arm bone)", "p": 45}, {"t": "Capitulum humeri", "m": "Capitulum of humerus — rounded projection at the distal end of the humerus for articulation with the radius", "e": "capitulum (L. capitulum: small head, diminutive of caput = head) + humeri (L. humerus: upper arm bone)", "p": 45}, {"t": "Trochlea humeri", "m": "Trochlea of humerus — articular cylinder at the distal end of the humerus for articulation with the ulna", "e": "trochlea (Gk. trochilia: pulley, wheel, from trochos = wheel) + humeri (L. humerus: upper arm bone)", "p": 45}, {"t": "Fossa olecrani", "m": "Olecranon fossa — deep pit above the trochlea on the posterior aspect of the humerus that receives the olecranon when the elbow joint is extended", "e": "fossa (L. fossa: ditch, pit, depression) + olecrani (Gk. ōlekranon: point of the elbow, from ōlenē = elbow + kranion = head)", "p": 45}, {"t": "Fossa coronoidea", "m": "Coronoid fossa — depression on the anterior aspect of the humerus proximal to the trochlea that receives the coronoid process of the ulna when the elbow joint is flexed", "e": "fossa (L. fossa: pit, depression) + coronoidea (Gk. korōnē: crow, crown + eidos: shape/form; crown-shaped)", "p": 45}, {"t": "Fossa radialis", "m": "Radial fossa — depression above the capitulum on the anterior aspect of the humerus that receives the head of the radius when there is strong flexion of the elbow joint", "e": "fossa (L. fossa: pit, depression) + radialis (L. radius: spoke, ray + -alis: relating to)", "p": 45}, {"t": "Epicondylus medialis", "m": "Medial epicondyle — medial protuberance which gives origin to the flexor muscles of the forearm", "e": "epi (Gk. epi: upon, above) + condylus (Gk. kondylos: knuckle, rounded projection) + medialis (L. medialis: of the middle, from medius = middle)", "p": 45}, {"t": "Sulcus nervi ulnaris", "m": "Groove for the ulnar nerve — occupies the posterior surface of the medial epicondyle", "e": "sulcus (L. sulcus: groove, furrow) + nervi (L. nervus: nerve) + ulnaris (L. ulna: forearm bone, from Gk. ōlenē = elbow + -aris: relating to)", "p": 45}, {"t": "Epicondylus lateralis", "m": "Lateral epicondyle — protuberance lateral to the capitulum that gives attachment to the extensor muscles of the forearm", "e": "epi (Gk. epi: upon, above) + condylus (Gk. kondylos: knuckle, rounded projection) + lateralis (L. lateralis: of the side, from latus = side)", "p": 45}, {"t": "Radius", "m": "The lateral of the two forearm bones", "e": "radius (L. radius: spoke of a wheel, ray, rod)", "p": 47}, {"t": "Caput radii", "m": "Head of radius — proximal end of the radius which articulates with the capitulum of the humerus", "e": "caput (L. caput: head) + radii (L. radius gen.: of the spoke/ray)", "p": 47}, {"t": "Fovea articularis", "m": "Articular fovea — concavity that receives the capitulum of the humerus", "e": "fovea (L. fovea: pit, small depression) + articularis (L. articulāris: of a joint, from articulus = joint)", "p": 47}, {"t": "Circumferentia articularis", "m": "Articular circumference — rim-like surface on the head of the radius for articulation with the radial notch of the ulna", "e": "circumferentia (L. circumferentia: circumference, from circum = around + ferre = to carry) + articularis (L. articulāris: of a joint)", "p": 47}, {"t": "Collum radii", "m": "Neck of radius — slender region at the proximal end of the radius between the head and tuberosity", "e": "collum (L. collum: neck) + radii (L. radius gen.: of the spoke/ray)", "p": 47}, {"t": "Corpus radii", "m": "Body of radius — radial shaft", "e": "corpus (L. corpus: body, shaft) + radii (L. radius gen.: of the spoke/ray)", "p": 47}, {"t": "Tuberositas radii", "m": "Radial tuberosity — roughened prominence on the medial aspect of the radius about 2 cm distal to the proximal end, attachment site of the biceps tendon", "e": "tuberositas (L. tuberositas: tuberosity, from tuber = swelling, lump) + radii (L. radius gen.: of the spoke/ray)", "p": 47}, {"t": "Margo interosseus", "m": "Interosseous margin — border facing the ulna and giving attachment to the interosseous membrane", "e": "margo (L. margo: border, edge) + interosseus (L. interosseus: between bones, from inter = between + os/ossis = bone)", "p": 47}, {"t": "Tuberositas pronatoria", "m": "Pronator tuberosity — roughened area at the middle of the lateral surface, attachment site of the pronator teres muscle", "e": "tuberositas (L. tuberositas: tuberosity, from tuber = swelling) + pronatoria (L. pronatorius: of the pronator, from pronare = to bend forward/prone)", "p": 47}, {"t": "Margo posterior", "m": "Posterior margin", "e": "margo (L. margo: border, edge) + posterior (L. posterior: behind, coming after)", "p": 47}, {"t": "Margo anterior", "m": "Anterior margin — margin facing anterolaterally", "e": "margo (L. margo: border, edge) + anterior (L. anterior: before, in front)", "p": 47}, {"t": "Tuberculum dorsale", "m": "Dorsal tubercle — bony ridge on the posterior aspect of the lower end of the radius between the grooves for the extensor pollicis longus and extensor carpi radialis brevis muscles", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = lump) + dorsale (L. dorsalis: of the back, from dorsum = back)", "p": 47}, {"t": "Incisura ulnaris", "m": "Ulnar notch — concavity forming the medial surface at the end of the radius for articulation with the ulna", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + ulnaris (L. ulnaris: of the ulna, from ulna = forearm bone)", "p": 47}, {"t": "Facies articularis carpalis", "m": "Articular carpal surface — joint surface on the inferior surface of the lower end of the radius for articulation with the carpus", "e": "facies (L. facies: face, surface) + articularis (L. articulāris: of a joint) + carpalis (L. carpalis: of the wrist, from Gk. karpos = wrist)", "p": 47}, {"t": "Ulna", "m": "Medial forearm bone", "e": "ulna (L. ulna: forearm, elbow; related to Gk. olene = elbow)", "p": 47}, {"t": "Olecranon", "m": "Proximal, posterior end of the ulna — attachment site of the extensor muscles of the elbow joint", "e": "olecranon (Gk. olekranon: point of the elbow, from olene = elbow + kranion = head/skull)", "p": 47}, {"t": "Tuberositas ulnae", "m": "Ulnar tuberosity — roughened area on the anterior surface of the upper part of the ulnar shaft for attachment of the brachialis muscle", "e": "tuberositas (L. tuberositas: tuberosity, from tuber = swelling) + ulnae (L. ulna gen.: of the ulna)", "p": 47}, {"t": "Incisura trochlearis", "m": "Trochlear notch — articular surface at the proximal end of the anterior face of the ulna for articulation with the trochlea of the humerus", "e": "incisura (L. incisura: notch, from incidere = to cut into) + trochlearis (L. trochlearis: of the trochlea, from Gk. trochilia = pulley)", "p": 47}, {"t": "Incisura radialis", "m": "Radial notch — joint surface on the lateral aspect of the ulna at the level of the coronoid process for articulation with the articular circumference of the radius", "e": "incisura (L. incisura: notch, from incidere = to cut into) + radialis (L. radialis: of the radius, from radius = spoke/ray)", "p": 47}, {"t": "Corpus ulnae", "m": "Body of ulna — ulnar shaft", "e": "corpus (L. corpus: body, shaft) + ulnae (L. ulna gen.: of the ulna)", "p": 47}, {"t": "Facies medialis", "m": "Medial surface — surface facing the trunk", "e": "facies (L. facies: face, surface) + medialis (L. medialis: middle, from medius = middle)", "p": 47}, {"t": "Crista m. supinatoris", "m": "Supinator crest — bony ridge extending distally from the radial notch for attachment of the supinator muscle", "e": "crista (L. crista: crest, ridge) + m. (L. musculus: muscle) + supinatoris (L. supinator gen.: of the supinator, from supinare = to lay on the back/supinate)", "p": 47}, {"t": "Caput ulnae", "m": "Head of ulna — distal end of the ulna", "e": "caput (L. caput: head) + ulnae (L. ulna gen.: of the ulna)", "p": 47}, {"t": "Ossa manus", "m": "Bones of the hand", "e": "ossa (L. os/ossis: bones) + manus (L. manus: hand)", "p": 50}, {"t": "Ossa metacarpi (metacarpalia) [I–V]", "m": "Metacarpal bones I–V", "e": "ossa (L. os/ossis: bones) + meta (Gk. meta: beyond, after) + karpos (Gk. karpos: wrist)", "p": 50}, {"t": "Basis metacarpalis", "m": "Base of metacarpal bone — proximal, broad end of a metacarpal bone", "e": "basis (Gk./L. basis: base, foundation) + metacarpalis (Gk. meta: beyond + karpos: wrist)", "p": 50}, {"t": "Corpus metacarpale", "m": "Body (shaft) of metacarpal bone", "e": "corpus (L. corpus: body, shaft) + metacarpale (Gk. meta: beyond + karpos: wrist)", "p": 50}, {"t": "Caput metacarpale", "m": "Head of metacarpal bone — distal articular end of a metacarpal bone", "e": "caput (L. caput: head) + metacarpale (Gk. meta: beyond + karpos: wrist)", "p": 50}, {"t": "Os metacarpale tertium [III]", "m": "Third metacarpal bone — metacarpal bone lying proximal to the middle finger", "e": "os (L. os: bone) + metacarpale (Gk. meta: beyond + karpos: wrist) + tertium (L. tertius: third)", "p": 50}, {"t": "Ossa digitorum (phalanges)", "m": "Fingers (digits)", "e": "ossa (L. os/ossis: bones) + digitorum (L. digitus: finger, genitive plural) + phalanges (Gk. phalanx: finger bone, battle line)", "p": 50}, {"t": "Phalanx proximalis", "m": "Proximal phalanx — proximal bone of a finger", "e": "phalanx (Gk. phalanx: finger bone) + proximalis (L. proximus: nearest, closest)", "p": 50}, {"t": "Phalanx media", "m": "Middle phalanx — the middle bones of the fingers", "e": "phalanx (Gk. phalanx: finger bone) + media (L. medius: middle)", "p": 50}, {"t": "Phalanx distalis", "m": "Distal (terminal) phalanx — distal, nail-bearing segment of the finger", "e": "phalanx (Gk. phalanx: finger bone) + distalis (L. distare: to be distant, far)", "p": 50}, {"t": "Tuberositas phalangis distalis", "m": "Tuberosity of distal phalanx — roughened expansions at the distal flexor side of each terminal phalanx for attachment of the tactile pads", "e": "tuberositas (L. tuber: swelling, bump + -ositas: quality of) + phalangis (Gk. phalanx: finger bone, genitive) + distalis (L. distare: to be distant)", "p": 50}, {"t": "Basis phalangis", "m": "Base of phalanx — proximal, thickened, articular end of the phalanx", "e": "basis (Gk./L. basis: base, foundation) + phalangis (Gk. phalanx: finger bone, genitive)", "p": 50}, {"t": "Corpus phalangis", "m": "Body (shaft) of phalanx", "e": "corpus (L. corpus: body, shaft) + phalangis (Gk. phalanx: finger bone, genitive)", "p": 50}, {"t": "Caput phalangis", "m": "Distal end (trochlea) of phalanx", "e": "caput (L. caput: head) + phalangis (Gk. phalanx: finger bone, genitive)", "p": 50}, {"t": "Ossa sesamoidea", "m": "Sesamoid bones — bones embedded in tendons or ligaments", "e": "ossa (L. os/ossis: bones) + sesamoidea (Gk. sesamon: sesame seed + eidos: resembling, shaped like)", "p": 50}, {"t": "Carpus", "m": "The wrist, which is situated between the forearm and metacarpal bones", "e": "carpus (Gk. karpos: wrist)", "p": 50}, {"t": "Ossa carpi (carpalia)", "m": "Carpal bones — the eight wrist bones", "e": "ossa (L. os/ossis: bones) + carpi (Gk. karpos: wrist, genitive) + carpalia (Gk. karpos: wrist)", "p": 50}, {"t": "Os centrale", "m": "Accessory carpal bone (ossicle) — occasionally found between the capitate, scaphoid and trapezoid bones", "e": "os (L. os: bone) + centrale (L. centralis: of the center, from centrum: center)", "p": 50}, {"t": "Os scaphoideum [os naviculare]", "m": "Scaphoid — proximal carpal bone situated between the lunate and trapezium bones", "e": "os (L. os: bone) + scaphoideum (Gk. skaphe: boat + eidos: resembling) + naviculare (L. navicula: small boat, from navis: ship)", "p": 50}, {"t": "Tuberculum ossis scaphoidei", "m": "Scaphoid tubercle — elevation on the anterior surface of the scaphoid, protrudes visibly with radial abduction of the hand", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber) + ossis (L. os/ossis: bone, genitive) + scaphoidei (Gk. skaphe: boat + eidos: resembling, genitive)", "p": 50}, {"t": "Os lunatum", "m": "Lunate — proximal carpal bone located between the scaphoid and triquetrum", "e": "os (L. os: bone) + lunatum (L. luna: moon + -atum: shaped like)", "p": 50}, {"t": "Os triquetrum", "m": "Triquetrum — proximal carpal bone situated between the hamate and lunate bones, dorsal to the pisiform bone", "e": "os (L. os: bone) + triquetrum (L. triquetrus: three-cornered, from tri: three + quetrus: cornered)", "p": 50}, {"t": "Os pisiforme", "m": "Pisiform — proximal carpal bone residing on the palmar aspect of the triquetrum with which it articulates; a true sesamoid bone within the tendon of the flexor carpi ulnaris", "e": "os (L. os: bone) + pisiforme (L. pisum: pea + forma: shape, form)", "p": 50}, {"t": "Os trapezium [os multangulum majus]", "m": "Trapezium — distal carpal bone located between the 1st metacarpal and the scaphoid", "e": "os (L. os: bone) + trapezium (Gk. trapezion: small table, irregular quadrilateral) + multangulum (L. multus: many + angulum: angle) + majus (L. major: greater, larger)", "p": 50}, {"t": "Tuberculum ossis trapezii", "m": "Tubercle of trapezium — elevation on the palmar side of the trapezium distal to the scaphoid tubercle and radial to the groove for the flexor carpi radialis", "e": "tuberculum (L. tuberculum: small swelling) + ossis (L. os/ossis: bone, genitive) + trapezii (Gk. trapezion: small table, genitive)", "p": 50}, {"t": "Os trapezoideum [os multangulum minus]", "m": "Trapezoid — distal carpal bone positioned between the 2nd metacarpal and the scaphoid and between the trapezium and capitate bones", "e": "os (L. os: bone) + trapezoideum (Gk. trapezion: small table + eidos: resembling) + multangulum (L. multus: many + angulum: angle) + minus (L. minor: lesser, smaller)", "p": 50}, {"t": "Os capitatum", "m": "Capitate — distal carpal bone centered between the 3rd metacarpal and the lunate bone", "e": "os (L. os: bone) + capitatum (L. caput/capitis: head + -atum: having, shaped like; so 'headed')", "p": 50}, {"t": "Os hamatum", "m": "Hamate — distal carpal bone located between the 4th and 5th metacarpals, capitate and triquetrum", "e": "os (L. os: bone) + hamatum (L. hamus: hook + -atum: having, provided with)", "p": 50}, {"t": "Hamulus ossis hamati", "m": "Hamulus (hook) of hamate — hook-shaped process on the palmar aspect of the hamate distal to the pisiform bone", "e": "hamulus (L. hamulus: small hook, diminutive of hamus) + ossis (L. os/ossis: bone, genitive) + hamati (L. hamus: hook + -atus: having, genitive)", "p": 50}, {"t": "Sulcus carpi", "m": "Carpal groove — palmar concavity between the tubercles of the scaphoid and trapezium on the radial side, and the hamulus and pisiform bone on the ulnar side", "e": "sulcus (L. sulcus: groove, furrow) + carpi (Gk. karpos: wrist, genitive)", "p": 50}, {"t": "Metacarpus", "m": "Region of the hand between the fingers and the wrist", "e": "meta (Gk. meta: beyond, after) + karpos (Gk. karpos: wrist)", "p": 50}, {"t": "Ossa membri inferioris", "m": "Bones of the lower limb", "e": "ossa (L. os/ossa: bones) + membri (L. membrum: limb, member, genitive) + inferioris (L. inferior: lower, genitive)", "p": 52}, {"t": "Cingulum membri inferioris", "m": "Pelvic girdle", "e": "cingulum (L. cingulum: girdle, belt, from cingere = to gird) + membri (L. membrum: limb, genitive) + inferioris (L. inferior: lower, genitive)", "p": 52}, {"t": "Cingulum pelvicum", "m": "Pelvic girdle", "e": "cingulum (L. cingulum: girdle, belt) + pelvicum (L. pelvis: basin, bowl, adjectival form)", "p": 52}, {"t": "Os coxae", "m": "Hip bone", "e": "os (L. os: bone) + coxae (L. coxa: hip, genitive)", "p": 52}, {"t": "Os pelvicum", "m": "Hip bone (pelvic bone)", "e": "os (L. os: bone) + pelvicum (L. pelvis: basin, bowl, adjectival form)", "p": 52}, {"t": "Foramen obturatum", "m": "Obturator foramen — large opening between the pubis and ischium", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + obturatum (L. obturare: to stop up, block)", "p": 52}, {"t": "Foramen obturatorium", "m": "Obturator foramen", "e": "foramen (L. foramen: opening, hole) + obturatorium (L. obturare: to stop up, adjectival form)", "p": 52}, {"t": "Acetabulum", "m": "Hip joint socket — cavity formed by the ilium, ischium and pubis", "e": "acetabulum (L. acetabulum: small cup for vinegar, from acetum = vinegar + -abulum = vessel suffix)", "p": 52}, {"t": "Limbus acetabuli", "m": "Margin of the acetabulum", "e": "limbus (L. limbus: border, margin, edge) + acetabuli (L. acetabulum: hip socket, genitive)", "p": 52}, {"t": "Margo acetabularis", "m": "Acetabular margin", "e": "margo (L. margo: margin, border, edge) + acetabularis (L. acetabulum: hip socket, adjectival form)", "p": 52}, {"t": "Fossa acetabuli", "m": "Acetabular fossa — deeper part embraced by the lunate surface", "e": "fossa (L. fossa: pit, ditch, from fodere = to dig) + acetabuli (L. acetabulum: hip socket, genitive)", "p": 52}, {"t": "Incisura acetabuli", "m": "Acetabular notch — notch in the lunate surface of the acetabulum", "e": "incisura (L. incisura: notch, cut, from incidere = to cut into) + acetabuli (L. acetabulum: hip socket, genitive)", "p": 52}, {"t": "Facies lunata", "m": "Lunate surface — cartilage covered, sickle-shaped articular surface of the acetabulum", "e": "facies (L. facies: surface, face, appearance) + lunata (L. lunatus: moon-shaped, crescent-shaped, from luna = moon)", "p": 52}, {"t": "Os ilii", "m": "Ilium", "e": "os (L. os: bone) + ilii (L. ilium/ilia: flank, groin, genitive)", "p": 52}, {"t": "Os iliacum", "m": "Ilium", "e": "os (L. os: bone) + iliacum (L. iliacus: of the flank/ilium, adjectival form)", "p": 52}, {"t": "Corpus ossis ilii", "m": "Body of the ilium — central portion of the ilium situated near the acetabulum", "e": "corpus (L. corpus: body) + ossis (L. os: bone, genitive) + ilii (L. ilium: flank, genitive)", "p": 52}, {"t": "Sulcus supraacetabularis", "m": "Supra-acetabular sulcus — groove formed between the acetabular margin and the body of the ilium", "e": "sulcus (L. sulcus: groove, furrow) + supra (L. supra: above) + acetabularis (L. acetabulum: hip socket, adjectival form)", "p": 52}, {"t": "Ala ossis ilii", "m": "Wing (or ala) of the ilium", "e": "ala (L. ala: wing) + ossis (L. os: bone, genitive) + ilii (L. ilium: flank, genitive)", "p": 52}, {"t": "Linea arcuata", "m": "Arcuate line — prominent bony ridge at the boundary between the greater and lesser pelvis", "e": "linea (L. linea: line, from linum = thread) + arcuata (L. arcuatus: arched, bow-shaped, from arcus = arch/bow)", "p": 52}, {"t": "Crista iliaca", "m": "Iliac crest", "e": "crista (L. crista: crest, ridge) + iliaca (L. iliacus: of the ilium, adjectival form)", "p": 52}, {"t": "Labium externum", "m": "External lip of the iliac crest — bony ridge for attachment of the external abdominal oblique muscle", "e": "labium (L. labium: lip, edge) + externum (L. externus: outer, external)", "p": 52}, {"t": "Tuberculum iliacum", "m": "Tubercle of iliac crest — palpable projection on the external lip of the iliac crest", "e": "tuberculum (L. tuberculum: small swelling/lump, diminutive of tuber = lump) + iliacum (L. iliacus: of the ilium, adjectival form)", "p": 52}, {"t": "Linea intermedia", "m": "Linea intermedia — rough bony area between the external and internal lips of the iliac crest", "e": "linea (L. linea: line) + intermedia (L. intermedius: in between, middle, from inter = between + medius = middle)", "p": 52}, {"t": "Labium internum", "m": "Internal lip of the iliac crest — bony ridge on the inner margin of the iliac crest", "e": "labium (L. labium: lip, edge) + internum (L. internus: inner, internal)", "p": 52}, {"t": "Spina iliaca anterior superior", "m": "Anterior superior iliac spine — bony projection marking the anterior limit of the iliac crest", "e": "spina (L. spina: spine, thorn) + iliaca (L. iliacus: of the ilium, adjectival form) + anterior (L. anterior: front, former) + superior (L. superior: upper, higher)", "p": 52}, {"t": "Spina iliaca anterior inferior", "m": "Anterior inferior iliac spine — bony process at the anterior margin of the ilium", "e": "spina (L. spina: spine, thorn) + iliaca (L. iliacus: of the ilium, adjectival form) + anterior (L. anterior: front, former) + inferior (L. inferior: lower)", "p": 52}, {"t": "Spina iliaca posterior superior", "m": "Posterior superior iliac spine — bony process at the posterior end of the iliac crest", "e": "spina (L. spina: spine, thorn) + iliaca (L. iliacus: of the ilium, adjectival form) + posterior (L. posterior: behind, later) + superior (L. superior: upper, higher)", "p": 52}, {"t": "Spina iliaca posterior inferior", "m": "Posterior inferior iliac spine — bony process at the superior end of the greater sciatic notch", "e": "spina (L. spina: spine, thorn) + iliaca (L. iliacus: of the ilium, adjectival form) + posterior (L. posterior: behind, later) + inferior (L. inferior: lower)", "p": 52}, {"t": "Fossa iliaca", "m": "Iliac fossa — concavity forming the internal surface of the ala of the ilium", "e": "fossa (L. fossa: pit, ditch, hollow) + iliaca (L. iliacus: of the ilium, adjectival form)", "p": 52}, {"t": "Facies glutealis", "m": "Gluteal surface — external surface of the ala of the ilium", "e": "facies (L. facies: surface, face) + glutealis (Gk. gloutos: buttock, Latinized adjectival form)", "p": 52}, {"t": "Linea glutealis anterior", "m": "Anterior gluteal line — flat ridge situated somewhat in the middle of the ala of the ilium between the fields of origin of the gluteus medius and minimus muscles", "e": "linea (L. linea: line) + glutealis (Gk. gloutos: buttock, Latinized adjectival form) + anterior (L. anterior: front, former)", "p": 52}, {"t": "Linea glutealis posterior", "m": "Posterior gluteal line — bony ridge between the fields of origin of the gluteus medius and maximus muscles", "e": "linea (L. linea: line) + glutealis (Gk. gloutos: buttock, Latinized adjectival form) + posterior (L. posterior: behind, later)", "p": 52}, {"t": "Linea glutealis inferior", "m": "Inferior gluteal line — bony ridge above the acetabulum between the fields of origin of the gluteus minimus and rectus femoris muscles", "e": "linea (L. linea: line) + glutealis (Gk. gloutos: buttock, Latinized adjectival form) + inferior (L. inferior: lower)", "p": 52}, {"t": "Facies sacropelvina", "m": "Sacropelvic surface — surface of the dorsal segment of the ilium facing the sacrum", "e": "facies (L. facies: surface, face) + sacro (L. sacer/sacrum: sacred, referring to the sacral bone) + pelvina (L. pelvis: basin, adjectival form)", "p": 52}, {"t": "Tuberositas iliaca", "m": "Iliac tuberosity — roughened area behind and above the auricular surface, gives attachment to the sacroiliac ligaments", "e": "tuberositas (L. tuberositas: roughness, knobby projection, from tuber = swelling/lump) + iliaca (L. iliacus: of the ilium, adjectival form)", "p": 52}, {"t": "Os ischii", "m": "Ischium — bone which forms the posterior and inferior boundary of the obturator foramen", "e": "os (L. os: bone) + ischii (Gk. ischion: hip joint, haunch)", "p": 54}, {"t": "Corpus ossis ischii", "m": "Body of ischium — the portion of the ischium situated behind the obturator foramen", "e": "corpus (L. corpus: body) + ossis (L. os/ossis: bone) + ischii (Gk. ischion: hip joint, haunch)", "p": 54}, {"t": "Ramus ossis ischii", "m": "Ramus of ischium — the portion of the ischium situated below the obturator foramen", "e": "ramus (L. ramus: branch) + ossis (L. os/ossis: bone) + ischii (Gk. ischion: hip joint, haunch)", "p": 54}, {"t": "Tuber ischiadicum", "m": "Ischial tuberosity — ischial process at the lower end of the lesser sciatic notch", "e": "tuber (L. tuber: bump, swelling, knob) + ischiadicum (Gk. ischion: hip joint, haunch; L. -adicus: adjectival suffix)", "p": 54}, {"t": "Spina ischiadica", "m": "Ischial spine — bony prominence between the greater and lesser sciatic notches", "e": "spina (L. spina: spine, thorn) + ischiadica (Gk. ischion: hip joint, haunch; L. -adica: adjectival suffix)", "p": 54}, {"t": "Incisura ischiadica major", "m": "Greater sciatic notch — large notch between the posterior inferior iliac spine and the ischial spine", "e": "incisura (L. incisura: notch, from incidere = to cut into) + ischiadica (Gk. ischion: hip joint; L. -adica: adjectival suffix) + major (L. major: greater, larger)", "p": 54}, {"t": "Incisura ischiadica minor", "m": "Lesser sciatic notch — notch between the ischial spine and the ischial tuberosity", "e": "incisura (L. incisura: notch, from incidere = to cut into) + ischiadica (Gk. ischion: hip joint; L. -adica: adjectival suffix) + minor (L. minor: lesser, smaller)", "p": 54}, {"t": "Os pubis", "m": "Pubis — bone which forms the anterior and inferior borders of the obturator foramen", "e": "os (L. os: bone) + pubis (L. pubes/pubis: pubic region, groin)", "p": 54}, {"t": "Corpus ossis pubis", "m": "Body of the pubis", "e": "corpus (L. corpus: body) + ossis (L. os/ossis: bone) + pubis (L. pubes/pubis: pubic region)", "p": 54}, {"t": "Tuberculum pubicum", "m": "Pubic tubercle — protuberance located anterolateral to the symphysis", "e": "tuberculum (L. tuberculum: small bump, diminutive of tuber = swelling) + pubicum (L. pubicus: of the pubis, from pubes = pubic region)", "p": 54}, {"t": "Facies symphysialis", "m": "Symphyseal surface — the median surface of the symphysis facing the contralateral pubis", "e": "facies (L. facies: face, surface) + symphysialis (Gk. symphysis: growing together, from syn = together + phyein = to grow; L. -alis: adjectival suffix)", "p": 54}, {"t": "Crista pubica", "m": "Pubic crest — ridge extending medially from the pubic tubercle to the symphysis", "e": "crista (L. crista: crest, ridge) + pubica (L. pubicus: of the pubis, from pubes = pubic region)", "p": 54}, {"t": "Ramus superior ossis pubis", "m": "Superior ramus of the pubis — the part of the pubis situated above the obturator foramen", "e": "ramus (L. ramus: branch) + superior (L. superior: upper, higher) + ossis (L. os/ossis: bone) + pubis (L. pubes/pubis: pubic region)", "p": 54}, {"t": "Eminentia iliopubica", "m": "Iliopubic (iliopectineal) eminence — flat prominence at the proximal portion of the pubis", "e": "eminentia (L. eminentia: prominence, from eminere = to stand out) + ilio- (L. ilium: flank, groin) + pubica (L. pubicus: of the pubis)", "p": 54}, {"t": "Pecten ossis pubis", "m": "Pecten (pectineal line) of the pubis — sharp, bony ridge which passes to the pubic tubercle as a continuation of the arcuate line", "e": "pecten (L. pecten: comb, ridge) + ossis (L. os/ossis: bone) + pubis (L. pubes/pubis: pubic region)", "p": 54}, {"t": "Crista obturatoria", "m": "Obturator crest — extends from the pubic tubercle to the acetabulum", "e": "crista (L. crista: crest, ridge) + obturatoria (L. obturare: to stop up, plug; -oria: adjectival suffix relating to the obturator foramen)", "p": 54}, {"t": "Sulcus obturatorius", "m": "Obturator groove — sulcus above the obturator foramen", "e": "sulcus (L. sulcus: groove, furrow) + obturatorius (L. obturare: to stop up, plug; -orius: adjectival suffix)", "p": 54}, {"t": "Tuberculum obturatorium anterius", "m": "Anterior obturator tubercle — small protuberance anterior to the obturator groove", "e": "tuberculum (L. tuberculum: small bump, diminutive of tuber = swelling) + obturatorium (L. obturare: to stop up; -orium: adjectival suffix) + anterius (L. anterior: in front, former)", "p": 54}, {"t": "Tuberculum obturatorium posterius", "m": "Posterior obturator tubercle — prominence occasionally present behind the obturator groove", "e": "tuberculum (L. tuberculum: small bump, diminutive of tuber = swelling) + obturatorium (L. obturare: to stop up; -orium: adjectival suffix) + posterius (L. posterior: behind, later)", "p": 54}, {"t": "Ramus inferior ossis pubis", "m": "Inferior ramus of pubis — the portion of the pubis located anteroinferior the obturator foramen between the symphysis and the suture line with the ischium", "e": "ramus (L. ramus: branch) + inferior (L. inferior: lower) + ossis (L. os/ossis: bone) + pubis (L. pubes/pubis: pubic region)", "p": 54}, {"t": "Cavitas pelvis", "m": "Pelvic cavity", "e": "cavitas (L. cavitas: hollowness, cavity, from cavus = hollow) + pelvis (L. pelvis: basin, bowl)", "p": 54}, {"t": "Arcus pubis", "m": "Pubic arch — the arch below the symphysis formed by the right and left pubic bones", "e": "arcus (L. arcus: arch, bow) + pubis (L. pubes/pubis: pubic region)", "p": 54}, {"t": "Angulus subpubicus", "m": "Subpubic angle — the angle between the right and left inferior ramus of the pubis", "e": "angulus (L. angulus: angle, corner) + sub- (L. sub: under, below) + pubicus (L. pubicus: of the pubis, from pubes = pubic region)", "p": 54}, {"t": "Pelvis major", "m": "Greater pelvis — the space between the two alae of the ilium above the linea terminalis", "e": "pelvis (L. pelvis: basin, bowl) + major (L. major: greater, larger)", "p": 54}, {"t": "Pelvis minor", "m": "Lesser pelvis — the space below the linea terminalis", "e": "pelvis (L. pelvis: basin, bowl) + minor (L. minor: lesser, smaller)", "p": 54}, {"t": "Linea terminalis", "m": "Terminal line — line extending along the arcuate line from the promontory to the upper margin of the symphysis", "e": "linea (L. linea: line, from linum = thread) + terminalis (L. terminalis: of a boundary, from terminus = boundary, end)", "p": 54}, {"t": "Apertura pelvis superior", "m": "Upper pelvic aperture (pelvic inlet) — upper opening of the lesser pelvis in the plane of the linea terminalis", "e": "apertura (L. apertura: opening, from aperire = to open) + pelvis (L. pelvis: basin, bowl) + superior (L. superior: upper, higher)", "p": 54}, {"t": "Apertura pelvis inferior", "m": "Lower pelvic aperture (pelvic outlet) — lower opening of the lesser pelvis between the coccyx, pubic arch and sacrotuberous ligaments", "e": "apertura (L. apertura: opening, from aperire = to open) + pelvis (L. pelvis: basin, bowl) + inferior (L. inferior: lower)", "p": 54}, {"t": "Axis pelvis", "m": "Pelvic axis — imaginary line passing through all median connecting lines between the symphysis and the anterior surface of the sacrum", "e": "axis (L. axis: axle, pivot, central line) + pelvis (L. pelvis: basin, bowl)", "p": 54}, {"t": "Diameter conjugata", "m": "Conjugate diameter — anteroposterior diameter of the pelvis, measured from the sacral promontory to the posterior surface of the symphysis (about 11 cm)", "e": "diameter (Gk. diametros: diagonal measure, from dia = through + metron = measure) + conjugata (L. conjugatus: joined together, from con = together + jugum = yoke)", "p": 54}, {"t": "Diameter transversa", "m": "Transverse diameter of pelvis — widest part of the inlet (ca. 13 cm)", "e": "diameter (Gk. diametros: diagonal measure, from dia = through + metron = measure) + transversa (L. transversus: turned across, from trans = across + vertere = to turn)", "p": 54}, {"t": "Diameter obliqua", "m": "Oblique diameter — measured from the iliosacral joint obliquely forward to the iliopubic eminence of the opposite side (ca. 12.5 cm)", "e": "diameter (Gk. diametros: diagonal measure, from dia = through + metron = measure) + obliqua (L. obliquus: slanting, oblique)", "p": 54}, {"t": "Inclinatio pelvis", "m": "Pelvic inclination — the angle between the plane of the pelvic inlet and the horizontal plane", "e": "inclinatio (L. inclinatio: inclination, leaning, from inclinare = to lean, bend) + pelvis (L. pelvis: basin, bowl)", "p": 54}, {"t": "Pars libera membri inferioris", "m": "Free lower limb", "e": "pars (L. pars: part) + libera (L. liber: free) + membri (L. membrum: limb, member) + inferioris (L. inferior: lower)", "p": 56}, {"t": "Os femoris", "m": "Thigh bone / Femur", "e": "os (L. os: bone) + femoris (L. femur/femoris: thigh)", "p": 56}, {"t": "Caput femoris", "m": "Head of femur", "e": "caput (L. caput: head) + femoris (L. femur/femoris: thigh)", "p": 56}, {"t": "Fovea capitis femoris", "m": "Pit (fovea) in the head of the femur", "e": "fovea (L. fovea: pit, small depression) + capitis (L. caput/capitis: head) + femoris (L. femur/femoris: thigh)", "p": 56}, {"t": "Collum femoris", "m": "Neck of femur", "e": "collum (L. collum: neck) + femoris (L. femur/femoris: thigh)", "p": 56}, {"t": "Trochanter major", "m": "Greater trochanter", "e": "trochanter (Gk. trochantēr: runner, from trechein = to run) + major (L. major: greater, larger)", "p": 56}, {"t": "Fossa trochanterica", "m": "Trochanteric fossa", "e": "fossa (L. fossa: ditch, pit, depression) + trochanterica (Gk./L. trochantēr: runner + -ica: pertaining to)", "p": 56}, {"t": "Trochanter minor", "m": "Lesser trochanter", "e": "trochanter (Gk. trochantēr: runner, from trechein = to run) + minor (L. minor: lesser, smaller)", "p": 56}, {"t": "Linea aspera", "m": "Rough double line on the posterior aspect of the femur", "e": "linea (L. linea: line) + aspera (L. asper: rough)", "p": 56}, {"t": "Linea intertrochanterica", "m": "Intertrochanteric line", "e": "linea (L. linea: line) + inter (L. inter: between) + trochanterica (Gk./L. trochantēr: runner + -ica: pertaining to)", "p": 56}, {"t": "Tuberculum quadratum", "m": "Quadrate tubercle", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber) + quadratum (L. quadratus: square, four-sided)", "p": 56}, {"t": "Crista intertrochanterica", "m": "Intertrochanteric crest", "e": "crista (L. crista: crest, ridge) + inter (L. inter: between) + trochanterica (Gk./L. trochantēr: runner + -ica: pertaining to)", "p": 56}, {"t": "Corpus femoris", "m": "Shaft of femur", "e": "corpus (L. corpus: body, shaft) + femoris (L. femur/femoris: thigh)", "p": 56}, {"t": "Labium laterale", "m": "Lateral lip of the linea aspera", "e": "labium (L. labium: lip) + laterale (L. lateralis: of the side, from latus = side)", "p": 56}, {"t": "Labium mediale", "m": "Medial lip of the linea aspera", "e": "labium (L. labium: lip) + mediale (L. medialis: middle, from medius = middle)", "p": 56}, {"t": "Linea pectinea", "m": "Pectineal line", "e": "linea (L. linea: line) + pectinea (L. pecten/pectinis: comb, referring to pectineus muscle)", "p": 56}, {"t": "Tuberositas glutaealis", "m": "Gluteal tuberosity", "e": "tuberositas (L. tuberositas: tuberosity, from tuber = swelling) + glutaealis (Gk. gloutos: buttock + L. -alis: pertaining to)", "p": 56}, {"t": "Fossa intercondylaris", "m": "Intercondylar fossa", "e": "fossa (L. fossa: pit, depression) + inter (L. inter: between) + condylaris (Gk. kondylos: knuckle, condyle + L. -aris: pertaining to)", "p": 56}, {"t": "Linea intercondylaris", "m": "Intercondylar line", "e": "linea (L. linea: line) + inter (L. inter: between) + condylaris (Gk. kondylos: knuckle, condyle + L. -aris: pertaining to)", "p": 56}, {"t": "Facies poplitea", "m": "Popliteal surface", "e": "facies (L. facies: surface, face) + poplitea (L. poples/poplitis: back of the knee + -ea: pertaining to)", "p": 56}, {"t": "Linea supracondylaris medialis", "m": "Medial supracondylar line", "e": "linea (L. linea: line) + supra (L. supra: above) + condylaris (Gk. kondylos: knuckle + L. -aris: pertaining to) + medialis (L. medialis: medial, from medius = middle)", "p": 56}, {"t": "Linea supracondylaris lateralis", "m": "Lateral supracondylar line", "e": "linea (L. linea: line) + supra (L. supra: above) + condylaris (Gk. kondylos: knuckle + L. -aris: pertaining to) + lateralis (L. lateralis: of the side, from latus = side)", "p": 56}, {"t": "Condylus medialis", "m": "Medial condyle", "e": "condylus (Gk. kondylos: knuckle, condyle) + medialis (L. medialis: medial, from medius = middle)", "p": 56}, {"t": "Tuberculum adductorium", "m": "Adductor tubercle", "e": "tuberculum (L. tuberculum: small swelling, from tuber = swelling) + adductorium (L. adducere: to lead toward, from ad = toward + ducere = to lead)", "p": 56}, {"t": "Condylus lateralis", "m": "Lateral condyle", "e": "condylus (Gk. kondylos: knuckle, condyle) + lateralis (L. lateralis: of the side, from latus = side)", "p": 56}, {"t": "Sulcus popliteus", "m": "Groove for popliteus", "e": "sulcus (L. sulcus: groove, furrow) + popliteus (L. poples/poplitis: back of the knee + -eus: pertaining to)", "p": 56}, {"t": "Facies patellaris", "m": "Patellar surface", "e": "facies (L. facies: surface, face) + patellaris (L. patella: small pan, kneecap + -aris: pertaining to)", "p": 56}, {"t": "Facies articularis fibularis", "m": "Articular facet for the fibula", "e": "facies (L. facies: surface, face) + articularis (L. articularis: of a joint) + fibularis (L. fibula: clasp, buckle + -aris: pertaining to)", "p": 56}, {"t": "Area intercondylaris anterior", "m": "Anterior intercondylar area", "e": "area (L. area: open space, area) + inter (L. inter: between) + condylaris (Gk. kondylos: knuckle + L. -aris: pertaining to) + anterior (L. anterior: front, former)", "p": 56}, {"t": "Area intercondylaris posterior", "m": "Posterior intercondylar area", "e": "area (L. area: open space, area) + inter (L. inter: between) + condylaris (Gk. kondylos: knuckle + L. -aris: pertaining to) + posterior (L. posterior: behind, latter)", "p": 56}, {"t": "Eminentia intercondylaris", "m": "Intercondylar eminence", "e": "eminentia (L. eminentia: eminence, projection, from eminere = to stand out) + inter (L. inter: between) + condylaris (Gk. kondylos: knuckle + L. -aris: pertaining to)", "p": 56}, {"t": "Tuberculum intercondylare mediale", "m": "Medial intercondylar tubercle", "e": "tuberculum (L. tuberculum: small swelling, from tuber = swelling) + inter (L. inter: between) + condylare (Gk. kondylos: knuckle + L. -are: pertaining to) + mediale (L. medialis: medial, from medius = middle)", "p": 56}, {"t": "Tuberculum intercondylare laterale", "m": "Lateral intercondylar tubercle", "e": "tuberculum (L. tuberculum: small swelling, from tuber = swelling) + inter (L. inter: between) + condylare (Gk. kondylos: knuckle + L. -are: pertaining to) + laterale (L. lateralis: of the side, from latus = side)", "p": 56}, {"t": "Corpus tibiae", "m": "Shaft of tibia", "e": "corpus (L. corpus: body, shaft) + tibiae (L. tibia: shinbone, flute)", "p": 58}, {"t": "Tuberositas tibiae", "m": "Tibial tuberosity — roughened area on the upper end of the anterior margin of the tibia", "e": "tuberositas (L. tuberōsitās: knobby projection, from tuber = swelling) + tibiae (L. tibia: shinbone)", "p": 58}, {"t": "Linea musculi solei", "m": "Soleal line of tibia — line extending obliquely from the upper, lateral part of the tibia", "e": "linea (L. līnea: line) + musculi (L. musculus: muscle, diminutive of mus = mouse) + solei (L. solea: sole/sandal, referring to the soleus muscle)", "p": 58}, {"t": "Malleolus medialis", "m": "Medial malleolus", "e": "malleolus (L. malleolus: small hammer, diminutive of malleus = hammer) + medialis (L. mediālis: of the middle, from medius = middle)", "p": 58}, {"t": "Sulcus malleolaris", "m": "Malleolar groove — small groove on the posterior aspect of the medial malleolus", "e": "sulcus (L. sulcus: groove, furrow) + malleolaris (L. malleolāris: of the malleolus, from malleolus = small hammer)", "p": 58}, {"t": "Facies articularis malleoli", "m": "Articular surface of malleolus — lateral surface of the medial malleolus facing the talus", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint, from articulus = joint) + malleoli (L. malleolus: small hammer)", "p": 58}, {"t": "Incisura fibularis", "m": "Fibular notch — depression on the lateral surface of the distal end of the tibia", "e": "incisura (L. incisūra: notch, incision, from incidere = to cut into) + fibularis (L. fibulāris: of the fibula, from fibula = clasp/pin)", "p": 58}, {"t": "Caput fibulae", "m": "Head of fibula — the proximal end of the fibula", "e": "caput (L. caput: head) + fibulae (L. fibula: clasp, pin, the smaller leg bone)", "p": 58}, {"t": "Facies articularis capitis fibulae", "m": "Articular surface facing the tibia at the proximal end of the fibula", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + capitis (L. caput: head, genitive capitis) + fibulae (L. fibula: clasp, pin)", "p": 58}, {"t": "Apex capitis fibulae", "m": "Apex (styloid process) of head of fibula — upward pointing process on the head of the fibula", "e": "apex (L. apex: tip, point) + capitis (L. caput: head, genitive capitis) + fibulae (L. fibula: clasp, pin)", "p": 58}, {"t": "Collum fibulae", "m": "Neck of fibula", "e": "collum (L. collum: neck) + fibulae (L. fibula: clasp, pin)", "p": 58}, {"t": "Corpus fibulae", "m": "Shaft of fibula", "e": "corpus (L. corpus: body, shaft) + fibulae (L. fibula: clasp, pin)", "p": 58}, {"t": "Crista medialis", "m": "Medial crest — bony ridge on the posterior surface at the border between the origins of the tibialis posterior and flexor hallucis longus muscles", "e": "crista (L. crista: crest, ridge) + medialis (L. mediālis: of the middle, from medius = middle)", "p": 58}, {"t": "Malleolus lateralis", "m": "Lateral malleolus", "e": "malleolus (L. malleolus: small hammer, diminutive of malleus = hammer) + lateralis (L. laterālis: of the side, from latus = side)", "p": 58}, {"t": "Fossa malleoli lateralis", "m": "Lateral malleolar fossa — depression on the posteromedial aspect of the lateral malleolus for attachment of the posterior talofibular ligament", "e": "fossa (L. fossa: pit, ditch, from fodere = to dig) + malleoli (L. malleolus: small hammer) + lateralis (L. laterālis: of the side, from latus = side)", "p": 58}, {"t": "Basis patellae", "m": "Base of patella — broad, superior border of the patella", "e": "basis (Gk./L. basis: base, from Gk. bainein = to go/stand) + patellae (L. patella: small pan/dish, diminutive of patina = pan)", "p": 58}, {"t": "Apex patellae", "m": "Apex of patella — inferior, pointed border of the patella", "e": "apex (L. apex: tip, point) + patellae (L. patella: small pan/dish, diminutive of patina = pan)", "p": 58}, {"t": "Ossa pedis", "m": "Bones of the foot", "e": "ossa (L. os/ossa: bones) + pedis (L. pes/pedis: of the foot)", "p": 60}, {"t": "Tarsus", "m": "The region of articulation extending from the heel to the metatarsals", "e": "tarsus (Gk. tarsos: flat surface, sole of the foot, ankle)", "p": 60}, {"t": "Ossa tarsi", "m": "Tarsal bones", "e": "ossa (L. os/ossa: bones) + tarsi (Gk. tarsos: of the ankle/flat surface)", "p": 60}, {"t": "Tarsalia", "m": "Tarsal bones", "e": "tarsalia (Gk. tarsos: ankle, plural neuter adjectival form)", "p": 60}, {"t": "Talus", "m": "The ankle bone, located between the tibia, calcaneus, navicular bone, and fibula", "e": "talus (L. talus: ankle bone, knucklebone)", "p": 60}, {"t": "Caput tali", "m": "Head of the talus — articulates with the navicular bone", "e": "caput (L. caput: head) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Talare", "m": "Of the talus", "e": "talare (L. talaris: relating to the talus/ankle)", "p": 60}, {"t": "Collum tali", "m": "Neck of the talus — proximal tapering part of the head of the talus", "e": "collum (L. collum: neck) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Corpus tali", "m": "Body of the talus", "e": "corpus (L. corpus: body) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Trochlea tali", "m": "Cylindrical surface of the talus that articulates with the tibia and fibula", "e": "trochlea (Gk. trochilia: pulley, wheel-block) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Facies superior", "m": "Superior surface — upper surface of the talus that articulates with the inferior articular surface of the tibia", "e": "facies (L. facies: face, surface) + superior (L. superior: upper, higher)", "p": 60}, {"t": "Facies malleolaris medialis", "m": "Medial malleolar surface — almost sagittally oriented surface of the talus that articulates with the medial malleolus", "e": "facies (L. facies: face, surface) + malleolaris (L. malleolus: little hammer, diminutive of malleus) + medialis (L. medialis: middle, medial)", "p": 60}, {"t": "Facies malleolaris lateralis", "m": "Lateral malleolar surface — surface on the lateral part of the talus that articulates with the lateral malleolus", "e": "facies (L. facies: face, surface) + malleolaris (L. malleolus: little hammer) + lateralis (L. lateralis: of the side, from latus = side)", "p": 60}, {"t": "Processus lateralis tali", "m": "Lateral process of the talus — bony projection below the lateral malleolar surface", "e": "processus (L. processus: projection, going forward) + lateralis (L. lateralis: of the side) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Facies articularis calcanea posterior", "m": "Posterior calcanean facet — posteroinferior surface that articulates with the calcaneus", "e": "facies (L. facies: surface) + articularis (L. articularis: of a joint) + calcanea (L. calcaneus: heel bone, from calx = heel) + posterior (L. posterior: behind, hinder)", "p": 60}, {"t": "Sulcus tali", "m": "Sulcus of talus — a groove between the middle and posterior articular facets for the calcaneus", "e": "sulcus (L. sulcus: groove, furrow) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Facies articularis calcanea media", "m": "Middle calcanean facet — middle articular surface of the calcaneus", "e": "facies (L. facies: surface) + articularis (L. articularis: of a joint) + calcanea (L. calcaneus: heel bone) + media (L. medius: middle)", "p": 60}, {"t": "Facies articularis calcanea anterior", "m": "Anterior calcanean facet — anterior articular surface of the calcaneus below the head of the talus", "e": "facies (L. facies: surface) + articularis (L. articularis: of a joint) + calcanea (L. calcaneus: heel bone) + anterior (L. anterior: before, in front)", "p": 60}, {"t": "Facies articularis navicularis", "m": "Surface on the anterior part of the head of the talus that articulates with the navicular bone", "e": "facies (L. facies: surface) + articularis (L. articularis: of a joint) + navicularis (L. navicularis: boat-shaped, from navicula = little boat)", "p": 60}, {"t": "Processus posterior tali", "m": "Posterior process of the talus — broad process below the posterior margin of the trochlea", "e": "processus (L. processus: projection) + posterior (L. posterior: behind) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Sulcus tendinis m. flex. hall. longi", "m": "Groove for the flexor hallucis longus tendon posteromedial to the posterior process of the talus", "e": "sulcus (L. sulcus: groove) + tendinis (L. tendo/tendinis: tendon, from tendere = to stretch) + musculi (L. musculus: muscle) + flexoris (L. flexor: bender, from flectere = to bend) + hallucis (L. hallux/hallucis: big toe) + longi (L. longus: long, genitive)", "p": 60}, {"t": "Tuberculum mediale", "m": "Medial tubercle — bony process anteromedial to the groove for the flexor hallucis longus tendon", "e": "tuberculum (L. tuberculum: small lump/swelling, diminutive of tuber) + mediale (L. medialis: medial, middle)", "p": 60}, {"t": "Tuberculum laterale", "m": "Lateral tubercle — bony process lateral to the groove for the flexor hallucis longus tendon", "e": "tuberculum (L. tuberculum: small lump/swelling, diminutive of tuber) + laterale (L. lateralis: of the side)", "p": 60}, {"t": "Os trigonum", "m": "Independent bone occasionally formed by the lateral tubercle of the posterior process of the talus due to a separate ossific center", "e": "os (L. os: bone) + trigonum (Gk. trigonon: triangle, from tri = three + gonia = angle)", "p": 60}, {"t": "Calcaneus", "m": "Heel bone", "e": "calcaneus (L. calcaneus: heel bone, from calx = heel)", "p": 60}, {"t": "Tuber calcanei", "m": "Tuberosity on the posterior aspect of the calcaneus", "e": "tuber (L. tuber: swelling, protuberance) + calcanei (L. calcaneus: of the heel bone, genitive)", "p": 60}, {"t": "Processus medialis tuberis calcanei", "m": "Medial process of the calcaneus — weak process anterior, medial and inferior to the tuberosity of the calcaneus", "e": "processus (L. processus: projection) + medialis (L. medialis: medial) + tuberis (L. tuber: of the swelling, genitive) + calcanei (L. calcaneus: of the heel bone, genitive)", "p": 60}, {"t": "Processus lateralis tuberis calcanei", "m": "Lateral process of the calcaneus — weak process inferolateral to the tuberosity of the calcaneus", "e": "processus (L. processus: projection) + lateralis (L. lateralis: of the side) + tuberis (L. tuber: of the swelling, genitive) + calcanei (L. calcaneus: of the heel bone, genitive)", "p": 60}, {"t": "Tuberculum calcanei", "m": "Anterior tubercle of the calcaneus — eminence on the anterior aspect of the inferior surface of the calcaneus", "e": "tuberculum (L. tuberculum: small swelling/lump) + calcanei (L. calcaneus: of the heel bone, genitive)", "p": 60}, {"t": "Sustentaculum tali", "m": "Medial prolongation of the calcaneus bearing the medial posterior facet of the calcaneus", "e": "sustentaculum (L. sustentaculum: support, prop, from sustentare = to support) + tali (L. talus: of the ankle bone, genitive)", "p": 60}, {"t": "Sulcus calcanei", "m": "Groove between the middle and posterior articular facets", "e": "sulcus (L. sulcus: groove, furrow) + calcanei (L. calcaneus: of the heel bone, genitive)", "p": 60}, {"t": "Sinus tarsi", "m": "Laterally opening, funnel-shaped space forming a continuation of the calcaneal sulcus and the sulcus of the talus", "e": "sinus (L. sinus: cavity, hollow, bay) + tarsi (Gk. tarsos: of the ankle/flat surface, genitive)", "p": 60}, {"t": "Facies articularis talaris anterior", "m": "Anterior facet for the talus — small anterior articular surface for the head of the talus", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint, from articulus = joint) + talaris (L. talāris: of the talus, from talus = ankle bone) + anterior (L. anterior: more in front, former)", "p": 62}, {"t": "Facies articularis talaris media", "m": "Middle facet for the talus — middle articular surface for the talus separated from the posterior facet by the sulcus calcanei", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + talaris (L. talāris: of the talus) + media (L. media: middle, from medius = middle)", "p": 62}, {"t": "Facies articularis talaris posterior", "m": "Posterior facet for the talus — large posterior surface for articulation with the talus", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + talaris (L. talāris: of the talus) + posterior (L. posterior: more behind, later)", "p": 62}, {"t": "Sulcus tendinis musculi peronei longi", "m": "Sulcus tendinis m. peronei (fibularis) longi — groove for the tendon of the peroneus longus muscle on the lateral aspect of the calcaneus below the peroneal trochlea", "e": "sulcus (L. sulcus: groove, furrow) + tendinis (L. tendo/tendinis: tendon, from tendere = to stretch) + musculi (L. musculus: muscle, little mouse) + peronei (Gk. perōnē: fibula, pin) + longi (L. longus: long)", "p": 62}, {"t": "Trochlea peronealis (fibularis)", "m": "Peroneal trochlea — bony eminence above the groove for the tendon of the peroneus longus, functions like a pulley", "e": "trochlea (Gk. trochilia: pulley, from trochos = wheel) + peronealis (Gk. perōnē: fibula, pin + L. -alis: pertaining to) + fibularis (L. fibula: pin, clasp + -aris: pertaining to)", "p": 62}, {"t": "Facies articularis cuboidea", "m": "Facies articularis cuboidea — cuboid articular surface forming the anterior aspect of the calcaneus", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + cuboidea (Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form)", "p": 62}, {"t": "Os naviculare", "m": "Navicular bone — bone medial to the head of the talus and the three cuneiform bones", "e": "os (L. os/ossis: bone) + naviculare (L. naviculāris: boat-shaped, from navicula = little boat, from navis = ship)", "p": 62}, {"t": "Tuberositas ossis navicularis", "m": "Tuberosity of navicular bone — rough area on the inferomedial aspect of the navicular bone, for attachment of the tibialis posterior muscle", "e": "tuberositas (L. tuberositās: bumpiness, from tuber = lump, swelling) + ossis (L. os/ossis: bone) + navicularis (L. naviculāris: boat-shaped, from navicula = little boat)", "p": 62}, {"t": "Os cuneiforme mediale", "m": "Medial cuneiform — most medial of the cuneiform bones, located between the navicular and the 1st metatarsal bones", "e": "os (L. os/ossis: bone) + cuneiforme (L. cuneus: wedge + forma: shape, form) + mediale (L. mediālis: medial, from medius = middle)", "p": 62}, {"t": "Os cuneiforme intermedium", "m": "Intermediate cuneiform — middle cuneiform bone located between the navicular and 2nd metatarsal bones", "e": "os (L. os/ossis: bone) + cuneiforme (L. cuneus: wedge + forma: shape) + intermedium (L. intermedius: intermediate, from inter = between + medius = middle)", "p": 62}, {"t": "Os cuneiforme laterale", "m": "Lateral cuneiform — most lateral cuneiform bone located between the navicular and 3rd metatarsal bones", "e": "os (L. os/ossis: bone) + cuneiforme (L. cuneus: wedge + forma: shape) + laterale (L. laterālis: lateral, from latus = side)", "p": 62}, {"t": "Os cuboideum", "m": "Cuboid bone — bone found between the calcaneus and the fourth and fifth metatarsals", "e": "os (L. os/ossis: bone) + cuboideum (Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form)", "p": 62}, {"t": "Sulcus tendinis musculi peronei (fibularis) longi", "m": "Groove for tendon of peroneus longus — groove on the inferolateral aspect of the cuboid that serves as a guide for the tendon", "e": "sulcus (L. sulcus: groove, furrow) + tendinis (L. tendo/tendinis: tendon) + musculi (L. musculus: muscle) + peronei (Gk. perōnē: fibula, pin) + fibularis (L. fibula: pin, clasp) + longi (L. longus: long)", "p": 62}, {"t": "Tuberositas ossis cuboidei", "m": "Tuberosity of cuboid — bony elevation on the inferior aspect of the cuboid bone proximal to the groove for the peroneus longus", "e": "tuberositas (L. tuberositās: bumpiness, from tuber = lump) + ossis (L. os/ossis: bone) + cuboidei (Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form)", "p": 62}, {"t": "Processus calcaneus", "m": "Calcanean process — plantar process of the cuboid bone; the inferior segment of the proximal articular surface projects upwardly and obliquely to support the calcaneus", "e": "processus (L. prōcessus: projection, going forward, from procedere = to go forward) + calcaneus (L. calcaneus: heel bone, from calx = heel)", "p": 62}, {"t": "Metatarsus", "m": "Metatarsus — the part of the foot situated between the tarsus and the toes, comprising five metatarsal bones", "e": "meta- (Gk. meta: after, beyond) + tarsus (Gk. tarsos: flat of the foot, ankle)", "p": 62}, {"t": "Ossa metatarsi (metatarsalia) [I–V]", "m": "Metatarsal bones — the five metatarsal bones", "e": "ossa (L. os/ossis: bone, plural ossa) + metatarsi (Gk. meta: after/beyond + tarsos: flat of foot) + metatarsalia (Gk. meta: after/beyond + tarsos: flat of foot + L. -alia: pertaining to, plural)", "p": 62}, {"t": "Basis metatarsalis", "m": "Base of metatarsal bone — the thickened proximal end of the metatarsal bones", "e": "basis (Gk./L. basis: base, foundation) + metatarsalis (Gk. meta: after/beyond + tarsos: flat of foot + L. -alis: pertaining to)", "p": 62}, {"t": "Corpus metatarsale", "m": "Shaft of metatarsal bone", "e": "corpus (L. corpus: body, shaft) + metatarsale (Gk. meta: after/beyond + tarsos: flat of foot + L. -ale: pertaining to)", "p": 62}, {"t": "Caput metatarsale", "m": "Head of metatarsal bone", "e": "caput (L. caput: head) + metatarsale (Gk. meta: after/beyond + tarsos: flat of foot + L. -ale: pertaining to)", "p": 62}, {"t": "Tuberositas ossis metatarsalis primi (I)", "m": "Tuberosity of first metatarsal — protuberance projecting downward and laterally from the proximal part of the first metatarsal bone", "e": "tuberositas (L. tuberositās: bumpiness, from tuber = lump) + ossis (L. os/ossis: bone) + metatarsalis (Gk. meta + tarsos + L. -alis) + primi (L. primus: first)", "p": 62}, {"t": "Tuberositas ossis metatarsalis quinti (V)", "m": "Tuberosity of fifth metatarsal — protuberance projecting laterally from the proximal part of the fifth metatarsal bone, attachment site of the peroneus brevis muscle", "e": "tuberositas (L. tuberositās: bumpiness, from tuber = lump) + ossis (L. os/ossis: bone) + metatarsalis (Gk. meta + tarsos + L. -alis) + quinti (L. quintus: fifth)", "p": 62}, {"t": "Ossa digitorum pedis", "m": "Phalanges of toes", "e": "ossa (L. os/ossis: bone, plural) + digitorum (L. digitus: finger, toe, genitive plural) + pedis (L. pes/pedis: foot)", "p": 62}, {"t": "Phalanges", "m": "Phalanges — osseous segments or bones that comprise the toes", "e": "phalanges (Gk. phalanx/phalanges: line of soldiers, bone of finger or toe, from phalangx = military formation)", "p": 62}, {"t": "Suturae cranii", "m": "Sutures of the skull", "e": "suturae (L. sutura: seam, from suere = to sew) + cranii (L. cranium, from Gk. kranion: skull)", "p": 64}, {"t": "Sutura coronalis", "m": "Coronal suture — lies between the frontal bone and the two parietal bones", "e": "sutura (L. sutura: seam, from suere = to sew) + coronalis (L. coronalis: of a crown, from corona = crown)", "p": 64}, {"t": "Sutura sagittalis", "m": "Sagittal suture — median suture situated between the right and left parietal bones", "e": "sutura (L. sutura: seam, from suere = to sew) + sagittalis (L. sagittalis: arrow-like, from sagitta = arrow)", "p": 64}, {"t": "Sutura lamboidea", "m": "Lambdoidal suture — located between the occipital bone and the two parietal bones", "e": "sutura (L. sutura: seam, from suere = to sew) + lamboidea (Gk. lambda: the Greek letter λ + eidos = form, shape)", "p": 64}, {"t": "Sutura occipitomastoidea", "m": "Occipitomastoid suture — continuation of the lambdoidal suture that extends to the base of the skull", "e": "sutura (L. sutura: seam) + occipito (L. occiput: back of the head, from ob = against + caput = head) + mastoidea (Gk. mastos: breast + eidos = form, shape)", "p": 64}, {"t": "Sutura sphenofrontalis", "m": "Sphenofrontal suture — smooth suture that extends flatly upward and backward lateral to the skull", "e": "sutura (L. sutura: seam) + spheno (Gk. sphen: wedge) + frontalis (L. frontalis: of the forehead, from frons = forehead, brow)", "p": 64}, {"t": "Sutura sphenoethmoidalis", "m": "Sphenoethmoidal suture — short line in front of the jugum sphenoidale that connects the body of the sphenoid and the ethmoid", "e": "sutura (L. sutura: seam) + spheno (Gk. sphen: wedge) + ethmoidalis (Gk. ethmos: sieve + eidos = form)", "p": 64}, {"t": "Sutura sphenosquamosa", "m": "Sphenosquamosal suture — line of junction between the squamous portion of the temporal bone and the greater wing of the sphenoid", "e": "sutura (L. sutura: seam) + spheno (Gk. sphen: wedge) + squamosa (L. squamosus: scaly, from squama = scale)", "p": 64}, {"t": "Sutura sphenoparietalis", "m": "Sphenoparietal suture — line of junction between the greater wing of the sphenoid and the parietal bone", "e": "sutura (L. sutura: seam) + spheno (Gk. sphen: wedge) + parietalis (L. parietalis: of a wall, from paries = wall)", "p": 64}, {"t": "Sutura squamosa", "m": "Squamous suture — line of junction between the squamous temporal and parietal bones", "e": "sutura (L. sutura: seam) + squamosa (L. squamosus: scaly, from squama = scale)", "p": 64}, {"t": "Sutura metopica", "m": "Frontal (metopic) suture — suture connecting the right and left halves of the frontal bone", "e": "sutura (L. sutura: seam) + metopica (Gk. metopon: forehead, from meta = between + ops = eye)", "p": 64}, {"t": "Sutura parietomastoidea", "m": "Parietomastoid suture — posterior suture connecting the parietal bone and the mastoid process of the temporal bone", "e": "sutura (L. sutura: seam) + parieto (L. paries: wall) + mastoidea (Gk. mastos: breast + eidos = form)", "p": 64}, {"t": "Sutura squamosomastoidea", "m": "Squamosomastoid suture — line of junction between the squamous and mastoid portions of the temporal bone", "e": "sutura (L. sutura: seam) + squamoso (L. squamosus: scaly, from squama = scale) + mastoidea (Gk. mastos: breast + eidos = form)", "p": 64}, {"t": "Sutura frontonasalis", "m": "Frontonasal suture — anterior line of junction between the frontal and nasal bones", "e": "sutura (L. sutura: seam) + fronto (L. frons: forehead) + nasalis (L. nasalis: of the nose, from nasus = nose)", "p": 64}, {"t": "Sutura frontoethmoidalis", "m": "Frontoethmoidal suture — internal line of junction between the ethmoid and frontal bones", "e": "sutura (L. sutura: seam) + fronto (L. frons: forehead) + ethmoidalis (Gk. ethmos: sieve + eidos = form)", "p": 64}, {"t": "Sutura frontomaxillaris", "m": "Frontomaxillary suture — suture lateral to the nasal bone connecting the nasal portion of the frontal bone and the frontal process of the maxilla", "e": "sutura (L. sutura: seam) + fronto (L. frons: forehead) + maxillaris (L. maxillaris: of the jaw, from maxilla = jaw)", "p": 64}, {"t": "Sutura frontolacrimalis", "m": "Frontolacrimal suture — line of junction between the frontal and lacrimal bones", "e": "sutura (L. sutura: seam) + fronto (L. frons: forehead) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 64}, {"t": "Sutura frontozygomatica", "m": "Frontozygomatic suture — suture at the lateral margin of the orbit between the frontal and zygomatic bones", "e": "sutura (L. sutura: seam) + fronto (L. frons: forehead) + zygomatica (Gk. zygon: yoke + -oma = swelling/process)", "p": 64}, {"t": "Sutura ethmoidomaxillaris", "m": "Ethmoidomaxillary suture — suture in the medial wall of the orbit connecting the orbital plate of the ethmoid bone and the maxilla", "e": "sutura (L. sutura: seam) + ethmoid (Gk. ethmos: sieve + eidos = form) + maxillaris (L. maxilla: jaw)", "p": 64}, {"t": "Sutura ethmoidolacrimalis", "m": "Ethmoidolacrimal suture — suture in the medial wall of the orbit between the ethmoid and lacrimal bones", "e": "sutura (L. sutura: seam) + ethmoid (Gk. ethmos: sieve + eidos = form) + lacrimalis (L. lacrima: tear)", "p": 64}, {"t": "Sutura sphenovomeriana", "m": "Sphenovomerine suture — suture at the nasal septum connecting the sphenoid bone and the vomer", "e": "sutura (L. sutura: seam) + spheno (Gk. sphen: wedge) + vomeriana (L. vomer: ploughshare)", "p": 64}, {"t": "Sutura sphenozygomatica", "m": "Sphenozygomatic suture — suture in the lateral wall of the orbit connecting the greater wing of the sphenoid and zygomatic bone", "e": "sutura (L. sutura: seam) + spheno (Gk. sphen: wedge) + zygomatica (Gk. zygon: yoke)", "p": 64}, {"t": "Sutura sphenomaxillaris", "m": "Sphenomaxillary suture — inconstant suture connecting the pterygoid process and the maxillae lateral to the palatine bone", "e": "sutura (L. sutura: seam) + spheno (Gk. sphen: wedge) + maxillaris (L. maxilla: jaw)", "p": 64}, {"t": "Sutura temporozygomatica", "m": "Temporozygomatic suture — suture connecting the zygomatic process of the temporal bone and the zygomatic bone on the lateral aspect of the zygomatic arch", "e": "sutura (L. sutura: seam) + temporo (L. tempora: temples of the head) + zygomatica (Gk. zygon: yoke)", "p": 64}, {"t": "Sutura internasalis", "m": "Internasal suture — suture connecting the right and left nasal bones", "e": "sutura (L. sutura: seam) + inter (L. inter: between) + nasalis (L. nasus: nose)", "p": 64}, {"t": "Sutura nasomaxillaris", "m": "Nasomaxillary suture — suture connecting the nasal bone and the frontal process of the maxilla", "e": "sutura (L. sutura: seam) + naso (L. nasus: nose) + maxillaris (L. maxilla: jaw)", "p": 64}, {"t": "Sutura lacrimomaxillaris", "m": "Lacrimomaxillary suture — suture connecting the anterior margin of the lacrimal bone and the maxilla", "e": "sutura (L. sutura: seam) + lacrimo (L. lacrima: tear) + maxillaris (L. maxilla: jaw)", "p": 64}, {"t": "Sutura lacrimoconchalis", "m": "Lacrimoconchal suture — suture within the nasal cavity connecting the lacrimal bone and the inferior nasal concha", "e": "sutura (L. sutura: seam) + lacrimo (L. lacrima: tear) + conchalis (Gk. konche: shell, conch)", "p": 64}, {"t": "Sutura intermaxillaris", "m": "Intermaxillary suture — medial line of junction between the right and left maxillary bones, located just below the anterior nasal spine", "e": "sutura (L. sutura: seam) + inter (L. inter: between) + maxillaris (L. maxilla: jaw)", "p": 64}, {"t": "Sutura palatomaxillaris", "m": "Palatomaxillary suture — line of junction between the palatine bone and the maxilla situated posteriorly in the orbit and on the lateral wall of the nasal cavity", "e": "sutura (L. sutura: seam) + palato (L. palatum: palate) + maxillaris (L. maxilla: jaw)", "p": 64}, {"t": "Sutura palatoethmoidalis", "m": "Palatoethmoidal suture — suture in the back of the orbit connecting the palatine and ethmoid bones", "e": "sutura (L. sutura: seam) + palato (L. palatum: palate) + ethmoidalis (Gk. ethmos: sieve + eidos = form)", "p": 64}, {"t": "Sutura palatina mediana", "m": "Median palatine suture — suture within the oral cavity connecting both halves of the palatine bone", "e": "sutura (L. sutura: seam) + palatina (L. palatum: palate) + mediana (L. medianus: middle, from medius = middle)", "p": 64}, {"t": "Sutura palatina transversa", "m": "Transverse palatine suture — line of junction between the palatine process of the maxilla and the palatine bone", "e": "sutura (L. sutura: seam) + palatina (L. palatum: palate) + transversa (L. transversus: crosswise, from trans = across + vertere = to turn)", "p": 64}, {"t": "Synchondroses cranii", "m": "Cranial synchondroses — cartilaginous joints between skull bones", "e": "synchondroses (Gk. syn: together + chondros: cartilage + osis: condition) + cranii (L. cranium, from Gk. kranion: skull)", "p": 66}, {"t": "Synchondrosis spheno-occipitalis", "m": "Spheno-occipital synchondrosis — developmental cartilaginous joint posero-inferior to the sella turcica between the sphenoid and occipital bones", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + osis: condition) + spheno (Gk. sphen: wedge) + occipitalis (L. occiput: back of the head, from ob: against + caput: head)", "p": 66}, {"t": "Synchondrosis sphenopetrosa", "m": "Sphenopetrosal synchondrosis — cartilaginous union between the sphenoid and petrous bones in the lateral continuation of the foramen lacerum", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + osis: condition) + spheno (Gk. sphen: wedge) + petrosa (L. petrosus: rocky, from petra: rock)", "p": 66}, {"t": "Synchondrosis petro-occipitalis", "m": "Petro-occipital synchondrosis — anteromedial cartilaginous continuation of the jugular foramen", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + osis: condition) + petro (L. petra: rock) + occipitalis (L. occiput: back of head, from ob: against + caput: head)", "p": 66}, {"t": "Synchondroses intraoccipitalis", "m": "Intraoccipital synchondroses — cartilaginous joints between developmental parts of the occipital bone", "e": "synchondroses (Gk. syn: together + chondros: cartilage + osis: condition) + intra (L. intra: within) + occipitalis (L. occiput: back of head, from ob: against + caput: head)", "p": 66}, {"t": "Synchondrosis intra-occipitalis posterior", "m": "Posterior intraoccipital synchondrosis — developmental synchondrosis between the posterior and lateral ossific centers of the occipital bone", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + osis: condition) + intra (L. intra: within) + occipitalis (L. occiput: back of head) + posterior (L. posterior: behind, later)", "p": 66}, {"t": "Synchondrosis intra-occipitalis anterior", "m": "Anterior intraoccipital synchondrosis — developmental cartilaginous joint between the anterior and lateral ossific centers of the occipital bone", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + osis: condition) + intra (L. intra: within) + occipitalis (L. occiput: back of head) + anterior (L. anterior: before, in front)", "p": 66}, {"t": "Synchondrosis spheno-ethmoidalis", "m": "Sphenoethmoidal synchondrosis — cartilaginous precursor of the spheno-ethmoidal suture", "e": "synchondrosis (Gk. syn: together + chondros: cartilage + osis: condition) + spheno (Gk. sphen: wedge) + ethmoidalis (Gk. ethmos: sieve + eidos: form/shape)", "p": 66}, {"t": "Articulationes columnae vertebralis", "m": "Joints of the vertebral column — connections of the vertebral column, thorax and skull", "e": "articulationes (L. articulatio: joint, from articulus: small joint) + columnae (L. columna: column, pillar) + vertebralis (L. vertebra: vertebra, from vertere: to turn)", "p": 66}, {"t": "Articulationes Thoracis et cranii", "m": "Joints of thorax and skull", "e": "articulationes (L. articulatio: joint) + thoracis (Gk. thorax: chest, breastplate) + et (L. et: and) + cranii (L. cranium, from Gk. kranion: skull)", "p": 66}, {"t": "Symphysis intervertebralis", "m": "Intervertebral symphysis — union between adjacent vertebral bodies", "e": "symphysis (Gk. sym: together + physis: growth) + inter (L. inter: between) + vertebralis (L. vertebra: vertebra, from vertere: to turn)", "p": 66}, {"t": "Discus intervertebralis", "m": "Intervertebral disc — an elastic plate consisting of ring-shaped fibrous lamellae, fibrocartilage, and a central gelatinous nucleus", "e": "discus (L. discus, from Gk. diskos: disc, quoit) + inter (L. inter: between) + vertebralis (L. vertebra: vertebra, from vertere: to turn)", "p": 66}, {"t": "Anulus fibrosus", "m": "Annular fibrous connection between adjacent vertebral bodies consisting of obliquely oriented connective tissue fibers", "e": "anulus (L. anulus: ring, small ring) + fibrosus (L. fibra: fiber + osus: full of)", "p": 66}, {"t": "Nucleus pulposus", "m": "Gelatinous, semifluid mass forming the central core of an intervertebral disc", "e": "nucleus (L. nucleus: kernel, from nux: nut) + pulposus (L. pulpa: flesh, soft material + osus: full of)", "p": 66}, {"t": "Ligamenta flava", "m": "Yellow ligaments — elastic networks of roughly parallel fibers between the vertebral arches", "e": "ligamenta (L. ligamentum: bandage, tie, from ligare: to bind) + flava (L. flavus: yellow)", "p": 66}, {"t": "Articulationes zygapophysiales", "m": "Zygapophysial joints — joints between articular processes of vertebrae", "e": "articulationes (L. articulatio: joint) + zygapophysiales (Gk. zygon: yoke + apo: away from + physis: growth)", "p": 66}, {"t": "Ligg. intertransversaria", "m": "Intertransverse ligaments — narrow ligaments between transverse processes of vertebrae", "e": "ligg. (L. ligamenta: ligaments, from ligare: to bind) + inter (L. inter: between) + transversaria (L. transversus: across, from trans: across + vertere: to turn)", "p": 66}, {"t": "Ligg. interspinalia", "m": "Interspinal ligaments — broad ligaments between adjacent spinous processes", "e": "ligg. (L. ligamenta: ligaments) + inter (L. inter: between) + spinalia (L. spina: spine, thorn)", "p": 66}, {"t": "Ligg. supraspinalia", "m": "Supraspinal ligaments — longitudinal ligaments connecting the tips of the spinous processes", "e": "ligg. (L. ligamenta: ligaments) + supra (L. supra: above) + spinalia (L. spina: spine, thorn)", "p": 66}, {"t": "Ligamentum nuchae", "m": "Sagittal extension of the supraspinal ligaments in the upper neck region", "e": "ligamentum (L. ligamentum: bandage, from ligare: to bind) + nuchae (ML. nucha: nape of neck, from Arabic nukha: spinal marrow)", "p": 66}, {"t": "Lig. longitudinale anterius", "m": "Anterior longitudinal ligament — longitudinal ligament attached to the ventral surface of the vertebral bodies", "e": "lig. (L. ligamentum: ligament) + longitudinale (L. longitudo: length, from longus: long) + anterius (L. anterior: in front, before)", "p": 66}, {"t": "Lig. longitudinale posterius", "m": "Posterior longitudinal ligament — longitudinal ligament connecting the intervertebral discs attached to dorsal surface of vertebral bodies", "e": "lig. (L. ligamentum: ligament) + longitudinale (L. longitudo: length, from longus: long) + posterius (L. posterior: behind, later)", "p": 66}, {"t": "Articulatio sacrococcygea", "m": "Sacrococcygeal joint — connection between the sacrum and coccyx", "e": "articulatio (L. articulatio: joint, from articulus: small joint) + sacro (L. sacer: sacred, holy — os sacrum: sacred bone) + coccygea (Gk. kokkyx: cuckoo, coccyx)", "p": 66}, {"t": "Lig. sacrococcygeum posterius (dorsale) superficiale", "m": "Superficial dorsal sacrococcygeal ligament", "e": "lig. (L. ligamentum: ligament) + sacrococcygeum (L. sacer: sacred + Gk. kokkyx: cuckoo/coccyx) + posterius (L. posterior: behind) + dorsale (L. dorsum: back) + superficiale (L. superficialis: on the surface, from super: above + facies: face/surface)", "p": 66}, {"t": "Lig. sacrococcygeum posterius (dorsale) profundum", "m": "Deep dorsal sacrococcygeal ligament", "e": "lig. (L. ligamentum: ligament) + sacrococcygeum (L. sacer: sacred + Gk. kokkyx: coccyx) + posterius (L. posterior: behind) + dorsale (L. dorsum: back) + profundum (L. profundus: deep, from pro: forward + fundus: bottom)", "p": 66}, {"t": "Lig. sacrococcygeum anterius (ventrale)", "m": "Ventral sacrococcygeal ligament", "e": "lig. (L. ligamentum: ligament) + sacrococcygeum (L. sacer: sacred + Gk. kokkyx: coccyx) + anterius (L. anterior: in front) + ventrale (L. venter: belly, front)", "p": 66}, {"t": "Lig. sacrococcygeum laterale", "m": "Lateral sacrococcygeal ligament", "e": "lig. (L. ligamentum: ligament) + sacrococcygeum (L. sacer: sacred + Gk. kokkyx: coccyx) + laterale (L. lateralis: of the side, from latus: side)", "p": 66}, {"t": "Articulatio atlantooccipitalis", "m": "Atlanto-occipital joint — joint between the atlas and the occipital bone", "e": "articulatio (L. articulatio: joint) + atlanto (Gk. Atlas: the Titan who held up the sky, first cervical vertebra) + occipitalis (L. occiput: back of head, from ob: against + caput: head)", "p": 66}, {"t": "Membrana atlanto-occipitalis anterior", "m": "Anterior atlanto-occipital membrane — membranous connection between the arch of the atlas and the occipital bone, lying in front of the apical ligament of the dens", "e": "membrana (L. membrana: membrane, skin, from membrum: limb) + atlanto (Gk. Atlas: the Titan, first cervical vertebra) + occipitalis (L. occiput: back of head) + anterior (L. anterior: in front)", "p": 66}, {"t": "Lig. atlanto-occipitale anterius", "m": "Anterior atlanto-occipital ligament — thickened portion of the atlanto-occipital membrane emanating from the anterior tubercle", "e": "lig. (L. ligamentum: ligament) + atlanto (Gk. Atlas: Titan, first cervical vertebra) + occipitale (L. occiput: back of head, from ob + caput) + anterius (L. anterior: in front)", "p": 66}, {"t": "Membrana atlanto-occipitalis posterior", "m": "Posterior atlanto-occipital membrane — connection between the arch of the atlas and the occipital bone situated in the posterior wall of the vertebral canal", "e": "membrana (L. membrana: membrane) + atlanto (Gk. Atlas: Titan, first cervical vertebra) + occipitalis (L. occiput: back of head) + posterior (L. posterior: behind)", "p": 66}, {"t": "Lig. atlanto-occipitale laterale", "m": "Lateral atlanto-occipital membrane — oblique tract of fibers extending from the transverse process of the atlas to the jugular process of the occipital bone", "e": "lig. (L. ligamentum: ligament) + atlanto (Gk. Atlas: Titan, first cervical vertebra) + occipitale (L. occiput: back of head) + laterale (L. lateralis: of the side, from latus: side)", "p": 66}, {"t": "Articulatio atlanto-axialis lateralis", "m": "Lateral atlanto-axial joint — joint between the inferior articular facet of the atlas and the superior articular facet of the axis", "e": "articulatio (L. articulātio: joint, from articulare = to divide into joints) + atlanto (Gk. Atlas: the titan who bears the world, used for first cervical vertebra) + axialis (L. axialis: of the axis, from axis = axle, pivot) + lateralis (L. laterālis: of the side, from latus = side)", "p": 68}, {"t": "Articulatio atlanto-axialis mediana", "m": "Median atlanto-axial joint — articulation between the atlas and the dens of the axis", "e": "articulatio (L. articulātio: joint) + atlanto (Gk. Atlas: titan, first cervical vertebra) + axialis (L. axialis: of the axis) + mediana (L. mediāna: middle, from medius = middle)", "p": 68}, {"t": "Ligg. alaria", "m": "Alar ligaments — paired ligaments extending from the dens of the axis to the lateral margin of the foramen magnum", "e": "ligg. (L. ligamenta: ligaments, pl. of ligamentum, from ligare = to bind) + alaria (L. alāria: of the wings, from ala = wing)", "p": 68}, {"t": "Lig. apicis dentis", "m": "Apical ligament of the dens — unpaired ligament extending from the apex of the dens to the anterior margin of the foramen magnum", "e": "lig. (L. ligamentum: ligament) + apicis (L. apex/apicis: tip, summit) + dentis (L. dens/dentis: tooth, here referring to the dens of the axis)", "p": 68}, {"t": "Lig. cruciforme atlantis", "m": "Cruciform ligament of atlas — cruciate ligament consisting of two ligamentous bands located between the dens and the tectorial membrane", "e": "lig. (L. ligamentum: ligament) + cruciforme (L. cruciformis: cross-shaped, from crux = cross + forma = shape) + atlantis (Gk. Atlas/atlantis: genitive of atlas, first cervical vertebra)", "p": 68}, {"t": "Fasciculi longitudinales", "m": "Longitudinal fasciculi of cruciform ligament — connective tissue tracts from the body of the axis to the anterior margin of the foramen magnum", "e": "fasciculi (L. fasciculus: small bundle, diminutive of fascis = bundle) + longitudinales (L. longitudinālis: longitudinal, from longitudo = length, from longus = long)", "p": 68}, {"t": "Lig. transversum atlantis", "m": "Transverse ligament of atlas — part of the cruciform ligament passing behind the dens and extending transversely from one side of the atlas to the other", "e": "lig. (L. ligamentum: ligament) + transversum (L. transversus: transverse, from trans = across + vertere = to turn) + atlantis (Gk. atlantis: genitive of atlas)", "p": 68}, {"t": "Membrana tectoria", "m": "Tectorial membrane — bilayered continuation of the posterior longitudinal ligament passing from the axis to the anterior margin of the foramen magnum", "e": "membrana (L. membrāna: membrane, thin skin, from membrum = limb) + tectoria (L. tectōria: of covering, from tegere = to cover)", "p": 68}, {"t": "Articulationes thoracis", "m": "Joints of thorax — articular connections of the skeleton of the thorax", "e": "articulationes (L. articulātiōnes: joints, pl. of articulatio) + thoracis (Gk. thōrax/thōracis: chest, breastplate)", "p": 68}, {"t": "Articulationes costovertebr ales", "m": "Costovertebral joints — joints between the ribs and vertebrae", "e": "articulationes (L. articulātiōnes: joints) + costo (L. costa: rib) + vertebrales (L. vertebrālis: of the vertebra, from vertebra = joint, from vertere = to turn)", "p": 68}, {"t": "Articulatio capitis costae", "m": "Joints of rib heads — articular unions that connect the heads of the ribs with the vertebral bodies and intervertebral discs", "e": "articulatio (L. articulātio: joint) + capitis (L. caput/capitis: head) + costae (L. costa/costae: rib)", "p": 68}, {"t": "Lig. capitis costae radiatum", "m": "Radiate ligament of head of rib — ligament radiating predominantly from the anterior side of the head of a rib to the adjacent vertebral body and intervertebral disc", "e": "lig. (L. ligamentum: ligament) + capitis (L. caput/capitis: head) + costae (L. costa: rib) + radiatum (L. radiātus: radiate, from radius = ray, spoke)", "p": 68}, {"t": "Lig. capitis costae intra-articulare", "m": "Intra-articular ligament of head of rib — ligament extending from the crest of the head of the rib to the intervertebral disc, lying between the two articular facets of the head of the rib", "e": "lig. (L. ligamentum: ligament) + capitis (L. caput/capitis: head) + costae (L. costa: rib) + intra (L. intra: within) + articulare (L. articulāris: of a joint)", "p": 68}, {"t": "Articulatio costotransversaria", "m": "Costotransverse joint — joint between the articular surface of the tubercle of the rib and the transverse process of the corresponding vertebra", "e": "articulatio (L. articulātio: joint) + costo (L. costa: rib) + transversaria (L. transversus: transverse, from trans = across + vertere = to turn)", "p": 68}, {"t": "Lig. costotransversarium", "m": "Costotransverse ligament — ligament between the neck of a rib and the transverse process of the corresponding vertebra", "e": "lig. (L. ligamentum: ligament) + costo (L. costa: rib) + transversarium (L. transversus: transverse)", "p": 68}, {"t": "Lig. costotransversarium superius", "m": "Superior costotransverse ligament — ligament extending from a rib to the next higher transverse process", "e": "lig. (L. ligamentum: ligament) + costo (L. costa: rib) + transversarium (L. transversus: transverse) + superius (L. superius: upper, from super = above)", "p": 68}, {"t": "Lig. costotransversarium laterale", "m": "Lateral costotransverse ligament — ligament extending from the end of a transverse process to the corresponding rib", "e": "lig. (L. ligamentum: ligament) + costo (L. costa: rib) + transversarium (L. transversus: transverse) + laterale (L. laterālis: of the side, from latus = side)", "p": 68}, {"t": "Lig. lumbocostale", "m": "Lumbocostal ligament — deep layer of the thoracolumbar fascia; fibrous connection between the costal process of the lumbar vertebrae, the twelfth rib, and the edge of the pelvis", "e": "lig. (L. ligamentum: ligament) + lumbo (L. lumbus: loin, lower back) + costale (L. costālis: of a rib, from costa = rib)", "p": 68}, {"t": "Foramen costotransversarium", "m": "Costotransverse foramen — opening for the intercostal nerves between the superior costotransverse ligament and the neck of the rib", "e": "foramen (L. forāmen: opening, hole, from forare = to bore) + costo (L. costa: rib) + transversarium (L. transversus: transverse)", "p": 68}, {"t": "Articulationes sternocostales", "m": "Sternocostal joints — articulations between the costal cartilage and sternum", "e": "articulationes (L. articulātiōnes: joints) + sterno (Gk. sternon: chest, breastbone) + costales (L. costālis: of a rib, from costa = rib)", "p": 68}, {"t": "Lig. sternocostale intra-articulare", "m": "Intra-articular sternocostal ligament — ligament within the articular cavity between the costal cartilage and sternum, especially pronounced at the 2nd rib", "e": "lig. (L. ligamentum: ligament) + sterno (Gk. sternon: breastbone) + costale (L. costālis: of a rib) + intra (L. intra: within) + articulare (L. articulāris: of a joint)", "p": 68}, {"t": "Ligg. sternocostalia radiata", "m": "Radiate sternocostal ligaments — fiber tracts located in front of the sternocostal joint and radiating from the end of the costal cartilage to the sternum", "e": "ligg. (L. ligamenta: ligaments) + sterno (Gk. sternon: breastbone) + costalia (L. costālis: of a rib) + radiata (L. radiāta: radiate, from radius = ray)", "p": 68}, {"t": "Membrana sterni", "m": "Sternal membrane — membranous covering of the anterior surface of the sternum formed by the fibers of the radiate sternocostal ligaments", "e": "membrana (L. membrāna: membrane, thin skin) + sterni (Gk./L. sternum/sterni: breastbone, from Gk. sternon = chest)", "p": 68}, {"t": "Ligg. costoxiphoidea", "m": "Costoxiphoid ligaments — fiber tracts extending downward from the 7th costal cartilage to the xiphoid process", "e": "ligg. (L. ligamenta: ligaments) + costo (L. costa: rib) + xiphoidea (Gk. xiphoeides: sword-shaped, from xiphos = sword + eidos = form)", "p": 68}, {"t": "Membrana intercostalis externa", "m": "External intercostal membrane — continuation of the external intercostal muscles at the sternal end of the intercostal space", "e": "membrana (L. membrāna: membrane) + intercostalis (L. intercostālis: between the ribs, from inter = between + costa = rib) + externa (L. externus: outer, from exter = outside)", "p": 68}, {"t": "Membrana intercostalis interna", "m": "Internal intercostal membrane — continuation of the internal intercostal muscles near the vertebral end of the intercostal space", "e": "membrana (L. membrāna: membrane) + intercostalis (L. intercostālis: between the ribs) + interna (L. internus: inner, from inter = within)", "p": 68}, {"t": "Synchondrosis sternocostalis costae primae", "m": "Sternocostal synchondrosis of the first rib", "e": "synchondrosis (Gk. synchondrōsis: union by cartilage, from syn = together + chondros = cartilage) + sternocostalis (sterno from Gk. sternon: breastbone + costalis from L. costa: rib) + costae (L. costa: rib) + primae (L. primus: first)", "p": 68}, {"t": "Articulationes interchondrales", "m": "Interchondral joints — articulations between the costal cartilages, usually between those of ribs 6–9", "e": "articulationes (L. articulātiōnes: joints) + inter (L. inter: between) + chondrales (Gk. chondros: cartilage)", "p": 68}, {"t": "Articulationes costochondrales", "m": "Costochondral joints — unions between the bony and cartilaginous parts of ribs without an articular cavity", "e": "articulationes (L. articulātiōnes: joints) + costo (L. costa: rib) + chondrales (Gk. chondros: cartilage)", "p": 68}, {"t": "Articulationes synoviales cranii", "m": "Synovial joints of the skull", "e": "articulationes (L. articulatio: joint, from articulare = to divide into joints) + synoviales (Gk./NL. synovialis: of synovial fluid, from syn = together + oon = egg) + cranii (L. cranium: skull, from Gk. kranion = skull)", "p": 70}, {"t": "Articulatio temporomandibularis", "m": "Temporomandibular joint", "e": "articulatio (L. articulatio: joint) + temporomandibularis (L. temporalis: of the temple, from tempus = temple + mandibularis: of the jaw, from mandere = to chew)", "p": 70}, {"t": "Discus articularis", "m": "Articular disc — biconcave disc of fibrous tissue and fibrocartilage", "e": "discus (L./Gk. discus: disc, from Gk. diskos = quoit, disc) + articularis (L. articularis: of a joint, from articulus = joint)", "p": 70}, {"t": "Lig. laterale", "m": "Lateral (temporomandibular) ligament — strong fibrous band on the lateral surface of the joint", "e": "lig. = ligamentum (L. ligamentum: band, tie, from ligare = to bind) + laterale (L. lateralis: of the side, from latus = side)", "p": 70}, {"t": "Lig. mediale", "m": "Medial ligament — reinforcement of the medial wall of the capsule", "e": "lig. = ligamentum (L. ligamentum: band, from ligare = to bind) + mediale (L. medialis: of the middle, from medius = middle)", "p": 70}, {"t": "Membrana synovialis superior", "m": "Superior synovial membrane — synovial lining of the superior articular cavity", "e": "membrana (L. membrana: membrane, skin, from membrum = limb) + synovialis (NL. synovialis: of synovial fluid, from Gk. syn = together + oon = egg) + superior (L. superior: upper, comparative of superus = above)", "p": 70}, {"t": "Membrana synovialis inferior", "m": "Inferior synovial membrane — synovial lining of the inferior articular cavity", "e": "membrana (L. membrana: membrane) + synovialis (NL. synovialis: of synovial fluid) + inferior (L. inferior: lower, comparative of inferus = below)", "p": 70}, {"t": "Lig. sphenomandibulare", "m": "Sphenomandibular ligament — flat ligament on the inner aspect of the mandibular ramus extending from the mandibular foramen to the spine of the sphenoid bone", "e": "lig. = ligamentum (L. ligamentum: band) + sphenomandibulare (Gk. sphen = wedge + L. mandibulare: of the jaw, from mandere = to chew)", "p": 70}, {"t": "Lig. stylomandibulare", "m": "Stylomandibular ligament — ligament passing from the anterior surface of the styloid process to the angle of the mandible", "e": "lig. = ligamentum (L. ligamentum: band) + stylomandibulare (Gk. stylos = pillar, column + L. mandibulare: of the jaw)", "p": 70}, {"t": "Lig. pterygospinale", "m": "Pterygospinal ligament — broad connective tissue band extending from the upper part of the lateral plate of the pterygoid process to the spine of the sphenoid", "e": "lig. = ligamentum (L. ligamentum: band) + pterygospinale (Gk. pteryx = wing + L. spinale: of the spine, from spina = thorn, spine)", "p": 70}, {"t": "Lig. stylohyoideum", "m": "Stylohyoid ligament — ligament running between the styloid process and the lesser horn of the hyoid bone", "e": "lig. = ligamentum (L. ligamentum: band) + stylohyoideum (Gk. stylos = pillar + Gk. hyoeides: U-shaped, from hy = letter upsilon + eidos = form)", "p": 70}, {"t": "Articulationes cinguli pectoralis", "m": "Joints of the shoulder girdle", "e": "articulationes (L. articulationes: joints) + cinguli (L. cingulum: girdle, from cingere = to gird) + pectoralis (L. pectoralis: of the chest, from pectus = chest)", "p": 70}, {"t": "Lig. coracoacromiale", "m": "Coracoacromial ligament — strong band extending from the coracoid process to the acromion", "e": "lig. = ligamentum (L. ligamentum: band) + coracoacromiale (Gk. korakoeides: crow-like, from korax = crow + Gk. akromion: tip of shoulder, from akros = tip + omos = shoulder)", "p": 70}, {"t": "Lig. transversum scapulae superius", "m": "Superior transverse scapular ligament — ligament lying medial to the coracoid process and bridging the scapular notch", "e": "lig. = ligamentum (L. ligamentum: band) + transversum (L. transversus: across, from trans = across + vertere = to turn) + scapulae (L. scapula: shoulder blade) + superius (L. superius: upper, from superus = above)", "p": 70}, {"t": "Lig. transversum scapulae inferius", "m": "Inferior transverse scapular ligament — weak fibrous band passing from the root of the spine of the scapula to the posterior margin of the glenoid cavity", "e": "lig. = ligamentum (L. ligamentum: band) + transversum (L. transversus: across) + scapulae (L. scapula: shoulder blade) + inferius (L. inferius: lower, from inferus = below)", "p": 70}, {"t": "Articulatio acromioclavicularis", "m": "Acromioclavicular joint — joint between the acromion and the clavicle", "e": "articulatio (L. articulatio: joint) + acromioclavicularis (Gk. akromion: tip of shoulder + L. clavicula: small key, collarbone, from clavis = key)", "p": 70}, {"t": "Lig. acromioclaviculare", "m": "Acromioclavicular ligament — strong fibrous band within and above the articular capsule", "e": "lig. = ligamentum (L. ligamentum: band) + acromioclaviculare (Gk. akromion: tip of shoulder + L. clavicula: small key, collarbone)", "p": 70}, {"t": "Lig. coracoclaviculare", "m": "Coracoclavicular ligament — two-part band connecting the coracoid process and the clavicle", "e": "lig. = ligamentum (L. ligamentum: band) + coracoclaviculare (Gk. korax = crow + L. clavicula: small key, collarbone)", "p": 70}, {"t": "Lig. trapezoideum", "m": "Trapezoid ligament — portion of the coracoclavicular ligament taking an upward and lateral course from the coracoid process to the clavicle", "e": "lig. = ligamentum (L. ligamentum: band) + trapezoideum (Gk. trapezoeides: table-shaped, from trapeza = table + eidos = form)", "p": 70}, {"t": "Lig. conoideum", "m": "Conoid ligament — portion of the coraco-clavicular ligament medial to the trapezoid ligament arising from the root of the coracoid process", "e": "lig. = ligamentum (L. ligamentum: band) + conoideum (Gk. konooeides: cone-shaped, from konos = cone + eidos = form)", "p": 70}, {"t": "Articulatio sternoclavicularis", "m": "Sternoclavicular joint — two-chambered joint between the sternum and clavicle", "e": "articulatio (L. articulatio: joint) + sternoclavicularis (Gk. sternon: breastbone + L. clavicula: small key, collarbone)", "p": 70}, {"t": "Lig. sternoclaviculare anterius", "m": "Anterior sternoclavicular ligament — band that reinforces the anterior wall of the joint capsule", "e": "lig. = ligamentum (L. ligamentum: band) + sternoclaviculare (Gk. sternon: breastbone + L. clavicula: collarbone) + anterius (L. anterius: front, anterior, from ante = before)", "p": 70}, {"t": "Lig. sternoclaviculare posterius", "m": "Posterior sternoclavicular ligament — band that reinforces the posterior wall of the joint capsule", "e": "lig. = ligamentum (L. ligamentum: band) + sternoclaviculare (Gk. sternon: breastbone + L. clavicula: collarbone) + posterius (L. posterius: behind, posterior, from post = after)", "p": 70}, {"t": "Lig. costoclaviculare", "m": "Costoclavicular ligament — ligamentous union between the first rib and the clavicle lateral to the sternoclavicular joint", "e": "lig. = ligamentum (L. ligamentum: band) + costoclaviculare (L. costa: rib + L. clavicula: small key, collarbone)", "p": 70}, {"t": "Lig. interclaviculare", "m": "Interclavicular ligament — ligament passing across the suprasternal notch and uniting both clavicles", "e": "lig. = ligamentum (L. ligamentum: band) + interclaviculare (L. inter = between + clavicula: small key, collarbone)", "p": 70}, {"t": "Articulationes membri superioris liberi", "m": "Joints of the free upper limb", "e": "articulationes (L. articulationes: joints) + membri (L. membrum: limb) + superioris (L. superior: upper) + liberi (L. liber: free)", "p": 70}, {"t": "Articulatio humeri (glenohumeral)", "m": "Shoulder (glenohumeral) joint", "e": "articulatio (L. articulatio: joint) + humeri (L. humerus: upper arm bone, from Gk. omos = shoulder) + glenohumeral (Gk. glene: socket, cavity + L. humerus: upper arm)", "p": 70}, {"t": "Articulatio glenohumeralis", "m": "Glenohumeral joint (shoulder joint)", "e": "articulatio (L. articulatio: joint) + glenohumeralis (Gk. glene = socket, cavity + L. humerus: upper arm + -alis: adjectival suffix)", "p": 70}, {"t": "Labrum glenoidale", "m": "Glenoid lip — fibrocartilaginous margin of the bony glenoid cavity", "e": "labrum (L. labrum: lip, rim, edge) + glenoidale (Gk. glenooeides: socket-like, from glene = socket + eidos = form)", "p": 70}, {"t": "Lig. coracohumerale", "m": "Coracohumeral ligament — thickened portion of the capsule passing from the root of the coracoid process to the upper margin of the greater and lesser tubercles", "e": "lig. = ligamentum (L. ligamentum: band) + coracohumerale (Gk. korax = crow + L. humerus: upper arm bone)", "p": 70}, {"t": "Ligg. glenohumeralia", "m": "Glenohumeral ligaments — three thickened bands (superior, middle, inferior) within the anterior wall of the capsule", "e": "ligg. = ligamenta (L. ligamenta: bands, plural of ligamentum) + glenohumeralia (Gk. glene = socket + L. humerus: upper arm + -alia: adjectival plural suffix)", "p": 70}, {"t": "Ligamentum laterale", "m": "Lateral ligament (of temporomandibular joint)", "e": "ligamentum (L. ligāmentum: a band, tie, from ligare = to bind) + laterale (L. laterālis: of the side, from latus = side)", "p": 71}, {"t": "Ligamentum sphenomandibulare", "m": "Sphenomandibular ligament", "e": "ligamentum (L. ligāmentum: a band, from ligare = to bind) + sphenomandibulare (Gk. sphēn = wedge + L. mandibula = jaw, from mandere = to chew)", "p": 71}, {"t": "Ligamentum stylomandibulare", "m": "Stylomandibular ligament", "e": "ligamentum (L. ligāmentum: a band) + stylomandibulare (Gk. stylos = pillar, styloid process + L. mandibula = jaw)", "p": 71}, {"t": "Ligamentum coracoclaviculare", "m": "Coracoclavicular ligament", "e": "ligamentum (L. ligāmentum: band) + coracoclaviculare (Gk. korakoeides = crow-like, coracoid + L. clavicula = little key/collarbone)", "p": 71}, {"t": "Ligamentum conoideum", "m": "Conoid ligament", "e": "ligamentum (L. ligāmentum: band) + conoideum (Gk. konoeides: cone-shaped, from konos = cone + eidos = form)", "p": 71}, {"t": "Ligamentum trapezoideum", "m": "Trapezoid ligament", "e": "ligamentum (L. ligāmentum: band) + trapezoideum (Gk. trapezoeides: table-shaped, from trapeza = table + eidos = form)", "p": 71}, {"t": "Ligamentum coracohumerale", "m": "Coracohumeral ligament", "e": "ligamentum (L. ligāmentum: band) + coracohumerale (Gk. korakoeides = crow-like/coracoid + L. humerus = upper arm bone, shoulder)", "p": 71}, {"t": "Ligamentum glenohumerale", "m": "Glenohumeral ligament", "e": "ligamentum (L. ligāmentum: band) + glenohumerale (Gk. glēnē = socket, shallow cavity + L. humerus = upper arm bone)", "p": 71}, {"t": "Capsula articularis", "m": "Articular capsule", "e": "capsula (L. capsula: small box/container, diminutive of capsa = box) + articularis (L. articulāris: of a joint)", "p": 71}, {"t": "Ligamentum laterale articulationis temporomandibularis", "m": "Lateral ligament of temporomandibular joint", "e": "ligamentum (L. ligāmentum: band) + laterale (L. laterālis: of the side) + articulationis (L. articulātio: joint, genitive form) + temporomandibularis (L./Gk. tempus = temple + mandibula = jaw)", "p": 71}, {"t": "Articulatio humeri", "m": "Shoulder joint (glenohumeral joint)", "e": "articulatio (L. articulātio: joint) + humeri (L. humerus: upper arm/shoulder, genitive form)", "p": 71}, {"t": "Humerus", "m": "Humerus (upper arm bone)", "e": "humerus (L. humerus: upper arm, shoulder)", "p": 71}, {"t": "Costa", "m": "Rib", "e": "costa (L. costa: rib, side)", "p": 71}, {"t": "Ligamentum sternoclaviculare anterius", "m": "Anterior sternoclavicular ligament", "e": "ligamentum (L. ligāmentum: band) + sternoclaviculare (Gk. sternon = breastbone + L. clavicula = collarbone) + anterius (L. anterior: front, former, from ante = before)", "p": 71}, {"t": "Ligamentum sternoclaviculare posterius", "m": "Posterior sternoclavicular ligament", "e": "ligamentum (L. ligāmentum: band) + sternoclaviculare (Gk. sternon = breastbone + L. clavicula = collarbone) + posterius (L. posterior: behind, from post = after/behind)", "p": 71}, {"t": "Ligamentum interclaviculare", "m": "Interclavicular ligament", "e": "ligamentum (L. ligāmentum: band) + interclaviculare (L. inter = between + clavicula = collarbone)", "p": 71}, {"t": "Ligamentum costoclaviculare", "m": "Costoclavicular ligament", "e": "ligamentum (L. ligāmentum: band) + costoclaviculare (L. costa = rib + clavicula = collarbone)", "p": 71}, {"t": "Ligamentum acromioclaviculare", "m": "Acromioclavicular ligament", "e": "ligamentum (L. ligāmentum: band) + acromioclaviculare (Gk. akron = tip + omos = shoulder + L. clavicula = collarbone)", "p": 71}, {"t": "Capsula articularis humeri", "m": "Articular capsule of the shoulder joint", "e": "capsula (L. capsula: small box/capsule) + articularis (L. articulāris: of a joint) + humeri (L. humerus: upper arm, genitive)", "p": 71}, {"t": "Articulatio cubiti", "m": "Elbow joint — articular connection between the upper arm and forearm", "e": "articulatio (L. articulātio: a joining, from articulare = to divide into joints) + cubiti (L. cubitus: elbow, forearm)", "p": 72}, {"t": "Articulatio humero-ulnaris", "m": "Humeroulnar joint — joint between the humerus and ulna", "e": "articulatio (L. articulātio: a joining) + humero (L. humerus: upper arm bone) + ulnaris (L. ulna: forearm bone, elbow)", "p": 72}, {"t": "Articulatio humeroradialis", "m": "Humeroradial joint — joint between the humerus and radius", "e": "articulatio (L. articulātio: a joining) + humero (L. humerus: upper arm bone) + radialis (L. radius: spoke of a wheel, radius bone)", "p": 72}, {"t": "Articulatio radio-ulnaris proximalis", "m": "Proximal radioulnar joint — joint formed by the articular circumference of the radius and the radial notch of the ulna", "e": "articulatio (L. articulātio: a joining) + radio (L. radius: spoke, radius bone) + ulnaris (L. ulna: forearm bone) + proximalis (L. proximus: nearest)", "p": 72}, {"t": "Lig. collaterale ulnare", "m": "Ulnar collateral ligament — collateral ligament on the medial part of the arm between the ulna and humerus", "e": "lig. (L. ligamentum: band, tie, from ligare = to bind) + collaterale (L. collateralis: alongside, from col- = together + latus = side) + ulnare (L. ulna: forearm bone)", "p": 72}, {"t": "Lig. collaterale radiale", "m": "Radial collateral ligament — ligament which spreads from the lateral epicondyle to the annular ligament of the radius and the ulna", "e": "lig. (L. ligamentum: band, tie) + collaterale (L. collateralis: alongside) + radiale (L. radius: spoke, radius bone)", "p": 72}, {"t": "Lig. anulare radii", "m": "Annular ligament of the radius — circular band embracing a part of the articular circumference of the radius", "e": "lig. (L. ligamentum: band, tie) + anulare (L. anularis: ring-shaped, from anulus = ring) + radii (L. radius: spoke, radius bone)", "p": 72}, {"t": "Lig. quadratum", "m": "Quadrate ligament — thin band of fibers passing from the distal margin of the radial notch of the ulna to the neck of the radius", "e": "lig. (L. ligamentum: band, tie) + quadratum (L. quadratus: square, four-sided, from quattuor = four)", "p": 72}, {"t": "Syndesmosis radioulnaris", "m": "Radioulnar syndesmosis — fibrous joint between the radius and ulna", "e": "syndesmosis (Gk. syndesmōsis: a binding together, from syn = together + desmos = band) + radio (L. radius: spoke, radius bone) + ulnaris (L. ulna: forearm bone)", "p": 72}, {"t": "Membrana interossea antebrachii", "m": "Interosseous membrane of forearm — membranous sheet which spreads between the interosseous margins of the radius and ulna", "e": "membrana (L. membrāna: membrane, thin skin) + interossea (L. interosseus: between bones, from inter = between + os = bone) + antebrachii (L. ante = before + brachium = arm)", "p": 72}, {"t": "Chorda obliqua", "m": "Oblique cord — ligamentous band extending obliquely downward from the ulnar tuberosity to the radius", "e": "chorda (Gk. khordē: string, cord) + obliqua (L. obliquus: slanting, oblique)", "p": 72}, {"t": "Articulatio radioulnaris distalis", "m": "Distal radioulnar joint", "e": "articulatio (L. articulātio: a joining) + radio (L. radius: spoke, radius bone) + ulnaris (L. ulna: forearm bone) + distalis (L. distalis: far, from distare = to stand apart)", "p": 72}, {"t": "Recessus sacciformis", "m": "Recessus sacciformis — proximal extension of the flaccid articular capsule", "e": "recessus (L. recessus: a recess, withdrawal, from recedere = to recede) + sacciformis (L. saccus = sack + forma = shape)", "p": 72}, {"t": "Articulatio radiocarpalis", "m": "Radiocarpal joint — proximal wrist joint between the proximal row of carpal bones and the radius including the articular disc", "e": "articulatio (L. articulātio: a joining) + radio (L. radius: spoke, radius bone) + carpalis (Gk. karpos: wrist)", "p": 72}, {"t": "Articulationes carpi", "m": "Carpal joints", "e": "articulationes (L. articulātio: a joining, plural) + carpi (Gk. karpos: wrist)", "p": 72}, {"t": "Articulationes intercarpales", "m": "Intercarpal joints — joints between the carpal bones permitting only slight movement", "e": "articulationes (L. articulātio: a joining, plural) + inter (L. inter: between) + carpales (Gk. karpos: wrist)", "p": 72}, {"t": "Articulatio mediocarpalis", "m": "Midcarpal joint — distal wrist joint between the proximal and distal rows of carpal bones", "e": "articulatio (L. articulātio: a joining) + medio (L. medius: middle) + carpalis (Gk. karpos: wrist)", "p": 72}, {"t": "Lig. radiocarpale dorsale", "m": "Dorsal radiocarpal ligament — ligament on the dorsum of the wrist extending from the radius to the triquetrum bone", "e": "lig. (L. ligamentum: band, tie) + radio (L. radius: spoke, radius bone) + carpale (Gk. karpos: wrist) + dorsale (L. dorsalis: of the back, from dorsum = back)", "p": 72}, {"t": "Lig. radiocarpale palmare", "m": "Palmar radiocarpal ligament — ligament on the flexor side radiating from the radius to the lunate and capitate bones", "e": "lig. (L. ligamentum: band, tie) + radio (L. radius: spoke, radius bone) + carpale (Gk. karpos: wrist) + palmare (L. palma: palm of the hand)", "p": 72}, {"t": "Lig. ulnocarpale palmare", "m": "Palmar ulnocarpal ligament — ligament extending from the flexor side of the head of the ulnar chiefly to the capitate bone", "e": "lig. (L. ligamentum: band, tie) + ulno (L. ulna: forearm bone) + carpale (Gk. karpos: wrist) + palmare (L. palma: palm of the hand)", "p": 72}, {"t": "Lig. carpi radiatum", "m": "Radiate carpal ligament — groups of fibers radiating to both sides of the wrist mainly from the head of the capitate bone", "e": "lig. (L. ligamentum: band, tie) + carpi (Gk. karpos: wrist) + radiatum (L. radiatus: radiating, from radius = ray, spoke)", "p": 72}, {"t": "Lig. collaterale carpi ulnare", "m": "Ulnar carpal collateral ligament — collateral ligament extending from the styloid process of the ulna to the triquetrum and pisiform bones", "e": "lig. (L. ligamentum: band, tie) + collaterale (L. collateralis: alongside) + carpi (Gk. karpos: wrist) + ulnare (L. ulna: forearm bone)", "p": 72}, {"t": "Lig. collaterale carpi radiale", "m": "Radial carpal collateral ligament — external collateral ligament passing from the styloid process of the radius to the scaphoid bone", "e": "lig. (L. ligamentum: band, tie) + collaterale (L. collateralis: alongside) + carpi (Gk. karpos: wrist) + radiale (L. radius: spoke, radius bone)", "p": 72}, {"t": "Ligg. intercarpalia dorsalia", "m": "Dorsal intercarpal ligaments — ligamentous bands extending between the proximal and distal rows of carpal bones on the dorsum of the wrist", "e": "ligg. (L. ligamenta: bands, ties, plural) + inter (L. inter: between) + carpalia (Gk. karpos: wrist) + dorsalia (L. dorsalis: of the back, from dorsum = back)", "p": 72}, {"t": "Ligg. intercarpalia palmaria", "m": "Palmar intercarpal ligaments — groups of ligaments between the carpal bones on the palmar aspect below the radiate carpal ligament", "e": "ligg. (L. ligamenta: bands, ties, plural) + inter (L. inter: between) + carpalia (Gk. karpos: wrist) + palmaria (L. palma: palm of the hand)", "p": 72}, {"t": "Ligamentum collaterale radiale", "m": "Radial collateral ligament of the elbow joint", "e": "ligamentum (L. ligāmentum: band, tie, from ligāre = to bind) + collaterale (L. collaterālis: alongside, from col- = together + latus = side) + radiale (L. radiālis: of the radius, from radius = spoke, ray)", "p": 73}, {"t": "Ligamentum collaterale ulnare", "m": "Ulnar collateral ligament of the elbow joint", "e": "ligamentum (L. ligāmentum: band, tie, from ligāre = to bind) + collaterale (L. collaterālis: alongside, from col- = together + latus = side) + ulnare (L. ulnāris: of the ulna, from ulna = forearm bone, elbow)", "p": 73}, {"t": "Tendo m. bicipitis brachii", "m": "Tendon of biceps brachii muscle", "e": "tendo (L. tendō: tendon, from tendere = to stretch) + musculus (L. musculus: muscle) + bicipitis (L. biceps: two-headed, from bi- = two + caput = head) + brachii (L. brachium: arm, from Gk. brakhiōn)", "p": 73}, {"t": "Articulatio radioulnaris", "m": "Radioulnar joint", "e": "articulatio (L. articulātiō: joint, from articulus = small joint, diminutive of artus = joint) + radioulnaris (L. radius = spoke/ray + ulna = forearm bone)", "p": 73}, {"t": "Ligamentum radiocarpale dorsale", "m": "Dorsal radiocarpal ligament", "e": "ligamentum (L. ligāmentum: band) + radiocarpale (L. radius = ray + carpalis = of the carpus) + dorsale (L. dorsālis: of the back, from dorsum = back)", "p": 73}, {"t": "Ligamentum ulnocarpale palmare", "m": "Palmar ulnocarpal ligament", "e": "ligamentum (L. ligāmentum: band) + ulnocarpale (L. ulna = forearm bone + carpalis = of the carpus) + palmare (L. palmāris: of the palm, from palma = palm)", "p": 73}, {"t": "Ligamentum collaterale carpi ulnare", "m": "Ulnar collateral ligament of the wrist", "e": "ligamentum (L. ligāmentum: band) + collaterale (L. collaterālis: alongside) + carpi (L. carpus: wrist, from Gk. karpos) + ulnare (L. ulnāris: of the ulna)", "p": 73}, {"t": "Ligamenta intercarpalia dorsalia", "m": "Dorsal intercarpal ligaments", "e": "ligamenta (L. ligāmentum: band, plural) + intercarpalia (L. inter = between + carpalis = of the carpus) + dorsalia (L. dorsālis: of the back, plural)", "p": 73}, {"t": "Ligamentum radiocarpale palmare", "m": "Palmar radiocarpal ligament", "e": "ligamentum (L. ligāmentum: band) + radiocarpale (L. radius = ray + carpalis = of the carpus) + palmare (L. palmāris: of the palm)", "p": 73}, {"t": "Ligamenta intercarpalia palmaria", "m": "Palmar intercarpal ligaments", "e": "ligamenta (L. ligāmentum: band, plural) + intercarpalia (L. inter = between + carpalis = of the carpus) + palmaria (L. palmāris: of the palm, plural)", "p": 73}, {"t": "Ligamentum collaterale carpi radiale", "m": "Radial collateral ligament of the wrist", "e": "ligamentum (L. ligāmentum: band) + collaterale (L. collaterālis: alongside) + carpi (L. carpus: wrist) + radiale (L. radiālis: of the radius)", "p": 73}, {"t": "Articulationes manus", "m": "Joints of the hand", "e": "articulationes (L. articulatio: joint, from articulare = to divide into joints) + manus (L. manus: hand)", "p": 74}, {"t": "Ligg. intercarpalia interossea", "m": "Interosseous intercarpal ligaments — ligaments penetrating directly through the joint clefts between the carpal bones within a row", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + intercarpalia (L. inter = between + carpalia = of the carpus, from Gk. karpos = wrist) + interossea (L. inter = between + ossea = of bone, from os = bone)", "p": 74}, {"t": "Articulatio ossis pisiformis", "m": "Pisotriquetral joint — articulation between the pisiform and triquetrum bones", "e": "articulatio (L. articulatio: joint) + ossis (L. os: bone, genitive ossis) + pisiformis (L. pisum = pea + forma = shape; pea-shaped)", "p": 74}, {"t": "Lig. pisohamatum", "m": "Pisohamate ligament — medial continuation of the tendon of the flexor carpi ulnaris to the hook of the hamate bone", "e": "lig. (L. ligamentum: ligament) + pisohamatum (L. pisum = pea + hamatum = hooked, from hamus = hook)", "p": 74}, {"t": "Lig. pisometacarpale", "m": "Pisometacarpal ligament — lateral continuation of the tendon of the flexor carpi ulnaris to the base of the fifth metacarpal", "e": "lig. (L. ligamentum: ligament) + pisometacarpale (L. pisum = pea + Gk. meta = beyond + karpos = wrist)", "p": 74}, {"t": "Canalis carpi", "m": "Carpal canal or tunnel — palmar canal located between the tubercles of the scaphoid and trapezium on one side and the pisiform bone and the hook of the hamulus on the other side", "e": "canalis (L. canalis: canal, channel) + carpi (L. carpus: wrist, genitive carpi, from Gk. karpos = wrist)", "p": 74}, {"t": "carpalis", "m": "of the carpus (alternate form used in carpal canal)", "e": "carpalis (L. carpalis: of the carpus, from Gk. karpos = wrist)", "p": 74}, {"t": "Articulationes carpometacarpales", "m": "Metacarpal articulations — slightly movable joints between the distal carpal bones and the metacarpals", "e": "articulationes (L. articulatio: joint) + carpo (L. carpus: wrist) + metacarpales (Gk. meta = beyond + karpos = wrist)", "p": 74}, {"t": "Ligg. carpometacarpalia dorsalia", "m": "Dorsal carpometacarpal ligaments — rigid ligaments on the dorsum of the hand between the distal carpal bones and the metacarpal bones", "e": "ligg. (L. ligamenta: ligaments) + carpometacarpalia (L. carpus = wrist + Gk. meta = beyond + karpos = wrist) + dorsalia (L. dorsalis: of the back, from dorsum = back)", "p": 74}, {"t": "Ligg. carpometacarpalia palmaria", "m": "Palmar carpometacarpal ligaments — ligaments on the palmar side of the hand between the distal carpal bones and the metacarpal bones", "e": "ligg. (L. ligamenta: ligaments) + carpometacarpalia (L. carpus = wrist + Gk. meta = beyond + karpos = wrist) + palmaria (L. palmaris: of the palm, from palma = palm)", "p": 74}, {"t": "Articulatio carpometacarpalis pollicis", "m": "Carpometacarpal joint of the thumb — saddle joint between the first metacarpal and the trapezium", "e": "articulatio (L. articulatio: joint) + carpometacarpalis (L. carpus = wrist + Gk. meta = beyond + karpos = wrist) + pollicis (L. pollex: thumb, genitive pollicis)", "p": 74}, {"t": "Articulationes intermetacarpales", "m": "Intermetacarpal joints — joints between the bases of the metacarpal bones", "e": "articulationes (L. articulatio: joint) + inter (L. inter: between) + metacarpales (Gk. meta = beyond + karpos = wrist)", "p": 74}, {"t": "Ligg. metacarpalia dorsalia", "m": "Dorsal metacarpal ligaments — ligaments between the proximal ends of the metacarpals on the extensor side", "e": "ligg. (L. ligamenta: ligaments) + metacarpalia (Gk. meta = beyond + karpos = wrist) + dorsalia (L. dorsalis: of the back, from dorsum = back)", "p": 74}, {"t": "Ligg. metacarpalia palmaria", "m": "Palmar metacarpal ligaments — ligaments between the bases of the metacarpal bones on the palmar side", "e": "ligg. (L. ligamenta: ligaments) + metacarpalia (Gk. meta = beyond + karpos = wrist) + palmaria (L. palmaris: of the palm, from palma = palm)", "p": 74}, {"t": "Ligg. metacarpalia interossea", "m": "Interosseous metacarpal ligaments — short, tense ligaments at the bases of the metacarpal bones lying in the intracapsular spaces between the dorsal and palmar metacarpal ligaments", "e": "ligg. (L. ligamenta: ligaments) + metacarpalia (Gk. meta = beyond + karpos = wrist) + interossea (L. inter = between + ossea = of bone, from os = bone)", "p": 74}, {"t": "Spatia interossea metacarpi", "m": "Interosseous spaces of metacarpus — spaces between the metacarpal bones", "e": "spatia (L. spatium: space, plural spatia) + interossea (L. inter = between + ossea = of bone, from os = bone) + metacarpi (Gk. meta = beyond + karpos = wrist, genitive)", "p": 74}, {"t": "Articulationes metacarpophalangeales", "m": "Metacarpophalangeal joints — joints between the heads of the metacarpal bones and the bases of the proximal phalanges", "e": "articulationes (L. articulatio: joint) + metacarpo (Gk. meta = beyond + karpos = wrist) + phalangeales (Gk. phalanx: bone of the finger or toe, from phalanx = line of soldiers)", "p": 74}, {"t": "Ligg. collateralia", "m": "Collateral ligaments — collateral ligaments of the metacarpophalangeal joints that slacken during extension and become tense when making a closed fist", "e": "ligg. (L. ligamenta: ligaments) + collateralia (L. collateralis: alongside, from col = together + latus = side)", "p": 74}, {"t": "Ligg. palmaria", "m": "Palmar ligaments — fibers in the floor of the tendon sheaths extending from the root of the collateral ligaments to the palmar side", "e": "ligg. (L. ligamenta: ligaments) + palmaria (L. palmaris: of the palm, from palma = palm)", "p": 74}, {"t": "Lig. metacarpale transversum profundum", "m": "Deep transverse metacarpal ligament — transversely oriented fibrous tracts on the palmar side of the heads of the metacarpal bones at the level of the joint spaces, holding the distal parts of the metacarpus together", "e": "lig. (L. ligamentum: ligament) + metacarpale (Gk. meta = beyond + karpos = wrist) + transversum (L. transversus: across, from trans = across + vertere = to turn) + profundum (L. profundus: deep, from pro = before + fundus = bottom)", "p": 74}, {"t": "Articulationes interphalangeales manus", "m": "Interphalangeal joints — middle and distal joints between the phalanges", "e": "articulationes (L. articulatio: joint) + inter (L. inter: between) + phalangeales (Gk. phalanx: bone of finger or toe) + manus (L. manus: hand)", "p": 74}, {"t": "Interosseus metacarpi spatium", "m": "Interosseous metacarpal space", "e": "inter (L. inter: between) + osseus (L. osseus: bony, from os = bone) + metacarpi (Gk. meta = after/beyond + karpos = wrist) + spatium (L. spatium: space)", "p": 75}, {"t": "Interossea metacarpalia ligamenta", "m": "Interosseous metacarpal ligaments", "e": "inter (L. inter: between) + ossea (L. osseus: bony, from os = bone) + metacarpalia (Gk. meta = after/beyond + karpos = wrist) + ligamenta (L. ligamentum: band, tie, from ligare = to bind)", "p": 75}, {"t": "Articulatio carpometacarpalis", "m": "Carpometacarpal joint", "e": "articulatio (L. articulatio: joint, from articulus = small joint) + carpo (Gk. karpos: wrist) + metacarpalis (Gk. meta = after/beyond + karpos = wrist)", "p": 75}, {"t": "Ligamenta intercarpea interossea", "m": "Interosseous intercarpal ligaments", "e": "ligamenta (L. ligamentum: band, from ligare = to bind) + inter (L. inter: between) + carpea (Gk. karpos: wrist) + interossea (L. inter = between + os = bone)", "p": 75}, {"t": "Articulatio intercarpalis", "m": "Intercarpal joint", "e": "articulatio (L. articulatio: joint, from articulus = small joint) + inter (L. inter: between) + carpalis (Gk. karpos: wrist)", "p": 75}, {"t": "Ligamentum collaterale", "m": "Collateral ligament", "e": "ligamentum (L. ligamentum: band, from ligare = to bind) + collaterale (L. collateralis: side by side, from col = together + latus = side)", "p": 75}, {"t": "Ligamenta metacarpalia transversa profunda", "m": "Deep transverse metacarpal ligaments", "e": "ligamenta (L. ligamentum: band, from ligare = to bind) + metacarpalia (Gk. meta = after/beyond + karpos = wrist) + transversa (L. transversus: crosswise, from trans = across + vertere = to turn) + profunda (L. profundus: deep)", "p": 75}, {"t": "Articulatio interphalangealis", "m": "Interphalangeal joint", "e": "articulatio (L. articulatio: joint) + inter (L. inter: between) + phalangealis (Gk. phalanx: row of soldiers, finger bone)", "p": 75}, {"t": "Articulatio metacarpophalangealis", "m": "Metacarpophalangeal joint", "e": "articulatio (L. articulatio: joint) + metacarpo (Gk. meta = after + karpos = wrist) + phalangealis (Gk. phalanx: finger bone)", "p": 75}, {"t": "Articulatio pisiformis", "m": "Pisiform joint", "e": "articulatio (L. articulatio: joint) + pisiformis (L. pisum = pea + forma = shape, pea-shaped)", "p": 75}, {"t": "Ligamentum palmare", "m": "Palmar ligament", "e": "ligamentum (L. ligamentum: band, from ligare = to bind) + palmare (L. palma: palm of the hand)", "p": 75}, {"t": "Ligamenta carpometacarpalia palmaria", "m": "Palmar carpometacarpal ligaments", "e": "ligamenta (L. ligamentum: band) + carpo (Gk. karpos: wrist) + metacarpalia (Gk. meta + karpos) + palmaria (L. palma: palm)", "p": 75}, {"t": "Ligamentum pisihametum", "m": "Pisohamate ligament", "e": "ligamentum (L. ligamentum: band) + pisi (L. pisum: pea) + hamatum (L. hamatus: hooked, from hamus = hook)", "p": 75}, {"t": "Ligamentum pisimetacarpale", "m": "Pisometacarpal ligament", "e": "ligamentum (L. ligamentum: band) + pisi (L. pisum: pea) + metacarpale (Gk. meta + karpos = wrist)", "p": 75}, {"t": "Ligamenta carpometacarpalia dorsalia", "m": "Dorsal carpometacarpal ligaments", "e": "ligamenta (L. ligamentum: band) + carpo (Gk. karpos: wrist) + metacarpalia (Gk. meta + karpos) + dorsalia (L. dorsum: back)", "p": 75}, {"t": "Ligamentum dorsale metacarpale", "m": "Dorsal metacarpal ligament", "e": "ligamentum (L. ligamentum: band) + dorsale (L. dorsum: back) + metacarpale (Gk. meta + karpos = wrist)", "p": 75}, {"t": "Articulatio carpi", "m": "Carpal joint", "e": "articulatio (L. articulatio: joint) + carpi (Gk. karpos: wrist)", "p": 75}, {"t": "Ligamentum collaterale carpi", "m": "Collateral ligament of the wrist", "e": "ligamentum (L. ligamentum: band) + collaterale (L. collateralis: alongside, from col + latus = side) + carpi (Gk. karpos: wrist)", "p": 75}, {"t": "Articulationes cinguli pelvici", "m": "Joints of the pelvic girdle", "e": "articulationes (L. articulatio: joint, from articulare = to divide into joints) + cinguli (L. cingulum: girdle, belt, from cingere = to gird) + pelvici (L. pelvis: basin, bowl)", "p": 76}, {"t": "Membrana obturatoria", "m": "Obturator membrane — membrane which closes off the obturator foramen except for the obturator canal", "e": "membrana (L. membrana: membrane, thin skin) + obturatoria (L. obturare: to stop up, close off)", "p": 76}, {"t": "Canalis obturatorius", "m": "Obturator canal — opening in the supralateral part of the obturator membrane", "e": "canalis (L. canalis: channel, canal, from canna = reed) + obturatorius (L. obturare: to stop up, close off)", "p": 76}, {"t": "Articulatio lumbosacralis", "m": "Lumbosacral joint — articulation between the sacrum and lumbar vertebra 5", "e": "articulatio (L. articulatio: joint, from articulare = to divide into joints) + lumbosacralis (L. lumbus: loin + sacralis: of the sacrum, from sacer = sacred, holy)", "p": 76}, {"t": "Lig. iliolumbale", "m": "Iliolumbar ligament — strong ligament that passes to the ilium mainly from the transverse processes of L4 and L5", "e": "lig. (L. ligamentum: ligament, band, from ligare = to bind) + iliolumbale (L. ilium: flank, hip bone + lumbus: loin)", "p": 76}, {"t": "Lig. sacrotuberale", "m": "Sacrotuberous ligament — strong ligament that extends from the medial margin of the ischial tuberosity to the sacrum and ilium", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + sacrotuberale (L. sacer: sacred + tuber: lump, swelling, protuberance)", "p": 76}, {"t": "Processus falciformis", "m": "Falciform process — slender extension of fibers from the sacrotuberous ligament to the inner aspect of the ischium", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + falciformis (L. falx: sickle + forma: shape, form)", "p": 76}, {"t": "Lig. sacrospinale", "m": "Sacrospinous ligament — fibrous band medial to the sacrotuberous ligament passing from the ischial spine to the sacrum and coccyx", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + sacrospinale (L. sacer: sacred + spina: spine, thorn)", "p": 76}, {"t": "Foramen sciaticum majus", "m": "Greater sciatic foramen — foramen between the greater sciatic notch, sacrum, sacrospinous ligament and the upper part of the sacrotuberous ligament", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + sciaticum (Gk. ischiadikos: of the hip, from ischion = hip joint) + majus (L. major: greater, larger)", "p": 76}, {"t": "Foramen sciaticum minus", "m": "Lesser sciatic foramen — foramen between the lesser sciatic notch and the sacrospinous and sacrotuberous ligaments", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + sciaticum (Gk. ischiadikos: of the hip, from ischion = hip joint) + minus (L. minor: lesser, smaller)", "p": 76}, {"t": "Articulatio sacroiliaca", "m": "Sacroiliac joint — joint connected by fibers that permits little motion, located between the sacrum and the ilium", "e": "articulatio (L. articulatio: joint, from articulare = to divide into joints) + sacroiliaca (L. sacer: sacred + ilium: flank, hip bone)", "p": 76}, {"t": "Ligg. sacroiliaca anteriora", "m": "Ventral sacroiliac ligaments — thin but broad fibrous bands extending from the anterior surface of the first and second sacral vertebrae to the ilium", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + sacroiliaca (L. sacer: sacred + ilium: flank, hip bone) + anteriora (L. anterior: front, before, from ante = before)", "p": 76}, {"t": "Ligg. sacroiliaca interossea", "m": "Interosseous sacroiliac ligaments — dorsal mass of ligaments passing from the tuberosity of the sacrum to the tuberosity of the ilium", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + sacroiliaca (L. sacer: sacred + ilium: flank, hip bone) + interossea (L. inter: between + os/ossis: bone)", "p": 76}, {"t": "Ligg. sacroiliaca posteriora", "m": "Dorsal sacroiliac ligaments — superficial bundle of ligaments attached dorsally to the interosseous sacroiliac ligaments between the sacrum and ilium", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + sacroiliaca (L. sacer: sacred + ilium: flank, hip bone) + posteriora (L. posterior: behind, back, from post = after, behind)", "p": 76}, {"t": "Symphysis pubica", "m": "Pubic symphysis — synchondrosis that articulates with the interpubic disc", "e": "symphysis (Gk. symphysis: growing together, from syn = together + phyein = to grow) + pubica (L. pubes: pubic region, grown up)", "p": 76}, {"t": "Lig. pubicum superius", "m": "Superior pubic ligament — fibrous connection between the two halves of the symphysis emanating from the pecten ossis pubis on either side", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + pubicum (L. pubes: pubic region) + superius (L. superior: upper, higher, from super = above)", "p": 76}, {"t": "Lig. arcuatum pubis", "m": "Arcuate pubic ligament — strong, curved ligament below the symphysis", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + arcuatum (L. arcuatus: arched, bowed, from arcus = arch, bow) + pubis (L. pubes: pubic region)", "p": 76}, {"t": "Discus interpubicus", "m": "Interpubic disc — fibrocartilage plate with a synovia-filled median groove, located between the articular surfaces of the right and left pubic bones", "e": "discus (Gk. diskos: disc, round plate) + interpubicus (L. inter: between + pubes: pubic region)", "p": 76}, {"t": "Articulationes membri inferioris liberi", "m": "Joints of the free lower limb", "e": "articulationes (L. articulatio: joint, from articulare = to divide into joints) + membri (L. membrum: limb, member) + inferioris (L. inferior: lower) + liberi (L. liber: free)", "p": 76}, {"t": "Articulatio coxae", "m": "Hip joint — joint formed by the acetabulum and the head of the femur", "e": "articulatio (L. articulatio: joint, from articulare = to divide into joints) + coxae (L. coxa: hip)", "p": 76}, {"t": "Zona orbicularis", "m": "Orbicular zone — ligamentous fibers encircling the neck of the femur", "e": "zona (Gk. zone: belt, girdle) + orbicularis (L. orbicularis: circular, from orbiculus = small circle, from orbis = circle)", "p": 76}, {"t": "Lig. iliofemorale", "m": "Iliofemoral ligament — strong anterior ligament of the hip joint capsule extending from the ilium to the intertrochanteric line", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + iliofemorale (L. ilium: flank, hip bone + femur/femoris: thigh)", "p": 76}, {"t": "Lig. ischiofemorale", "m": "Ischiofemoral ligament — radiates into the orbicular zone from the posterior margin of the acetabulum and is attached to the anterior margin of the greater trochanter and to the intertrochanteric line", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + ischiofemorale (Gk. ischion: hip joint, seat bone + L. femur/femoris: thigh)", "p": 76}, {"t": "Lig. pubofemorale", "m": "Pubofemoral ligament — ligament that arises medially from the joint capsule of the pubic bone and extends to the orbicular zone and to the part of the femur proximal to the lesser trochanter", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + pubofemorale (L. pubes: pubic region + femur/femoris: thigh)", "p": 76}, {"t": "Labrum acetabulare", "m": "Acetabular lip — a ring of fibrocartilage and connective tissue that completes and deepens the bony acetabulum", "e": "labrum (L. labrum: lip, rim, edge) + acetabulare (L. acetabulum: vinegar cup, socket, from acetum = vinegar + -abulum = container)", "p": 76}, {"t": "Lig. transversum acetabuli", "m": "Transverse acetabular ligament — bridges the acetabular notch", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + transversum (L. transversus: lying across, from trans = across + vertere = to turn) + acetabuli (L. acetabulum: socket, vinegar cup, from acetum = vinegar)", "p": 76}, {"t": "Lig. capitis femoris", "m": "Ligament of head of femur — a smooth ligament extending from the acetabular notch to the pit on the head of the femur; transmits blood vessels and has no direct mechanical action", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + capitis (L. caput/capitis: head) + femoris (L. femur/femoris: thigh)", "p": 76}, {"t": "Articulatio genus", "m": "Knee joint", "e": "articulatio (L. articulātio: joint, from articulare = to divide into joints) + genus (L. genus/genu: knee)", "p": 78}, {"t": "Meniscus lateralis", "m": "Lateral meniscus", "e": "meniscus (Gk. mēniskos: crescent, small moon) + lateralis (L. laterālis: of the side, from latus = side)", "p": 78}, {"t": "Lig. meniscofemorale anterius", "m": "Anterior meniscofemoral ligament", "e": "lig. (L. ligamentum: band, tie, from ligare = to bind) + meniscofemorale (L./Gk. meniscus = crescent + femur/femoris = thigh bone) + anterius (L. anterior: before, in front)", "p": 78}, {"t": "Lig. meniscofemorale posterius", "m": "Posterior meniscofemoral ligament", "e": "lig. (L. ligamentum: band, tie) + meniscofemorale (Gk./L. meniskos = crescent + femur = thigh) + posterius (L. posterior: behind, after)", "p": 78}, {"t": "Meniscus medialis", "m": "Medial meniscus", "e": "meniscus (Gk. mēniskos: crescent, small moon) + medialis (L. mediālis: middle, from medius = middle)", "p": 78}, {"t": "Lig. transversum genus", "m": "Transverse ligament of knee", "e": "lig. (L. ligamentum: band) + transversum (L. transversus: across, from trans = across + vertere = to turn) + genus (L. genu: knee)", "p": 78}, {"t": "Ligg. cruciata genus", "m": "Cruciate ligaments of knee", "e": "ligg. (L. ligamenta: plural of ligamentum, band) + cruciata (L. cruciātus: cross-shaped, from crux/crucis = cross) + genus (L. genu: knee)", "p": 78}, {"t": "Lig. cruciatum anterius", "m": "Anterior cruciate ligament", "e": "lig. (L. ligamentum: band) + cruciatum (L. cruciātus: cross-shaped, from crux = cross) + anterius (L. anterior: in front)", "p": 78}, {"t": "Lig. cruciatum posterius", "m": "Posterior cruciate ligament", "e": "lig. (L. ligamentum: band) + cruciatum (L. cruciātus: cross-shaped, from crux = cross) + posterius (L. posterior: behind)", "p": 78}, {"t": "Plica synovialis infrapatellaris", "m": "Infrapatellar synovial fold", "e": "plica (L. plica: fold, from plicare = to fold) + synovialis (NL. synovialis: of synovial fluid, from Gk. syn = together + L. ovum = egg) + infrapatellaris (L. infra = below + patella = kneecap, small pan)", "p": 78}, {"t": "Plicae alares", "m": "Alar folds", "e": "plicae (L. plicae: plural of plica, fold) + alares (L. alāris: wing-like, from ala = wing)", "p": 78}, {"t": "Lig. collaterale fibulare", "m": "Fibular collateral ligament", "e": "lig. (L. ligamentum: band) + collaterale (L. collaterālis: alongside, from col- = together + latus = side) + fibulare (L. fibulāris: of the fibula, from fibula = clasp, brooch)", "p": 78}, {"t": "Lig. collaterale tibiale", "m": "Tibial collateral ligament", "e": "lig. (L. ligamentum: band) + collaterale (L. collaterālis: alongside, from col- = together + latus = side) + tibiale (L. tibiālis: of the tibia, from tibia = shinbone, flute)", "p": 78}, {"t": "Lig. popliteum obliquum", "m": "Oblique popliteal ligament", "e": "lig. (L. ligamentum: band) + popliteum (L. popliteus: of the back of the knee, from poples = back of the knee) + obliquum (L. obliquus: slanting, oblique)", "p": 78}, {"t": "Lig. popliteum arcuatum", "m": "Arcuate popliteal ligament", "e": "lig. (L. ligamentum: band) + popliteum (L. popliteus: of the back of the knee) + arcuatum (L. arcuātus: arched, bow-shaped, from arcus = arch, bow)", "p": 78}, {"t": "Ligamentum patellae", "m": "Patellar ligament", "e": "ligamentum (L. ligamentum: band, tie, from ligare = to bind) + patellae (L. patella: genitive of patella, kneecap, small pan, from patina = pan)", "p": 78}, {"t": "Retinaculum patellae mediale", "m": "Medial retinaculum of patella", "e": "retinaculum (L. retinaculum: retaining band, from retinere = to hold back) + patellae (L. patella: genitive, kneecap) + mediale (L. mediālis: medial, from medius = middle)", "p": 78}, {"t": "Retinaculum patellae laterale", "m": "Lateral retinaculum of patella", "e": "retinaculum (L. retinaculum: retaining band, from retinere = to hold back) + patellae (L. patella: genitive, kneecap) + laterale (L. laterālis: lateral, from latus = side)", "p": 78}, {"t": "Corpus adiposum infrapatellare", "m": "Infrapatellar fat pad", "e": "corpus (L. corpus: body) + adiposum (L. adipōsus: fatty, from adeps = fat) + infrapatellare (L. infra = below + patella = kneecap)", "p": 78}, {"t": "Articulatio tibiofibularis", "m": "Tibiofibular joint", "e": "articulatio (L. articulātio: joint) + tibiofibularis (L. tibia = shinbone + fibula = clasp, brooch; of both tibia and fibula)", "p": 78}, {"t": "Lig. capitis fibulae anterius", "m": "Anterior ligament of head of fibula", "e": "lig. (L. ligamentum: band) + capitis (L. caput/capitis: genitive, head) + fibulae (L. fibula: genitive, of the fibula, clasp) + anterius (L. anterior: in front)", "p": 78}, {"t": "Lig. capitis fibulae posterius", "m": "Posterior ligament of head of fibula", "e": "lig. (L. ligamentum: band) + capitis (L. caput/capitis: genitive, head) + fibulae (L. fibula: genitive, of the fibula) + posterius (L. posterior: behind)", "p": 78}, {"t": "Syndesmosis tibiofibularis", "m": "Tibiofibular syndesmosis", "e": "syndesmosis (Gk. syndesmōsis: a binding together, from syn = together + desmos = band, ligament) + tibiofibularis (L. tibia = shinbone + fibula = clasp; of tibia and fibula)", "p": 78}, {"t": "Membrana interossea cruris", "m": "Interosseous membrane", "e": "membrana (L. membrana: membrane, skin) + interossea (L. interosseus: between bones, from inter = between + os/ossis = bone) + cruris (L. crus/cruris: genitive, of the leg)", "p": 78}, {"t": "Lig. tibiofibulare anterius", "m": "Anterior tibiofibular ligament", "e": "lig. (L. ligamentum: band) + tibiofibulare (L. tibia = shinbone + fibula = clasp; tibiofibular) + anterius (L. anterior: in front)", "p": 78}, {"t": "Lig. tibiofibulare posterius", "m": "Posterior tibiofibular ligament", "e": "lig. (L. ligamentum: band) + tibiofibulare (L. tibia = shinbone + fibula = clasp; tibiofibular) + posterius (L. posterior: behind)", "p": 78}, {"t": "Articulatio talocruralis", "m": "Ankle (talocrural) joint — upper ankle joint between the talus, tibia and fibula", "e": "articulatio (L. articulātio: joint, from articulare = to divide into joints) + talo- (L. talus: ankle bone) + cruralis (L. crurālis: of the leg, from crus = leg)", "p": 80}, {"t": "Lig. mediale (deltoideum) articulationis talocruralis", "m": "Medial or deltoid ligament — ligament on the medial side of the ankle which consists of four segments", "e": "lig. = ligamentum (L. ligamentum: band, tie, from ligare = to bind) + mediale (L. mediālis: of the middle) + deltoideum (Gk. delta: Δ-shaped + eidos: form) + articulationis (L. articulātiō: joint) + talocruralis (L. talus: ankle bone + crurālis: of the leg)", "p": 80}, {"t": "Pars tibionavicularis", "m": "Tibionavicular part — group of fibers connecting the medial malleolus to the dorsal and medial surfaces of the navicular bone", "e": "pars (L. pars: part) + tibio- (L. tibia: shinbone) + navicularis (L. nāviculāris: boat-shaped, from nāvicula = small boat)", "p": 80}, {"t": "Pars tibiocalcanea", "m": "Tibiocalcaneal part — group of fibers connecting the medial malleolus to the sustentaculum tali", "e": "pars (L. pars: part) + tibio- (L. tibia: shinbone) + calcanea (L. calcaneus: heel bone, from calx = heel)", "p": 80}, {"t": "Pars tibiotalaris anterior", "m": "Anterior tibiotalar part — segment of the deltoid ligament connecting the medial malleolus to the medial surface of the talus as far as the neck of the talus", "e": "pars (L. pars: part) + tibio- (L. tibia: shinbone) + talaris (L. talāris: of the talus, from talus = ankle bone) + anterior (L. anterior: front, former)", "p": 80}, {"t": "Pars tibiotalaris posterior", "m": "Posterior tibiotalar part — fibers extending posteriorly from the medial malleolus almost as far as the posterior process of the talus", "e": "pars (L. pars: part) + tibio- (L. tibia: shinbone) + talaris (L. talāris: of the talus) + posterior (L. posterior: behind, later)", "p": 80}, {"t": "Lig. talofibulare anterius", "m": "Anterior talofibular ligament — ligament extending from the lateral malleolus to the lateral surface of the neck of the talus", "e": "ligamentum (L. ligamentum: band) + talo- (L. talus: ankle bone) + fibulare (L. fibula: pin, clasp; the outer leg bone) + anterius (L. anterior: front)", "p": 80}, {"t": "Lig. talofibulare posterius", "m": "Posterior talofibular ligament — originates in the lateral malleolar fossa and inserts at the lateral tubercle of the posterior process of the talus", "e": "ligamentum (L. ligamentum: band) + talo- (L. talus: ankle bone) + fibulare (L. fibula: pin, outer leg bone) + posterius (L. posterior: behind)", "p": 80}, {"t": "Lig. calcaneofibulare", "m": "Calcaneofibular ligament — passes obliquely and posteriorly from the apex of the lateral malleolus to the calcaneus", "e": "ligamentum (L. ligamentum: band) + calcaneo- (L. calcaneus: heel bone) + fibulare (L. fibula: outer leg bone)", "p": 80}, {"t": "Articulationes intertarseae", "m": "Intertarsal joints — joints between the tarsal bones", "e": "articulationes (L. articulātiō: joint) + inter- (L. inter: between) + tarseae (Gk. tarsos: flat of the foot, ankle)", "p": 80}, {"t": "Articulationes pedis", "m": "Joints of the foot", "e": "articulationes (L. articulātiō: joint) + pedis (L. pes/pedis: foot)", "p": 80}, {"t": "Articulatio talocalcaneonavicularis", "m": "Talocalcaneonavicular joint — the anterior portion of the lower ankle joint in which the talus articulates with the calcaneus and navicular bones", "e": "articulatio (L. articulātio: joint) + talo- (L. talus: ankle bone) + calcaneo- (L. calcaneus: heel bone) + navicularis (L. nāviculāris: boat-shaped, from nāvicula = small boat)", "p": 80}, {"t": "Articulatio subtalaris (talocalcanea)", "m": "Subtalar joint — joint between the talus and calcaneus representing the posterior part of the lower ankle joint", "e": "articulatio (L. articulātio: joint) + sub- (L. sub: under, below) + talaris (L. talāris: of the talus) + talo- (L. talus: ankle bone) + calcanea (L. calcaneus: heel bone)", "p": 80}, {"t": "Lig. talocalcaneum laterale", "m": "Lateral talocalcaneal ligament — passes from the trochlea of the talus to the lateral surface of the calcaneus", "e": "ligamentum (L. ligamentum: band) + talo- (L. talus: ankle bone) + calcaneum (L. calcaneus: heel bone) + laterale (L. laterālis: of the side, from latus = side)", "p": 80}, {"t": "Lig. talocalcaneum mediale", "m": "Medial talocalcaneal ligament — extends from the medial tubercle of the posterior process of the talus to the sustentaculum tali", "e": "ligamentum (L. ligamentum: band) + talo- (L. talus: ankle bone) + calcaneum (L. calcaneus: heel bone) + mediale (L. mediālis: of the middle)", "p": 80}, {"t": "Lig. talocalcaneum posterior", "m": "Posterior talocalcaneal ligament — fibrous band extending from the posterior process of the talus to the calcaneus, bridging the sulcus of the tendon of the flexor hallucis longus muscle", "e": "ligamentum (L. ligamentum: band) + talo- (L. talus: ankle bone) + calcaneum (L. calcaneus: heel bone) + posterior (L. posterior: behind)", "p": 80}, {"t": "Articulatio tarsi transversa", "m": "Transverse tarsal (midtarsal) joint — joint situated in front of the talus and calcaneus but proximal to the cuboid and navicular bones", "e": "articulatio (L. articulātio: joint) + tarsi (Gk. tarsos: flat of the foot) + transversa (L. transversus: lying across, from trans = across + vertere = to turn)", "p": 80}, {"t": "Articulatio calcaneocuboidea", "m": "Calcaneocuboid joint — joint between the calcaneus and cuboid bones", "e": "articulatio (L. articulātio: joint) + calcaneo- (L. calcaneus: heel bone) + cuboidea (Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form)", "p": 80}, {"t": "Articulatio cuneocuboidea", "m": "Cuneocuboid joint — articulation between the cuboid bone and lateral cuneiform bone", "e": "articulatio (L. articulātio: joint) + cuneo- (L. cuneus: wedge) + cuboidea (Gk. kuboeides: cube-shaped)", "p": 80}, {"t": "Articulatio cuneonavicularis", "m": "Cuneonavicular joint — joint between the navicular bone and cuneiform bones", "e": "articulatio (L. articulātio: joint) + cuneo- (L. cuneus: wedge) + navicularis (L. nāviculāris: boat-shaped, from nāvicula = small boat)", "p": 80}, {"t": "Articulationes intercuneiformes", "m": "Intercuneiform joints — joints between the cuneiform bones", "e": "articulationes (L. articulātiō: joint) + inter- (L. inter: between) + cuneiformes (L. cuneus: wedge + forma: shape)", "p": 80}, {"t": "Ligg. tarsi interossea", "m": "Interosseous ligaments of the tarsus — three interosseous ligaments present between the tarsal bones", "e": "ligamenta (L. ligamentum: band) + tarsi (Gk. tarsos: flat of the foot) + interossea (L. inter: between + os/ossis: bone)", "p": 80}, {"t": "Lig. talocalcaneum interosseum", "m": "Interosseous talocalcaneal ligament — strong mass of ligaments in the sinus tarsi", "e": "ligamentum (L. ligamentum: band) + talo- (L. talus: ankle bone) + calcaneum (L. calcaneus: heel bone) + interosseum (L. inter: between + os/ossis: bone)", "p": 80}, {"t": "Lig. cuneocuboideum interosseum", "m": "Interosseous cuneocuboid ligament — taut connection between the lateral cuneiform bone and the cuboid bone", "e": "ligamentum (L. ligamentum: band) + cuneo- (L. cuneus: wedge) + cuboideum (Gk. kuboeides: cube-shaped) + interosseum (L. inter: between + os/ossis: bone)", "p": 80}, {"t": "Ligg. intercuneiformia interossea", "m": "Interosseous intercuneiform ligaments — taut ligaments between the three cuneiform bones", "e": "ligamenta (L. ligamentum: band) + inter- (L. inter: between) + cuneiformia (L. cuneus: wedge + forma: shape) + interossea (L. inter: between + os/ossis: bone)", "p": 80}, {"t": "Ligg. tarsi dorsalia", "m": "Dorsal ligaments of the tarsus — eight dorsal ligaments present between the tarsal bones", "e": "ligamenta (L. ligamentum: band) + tarsi (Gk. tarsos: flat of the foot) + dorsalia (L. dorsālis: of the back, from dorsum = back)", "p": 80}, {"t": "Lig. talonaviculare", "m": "Talonavicular ligament — dorsal ligament between the head of the talus and the navicular bone", "e": "ligamentum (L. ligamentum: band) + talo- (L. talus: ankle bone) + naviculare (L. nāviculāris: boat-shaped, from nāvicula = small boat)", "p": 80}, {"t": "Ligg. intercuneiformia dorsalia", "m": "Dorsal intercuneiform ligaments — dorsal ligaments between the cuneiform bones", "e": "ligamenta (L. ligamentum: band) + inter- (L. inter: between) + cuneiformia (L. cuneus: wedge + forma: shape) + dorsalia (L. dorsālis: of the back)", "p": 80}, {"t": "Lig. cuneocuboideum dorsale", "m": "Dorsal cuneocuboid ligaments — dorsal ligaments between the lateral cuneiform bone and the cuboid bone", "e": "ligamentum (L. ligamentum: band) + cuneo- (L. cuneus: wedge) + cuboideum (Gk. kuboeides: cube-shaped) + dorsale (L. dorsālis: of the back)", "p": 80}, {"t": "Lig. cuboideonaviculare dorsale", "m": "Dorsal cuboideonavicular ligament — ligament between the cuboid and navicular bones", "e": "ligamentum (L. ligamentum: band) + cuboideo- (Gk. kuboeides: cube-shaped) + naviculare (L. nāviculāris: boat-shaped) + dorsale (L. dorsālis: of the back)", "p": 80}, {"t": "Lig. bifurcatum", "m": "Bifurcate ligament — V-shaped double ligament in front of the sinus tarsi on the dorsum of the foot, extending forward from the calcaneus", "e": "ligamentum (L. ligamentum: band) + bifurcatum (L. bifurcātus: two-forked, from bi = two + furca = fork)", "p": 80}, {"t": "Lig. calcaneonaviculare", "m": "Calcaneonavicular ligament — extends laterally from the head of the talus to the navicular bone", "e": "ligamentum (L. ligamentum: band) + calcaneo- (L. calcaneus: heel bone) + naviculare (L. nāviculāris: boat-shaped, from nāvicula = small boat)", "p": 80}, {"t": "Lig. calcaneocuboideum", "m": "Calcaneocuboid ligament — extends from the calcaneus and attaches near the middle of the cuboid bone", "e": "ligamentum (L. ligamentum: band) + calcaneo- (L. calcaneus: heel bone) + cuboideum (Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form)", "p": 80}, {"t": "Ligg. cuneonavicularia dorsalia", "m": "Dorsal cuneonavicular ligaments — broad group of ligaments on the dorsum of the foot connecting the navicular bone with the three cuneiform bones", "e": "ligamenta (L. ligamentum: band) + cuneo- (L. cuneus: wedge) + navicularia (L. nāviculāris: boat-shaped) + dorsalia (L. dorsālis: of the back, from dorsum = back)", "p": 80}, {"t": "Lig. calcaneocuboideum dorsale", "m": "Dorsal calcaneocuboid ligament — moderate reinforcement of the joint capsule lateral to the bifurcate ligament", "e": "ligamentum (L. ligamentum: band) + calcaneo- (L. calcaneus: heel bone) + cuboideum (Gk. kuboeides: cube-shaped) + dorsale (L. dorsālis: of the back)", "p": 80}, {"t": "Ligg. tarsi plantaria", "m": "Plantar ligaments of tarsus — ligaments on the palmar aspect of the foot", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + tarsi (L. tarsus, Gk. tarsos: flat of the foot, ankle) + plantaria (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Lig. plantare longum", "m": "Long plantar ligament — stout ligament passing from the calcaneus to the cuboid bone and bases of metatarsals II–V", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + plantare (L. plantaris: of the sole, from planta = sole of the foot) + longum (L. longus: long)", "p": 82}, {"t": "Lig. calcaneocuboideum plantare", "m": "Plantar calcaneocuboid ligament or short plantar ligament — shorter portion of the long plantar ligament", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + calcaneocuboideum (L. calcaneus: heel bone, from calx = heel + Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form) + plantare (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Lig. calcaneonaviculare plantare", "m": "Plantar calcaneonavicular (spring) ligament — lies medial to the above-mentioned ligament and supports the articular cavity for the head of the talus", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + calcaneonaviculare (L. calcaneus: heel bone, from calx = heel + navicularis: boat-shaped, from navicula = small boat, from navis = ship) + plantare (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Ligg. cuneonavicularia plantaria", "m": "Plantar cuneonavicular ligaments — groups of ligaments connecting the navicular bone with the cuneiform bones", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + cuneonavicularia (L. cuneus: wedge + navicularis: boat-shaped, from navicula = small boat, from navis = ship) + plantaria (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Lig. cuboideonaviculare plantare", "m": "Plantar cuboideonavicular ligament — plantar ligament connecting the cuboid and navicular bones, supports transverse plantar arch", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + cuboideonaviculare (Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form + L. navicularis: boat-shaped, from navicula = small boat) + plantare (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Ligg. intercuniformia plantare", "m": "Plantar intercuneiform ligaments — fibrous bands on the plantar aspect between the cuneiform bones, support transverse plantar arch", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + intercuniformia (L. inter: between + cuniformia: wedge-shaped, from cuneus = wedge + forma = shape) + plantare (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Lig. cuneocuboideum plantare", "m": "Plantar cuneocuboid ligament — fibrous brace on the plantar aspect between the lateral cuneiform and cuboid bones", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + cuneocuboideum (L. cuneus: wedge + Gk. kuboeides: cube-shaped, from kubos = cube + eidos = form) + plantare (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Articulationes tarsometatarsales", "m": "Tarsometatarsal joints — joints between the tarsal and metatarsal bones of the foot", "e": "articulationes (L. articulatio: joint, from articulare = to divide into joints, from articulus = small joint) + tarsometatarsales (Gk. tarsos: flat of foot/ankle + meta: after/beyond + tarsos: flat of foot, hence metatarsal = beyond the tarsus)", "p": 82}, {"t": "Ligg. tarsometatarsalia dorsalia", "m": "Dorsal tarsometatarsal ligaments — ligaments on the dorsum of the foot between the tarsal and metatarsal bones", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + tarsometatarsalia (Gk. tarsos: flat of foot + meta: beyond + tarsos: flat of foot) + dorsalia (L. dorsalis: of the back/dorsum, from dorsum = back)", "p": 82}, {"t": "Ligg. tarsometatarsalia plantaria", "m": "Plantar tarsometatarsal ligaments — ligaments on the plantar aspect between the tarsal and metatarsal bones", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + tarsometatarsalia (Gk. tarsos: flat of foot + meta: beyond + tarsos: flat of foot) + plantaria (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Ligg. cuneometatarsalia interossea", "m": "Interosseous cuneometatarsal ligaments — ligaments occupying the joint spaces between the cuneiform and metatarsal bones", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + cuneometatarsalia (L. cuneus: wedge + Gk. meta: beyond + tarsos: flat of foot) + interossea (L. inter: between + ossea: of bone, from os = bone)", "p": 82}, {"t": "Articulationes intermetatarsales", "m": "Intermetatarsal joints — joints between the bases of the metatarsal bones", "e": "articulationes (L. articulatio: joint, from articulus = small joint) + intermetatarsales (L. inter: between + Gk. meta: beyond + tarsos: flat of foot)", "p": 82}, {"t": "Ligg. metatarsalia interossea", "m": "Interosseous metatarsal ligaments — ligaments between the bases of the metatarsal bones forming the distal limits of articular spaces", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + metatarsalia (Gk. meta: beyond + tarsos: flat of foot) + interossea (L. inter: between + ossea: of bone, from os = bone)", "p": 82}, {"t": "Ligg. metatarsalia dorsalia", "m": "Dorsal metatarsal ligaments — ligaments between the bases of the metatarsal bones on the dorsum of the foot", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + metatarsalia (Gk. meta: beyond + tarsos: flat of foot) + dorsalia (L. dorsalis: of the back/dorsum, from dorsum = back)", "p": 82}, {"t": "Ligg. metatarsalia plantaria", "m": "Plantar metatarsal ligaments — ligaments between the bases of the metatarsal bones on the plantar aspect", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + metatarsalia (Gk. meta: beyond + tarsos: flat of foot) + plantaria (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Spatia interossea metatarsi", "m": "Metatarsal interosseous spaces — spaces between the shafts of the metatarsal bones occupied by corresponding muscles", "e": "spatia (L. spatium: space, interval) + interossea (L. inter: between + ossea: of bone, from os = bone) + metatarsi (Gk. meta: beyond + tarsos: flat of foot)", "p": 82}, {"t": "Articulationes metatarsophalangeales", "m": "Metatarsophalangeal joints", "e": "articulationes (L. articulatio: joint, from articulus = small joint) + metatarsophalangeales (Gk. meta: beyond + tarsos: flat of foot + phalanx: row/bone of finger or toe, from Gk. phalanx = line of soldiers)", "p": 82}, {"t": "Ligg. plantaria", "m": "Plantar ligaments — connective tissue reinforcement of the capsule of the metatarsophalangeal joint", "e": "ligg. (L. ligamenta: ligaments, from ligare = to bind) + plantaria (L. plantaris: of the sole, from planta = sole of the foot)", "p": 82}, {"t": "Lig. metatarsale transversum profundum", "m": "Deep transverse metatarsal ligament — transversely oriented ligament connecting the heads of the metatarsal bones", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + metatarsale (Gk. meta: beyond + tarsos: flat of foot) + transversum (L. transversus: lying across, from trans = across + vertere = to turn) + profundum (L. profundus: deep, from pro = before/forward + fundus = bottom)", "p": 82}, {"t": "Articulationes interphalangeales pedis", "m": "Interphalangeal joints of the foot — middle and terminal joints between the phalanges of the foot", "e": "articulationes (L. articulatio: joint, from articulus = small joint) + interphalangeales (L. inter: between + Gk. phalanx: bone of finger or toe) + pedis (L. pes, pedis: foot)", "p": 82}, {"t": "Muscular System", "m": "Muscular System", "e": "muscularis (L. musculāris: of muscles, from musculus = muscle, lit. 'little mouse') + systema (Gk. sústēma: composite whole, from syn = together + histanai = to set up)", "p": 84}, {"t": "Musculi dorsi", "m": "The muscles of the back", "e": "musculi (L. musculus: muscle, pl. musculi) + dorsi (L. dorsum: back, gen. dorsi)", "p": 84}, {"t": "M. trapezius", "m": "Trapezius muscle", "e": "musculus (L. musculus: muscle) + trapezius (Gk. trapézion: small table, trapezoid shape, from trapeza = table)", "p": 84}, {"t": "M. transversus nuchae", "m": "Rare platysmal muscle situated between the insertions of the trapezius and sternocleidomastoid", "e": "musculus (L. musculus: muscle) + transversus (L. transversus: lying across, from trans = across + vertere = to turn) + nuchae (ML. nucha: nape of neck, from Arabic nukha' = spinal marrow, gen. nuchae)", "p": 84}, {"t": "M. latissimus dorsi", "m": "Broadest muscle of the back", "e": "musculus (L. musculus: muscle) + latissimus (L. latissimus: broadest, superlative of latus = wide) + dorsi (L. dorsum: back, gen. dorsi)", "p": 84}, {"t": "M. rhomboideus major", "m": "Larger rhomboid muscle; medial and upward movement of scapula", "e": "musculus (L. musculus: muscle) + rhomboideus (Gk. rhomboeidēs: rhombus-shaped, from rhombos = spinning top/rhombus + eidos = form) + major (L. maior: larger, comparative of magnus = great)", "p": 84}, {"t": "M. rhomboideus minor", "m": "Smaller rhomboid muscle; medial and upward movement of scapula", "e": "musculus (L. musculus: muscle) + rhomboideus (Gk. rhomboeidēs: rhombus-shaped, from rhombos = rhombus + eidos = form) + minor (L. minor: smaller, comparative of parvus = small)", "p": 84}, {"t": "M. levator scapulae", "m": "Elevates superior angle of scapula and rotates neck", "e": "musculus (L. musculus: muscle) + levator (L. levātor: lifter, from levare = to lift) + scapulae (L. scapula: shoulder blade, gen. scapulae)", "p": 84}, {"t": "M. serratus posterior inferior", "m": "Retroversion of four lower ribs", "e": "musculus (L. musculus: muscle) + serratus (L. serrātus: saw-toothed, from serra = saw) + posterior (L. posterior: behind, coming after) + inferior (L. inferior: lower)", "p": 84}, {"t": "M. serratus posterior superior", "m": "Raises ribs in inspiration", "e": "musculus (L. musculus: muscle) + serratus (L. serrātus: saw-toothed, from serra = saw) + posterior (L. posterior: behind) + superior (L. superior: upper, comparative of superus = above)", "p": 84}, {"t": "M. erector spinae", "m": "Collective term for the muscles of the lateral and medial tracts of the back", "e": "musculus (L. musculus: muscle) + erector (L. ērēctor: one who erects, from erigere = to erect) + spinae (L. spina: spine/thorn, gen. spinae)", "p": 84}, {"t": "Tractus laterale", "m": "Lateral tract", "e": "tractus (L. tractus: tract, course, from trahere = to draw/pull) + laterale (L. lateralis: of the side, from latus = side)", "p": 84}, {"t": "M. longissimus", "m": "Longest muscle; consists of three parts", "e": "musculus (L. musculus: muscle) + longissimus (L. longissimus: longest, superlative of longus = long)", "p": 84}, {"t": "M. longissimus thoracis", "m": "Lateral and backward flexion of vertebral column", "e": "musculus (L. musculus: muscle) + longissimus (L. longissimus: longest, superlative of longus = long) + thoracis (Gk. thōrax: chest, breastplate, gen. thōracis)", "p": 84}, {"t": "M. longissimus cervicis", "m": "Lies between the iliocostalis cervicis and longissimus capitis muscles", "e": "musculus (L. musculus: muscle) + longissimus (L. longissimus: longest, superlative of longus = long) + cervicis (L. cervix: neck, gen. cervicis)", "p": 84}, {"t": "M. longissimus capitis", "m": "Lateral and backward flexion of the head; rotates face toward ipsilateral side", "e": "musculus (L. musculus: muscle) + longissimus (L. longissimus: longest, superlative of longus = long) + capitis (L. caput: head, gen. capitis)", "p": 84}, {"t": "M. iliocostalis", "m": "Iliocostal muscle, consisting of three segments", "e": "musculus (L. musculus: muscle) + iliocostalis (L. ilium: flank/hip bone + costa: rib + -alis: pertaining to)", "p": 84}, {"t": "M. iliocostalis lumborum", "m": "Extension and lateral flexion of lower vertebral column", "e": "musculus (L. musculus: muscle) + iliocostalis (L. ilium: flank + costa: rib + -alis: pertaining to) + lumborum (L. lumbus: loin, gen. pl. lumborum)", "p": 84}, {"t": "M. iliocostalis thoracis", "m": "Flattening of thoracic kyphosis, lateral flexion", "e": "musculus (L. musculus: muscle) + iliocostalis (L. ilium: flank + costa: rib + -alis: pertaining to) + thoracis (Gk. thōrax: chest, gen. thōracis)", "p": 84}, {"t": "M. iliocostalis cervicis", "m": "Transverse processes of middle cervical vertebrae", "e": "musculus (L. musculus: muscle) + iliocostalis (L. ilium: flank + costa: rib + -alis: pertaining to) + cervicis (L. cervix: neck, gen. cervicis)", "p": 84}, {"t": "M. splenius cervicis", "m": "Backward flexion and rotation of head", "e": "musculus (L. musculus: muscle) + splenius (Gk. splēnion: bandage/patch, from splēn = spleen, used figuratively for a flat muscle) + cervicis (L. cervix: neck, gen. cervicis)", "p": 84}, {"t": "M. splenius capitis", "m": "Backward flexion and rotation of head", "e": "musculus (L. musculus: muscle) + splenius (Gk. splēnion: bandage/patch) + capitis (L. caput: head, gen. capitis)", "p": 84}, {"t": "MM. intertransversarii", "m": "Muscular connection of adjacent transverse processes; lateral flexion", "e": "musculi (L. musculus: muscle, pl.) + inter (L. inter: between) + transversarii (L. transversus: lying across, from trans = across + vertere = to turn, pl. adj.)", "p": 84}, {"t": "Mm. intertransversarii laterales lumborum", "m": "Muscles between adjacent costal processes; ventral rami of spinal nerves", "e": "musculi (L. musculus: muscle, pl.) + inter (L. inter: between) + transversarii (L. transversus: across + vertere = to turn) + laterales (L. lateralis: of the side, from latus = side, pl.) + lumborum (L. lumbus: loin, gen. pl.)", "p": 84}, {"t": "Mm. intertransversarii mediales lumborum", "m": "Muscles between the mamillary processes", "e": "musculi (L. musculus: muscle, pl.) + inter (L. inter: between) + transversarii (L. transversus: across) + mediales (L. medialis: middle, from medius = middle, pl.) + lumborum (L. lumbus: loin, gen. pl.)", "p": 84}, {"t": "Mm. intertransversarii thoracis", "m": "Usually absent", "e": "musculi (L. musculus: muscle, pl.) + inter (L. inter: between) + transversarii (L. transversus: across) + thoracis (Gk. thōrax: chest, gen.)", "p": 84}, {"t": "Mm. intertransversarii posteriores cervicis", "m": "Muscles between posterior tubercles of transverse processes of cervical vertebrae", "e": "musculi (L. musculus: muscle, pl.) + inter (L. inter: between) + transversarii (L. transversus: across) + posteriores (L. posterior: behind, pl.) + cervicis (L. cervix: neck, gen.)", "p": 84}, {"t": "Pars medialis", "m": "Medial part of Mm. intertransversarii posteriores cervicis", "e": "pars (L. pars: part) + medialis (L. medialis: of the middle, from medius = middle)", "p": 84}, {"t": "Pars lateralis", "m": "Lateral part of Mm. intertransversarii posteriores cervicis; ventral ramus of spinal nerves", "e": "pars (L. pars: part) + lateralis (L. lateralis: of the side, from latus = side)", "p": 84}, {"t": "Mm. intertransversarii anteriores cervicis", "m": "Muscles connecting the anterior tubercles of the cervical transverse processes", "e": "musculi (L. musculus: muscle, pl.) + inter (L. inter: between) + transversarii (L. transversus: across, from trans = across + vertere = to turn) + anteriores (L. anterior: in front, pl.) + cervicis (L. cervix: neck, gen.)", "p": 84}, {"t": "Tractus mediale", "m": "Medial tract", "e": "tractus (L. tractus: tract, course, from trahere = to draw/pull) + mediale (L. medialis: of the middle, from medius = middle)", "p": 86}, {"t": "M. spinalis", "m": "Muscular system attached to the spinous processes", "e": "musculus (L. musculus: muscle, little mouse) + spinalis (L. spinalis: of the spine, from spina = thorn, spine)", "p": 86}, {"t": "M. spinalis thoracis", "m": "Spinalis of the thorax; transverse processes of T11–L2, spinous processes of T2–11", "e": "musculus (L. musculus: muscle) + spinalis (L. spinalis: of the spine, from spina = thorn) + thoracis (L. thorax, thoracis: chest, from Gk. thōrax = breastplate/chest)", "p": 86}, {"t": "M. spinalis cervicis", "m": "Spinalis of the neck; transverse processes of C6–T2, spinous processes of C2–4", "e": "musculus (L. musculus: muscle) + spinalis (L. spinalis: of the spine) + cervicis (L. cervix, cervicis: neck)", "p": 86}, {"t": "M. spinalis capitis", "m": "Inconstant part of semispinalis capitis with additional origins from the upper thoracic and lower cervical spinous processes", "e": "musculus (L. musculus: muscle) + spinalis (L. spinalis: of the spine) + capitis (L. caput, capitis: head)", "p": 86}, {"t": "MM. INTERSPINALES", "m": "Muscles extending only between the spinous processes of continuous vertebrae; dorsiflexion", "e": "musculi (L. musculus: muscle) + inter (L. inter: between) + spinales (L. spinalis: of the spine, from spina = thorn)", "p": 86}, {"t": "Mm. interspinales cervicis", "m": "Paired interspinal muscles of the cervical region due to the bifid cervical spinous processes", "e": "musculi (L. musculus: muscle) + inter (L. inter: between) + spinales (L. spinalis: of the spine) + cervicis (L. cervix, cervicis: neck)", "p": 86}, {"t": "Mm. interspinales thoracis", "m": "Interspinal muscles of the thorax; usually absent", "e": "musculi (L. musculus: muscle) + inter (L. inter: between) + spinales (L. spinalis: of the spine) + thoracis (L. thorax, thoracis: chest)", "p": 86}, {"t": "Mm. interspinales lumborum", "m": "Especially strong interspinal muscle bands of the lumbar region", "e": "musculi (L. musculus: muscle) + inter (L. inter: between) + spinales (L. spinalis: of the spine) + lumborum (L. lumbus, lumbi: loin, lower back)", "p": 86}, {"t": "MM. TRANSVERSOSPINALES", "m": "Collective term for the following nine muscles", "e": "musculi (L. musculus: muscle) + transversus (L. transversus: transverse, from trans = across + vertere = to turn) + spinales (L. spinalis: of the spine, from spina = thorn)", "p": 86}, {"t": "M. semispinalis", "m": "The longest superficial portion of the transversospinales spanning four or more vertebrae", "e": "musculus (L. musculus: muscle) + semi (L. semi: half) + spinalis (L. spinalis: of the spine, from spina = thorn)", "p": 86}, {"t": "M. semispinalis thoracis", "m": "Semispinalis of the thorax; transverse processes of T7–I2, spinous processes of C6–T6; primarily dorsiflexion", "e": "musculus (L. musculus: muscle) + semi (L. semi: half) + spinalis (L. spinalis: of the spine) + thoracis (L. thorax, thoracis: chest)", "p": 86}, {"t": "M. semispinalis cervicis", "m": "Semispinalis of the neck; transverse processes of T1–6, spinous processes of C2–5; mainly dorsiflexion", "e": "musculus (L. musculus: muscle) + semi (L. semi: half) + spinalis (L. spinalis: of the spine) + cervicis (L. cervix, cervicis: neck)", "p": 86}, {"t": "M. semispinalis capitis", "m": "Semispinalis of the head; transverse processes of C4–T6, occipital bone between superior and inferior nuchal lines; dorsiflexion of head and rotation", "e": "musculus (L. musculus: muscle) + semi (L. semi: half) + spinalis (L. spinalis: of the spine) + capitis (L. caput, capitis: head)", "p": 86}, {"t": "Mm. multifidi", "m": "Portion of the transversospinal system spanning 2–4 vertebrae; dorsolateral flexion and slight rotation", "e": "musculi (L. musculus: muscle) + multifidi (L. multifidus: divided into many parts, from multus = many + findere = to split)", "p": 86}, {"t": "Mm. rotatores", "m": "Deepest layer of the transversospinal system with short fibers providing stronger rotation; attach to adjacent or superior vertebra", "e": "musculi (L. musculus: muscle) + rotatores (L. rotator: one who rotates, from rotare = to rotate, from rota = wheel)", "p": 86}, {"t": "Mm. rotatores cervicis", "m": "Rotatores of the neck; inferior articular process, arch or root of spinous process of cervical vertebrae", "e": "musculi (L. musculus: muscle) + rotatores (L. rotator: one who rotates, from rotare = to rotate) + cervicis (L. cervix, cervicis: neck)", "p": 86}, {"t": "Mm. rotatores thoracis", "m": "Rotatores of the thorax; transverse process of thoracic vertebrae, spinous process", "e": "musculi (L. musculus: muscle) + rotatores (L. rotator: one who rotates) + thoracis (L. thorax, thoracis: chest)", "p": 86}, {"t": "Mm. rotatores lumborum", "m": "Rotatores of the lumbar region; mamillary process, roots of spinous process of lumbar vertebrae", "e": "musculi (L. musculus: muscle) + rotatores (L. rotator: one who rotates) + lumborum (L. lumbus: loin, lower back)", "p": 86}, {"t": "Fascia thoracolumbalis", "m": "Thoracolumbar fascia; encasing fascia of the erector spinae muscle attached to spinous and costal processes", "e": "fascia (L. fascia: band, bandage, sheet) + thoraco (Gk. thōrax: chest) + lumbalis (L. lumbalis: of the loins, from lumbus = loin)", "p": 86}, {"t": "Fascia nuchae", "m": "Nuchal fascia; dorsal continuation of the superficial layer of the cervical fascia investing the true neck musculature", "e": "fascia (L. fascia: band, sheet) + nuchae (Medieval L. nucha: nape of the neck, from Arabic nukha = spinal marrow)", "p": 86}, {"t": "Musculi capitis", "m": "Head muscles", "e": "musculi (L. musculus: muscle) + capitis (L. caput, capitis: head)", "p": 86}, {"t": "MM. SUBOCCIPITALES", "m": "The following seven suboccipital muscles", "e": "musculi (L. musculus: muscle) + sub (L. sub: under, below) + occipitales (L. occiput, occipitis: back of the head, from ob = against/behind + caput = head)", "p": 86}, {"t": "M. rectus capitis anterior", "m": "Lateral mass of the atlas to basilar part of occipital bone; forward flexion of head", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight, from regere = to keep straight) + capitis (L. caput, capitis: head) + anterior (L. anterior: in front, from ante = before)", "p": 86}, {"t": "M. rectus capitis posterior major", "m": "Spinous process of axis to middle of inferior nuchal line; outward rotation and dorsiflexion of head", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight) + capitis (L. caput, capitis: head) + posterior (L. posterior: behind, from post = after) + major (L. major: greater, larger)", "p": 86}, {"t": "M. rectus capitis posterior minor", "m": "Posterior tubercle of atlas to inner third of inferior nuchal line; mainly dorsiflexion of head", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight) + capitis (L. caput, capitis: head) + posterior (L. posterior: behind) + minor (L. minor: smaller, lesser)", "p": 86}, {"t": "M. rectus capitis lateralis", "m": "Lateral straight muscle of the head", "e": "musculus (L. musculus: muscle, little mouse) + rectus (L. rectus: straight, from regere = to straighten) + capitis (L. caput/capitis: of the head) + lateralis (L. lateralis: of the side, from latus = side)", "p": 88}, {"t": "M. obliquus capitis superior", "m": "Superior oblique muscle of the head", "e": "musculus (L. musculus: muscle) + obliquus (L. obliquus: oblique, slanting) + capitis (L. caput/capitis: of the head) + superior (L. superior: upper, higher)", "p": 88}, {"t": "M. obliquus capitis inferior", "m": "Inferior oblique muscle of the head", "e": "musculus (L. musculus: muscle) + obliquus (L. obliquus: oblique, slanting) + capitis (L. caput/capitis: of the head) + inferior (L. inferior: lower)", "p": 88}, {"t": "M. longus capitis", "m": "Long muscle of the head", "e": "musculus (L. musculus: muscle) + longus (L. longus: long) + capitis (L. caput/capitis: of the head)", "p": 88}, {"t": "Musculi faciales et masticatorii", "m": "Facial and masticatory muscles", "e": "musculi (L. musculus: muscle, plural) + faciales (L. facialis: of the face, from facies = face) + et (L. et: and) + masticatorii (L. masticatorius: of chewing, from masticare = to chew, from Gk. mastikhan = to gnash the teeth)", "p": 88}, {"t": "M. epicranius", "m": "Collective term for muscles attaching to the galea aponeurotica", "e": "musculus (L. musculus: muscle) + epicranius (Gk. epi = upon + kranion = skull)", "p": 88}, {"t": "M. occipitofrontalis", "m": "Muscle extending anteriorly and posteriorly into the galea aponeurotica", "e": "musculus (L. musculus: muscle) + occipitofrontalis (L. occiput/occipitis = back of the head + frontalis = of the forehead, from frons = forehead)", "p": 88}, {"t": "Venter frontalis", "m": "Frontal belly — the portion of the occipitofrontalis passing from the galea aponeurotica to the eyebrows", "e": "venter (L. venter: belly, stomach) + frontalis (L. frontalis: of the forehead, from frons/frontis = forehead)", "p": 88}, {"t": "Venter occipitalis", "m": "Occipital belly — the portion of the occipitofrontalis passing from the supreme nuchal line to the galea aponeurotica", "e": "venter (L. venter: belly, stomach) + occipitalis (L. occipitalis: of the back of the head, from occiput/occipitis = back of skull, from ob = against + caput = head)", "p": 88}, {"t": "M. temporoparietalis", "m": "Region of superior auricular muscle", "e": "musculus (L. musculus: muscle) + temporoparietalis (L. temporalis = of the temple, from tempus/temporis = temple + parietalis = of the wall, from paries/parietis = wall)", "p": 88}, {"t": "Galea aponeurotica", "m": "Displaceable, helmet-like, superficial tendon for the two parts of the epicranius", "e": "galea (L. galea: helmet) + aponeurotica (Gk. apo = away from + neuron = sinew/tendon, hence aponeurosis = flat tendinous sheet)", "p": 88}, {"t": "Aponeurosis epicranialis", "m": "Displaceable, helmet-like, superficial tendon for the two parts of the epicranius", "e": "aponeurosis (Gk. apo = away from + neuron = sinew/tendon: flat tendinous sheet) + epicranialis (Gk. epi = upon + kranion = skull)", "p": 88}, {"t": "M. procerus", "m": "Muscle arising from dorsum of nose, inserting into skin above the nose; depresses frontal skin", "e": "musculus (L. musculus: muscle) + procerus (L. procerus: tall, elongated, from pro = forward + crus = leg/shank, or from procedere = to go forward)", "p": 88}, {"t": "M. nasalis", "m": "Common term for the two nasal muscles", "e": "musculus (L. musculus: muscle) + nasalis (L. nasalis: of the nose, from nasus = nose)", "p": 88}, {"t": "Pars transversa nasalis", "m": "Transverse part of nasalis (compressor naris)", "e": "pars (L. pars: part) + transversa (L. transversus: lying across, from trans = across + vertere = to turn) + nasalis (L. nasalis: of the nose, from nasus = nose)", "p": 88}, {"t": "Pars alaris nasalis", "m": "Alar part of nasalis (dilatator naris)", "e": "pars (L. pars: part) + alaris (L. alaris: of the wing, from ala = wing) + nasalis (L. nasalis: of the nose, from nasus = nose)", "p": 88}, {"t": "M. depressor septi", "m": "Muscle arising from above the medial incisor tooth, inserting into cartilaginous nasal septum; depresses tip of nose", "e": "musculus (L. musculus: muscle) + depressor (L. depressor: one who presses down, from de = down + premere = to press) + septi (L. septum/septi: partition, wall, from saepire = to enclose)", "p": 88}, {"t": "M. orbicularis oculi", "m": "Circular sphincter muscle of the eye comprising three segments; closes eyelids and assists flow of tears", "e": "musculus (L. musculus: muscle) + orbicularis (L. orbicularis: circular, from orbiculus = small circle, from orbis = circle/ring) + oculi (L. oculus/oculi: of the eye)", "p": 88}, {"t": "Pars palpebralis", "m": "Palpebral part — fibers in the eyelids passing from the medial palpebral ligament", "e": "pars (L. pars: part) + palpebralis (L. palpebralis: of the eyelid, from palpebra = eyelid)", "p": 88}, {"t": "Pars lacrimalis", "m": "Lacrimal part — arises from posterior lacrimal crest, curves around lacrimal canaliculus", "e": "pars (L. pars: part) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 88}, {"t": "M. corrugator supercilii", "m": "Muscle arising from nasal part of frontal bone, inserting into skin over the middle of the eyebrow", "e": "musculus (L. musculus: muscle) + corrugator (L. corrugator: one who wrinkles, from con = together + rugare = to wrinkle) + supercilii (L. supercilium/supercilii: of the eyebrow, from super = above + cilium = eyelid/edge)", "p": 88}, {"t": "M. depressor supercilii", "m": "Muscle medial to the corrugator supercilii that radiates into skin of medial part of eyebrow", "e": "musculus (L. musculus: muscle) + depressor (L. depressor: one who presses down, from de = down + premere = to press) + supercilii (L. supercilium/supercilii: of the eyebrow, from super = above + cilium = eyelid/edge)", "p": 88}, {"t": "M. auricularis anterior", "m": "Muscle in front of the ear arising from temporal fascia, inserting into spine of helix", "e": "musculus (L. musculus: muscle) + auricularis (L. auricularis: of the ear, from auricula = little ear, from auris = ear) + anterior (L. anterior: in front, former)", "p": 88}, {"t": "M. auricularis superior", "m": "Muscle arising from galea aponeurotica, inserting into root of pinna", "e": "musculus (L. musculus: muscle) + auricularis (L. auricularis: of the ear, from auricula = little ear, from auris = ear) + superior (L. superior: upper, higher)", "p": 88}, {"t": "M. auricularis posterior", "m": "Muscle arising from mastoid process, inserting into root of pinna", "e": "musculus (L. musculus: muscle) + auricularis (L. auricularis: of the ear, from auricula = little ear, from auris = ear) + posterior (L. posterior: behind, after)", "p": 88}, {"t": "M. orbicularis oris", "m": "Muscle that encircles the mouth opening, consisting of two parts; assists in closing the lips", "e": "musculus (L. musculus: muscle) + orbicularis (L. orbicularis: circular, from orbiculus = small circle, from orbis = circle/ring) + oris (L. os/oris: of the mouth)", "p": 88}, {"t": "Pars marginalis", "m": "Marginal part — peripheral margin of orbicularis oris radiating into neighboring muscles", "e": "pars (L. pars: part) + marginalis (L. marginalis: of the margin/edge, from margo/marginis = edge, border)", "p": 88}, {"t": "Pars labialis", "m": "Labial part — main part of orbicularis oris including portion that takes a hook-like bend externally below the red portion of the lips", "e": "pars (L. pars: part) + labialis (L. labialis: of the lip, from labium = lip)", "p": 88}, {"t": "Musculi thoracis", "m": "Muscles of thorax", "e": "musculi (L. musculus: muscle, lit. little mouse) + thoracis (L. thorax, thoracis: chest, from Gk. thōrax: breastplate, chest)", "p": 94}, {"t": "Pars clavicularis", "m": "Clavicular part — the portion originating from the clavicle", "e": "pars (L. pars: part, portion) + clavicularis (L. clavicularis: of the clavicle, from clavicula: little key, diminutive of clavis: key)", "p": 94}, {"t": "Pars sternocostalis", "m": "Sternocostal part — the portion arising from the sternum and ribs", "e": "pars (L. pars: part, portion) + sternocostalis (L. sternum: breastbone, from Gk. sternon: chest + costalis: of the ribs, from costa: rib)", "p": 94}, {"t": "Pars abdominalis", "m": "Abdominal part — the portion arising from the rectus sheath", "e": "pars (L. pars: part, portion) + abdominalis (L. abdominalis: of the abdomen, from abdomen: belly)", "p": 94}, {"t": "Fascia pectoralis", "m": "Pectoral fascia — covers the pectoralis major muscle, attached to the clavicle and sternum and continuous with the axillary fascia", "e": "fascia (L. fascia: band, bandage, strip) + pectoralis (L. pectoralis: of the chest, from pectus, pectoris: chest, breast)", "p": 94}, {"t": "Fascia clavipectoralis", "m": "Clavipectoral fascia — fascia attached to the coracoid process and the clavicle, covers the pectoralis minor and subclavius muscles", "e": "fascia (L. fascia: band, bandage) + clavipectoralis (L. clavicula: little key/clavicle + pectoralis: of the chest, from pectus: chest)", "p": 94}, {"t": "Mm. levatores costarum", "m": "Muscles behind and below the long back muscles, originating from thoracic transverse processes, inserting on ribs", "e": "mm. (L. musculi: muscles, plural abbreviation) + levatores (L. levator: lifter, from levare: to lift, raise) + costarum (L. costa: rib, gen. plural costarum: of the ribs)", "p": 94}, {"t": "Mm. levatores costarum longi", "m": "Long levatores costarum — pass over a rib to insert on the next lower rib", "e": "mm. (L. musculi: muscles) + levatores (L. levator: lifter, from levare: to lift) + costarum (L. costa: rib, gen. plural) + longi (L. longus: long)", "p": 94}, {"t": "Mm. levatores costarum breves", "m": "Short levatores costarum — transverse process to next lower rib", "e": "mm. (L. musculi: muscles) + levatores (L. levator: lifter, from levare: to lift) + costarum (L. costa: rib, gen. plural) + breves (L. brevis: short)", "p": 94}, {"t": "Mm. intercostales externi", "m": "External intercostal muscles — extend obliquely forward and downward between the ribs", "e": "mm. (L. musculi: muscles) + intercostales (L. inter: between + costa: rib + -alis: relating to) + externi (L. externus: outer, external, from exter: outside)", "p": 94}, {"t": "Mm. intercostales interni", "m": "Internal intercostal muscles — pass obliquely backward and downward between the ribs", "e": "mm. (L. musculi: muscles) + intercostales (L. inter: between + costa: rib) + interni (L. internus: inner, internal)", "p": 94}, {"t": "Mm. intercostales intimi", "m": "Innermost intercostal muscles — internal portion of the internal intercostal muscles separated by the intercostal vessels", "e": "mm. (L. musculi: muscles) + intercostales (L. inter: between + costa: rib) + intimi (L. intimus: innermost, superlative of internus: inner)", "p": 94}, {"t": "Mm. subcostales", "m": "Subcostal muscles — internal intercostal muscles that pass over 1–2 ribs", "e": "mm. (L. musculi: muscles) + subcostales (L. sub: under, below + costa: rib + -alis: relating to)", "p": 94}, {"t": "M. transversus thoracis", "m": "Situated on the inner surface of the anterior thoracic wall, radiates obliquely upward from the sternum to costal cartilages 2–6", "e": "m. (L. musculus: muscle) + transversus (L. transversus: transverse, lying across, from trans: across + vertere: to turn) + thoracis (L. thorax, thoracis: chest, from Gk. thōrax: breastplate)", "p": 94}, {"t": "Fascia thoracica", "m": "Thoracic fascia — epimysium of the inner thoracic musculature", "e": "fascia (L. fascia: band, bandage, strip) + thoracica (L. thoracicus: of the thorax, from Gk. thōrax: chest)", "p": 94}, {"t": "Diaphragma", "m": "Diaphragm — dome-shaped, muscular partition between the thoracic and abdominal cavities", "e": "diaphragma (Gk. diaphragma: partition, from dia: through/across + phragma: fence, partition, from phrassein: to enclose)", "p": 94}, {"t": "Pars lumbalis diaphragmatis", "m": "Lumbar part of diaphragm — medial part of the diaphragm arising from the lumbar vertebral bodies, intervertebral discs and fibrous arches", "e": "pars (L. pars: part, portion) + lumbalis (L. lumbalis: of the loins, from lumbus: loin) + diaphragmatis (Gk. diaphragma, gen. diaphragmatis: partition)", "p": 94}, {"t": "Crus dextrum", "m": "Right crus of lumbar part — origin L1–3(4)", "e": "crus (L. crus: leg, shank; also pillar or root of a structure) + dextrum (L. dexter: right, right-hand side)", "p": 94}, {"t": "Crus sinistrum", "m": "Left crus of lumbar part — origin L1–2(3)", "e": "crus (L. crus: leg, shank; also pillar or root) + sinistrum (L. sinister: left, left-hand side)", "p": 94}, {"t": "Pars costalis diaphragmatis", "m": "Costal part of diaphragm — the part of the diaphragm originating from ribs 7–12", "e": "pars (L. pars: part, portion) + costalis (L. costalis: of the ribs, from costa: rib) + diaphragmatis (Gk. diaphragma, gen. diaphragmatis: partition)", "p": 94}, {"t": "Pars sternalis diaphragmatis", "m": "Sternal part of diaphragm — the part of the diaphragm arising from the sternum", "e": "pars (L. pars: part, portion) + sternalis (L. sternalis: of the sternum, from Gk. sternon: chest) + diaphragmatis (Gk. diaphragma, gen. diaphragmatis: partition)", "p": 94}, {"t": "Hiatus aorticus", "m": "Aortic (opening) hiatus — passageway for the aorta between the right and left crus of the lumbar part", "e": "hiatus (L. hiatus: gap, opening, from hiare: to gape, open) + aorticus (L. aorticus: of the aorta, from Gk. aortē: aorta, from aeirein: to lift)", "p": 94}, {"t": "Hiatus oesophageus", "m": "Esophageal (opening) hiatus — passageway for the esophagus and the vagus nerves above the aortic opening", "e": "hiatus (L. hiatus: gap, opening, from hiare: to gape) + oesophageus (L./Gk. oesophageus: of the esophagus, from Gk. oisophagos: gullet, from oisein: to carry + phagein: to eat)", "p": 94}, {"t": "Centrum tendineum", "m": "Central tendon — clover-leaf-shaped, tendinous central area of the diaphragm", "e": "centrum (L. centrum: center, from Gk. kentron: center, point) + tendineum (L. tendineus: of a tendon, from tendo, tendinis: tendon, from tendere: to stretch)", "p": 94}, {"t": "Foramen venae cavae", "m": "Foramen for the inferior vena cava — opening in the central tendon for the inferior vena cava", "e": "foramen (L. foramen: opening, hole, from forare: to pierce) + venae (L. vena: vein, gen. venae: of the vein) + cavae (L. cavus: hollow, gen. cavae: of the hollow)", "p": 94}, {"t": "Lig. arcuatum mediale", "m": "Medial arcuate ligament — tendinous arch between the body and transverse process of L1 or L2 forming the passageway for the psoas muscle", "e": "lig. (L. ligamentum: ligament, band, from ligare: to bind) + arcuatum (L. arcuatus: arched, bow-shaped, from arcus: arch, bow) + mediale (L. medialis: medial, of the middle, from medius: middle)", "p": 94}, {"t": "Lig. arcuatum laterale", "m": "Lateral arcuate ligament — tendinous arch over the quadratus lumborum muscle between the transverse process of L1 and the 12th rib", "e": "lig. (L. ligamentum: ligament, from ligare: to bind) + arcuatum (L. arcuatus: arched, from arcus: arch, bow) + laterale (L. lateralis: lateral, of the side, from latus, lateris: side)", "p": 94}, {"t": "Lig. arcuatum medianum", "m": "Median arcuate ligament — tendinous arch over the aortic hiatus", "e": "lig. (L. ligamentum: ligament, from ligare: to bind) + arcuatum (L. arcuatus: arched, from arcus: arch, bow) + medianum (L. medianus: median, middle, from medius: middle)", "p": 94}, {"t": "Musculi abdominis", "m": "Abdominal muscles", "e": "musculi (L. musculus: muscle, lit. 'little mouse') + abdominis (L. abdomen/abdominis: belly, abdomen)", "p": 96}, {"t": "M. rectus abdominis", "m": "Rectus abdominis muscle — forward flexion of trunk, lowering of thorax, elevation of pelvis", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight) + abdominis (L. abdomen/abdominis: belly)", "p": 96}, {"t": "Intersectiones tendineae", "m": "Tendinous intersections — the 3–4 intermediate tendons of the rectus abdominis muscle", "e": "intersectiones (L. intersectio: intersection, from inter = between + secare = to cut) + tendineae (L. tendineus: of a tendon, from tendere = to stretch)", "p": 96}, {"t": "Vagina m. recti abdominis", "m": "Rectus sheath — covering of the rectus abdominis muscle formed by the aponeuroses of the flat abdominal muscles", "e": "vagina (L. vagina: sheath, scabbard) + musculi (L. musculus: muscle) + recti (L. rectus: straight) + abdominis (L. abdomen: belly)", "p": 96}, {"t": "Lamina anterior", "m": "Anterior layer of rectus sheath", "e": "lamina (L. lamina: layer, plate, leaf) + anterior (L. anterior: in front, former)", "p": 96}, {"t": "Lamina posterior", "m": "Posterior layer of rectus sheath", "e": "lamina (L. lamina: layer, plate) + posterior (L. posterior: behind, later)", "p": 96}, {"t": "M. pyramidalis", "m": "Pyramidalis muscle — muscle enclosed within the split anterior layer of the rectus sheath, passes from pubis and symphysis to the linea alba", "e": "musculus (L. musculus: muscle) + pyramidalis (L. pyramidalis: pyramid-shaped, from Gk. pyramis = pyramid)", "p": 96}, {"t": "M. obliquus externus abdominis", "m": "External abdominal oblique muscle — lowering of thorax, rotation of trunk, lateral flexion", "e": "musculus (L. musculus: muscle) + obliquus (L. obliquus: slanting, oblique) + externus (L. externus: external, outer) + abdominis (L. abdomen: belly)", "p": 96}, {"t": "Lig. inguinale", "m": "Inguinal ligament — lower edge of the external oblique aponeurosis, passes from anterior superior iliac spine to the pubic tubercle", "e": "ligamentum (L. ligamentum: band, tie, from ligare = to bind) + inguinale (L. inguinalis: of the groin, from inguen = groin)", "p": 96}, {"t": "Arcus inguinalis", "m": "Inguinal ligament (alternative name)", "e": "arcus (L. arcus: arch, bow) + inguinalis (L. inguinalis: of the groin, from inguen = groin)", "p": 96}, {"t": "Lig. lacunare", "m": "Lacunar ligament — connective tissue fibers arching downward to the pubis at the medial attachment of the inguinal ligament", "e": "ligamentum (L. ligamentum: band, from ligare = to bind) + lacunare (L. lacunaris: of a lacuna/gap, from lacuna = pit, gap)", "p": 96}, {"t": "Lig. pectineale", "m": "Pectineal ligament — continuation of the lacunar ligament along the pecten pubis", "e": "ligamentum (L. ligamentum: band) + pectineale (L. pectinealis: of the pecten/comb, from pecten = comb, referring to pubic comb)", "p": 96}, {"t": "Lig. reflexum", "m": "Reflected ligament — curved band of fibers passing upward from the medial attachment of the inguinal ligament forming the medial lining of the superficial inguinal ring", "e": "ligamentum (L. ligamentum: band) + reflexum (L. reflexus: bent back, from re = back + flectere = to bend)", "p": 96}, {"t": "Anulus inguinalis superficialis", "m": "Superficial inguinal ring — external opening of the inguinal canal", "e": "anulus (L. anulus: ring, from anus = ring) + inguinalis (L. inguinalis: of the groin) + superficialis (L. superficialis: superficial, from superficies = surface)", "p": 96}, {"t": "Crus mediale", "m": "Medial crus — group of fibers of the external oblique aponeurosis ascending obliquely medial to the superficial inguinal ring", "e": "crus (L. crus: leg, limb, pillar) + mediale (L. medialis: medial, from medius = middle)", "p": 96}, {"t": "Crus laterale", "m": "Lateral crus — group of fibers of the external oblique aponeurosis ascending lateral to the superficial inguinal ring", "e": "crus (L. crus: leg, limb, pillar) + laterale (L. lateralis: lateral, from latus = side)", "p": 96}, {"t": "Fibrae intercrurales", "m": "Intercrural fibers — curved fibers between the medial and lateral crura", "e": "fibrae (L. fibra: fiber, filament) + intercrurales (L. intercruralis: between the crura, from inter = between + crus = leg/pillar)", "p": 96}, {"t": "M. obliquus internus abdominis", "m": "Internal abdominal oblique muscle — lowering of ribs, forward and lateral flexion", "e": "musculus (L. musculus: muscle) + obliquus (L. obliquus: slanting) + internus (L. internus: internal, inner) + abdominis (L. abdomen: belly)", "p": 96}, {"t": "M. cremaster", "m": "Cremaster muscle — muscle fibers derived primarily from the internal oblique abdominal muscle; invests the spermatic cord and elevates the testis", "e": "musculus (L. musculus: muscle) + cremaster (Gk. kremastēr: suspender, from kremannynai = to hang)", "p": 96}, {"t": "M. transversus abdominis", "m": "Transversus abdominis muscle — origin inner surface of ribs 7–12, thoracolumbar fascia, iliac crest, inguinal ligament", "e": "musculus (L. musculus: muscle) + transversus (L. transversus: transverse, from trans = across + vertere = to turn) + abdominis (L. abdomen: belly)", "p": 96}, {"t": "Tendo conjunctivus", "m": "Conjoined tendon — falx inguinalis; fibers from the aponeurosis of the transversus muscle into the pectineal ligament", "e": "tendo (L. tendo: tendon, from tendere = to stretch) + conjunctivus (L. conjunctivus: conjoined, from con = together + jungere = to join)", "p": 96}, {"t": "Falx inguinalis", "m": "Conjoined tendon — falx inguinalis", "e": "falx (L. falx: sickle, scythe) + inguinalis (L. inguinalis: of the groin, from inguen = groin)", "p": 96}, {"t": "Linea alba", "m": "Linea alba — the white tendinous line (raphe) formed by the abdominal aponeuroses, situated between the right and left rectus abdominis muscles", "e": "linea (L. linea: line) + alba (L. albus: white)", "p": 96}, {"t": "Anulus umbilicalis", "m": "Umbilical ring — fibrous ring around the umbilicus in the linea alba", "e": "anulus (L. anulus: ring) + umbilicalis (L. umbilicalis: of the navel, from umbilicus = navel)", "p": 96}, {"t": "Adminiculum lineae albae", "m": "Adminiculum lineae albae — inferior attachment of the linea alba at the symphysis", "e": "adminiculum (L. adminiculum: support, prop, from ad = to + manus = hand) + lineae (L. linea: line, genitive) + albae (L. albus: white, genitive)", "p": 96}, {"t": "Lig. suspensorium penis", "m": "Suspensory ligament of penis (clitoris) — radiates from the pubis into the deep fascia of the penis (clitoris)", "e": "ligamentum (L. ligamentum: band) + suspensorium (L. suspensorius: suspending, from suspendere = to hang up) + penis (L. penis: penis, tail)", "p": 96}, {"t": "Lig. suspensorium clitoridis", "m": "Suspensory ligament of clitoris — radiates from the pubis into the deep fascia of the clitoris", "e": "ligamentum (L. ligamentum: band) + suspensorium (L. suspensorius: suspending) + clitoridis (Gk. kleitoris: clitoris, genitive)", "p": 96}, {"t": "Lig. fundiforme penis", "m": "Fundiform ligament of penis — elastic band arising from the abdominal fascia and linea alba and extending sling-like onto the penis", "e": "ligamentum (L. ligamentum: band) + fundiforme (L. fundiformis: sling-shaped, from funda = sling + forma = shape) + penis (L. penis: penis)", "p": 96}, {"t": "Trigonum lumbale", "m": "Lumbar triangle — weak area of the back bordered by the latissimus dorsi, external abdominal oblique muscle and iliac crest", "e": "trigonum (L. trigonum: triangle, from Gk. trigonon = three-cornered, from tri = three + gonia = angle) + lumbale (L. lumbalis: of the loins, from lumbus = loin)", "p": 96}, {"t": "Fascia transversalis", "m": "Transversalis fascia — fascia between the peritoneum and abdominal musculature", "e": "fascia (L. fascia: band, bandage, sheet) + transversalis (L. transversalis: transverse, from trans = across + vertere = to turn)", "p": 96}, {"t": "Anulus inguinalis profundus", "m": "Deep inguinal ring — inner inguinal ring at the transition of the transversalis fascia into the internal spermatic fascia", "e": "anulus (L. anulus: ring) + inguinalis (L. inguinalis: of the groin) + profundus (L. profundus: deep, from pro = forward + fundus = bottom)", "p": 96}, {"t": "Canalis inguinalis", "m": "Inguinal canal — walls: inguinal ligament, external oblique aponeurosis, internal oblique and transversus abdominis muscles, interfoveolar ligament; contains the spermatic cord", "e": "canalis (L. canalis: canal, channel, pipe) + inguinalis (L. inguinalis: of the groin, from inguen = groin)", "p": 96}, {"t": "Lig. interfoveolare", "m": "Interfoveolar ligament — thickened portion of the transversalis fascia behind the inguinal canal", "e": "ligamentum (L. ligamentum: band) + interfoveolare (L. interfoveolaris: between the foveolae, from inter = between + foveola = small pit, diminutive of fovea = pit)", "p": 96}, {"t": "M. quadratus lumborum", "m": "Quadratus lumborum muscle — origin: iliac crest and processes of lumbar vertebrae; lowers ribs, lateral flexion", "e": "musculus (L. musculus: muscle) + quadratus (L. quadratus: squared, four-sided, from quattuor = four) + lumborum (L. lumbus: loin, genitive plural)", "p": 96}, {"t": "Linea semilunaris", "m": "Linea semilunaris — arched musculotendinous margin of the transversus abdominis muscle", "e": "linea (L. linea: line) + semilunaris (L. semilunaris: half-moon-shaped, from semi = half + luna = moon)", "p": 96}, {"t": "M. flexor carpi radialis", "m": "Flexor carpi radialis muscle — pronation, flexion and radial abduction of the wrist joint", "e": "musculus (L. musculus: muscle, little mouse) + flexor (L. flexor: one who bends, from flectere = to bend) + carpi (L. carpus, from Gk. karpos: wrist) + radialis (L. radialis: of the radius, from radius = spoke, ray)", "p": 100}, {"t": "M. palmaris longus", "m": "Palmaris longus muscle — tenses aponeurosis and flexes the wrist joint and fingers 2–5 at the metacarpophalangeal joints", "e": "musculus (L. musculus: muscle) + palmaris (L. palmaris: of the palm, from palma = palm of the hand) + longus (L. longus: long)", "p": 100}, {"t": "M. flexor carpi ulnaris", "m": "Flexor carpi ulnaris muscle — ulnar abduction and flexion of the wrist joint", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: one who bends) + carpi (L. carpus, from Gk. karpos: wrist) + ulnaris (L. ulnaris: of the ulna, from ulna = elbow, forearm bone)", "p": 100}, {"t": "Humeral head of flexor carpi ulnaris", "m": "Humeral head of flexor carpi ulnaris — the part arising from the epicondyle of the humerus", "e": "humeralis (L. humeralis: of the humerus, from humerus = upper arm bone) + caput (L. caput: head) + flexor (L. flexor: one who bends) + carpi (L. carpus, from Gk. karpos: wrist) + ulnaris (L. ulnaris: of the ulna)", "p": 100}, {"t": "Ulnar head of flexor carpi ulnaris", "m": "Ulnar head of flexor carpi ulnaris — the portion originating from the ulna", "e": "ulnaris (L. ulnaris: of the ulna) + caput (L. caput: head) + flexor (L. flexor: one who bends) + carpi (L. carpus, from Gk. karpos: wrist) + ulnaris (L. ulnaris: of the ulna)", "p": 100}, {"t": "M. flexor digitorum superficialis", "m": "Flexor digitorum superficialis muscle — flexion of all joints it crosses", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: one who bends) + digitorum (L. digitus: finger, toe; genitive plural) + superficialis (L. superficialis: superficial, from superficies = surface, from super = above + facies = face)", "p": 100}, {"t": "Humeroulnar head of flexor digitorum superficialis", "m": "Humeroulnar head — the portion arising from the humerus and ulna", "e": "humerus (L. humerus: upper arm bone) + ulna (L. ulna: forearm bone, elbow) + caput (L. caput: head) + flexor (L. flexor: one who bends) + digitorum (L. digitus: finger) + superficialis (L. superficialis: superficial)", "p": 100}, {"t": "Radial head of flexor digitorum superficialis", "m": "Radial head — the portion arising from the radius", "e": "radialis (L. radialis: of the radius) + caput (L. caput: head) + flexor (L. flexor: one who bends) + digitorum (L. digitus: finger) + superficialis (L. superficialis: superficial)", "p": 100}, {"t": "M. flexor digitorum profundus", "m": "Flexor digitorum profundus muscle — flexion of all joints crossed", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: one who bends) + digitorum (L. digitus: finger) + profundus (L. profundus: deep, from pro = forward + fundus = bottom)", "p": 100}, {"t": "M. flexor pollicis longus", "m": "Flexor pollicis longus muscle — flexion of joints crossed", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: one who bends) + pollicis (L. pollex: thumb; genitive singular) + longus (L. longus: long)", "p": 100}, {"t": "M. pronator quadratus", "m": "Pronator quadratus muscle — pronation", "e": "musculus (L. musculus: muscle) + pronator (L. pronator: one who pronates, from pronare = to bend forward, from pronus = inclined forward) + quadratus (L. quadratus: square, four-sided, from quattuor = four)", "p": 100}, {"t": "M. brachioradialis", "m": "Brachioradialis muscle — flexion of the elbow joint, brings arm from extreme pronation and supination to intermediate position", "e": "musculus (L. musculus: muscle) + brachium (L. brachium, from Gk. brachion: arm) + radialis (L. radialis: of the radius)", "p": 100}, {"t": "M. extensor carpi radialis longus", "m": "Extensor carpi radialis longus muscle — radial abduction and dorsiflexion of the wrist joint, flexion of the elbow joint", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends, from extendere = to stretch out) + carpi (L. carpus, from Gk. karpos: wrist) + radialis (L. radialis: of the radius) + longus (L. longus: long)", "p": 100}, {"t": "M. extensor carpi radialis brevis", "m": "Extensor carpi radialis brevis muscle — extension and radial abduction of wrist joint", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends) + carpi (L. carpus, from Gk. karpos: wrist) + radialis (L. radialis: of the radius) + brevis (L. brevis: short)", "p": 100}, {"t": "M. extensor digitorum", "m": "Extensor digitorum muscle — extension of fingers and dorsiflexion of the wrist joint", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends) + digitorum (L. digitus: finger; genitive plural)", "p": 100}, {"t": "Intertendinous connections", "m": "Intertendinous connections — oblique tendinous connections between the extensor tendons of the fingers on the dorsum of the hand", "e": "inter (L. inter: between) + tendo (L. tendo: tendon, from tendere = to stretch) + connexus (L. connexus: connection, from conectere = to bind together)", "p": 100}, {"t": "Connexus intertendineus", "m": "Intertendinous connections — oblique tendinous connections between the extensor tendons", "e": "connexus (L. connexus: connection, binding together) + inter (L. inter: between) + tendineus (L. tendineus: of a tendon, from tendo = tendon)", "p": 100}, {"t": "Juncturae tendineum", "m": "Tendinous junctions — alternative term for intertendinous connections", "e": "junctura (L. junctura: joint, junction, from jungere = to join) + tendineum (L. tendineus: of tendons, from tendo = tendon)", "p": 100}, {"t": "M. extensor digiti minimi", "m": "Extensor digiti minimi muscle — extension of little finger, abduction and dorsiflexion of the wrist joint", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends) + digiti (L. digitus: finger; genitive singular) + minimi (L. minimus: smallest, least; genitive singular)", "p": 100}, {"t": "M. extensor carpi ulnaris", "m": "Extensor carpi ulnaris muscle — dorsiflexion, ulnar abduction", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends) + carpi (L. carpus, from Gk. karpos: wrist) + ulnaris (L. ulnaris: of the ulna)", "p": 100}, {"t": "Humeral head of extensor carpi ulnaris", "m": "Humeral head of extensor carpi ulnaris — the part arising from the humerus", "e": "humeralis (L. humeralis: of the humerus) + caput (L. caput: head) + extensor (L. extensor: one who extends) + carpi (L. carpus: wrist) + ulnaris (L. ulnaris: of the ulna)", "p": 100}, {"t": "Ulnar head of extensor carpi ulnaris", "m": "Ulnar head of extensor carpi ulnaris — the portion arising from the ulna", "e": "ulnaris (L. ulnaris: of the ulna) + caput (L. caput: head) + extensor (L. extensor: one who extends) + carpi (L. carpus: wrist) + ulnaris (L. ulnaris: of the ulna)", "p": 100}, {"t": "M. supinator", "m": "Supinator muscle — supination", "e": "musculus (L. musculus: muscle) + supinator (L. supinator: one who supinates, from supinare = to bend backward, from supinus = lying on the back)", "p": 100}, {"t": "M. abductor pollicis longus", "m": "Abductor pollicis longus muscle — radial abduction and dorsiflexion of the metacarpophalangeal joint of the thumb, supination", "e": "musculus (L. musculus: muscle) + abductor (L. abductor: one who draws away, from abducere = to lead away) + pollicis (L. pollex: thumb; genitive singular) + longus (L. longus: long)", "p": 100}, {"t": "M. extensor pollicis brevis", "m": "Extensor pollicis brevis muscle — abduction and extension of thumb at the metacarpophalangeal joint", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends) + pollicis (L. pollex: thumb; genitive singular) + brevis (L. brevis: short)", "p": 100}, {"t": "M. extensor pollicis longus", "m": "Extensor pollicis longus muscle — adducts and extends the thumb, supinator", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends) + pollicis (L. pollex: thumb; genitive singular) + longus (L. longus: long)", "p": 100}, {"t": "M. extensor indicis", "m": "Extensor indicis muscle — extends the index finger and wrist joint", "e": "musculus (L. musculus: muscle) + extensor (L. extensor: one who extends) + indicis (L. index: index finger, pointer, from indicare = to point out; genitive singular)", "p": 100}, {"t": "M. palmaris brevis", "m": "Palmaris brevis muscle — skin of ulnar aspect of hand", "e": "musculus (L. musculus: muscle) + palmaris (L. palmaris: of the palm, from palma = palm) + brevis (L. brevis: short)", "p": 100}, {"t": "Caput ulnare", "m": "Ulnar head — the portion originating from the ulna", "e": "caput (L. caput: head) + ulnare (L. ulnaris: of the ulna, from ulna = forearm bone)", "p": 100}, {"t": "Caput humeroulnare", "m": "Humeroulnar head — the portion arising from the humerus and ulna", "e": "caput (L. caput: head) + humerus (L. humerus: upper arm bone) + ulna (L. ulna: forearm bone)", "p": 100}, {"t": "Caput radiale", "m": "Radial head — the portion arising from the radius", "e": "caput (L. caput: head) + radiale (L. radialis: of the radius, from radius = spoke, ray)", "p": 100}, {"t": "M. abductor pollicis brevis", "m": "Abductor pollicis brevis muscle — origin: Scaphoid bone and flexor retinaculum; insertion: Lateral sesamoid bone and radially the proximal phalanx of the thumb", "e": "musculus (L. musculus: muscle, little mouse) + abductor (L. abductor: one who leads away, from ab = away + ducere = to lead) + pollicis (L. pollex/pollicis: thumb, big toe) + brevis (L. brevis: short)", "p": 102}, {"t": "M. flexor pollicis brevis", "m": "Flexor pollicis brevis muscle — origin: Carpal bones, base of 1st metacarpal and flexor retinaculum; insertion: Lateral sesamoid bone, radially aspect of proximal phalanx of thumb", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: one who bends, from flectere = to bend) + pollicis (L. pollex/pollicis: thumb) + brevis (L. brevis: short)", "p": 102}, {"t": "Caput superficiale", "m": "Superficial head — the portion situated on the tendon of the flexor pollicis longus and innervated by the median nerve", "e": "caput (L. caput: head) + superficialis (L. superficialis: of the surface, from super = above + facies = face, surface)", "p": 102}, {"t": "Caput profundum", "m": "Deep head — the portion situated below the tendon of the flexor pollicis longus and innervated by the ulnar nerve", "e": "caput (L. caput: head) + profundum (L. profundus: deep, from pro = forward/down + fundus = bottom)", "p": 102}, {"t": "M. opponens pollicis", "m": "Opponens pollicis muscle — origin: Trapezium and flexor retinaculum; insertion: First metacarpal; action: Adduction and opposition of thumb", "e": "musculus (L. musculus: muscle) + opponens (L. opponens: opposing, present participle of opponere = to place against, from ob = against + ponere = to place) + pollicis (L. pollex/pollicis: thumb)", "p": 102}, {"t": "M. adductor pollicis", "m": "Adductor pollicis muscle — origin: Capitate, radiate carpal ligament, metacarpal bone 3; insertion: Medial sesamoid bone, ulnar aspect of base of proximal phalanx of thumb", "e": "musculus (L. musculus: muscle) + adductor (L. adductor: one who leads toward, from ad = toward + ducere = to lead) + pollicis (L. pollex/pollicis: thumb)", "p": 102}, {"t": "Caput obliquum", "m": "Oblique head — the portion arising from the capitate and radiate carpal ligament", "e": "caput (L. caput: head) + obliquum (L. obliquus: slanting, diagonal, from ob = against + liquis = slanting)", "p": 102}, {"t": "Caput transversum", "m": "Transverse head — the portion originating from the 3rd metacarpal bone", "e": "caput (L. caput: head) + transversum (L. transversus: turned across, from trans = across + vertere = to turn)", "p": 102}, {"t": "M. abductor digiti minimi", "m": "Abductor digiti minimi muscle — origin: Pisoform and flexor retinaculum; insertion: Base of proximal phalanx of little finger and dorsal aponeurosis; action: Abduction, flexion and extension of the little finger", "e": "musculus (L. musculus: muscle) + abductor (L. abductor: from ab = away + ducere = to lead) + digiti (L. digitus: finger, toe) + minimi (L. minimus: smallest, superlative of parvus = small)", "p": 102}, {"t": "M. flexor digiti minimi brevis", "m": "Flexor digiti minimi brevis muscle — origin: Hook of hamate and flexor retinaculum; insertion: Base of proximal phalanx of little finger; action: Flexion of finger at the metacarpophalangeal joint", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: from flectere = to bend) + digiti (L. digitus: finger) + minimi (L. minimus: smallest) + brevis (L. brevis: short)", "p": 102}, {"t": "M. opponens digiti minimi", "m": "Opponens digiti minimi muscle — origin: Hook of hamulus and flexor retinaculum; insertion: Head and shaft of 5th metacarpal; action: Draws the little finger toward the palm of the hand", "e": "musculus (L. musculus: muscle) + opponens (L. opponens: opposing, from ob = against + ponere = to place) + digiti (L. digitus: finger) + minimi (L. minimus: smallest)", "p": 102}, {"t": "Mm. lumbricales", "m": "Lumbrical muscles — origin: Tendons of flexor digitorum profundus; insertion: Dorsal aponeuroses of fingers 2–5; action: Flexion of finger at the metacarpophalangeal joints, extension at the interphalangeal joints", "e": "musculi (L. musculus: muscle, plural) + lumbricales (L. lumbricalis: earthworm-like, from lumbricus = earthworm, referring to the worm-like shape)", "p": 102}, {"t": "Mm. interossei dorsales", "m": "Dorsal interosseous muscles — origin: Arises by two heads from the metacarpals; insertion: Dorsal aponeurosis of fingers 2–4; action: Spreading of fingers 2–4 away from axis of middle finger, radial and ulnar abduction of middle finger, flexion of finger at the metacarpophalangeal joint and extension of the interphalangeal joints", "e": "musculi (L. musculus: muscle, plural) + interossei (L. interosseus: between bones, from inter = between + os/ossis = bone) + dorsales (L. dorsalis: of the back, from dorsum = back)", "p": 102}, {"t": "Mm. interossei palmares", "m": "Palmar interosseous muscles — origin: Metacarpal bones 2, 4 and 5; insertion: Dorsal aponeuroses of fingers 2, 4 and 5; action: Adduction of index, ring and little fingers toward the middle finger, flexion of the metacarpophalangeal joints, extension of the interphalangeal joints", "e": "musculi (L. musculus: muscle, plural) + interossei (L. interosseus: between bones, from inter = between + os/ossis = bone) + palmares (L. palmaris: of the palm, from palma = palm of the hand)", "p": 102}, {"t": "Fascia axillaris", "m": "Axillary fascia — situated on the adipose body of the axilla; it unites the lateral margins of the pectoral and latissimus dorsi muscles", "e": "fascia (L. fascia: band, bandage, sheet of connective tissue) + axillaris (L. axillaris: of the armpit, from axilla = armpit, diminutive of ala = wing)", "p": 102}, {"t": "Fascia deltoidea", "m": "Deltoid fascia — strongly fused investing fascia of the deltoid muscle", "e": "fascia (L. fascia: band, sheet) + deltoidea (Gk. deltoeides: delta-shaped, from delta = Greek letter Δ + eidos = form, shape)", "p": 102}, {"t": "Fascie brachii", "m": "Brachial fascia — fascia enclosing the upper arm muscles", "e": "fascia (L. fascia: band, sheet) + brachii (L. brachium/brachii: of the upper arm, from Gk. brachion = upper arm)", "p": 102}, {"t": "Septum intermusculare brachii mediale", "m": "Medial intermuscular septum of the arm — tendinous sheet for muscle origin between the medial margin of the humerus and the brachial fascia", "e": "septum (L. septum: partition, wall, from saepire = to enclose) + intermusculare (L. intermuscularis: between muscles, from inter = between + musculus = muscle) + brachii (L. brachium: upper arm) + mediale (L. medialis: of the middle, from medius = middle)", "p": 102}, {"t": "Septum intermusculare brachii laterale", "m": "Lateral intermuscular septum of the arm — tendinous sheet for muscle attachment between the lateral margin of the humerus and the brachial fascia", "e": "septum (L. septum: partition, wall) + intermusculare (L. intermuscularis: between muscles) + brachii (L. brachium: upper arm) + laterale (L. lateralis: of the side, from latus = side)", "p": 102}, {"t": "Fascia antebrachii", "m": "Antebrachial fascia — fascia enveloping the forearm muscles", "e": "fascia (L. fascia: band, sheet) + antebrachii (L. antebrachium: forearm, from ante = before/in front + brachium = upper arm)", "p": 102}, {"t": "Fascia dorsalis manus", "m": "Fascia of the dorsum of the hand — fascia situated on the dorsal tendons of the hand", "e": "fascia (L. fascia: band, sheet) + dorsalis (L. dorsalis: of the back/dorsum, from dorsum = back) + manus (L. manus: hand)", "p": 102}, {"t": "Retinaculum extensorum", "m": "Extensor retinaculum — transverse fascial fibers over the 6 conduction canals of the 10 extensor tendons", "e": "retinaculum (L. retinaculum: retaining band, from retinere = to hold back, from re = back + tenere = to hold) + extensorum (L. extensor: one who extends, from extendere = to stretch out; genitive plural)", "p": 102}, {"t": "Lig. metacarpale transversum superficiale", "m": "Superficial transverse metacarpal ligament — transverse reinforcement of the palmar fascia of the hand at the level of the heads of the metacarpals", "e": "ligamentum (L. ligamentum: ligament, band, from ligare = to bind) + metacarpale (Gk./L. metacarpalis: of the metacarpus, from Gk. meta = after/beyond + karpos = wrist) + transversum (L. transversus: across, from trans = across + vertere = to turn) + superficiale (L. superficialis: of the surface, from super = above + facies = face)", "p": 102}, {"t": "Aponeurosis palmaris", "m": "Palmar aponeurosis — membranous expansion of the tendon of the palmaris longus muscle", "e": "aponeurosis (Gk. aponeurosis: tendinous expansion, from apo = away from + neuron = sinew, tendon) + palmaris (L. palmaris: of the palm, from palma = palm of the hand)", "p": 102}, {"t": "Fasciculi transversi", "m": "Transverse fasciculi — transversely oriented fibrous bundles of the palmar aponeurosis", "e": "fasciculi (L. fasciculus: small bundle, diminutive of fascis = bundle; plural) + transversi (L. transversus: across, turned crosswise; plural)", "p": 102}, {"t": "Retinaculum flexorum", "m": "Flexor retinaculum — stout fibrous band between the scaphoid, trapezoid, pisiform and hamate bones; it binds the flexor tendons", "e": "retinaculum (L. retinaculum: retaining band, from retinere = to hold back) + flexorum (L. flexor: one who bends, from flectere = to bend; genitive plural)", "p": 102}, {"t": "Vaginae fibrosae digitorum manus", "m": "Fibrous sheaths of fingers — fibrous synovial tunnel for the digital flexor tendons", "e": "vaginae (L. vagina: sheath, scabbard; plural) + fibrosae (L. fibrosus: fibrous, from fibra = fiber; plural) + digitorum (L. digitus: finger, toe; genitive plural) + manus (L. manus: hand)", "p": 102}, {"t": "Pars anularis vaginae fibrosae", "m": "Annular part of fibrous sheath — very compact circular fibers of the fibrous sheath located between the joints", "e": "pars (L. pars: part) + anularis (L. anularis: ring-shaped, from anulus = ring, diminutive of anus = ring) + vaginae (L. vagina: sheath) + fibrosae (L. fibrosus: fibrous, from fibra = fiber)", "p": 102}, {"t": "Pars cruciformis vaginae fibrosae", "m": "Cruciate part of fibrous sheath — crossed fibers that reinforce the joints", "e": "pars (L. pars: part) + cruciformis (L. cruciformis: cross-shaped, from crux/crucis = cross + forma = shape) + vaginae (L. vagina: sheath) + fibrosae (L. fibrosus: fibrous, from fibra = fiber)", "p": 102}, {"t": "Vaginae synoviales digitorum manus", "m": "Synovial sheaths of the fingers — tendon sheaths of the digital flexor tendons", "e": "vaginae (L. vagina: sheath; plural) + synoviales (Gk./L. synovialis: of synovial fluid, from Gk. syn = together + L. ovum = egg, referring to egg-white-like fluid; plural) + digitorum (L. digitus: finger; genitive plural) + manus (L. manus: hand)", "p": 102}, {"t": "Vincula tendinum", "m": "Vincula tendinum — connective tissue fasciculi (mesotendons) transporting vessels to the tendons", "e": "vincula (L. vinculum: bond, chain, from vincire = to bind; plural) + tendinum (L. tendo/tendinis: tendon, from tendere = to stretch; genitive plural)", "p": 102}, {"t": "Vinculum longum", "m": "Vinculum longum — longer fasciculus at the level of the proximal phalanx", "e": "vinculum (L. vinculum: bond, chain, from vincire = to bind) + longum (L. longus: long)", "p": 102}, {"t": "Vinculum breve", "m": "Vinculum breve — shorter fasciculus near the insertions of the tendons", "e": "vinculum (L. vinculum: bond, chain, from vincire = to bind) + breve (L. brevis: short)", "p": 102}, {"t": "Chiasma tendinum", "m": "Chiasma tendinum — crossing of the tendons of the flexor digitorum superficialis and profundus", "e": "chiasma (Gk. chiasma: crossing, from chiazein = to mark with a chi X, from chi = Greek letter X) + tendinum (L. tendo/tendinis: tendon, from tendere = to stretch; genitive plural)", "p": 102}, {"t": "M. abductor hallucis", "m": "Abductor muscle of great toe", "e": "musculus (L. musculus: muscle, little mouse) + abductor (L. abductor: one who leads away, from ab = away + ducere = to lead) + hallucis (L. hallux/hallucis: great toe)", "p": 108}, {"t": "M. flexor hallucis brevis", "m": "Short flexor muscle of the great toe", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: bender, from flectere = to bend) + hallucis (L. hallux/hallucis: great toe) + brevis (L. brevis: short)", "p": 108}, {"t": "Caput mediale", "m": "Medial head", "e": "caput (L. caput: head) + mediale (L. medialis: middle, from medius = middle)", "p": 108}, {"t": "Caput laterale", "m": "Lateral head", "e": "caput (L. caput: head) + laterale (L. lateralis: of the side, from latus = side)", "p": 108}, {"t": "M. adductor hallucis", "m": "Important muscle for the transverse arch of the foot", "e": "musculus (L. musculus: muscle) + adductor (L. adductor: one who leads toward, from ad = toward + ducere = to lead) + hallucis (L. hallux/hallucis: great toe)", "p": 108}, {"t": "M. flexor digitorum brevis", "m": "Flexes toes and supports the longitudinal arch of the foot", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: bender, from flectere = to bend) + digitorum (L. digitus: finger/toe, gen. plural) + brevis (L. brevis: short)", "p": 108}, {"t": "M. quadratus plantae", "m": "Flexes toes and supports longitudinal arch of foot", "e": "musculus (L. musculus: muscle) + quadratus (L. quadratus: squared, four-sided, from quattuor = four) + plantae (L. planta: sole of the foot, gen. singular)", "p": 108}, {"t": "m. flexor accessorius", "m": "Alternative name for M. quadratus plantae", "e": "musculus (L. musculus: muscle) + flexor (L. flexor: bender, from flectere = to bend) + accessorius (L. accessorius: accessory, supplementary, from accedere = to come near)", "p": 108}, {"t": "Mm. lumbricales pedis", "m": "Lumbrical muscles of the foot; flexion at the metatarsophalangeal joint, brings toes closer to big toe", "e": "musculi (L. musculus: muscle, plural) + lumbricales (L. lumbricalis: worm-like, from lumbricus = earthworm) + pedis (L. pes/pedis: foot)", "p": 108}, {"t": "Mm. interossei dorsales pedis", "m": "Abduction and flexion of toes at the metatarsophalangeal joints and extension at the interphalangeal joints", "e": "musculi (L. musculus: muscle, plural) + interossei (L. interosseus: between bones, from inter = between + os/ossis = bone) + dorsales (L. dorsalis: of the back, from dorsum = back) + pedis (L. pes/pedis: foot)", "p": 108}, {"t": "Mm. interossei plantares", "m": "Adduction and flexion of toes at the metatarsophalangeal joints", "e": "musculi (L. musculus: muscle, plural) + interossei (L. interosseus: between bones, from inter = between + os/ossis = bone) + plantares (L. plantaris: of the sole, from planta = sole of foot)", "p": 108}, {"t": "Fascia lata", "m": "Fascia of thigh which envelops the entire thigh musculature", "e": "fascia (L. fascia: band, bandage, sheet of connective tissue) + lata (L. latus: broad, wide)", "p": 108}, {"t": "Tractus iliotibialis", "m": "Vertical thick band of fascia lata that extends from the anterior segment of the iliac crest to the lateral tibial condyle", "e": "tractus (L. tractus: tract, band, from trahere = to draw) + iliotibialis (L. ilium = flank/hip bone + tibia = shin bone + -alis = pertaining to)", "p": 108}, {"t": "Septum intermusculare femoris laterale", "m": "Lateral intermuscular septum of thigh; firm connective tissue layer extending from the fascia lata to the lateral lip of the linea aspera between the biceps femoris and vastus lateralis muscles", "e": "septum (L. septum: partition, wall, from saepire = to enclose) + intermusculare (L. inter = between + musculus = muscle) + femoris (L. femur/femoris: thigh) + laterale (L. lateralis: of the side, from latus = side)", "p": 108}, {"t": "Septum intermusculare femoris mediale", "m": "Medial intermuscular septum of thigh; stout connective tissue layer extending from the fascia lata to the medial lip of the linea aspera", "e": "septum (L. septum: partition, wall) + intermusculare (L. inter = between + musculus = muscle) + femoris (L. femur/femoris: thigh) + mediale (L. medialis: middle, from medius = middle)", "p": 108}, {"t": "Canalis adductorius", "m": "Adductor canal; channel between adductors, vastus medialis and vastoadductor membrane", "e": "canalis (L. canalis: channel, canal, from canna = reed/pipe) + adductorius (L. adductorius: pertaining to adduction, from adducere = to lead toward)", "p": 108}, {"t": "Hiatus tendineus", "m": "Opening near the attachment of the adductor magnus at the level of the inferior margin of the adductor longus", "e": "hiatus (L. hiatus: opening, gap, from hiare = to gape) + tendineus (L. tendineus: of a tendon, from tendo = tendon)", "p": 108}, {"t": "adductorius", "m": "Pertaining to the adductor (used in Hiatus tendineus adductorius)", "e": "adductorius (L. adductorius: pertaining to adduction, from ad = toward + ducere = to lead)", "p": 108}, {"t": "Fascia iliaca", "m": "Fascia over the iliac and inferior portion of the psoas muscles", "e": "fascia (L. fascia: band, sheet of connective tissue) + iliaca (L. iliacus: of the ilium/flank, from ilium = flank bone)", "p": 108}, {"t": "Lacuna musculorum", "m": "Compartment for passage of the iliopsoas muscle and the femoral and lateral femoral cutaneous nerves between the ilium, inguinal ligament and iliopectineal arch", "e": "lacuna (L. lacuna: pit, gap, hollow, from lacus = lake) + musculorum (L. musculus: muscle, gen. plural)", "p": 108}, {"t": "Arcus iliopectineus", "m": "Iliopectineal arch; portion of the iliac fascia between the inguinal ligament and the iliopubic eminence", "e": "arcus (L. arcus: arch, bow) + iliopectineus (L. ilium = hip bone + pecten/pectinis = comb/pubic bone, referring to the pectineal line)", "p": 108}, {"t": "Lacuna vasorum", "m": "Vascular lacuna; compartment between the pubis, inguinal ligament and iliopectineal arch for passage of the femoral artery and femoral branch of the genitofemoral nerve", "e": "lacuna (L. lacuna: pit, gap, hollow) + vasorum (L. vas/vasis: vessel, gen. plural)", "p": 108}, {"t": "Trigonum femorale", "m": "Femoral triangle; triangle between the sartorius and adductor longus muscles and the inguinal ligament", "e": "trigonum (L. trigonum: triangle, from Gk. trigonon: three-cornered, from tri = three + gonia = angle) + femorale (L. femoralis: of the thigh, from femur = thigh)", "p": 108}, {"t": "Canalis femoralis", "m": "Femoral canal; passage within the medial segment of the vascular lacuna that extends from the inguinal ligament to the saphenous opening", "e": "canalis (L. canalis: channel, canal) + femoralis (L. femoralis: of the thigh, from femur = thigh)", "p": 108}, {"t": "Anulus femoralis", "m": "Femoral ring — entrance into the femoral canal bordered by the femoral vein, inguinal ligament, falx inguinalis and pectineal ligament", "e": "anulus (L. anulus: ring, circle) + femoralis (L. femoralis: of the femur/thigh, from femur = thigh)", "p": 110}, {"t": "Septum femorale", "m": "Femoral septum — fibrous membrane that closes the entrance of the femoral canal", "e": "septum (L. septum: partition, wall, from saepire = to enclose) + femorale (L. femoralis: of the femur/thigh, from femur = thigh)", "p": 110}, {"t": "Hiatus saphenus", "m": "Saphenous opening — large opening in the fascia lata directly below the inguinal ligament for passage of the great saphenous vein", "e": "hiatus (L. hiatus: opening, gap, from hiare = to gape) + saphenus (Gk. saphēnēs: manifest, visible, referring to the prominent vein)", "p": 110}, {"t": "Margo falciformis", "m": "Falciform margin — curved principal lateral margin of the saphenous opening", "e": "margo (L. margo: edge, border, margin) + falciformis (L. falx = sickle + forma = shape, thus sickle-shaped)", "p": 110}, {"t": "Cornu superius", "m": "Superior horn — upper curved portion of the falciform margin", "e": "cornu (L. cornu: horn, projection) + superius (L. superius: upper, higher, from super = above)", "p": 110}, {"t": "Cornu inferius", "m": "Inferior horn — lower curved portion of the falciform margin", "e": "cornu (L. cornu: horn, projection) + inferius (L. inferius: lower, from inferus = below)", "p": 110}, {"t": "Fascia cribrosa", "m": "Cribriform fascia — loose, perforated connective tissue lamina covering the saphenous opening", "e": "fascia (L. fascia: band, bandage, sheet) + cribrosa (L. cribrōsus: sieve-like, perforated, from cribrum = sieve)", "p": 110}, {"t": "Fascia cruris", "m": "Fascia of the leg (crural fascia) — superficial investing fascia of the leg which serves partially for muscle attachment and is fused to the free bony margins of the tibia", "e": "fascia (L. fascia: band, sheet, bandage) + cruris (L. crus/cruris: leg, shin)", "p": 110}, {"t": "Septum intermusculare cruris anterius", "m": "Anterior intermuscular septum of leg — connective tissue septum between the peroneal and extensor compartments", "e": "septum (L. septum: partition, wall) + intermusculare (L. inter = between + musculus = muscle) + cruris (L. crus/cruris: leg) + anterius (L. anterius: anterior, in front, from ante = before)", "p": 110}, {"t": "Septum intermusculare cruris posterius", "m": "Posterior intermuscular septum of leg — connective tissue septum between the peroneal and flexor compartments", "e": "septum (L. septum: partition, wall) + intermusculare (L. inter = between + musculus = muscle) + cruris (L. crus/cruris: leg) + posterius (L. posterius: posterior, behind, from post = after)", "p": 110}, {"t": "Retinaculum mm. extensorum superius", "m": "Superior extensor retinaculum — transverse thickened band of the crural fascia that holds the extensor tendons in place", "e": "retinaculum (L. retinaculum: band, restraint, from retinere = to hold back) + mm. (abbreviation for musculi/muscles) + extensorum (L. extensor: one who stretches, from extendere = to stretch out) + superius (L. superius: upper, from super = above)", "p": 110}, {"t": "Retinaculum mm. flexorum", "m": "Flexor retinaculum — fibrous band on the long flexor tendons extending from the medial malleolus to the calcaneus", "e": "retinaculum (L. retinaculum: band, restraint, from retinere = to hold back) + mm. (abbreviation for musculi) + flexorum (L. flexor: one who bends, from flectere = to bend)", "p": 110}, {"t": "Retinaculum mm. extensorum inferius", "m": "Inferior extensor retinaculum — usually cruciate band that supports the extensor tendons, extending from both malleoli to the foot margins of the opposite side, primarily to the calcaneus", "e": "retinaculum (L. retinaculum: band, restraint, from retinere = to hold back) + mm. (abbreviation for musculi) + extensorum (L. extensor: stretcher, from extendere = to stretch out) + inferius (L. inferius: lower, from inferus = below)", "p": 110}, {"t": "Retinaculum mm. peroneorum (fibularium) superius", "m": "Superior peroneal (fibular) retinaculum — upper band that holds peroneal tendons in place; extends from the lateral malleolus to the calcaneus", "e": "retinaculum (L. retinaculum: band, restraint) + mm. (musculi) + peroneorum (Gk. peronē: fibula, pin, brooch) + fibularium (L. fibula: clasp, pin, the smaller bone of the leg) + superius (L. superius: upper, from super = above)", "p": 110}, {"t": "Retinaculum mm. peroneorum (fibularium) inferius", "m": "Inferior (fibular) peroneal retinaculum — lower band that holds the peroneal tendons in place, passing from the extensor retinaculum to the outer surface of the calcaneus", "e": "retinaculum (L. retinaculum: band, restraint) + mm. (musculi) + peroneorum (Gk. peronē: fibula, pin) + fibularium (L. fibula: clasp, pin, the smaller leg bone) + inferius (L. inferius: lower, from inferus = below)", "p": 110}, {"t": "Fascia dorsalis pedis", "m": "Dorsal fascia of the foot — thin fascia on the dorsum of the foot connected above with the inferior extensor retinaculum", "e": "fascia (L. fascia: band, sheet) + dorsalis (L. dorsalis: of the back, from dorsum = back) + pedis (L. pes/pedis: foot)", "p": 110}, {"t": "Aponeurosis plantaris", "m": "Plantar aponeurosis — tough, tendinous sheet on the sole of the foot extending from the tuber calcanei to as far as the middle phalanges, bracing the longitudinal arch of the foot", "e": "aponeurosis (Gk. aponeurōsis: a becoming tendinous, from apo = away from + neuron = sinew/tendon) + plantaris (L. plantaris: of the sole of the foot, from planta = sole)", "p": 110}, {"t": "Lig. metatarsale transversum superficiale", "m": "Superficial transverse metatarsal ligament — transverse fibrous tract in the vicinity of the distal transverse fibers of the plantar aponeurosis", "e": "lig. (abbreviation for ligamentum: L. ligamentum = band, tie, from ligare = to bind) + metatarsale (Gk. meta = beyond/after + tarsos = flat of the foot) + transversum (L. transversus: lying across, from trans = across + vertere = to turn) + superficiale (L. superficialis: on the surface, from super = above + facies = surface)", "p": 110}, {"t": "Bursae et vaginae synoviales", "m": "Synovial bursae (sacs) and sheaths", "e": "bursae (L. bursa: purse, pouch, from Gk. byrsa = hide, wineskin) + et (L. et: and) + vaginae (L. vagina: sheath, scabbard) + synoviales (Gk./NL. synovia: joint fluid, from syn = together + ōon = egg, referring to egg-white consistency)", "p": 110}, {"t": "Vaginae synoviales tendinum digitorum pedis", "m": "Synovial sheaths of the digits of the foot — synovial portion of the tendon sheaths for the flexors of the toes", "e": "vaginae (L. vagina: sheath, scabbard) + synoviales (Gk./NL. synovia: joint fluid) + tendinum (L. tendo/tendinis: tendon, from tendere = to stretch) + digitorum (L. digitus: finger, toe) + pedis (L. pes/pedis: foot)", "p": 110}, {"t": "Vaginae fibrosae tendinum digitorum pedis", "m": "Fibrous sheaths of the digits of the foot — tough fibrous sheath that reinforces the tendon sheaths on the flexor side of the toes", "e": "vaginae (L. vagina: sheath, scabbard) + fibrosae (L. fibrosus: fibrous, from fibra = fiber) + tendinum (L. tendo/tendinis: tendon) + digitorum (L. digitus: finger, toe) + pedis (L. pes/pedis: foot)", "p": 110}, {"t": "Vagina tendinis m. obliqui superioris", "m": "Tendon sheath of superior oblique muscle — synovial sheath of the superior oblique muscle of the eyeball", "e": "vagina (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon, from tendere = to stretch) + m. (L. musculus: muscle) + obliqui (L. obliquus: oblique, slanting) + superioris (L. superior: upper, higher)", "p": 112}, {"t": "Bursa m. tensoris veli palatini", "m": "Synovial bursa of tensor veli palatini — synovial bursa between the pterygoid hamulus and the tendon of the tensor veli palatini muscle", "e": "bursa (L./Gk. bursa: purse, pouch) + m. (L. musculus: muscle) + tensoris (L. tensor: one who stretches, from tendere = to stretch) + veli (L. velum: veil, sail) + palatini (L. palatinus: of the palate, from palatum = palate)", "p": 112}, {"t": "B. subcutanea prominentiae laryngealis", "m": "Subcutaneous bursa of the laryngeal prominence — synovial bursa between the skin and the laryngeal prominence of the thyroid cartilage", "e": "bursa (L./Gk. bursa: purse, pouch) + subcutanea (L. sub: under + cutanea from cutis: skin) + prominentiae (L. prominentia: prominence, projection, from prominere = to jut out) + laryngealis (Gk. larynx/laryngos: larynx + L. -alis: pertaining to)", "p": 112}, {"t": "B. retrohyoidea", "m": "Retrohyoid bursa — synovial bursa between the body of the hyoid bone and the median thyrohyoid ligament", "e": "bursa (L./Gk. bursa: purse, pouch) + retro (L. retro: behind, backward) + hyoidea (Gk. hyoeides: shaped like the letter upsilon, from hys = U-shaped + eidos = form)", "p": 112}, {"t": "B. infrahyoidea", "m": "Infrahyoid bursa — synovial bursa between the upper end of the sternohyoid muscle and the thyrohyoid membrane", "e": "bursa (L./Gk. bursa: purse, pouch) + infra (L. infra: below, beneath) + hyoidea (Gk. hyoeides: shaped like the letter upsilon, from hys = U-shaped + eidos = form)", "p": 112}, {"t": "Bursae membri superioirs", "m": "Synovial bursae of upper limb", "e": "bursae (L./Gk. bursa: purse, pouch, plural) + membri (L. membrum: limb, member) + superioirs (L. superior: upper, higher)", "p": 112}, {"t": "B. subtendinea m. trapezii", "m": "Subtendinous bursa of trapezius — synovial bursa between the trapezius muscle (ascending part) and the spine of the scapula", "e": "bursa (L./Gk. bursa: purse, pouch) + subtendinea (L. sub: under + tendinea from tendo: tendon) + m. (L. musculus: muscle) + trapezii (Gk. trapezion: small table, trapezoid shape, from trapeza = table)", "p": 112}, {"t": "B. subcutanea acromialis", "m": "Synovial bursa between the acromion and the skin", "e": "bursa (L./Gk. bursa: purse, pouch) + subcutanea (L. sub: under + cutanea from cutis: skin) + acromialis (Gk. akron: tip, extremity + omos: shoulder + L. -alis: pertaining to)", "p": 112}, {"t": "B. subacromialis", "m": "Subacromial bursa — synovial bursa between the acromion, coracoacromial ligament and supraspinous tendon", "e": "bursa (L./Gk. bursa: purse, pouch) + sub (L. sub: under, beneath) + acromialis (Gk. akron: tip + omos: shoulder + L. -alis: pertaining to)", "p": 112}, {"t": "B. subdeltoidea", "m": "Subdeltoid bursa — synovial bursa between the deltoid muscle and the greater tubercle of the humerus", "e": "bursa (L./Gk. bursa: purse, pouch) + sub (L. sub: under, beneath) + deltoidea (Gk. delta: the letter delta + eidos: form, shape — triangular)", "p": 112}, {"t": "B. m. coracobrachialis", "m": "Coracobrachial bursa — synovial bursa between the tendons of the subscapularis and coracobrachialis muscles below the apex of the coracoid process", "e": "bursa (L./Gk. bursa: purse, pouch) + m. (L. musculus: muscle) + coraco (Gk. korakoeides: raven-like, from korax = raven) + brachialis (L./Gk. brachium: arm + L. -alis: pertaining to)", "p": 112}, {"t": "B. subtendinea m. infraspinati", "m": "Subtendinous bursa of infraspinatus muscle — synovial bursa between the tendon of the infraspinatus and the capsule of the shoulder joint", "e": "bursa (L./Gk. bursa: purse, pouch) + subtendinea (L. sub: under + tendinea from tendo: tendon) + m. (L. musculus: muscle) + infraspinati (L. infra: below + spina: spine + -atus: having)", "p": 112}, {"t": "B. subtendinea m. subscapularis", "m": "Subtendinous bursa of subscapularis muscle — synovial bursa between the tendon of the subscapularis and the capsule of the shoulder joint", "e": "bursa (L./Gk. bursa: purse, pouch) + subtendinea (L. sub: under + tendinea from tendo: tendon) + m. (L. musculus: muscle) + subscapularis (L. sub: under + scapula: shoulder blade + -aris: pertaining to)", "p": 112}, {"t": "B. subtendinea m. tertis majoris", "m": "Subtendinous bursa of teres major muscle — synovial bursa between the tendon of the teres major and the humerus", "e": "bursa (L./Gk. bursa: purse, pouch) + subtendinea (L. sub: under + tendinea from tendo: tendon) + m. (L. musculus: muscle) + tertis (L. teres: rounded, smooth) + majoris (L. major: greater, larger)", "p": 112}, {"t": "B. subtendinea m. latissimi dorsi", "m": "Subtendinous bursa of latissimus dorsi muscle — synovial bursa between the tendons of the teres major and latissimus dorsi", "e": "bursa (L./Gk. bursa: purse, pouch) + subtendinea (L. sub: under + tendinea from tendo: tendon) + m. (L. musculus: muscle) + latissimi (L. latissimus: broadest, superlative of latus = wide) + dorsi (L. dorsum: back)", "p": 112}, {"t": "B. subcutanea olecrani", "m": "Subcutaneous bursa of olecranon — synovial bursa between the olecranon and the skin", "e": "bursa (L./Gk. bursa: purse, pouch) + subcutanea (L. sub: under + cutanea from cutis: skin) + olecrani (Gk. olekranon: point of the elbow, from olene = elbow + kranion = head)", "p": 112}, {"t": "B. intratendinea olecrani", "m": "Intratendinous bursa of olecranon — synovial bursa within the triceps tendon near the olecranon", "e": "bursa (L./Gk. bursa: purse, pouch) + intratendinea (L. intra: within + tendinea from tendo: tendon) + olecrani (Gk. olekranon: point of the elbow, from olene = elbow + kranion = head)", "p": 112}, {"t": "B. subtendinea m. tricipitis brachii", "m": "Subtendinous bursa of triceps brachii — synovial bursa between the triceps tendon and the olecranon", "e": "bursa (L./Gk. bursa: purse, pouch) + subtendinea (L. sub: under + tendinea from tendo: tendon) + m. (L. musculus: muscle) + tricipitis (L. triceps: three-headed, from tri = three + caput = head) + brachii (L./Gk. brachium: arm)", "p": 112}, {"t": "B. bicipitoradialis", "m": "Bicipitoradial bursa — synovial bursa between the biceps tendon and the anterior part of the radial tuberosity", "e": "bursa (L./Gk. bursa: purse, pouch) + bicipito (L. biceps: two-headed, from bi = two + caput = head) + radialis (L. radius: spoke, rod + -alis: pertaining to)", "p": 112}, {"t": "B. cubitalis interossea", "m": "Synovial bursa between the biceps tendon and the ulna or oblique cord", "e": "bursa (L./Gk. bursa: purse, pouch) + cubitalis (L. cubitus: elbow + -alis: pertaining to) + interossea (L. inter: between + os/ossis: bone + -ea: pertaining to)", "p": 112}, {"t": "Vag. tendinum mm. abductoris longi et extensoris brevis pollicis", "m": "Tendon sheath of abductor pollicis longus and extensor pollicis brevis muscles — common tendon sheath forming the first tendon compartment on the dorsum of the hand", "e": "vagina (L. vagina: sheath) + tendinum (L. tendo/tendinis: tendon, plural) + mm. (L. musculi: muscles) + abductoris (L. abductor: one who leads away, from ab = away + ducere = to lead) + longi (L. longus: long) + et (L. et: and) + extensoris (L. extensor: one who stretches out, from extendere = to stretch out) + brevis (L. brevis: short) + pollicis (L. pollex/pollicis: thumb)", "p": 112}, {"t": "Vag. tendinum mm. extensorum carpi radialium", "m": "Tendon sheath of extensor carpi radialis longus and brevis muscles — common tendon sheath forming the second tendon compartment on the dorsum of the hand", "e": "vagina (L. vagina: sheath) + tendinum (L. tendo/tendinis: tendon, plural) + mm. (L. musculi: muscles) + extensorum (L. extensor: one who stretches out, genitive plural) + carpi (L. carpus from Gk. karpos: wrist) + radialium (L. radius: spoke, rod + -alis: pertaining to, genitive plural)", "p": 112}, {"t": "Vag. tendinis m. extensoris pollicis longi", "m": "Tendon sheath of extensor pollicis longus muscle — forms the third tendon compartment", "e": "vagina (L. vagina: sheath) + tendinis (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + extensoris (L. extensor: one who stretches out, from extendere = to stretch out) + pollicis (L. pollex/pollicis: thumb) + longi (L. longus: long)", "p": 112}, {"t": "Vag. tendinum mm. extensoris digitorum et extensoris indicis", "m": "Tendon sheath of extensor digitorum and extensor indicis muscles — tendon sheath forming the fourth tendon compartment on the dorsum of the hand", "e": "vagina (L. vagina: sheath) + tendinum (L. tendo/tendinis: tendon, plural) + mm. (L. musculi: muscles) + extensoris (L. extensor: one who stretches out) + digitorum (L. digitus: finger + -orum: of the fingers) + et (L. et: and) + extensoris (L. extensor: one who stretches out) + indicis (L. index/indicis: index finger, pointer, from indicare = to point out)", "p": 112}, {"t": "Vag. tendinis m. extensoris digiti minimi", "m": "Tendon sheath of extensor digiti minimi muscle — forms the fifth tendon compartment on the dorsum of the hand", "e": "vagina (L. vagina: sheath) + tendinis (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + extensoris (L. extensor: one who stretches out) + digiti (L. digitus: finger) + minimi (L. minimus: smallest, least, superlative of parvus = small)", "p": 112}, {"t": "Vag. tendinis m. extensoris carpi ulnaris", "m": "Tendon sheath of extensor carpi ulnaris muscle — forms the sixth tendon compartment on the dorsum of the hand", "e": "vagina (L. vagina: sheath) + tendinis (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + extensoris (L. extensor: one who stretches out) + carpi (L. carpus from Gk. karpos: wrist) + ulnaris (L. ulna: elbow, forearm + -aris: pertaining to)", "p": 112}, {"t": "Vag. m. extensoris carpi radialis brevis", "m": "Sheath of extensor carpi radialis brevis muscle — synovial bursa at the attachment between the tendon and base of the 3rd metacarpal", "e": "vagina (L. vagina: sheath) + m. (L. musculus: muscle) + extensoris (L. extensor: one who stretches out) + carpi (L. carpus from Gk. karpos: wrist) + radialis (L. radius: spoke, rod + -alis: pertaining to) + brevis (L. brevis: short)", "p": 112}, {"t": "Vag. tendinis m. flexoris carpi radialis", "m": "Tendon sheath of flexor carpi radialis muscle — individual tendon sheath for the flexor carpi radialis at the insertion of the tendon to the base of the 2nd metacarpal bone", "e": "vagina (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon, from tendere = to stretch) + musculus (L. musculus: muscle, little mouse) + flexoris (L. flexor: one who bends, from flectere = to bend) + carpi (L. carpus, from Gk. karpos: wrist) + radialis (L. radialis: of the radius, from radius = spoke, ray)", "p": 114}, {"t": "Vag. communis mm. flexorum", "m": "Common sheath of flexor muscles — common tendon sheath for the two long flexors of the fingers", "e": "vagina (L. vagina: sheath) + communis (L. communis: common, shared) + musculi (L. musculus: muscle) + flexorum (L. flexor: one who bends, genitive plural)", "p": 114}, {"t": "Vag. tendinis m. flexoris pollicis longi", "m": "Tendon sheath of flexor pollicis longus muscle — separate synovial sheath for the long flexor of the thumb", "e": "vagina (L. vagina: sheath) + tendinis (L. tendo: tendon) + musculus (L. musculus: muscle) + flexoris (L. flexor: bender) + pollicis (L. pollex/pollicis: thumb, big toe) + longi (L. longus: long)", "p": 114}, {"t": "Vag. tendinum digitorum manus", "m": "Tendon sheaths for flexors in region of fingers", "e": "vagina (L. vagina: sheath) + tendinum (L. tendo: tendon, genitive plural) + digitorum (L. digitus: finger, toe, genitive plural) + manus (L. manus: hand)", "p": 114}, {"t": "Bursae membri inferioris", "m": "Synovial bursae of lower limb", "e": "bursae (L. bursa, from Gk. byrsa: purse, wineskin, plural) + membri (L. membrum: limb, member, genitive) + inferioris (L. inferior: lower, genitive)", "p": 114}, {"t": "Bursa subcutanea trochanterica", "m": "Subcutaneous trochanteric bursa — synovial bursa on the tendon of the gluteus maximus between the skin and greater trochanter", "e": "bursa (L. bursa, from Gk. byrsa: purse, pouch) + subcutanea (L. sub: under + cutis: skin, so: under the skin) + trochanterica (Gk. trochanter: runner, from trechein = to run; refers to the bony prominence)", "p": 114}, {"t": "B. trochanterica m. glutei maximi", "m": "Trochanteric bursa of gluteus maximus — synovial bursa between the tendon of the gluteus maximus and the greater trochanter", "e": "bursa (L. bursa: pouch) + trochanterica (Gk. trochanter: runner) + musculus (L. musculus: muscle) + glutei (Gk. gloutos: buttock, genitive) + maximi (L. maximus: greatest, largest, genitive)", "p": 114}, {"t": "Bb. trochantericae m. glutei medii", "m": "Trochanteric bursae of gluteus medius — two synovial bursae, an anterior one between the tendon of insertion of the gluteus medius and the greater trochanter, and a posterior one between this tendon and the piriformis muscle", "e": "bursae (L. bursa: pouch, plural) + trochantericae (Gk. trochanter: runner, plural) + musculus (L. musculus: muscle) + glutei (Gk. gloutos: buttock, genitive) + medii (L. medius: middle, genitive)", "p": 114}, {"t": "B. trochanterica m. glutei minimi", "m": "Trochanteric bursa of gluteus minimus — synovial bursa between the tendon of insertion of the gluteus minimus and the greater trochanter", "e": "bursa (L. bursa: pouch) + trochanterica (Gk. trochanter: runner) + musculus (L. musculus: muscle) + glutei (Gk. gloutos: buttock, genitive) + minimi (L. minimus: smallest, least, genitive)", "p": 114}, {"t": "B. m. piriformis", "m": "Bursa of piriformis muscle — synovial bursa between the piriformis tendon, femur and superior gemellus muscle", "e": "bursa (L. bursa: pouch) + musculus (L. musculus: muscle) + piriformis (L. pirum: pear + forma: shape, so: pear-shaped)", "p": 114}, {"t": "B. ischiadica (sciatica) m. obturatoris interni", "m": "Ischial bursa of obturator internus muscle — synovial bursa between the cartilage-covered surface of the lesser sciatic notch and the tendon of the obturator internus", "e": "bursa (L. bursa: pouch) + ischiadica (Gk. ischion: hip joint, ischium) + sciatica (Gk. ischiadikos: of the hip) + musculus (L. musculus: muscle) + obturatoris (L. obturare: to stop up, obstruct, genitive) + interni (L. internus: internal, inner, genitive)", "p": 114}, {"t": "B. subtendinea m. obturatoris interni", "m": "Subtendinous bursa of obturator internus muscle — synovial bursa below the insertion of the obturator internus", "e": "bursa (L. bursa: pouch) + subtendinea (L. sub: under + tendo: tendon, so: under the tendon) + musculus (L. musculus: muscle) + obturatoris (L. obturare: to stop up, genitive) + interni (L. internus: internal, genitive)", "p": 114}, {"t": "Bb. intermusculares mm. gluteorum", "m": "Intermuscular bursae of gluteal muscles — 2-3 synovial bursae that extend inferiorly from the gluteus maximus to the linea aspera", "e": "bursae (L. bursa: pouch, plural) + intermusculares (L. inter: between + musculus: muscle, so: between muscles) + musculi (L. musculus: muscle, plural) + gluteorum (Gk. gloutos: buttock, genitive plural)", "p": 114}, {"t": "B. ischiadica (sciatica) m. glutei maximi", "m": "Ischial bursa of gluteus maximus muscle — synovial bursa between the ischial tuberosity and the inferior surface of the gluteus maximus", "e": "bursa (L. bursa: pouch) + ischiadica (Gk. ischion: ischium) + sciatica (Gk. ischiadikos: of the hip) + musculus (L. musculus: muscle) + glutei (Gk. gloutos: buttock, genitive) + maximi (L. maximus: greatest, genitive)", "p": 114}, {"t": "B. iliopectinea", "m": "Iliopectineal bursa — synovial bursa between the iliopsoas muscle and the pelvic bone, lies above and often communicates with the hip joint", "e": "bursa (L. bursa: pouch) + iliopectinea (L. ilium: flank, groin + pecten/pectinis: comb, referring to the pectineal line, so: of the ilium and pectineal area)", "p": 114}, {"t": "B. subtendinea iliaca", "m": "Subtendinous iliac bursa — synovial bursa between the lesser trochanter and the iliopsoas tendon", "e": "bursa (L. bursa: pouch) + subtendinea (L. sub: under + tendo: tendon) + iliaca (L. iliacus: of the ilium, from ilium: flank)", "p": 114}, {"t": "B. m. bicipitis femoris superior", "m": "Superior bursa of biceps femoris muscle — synovial bursa between the origins of the biceps femoris and semimembranosus muscles", "e": "bursa (L. bursa: pouch) + musculus (L. musculus: muscle) + bicipitis (L. biceps: two-headed, from bi: two + caput: head, genitive) + femoris (L. femur/femoris: thigh, genitive) + superior (L. superior: upper, higher)", "p": 114}, {"t": "B. subcutanea prepatellaris", "m": "Subcutaneous prepatellar bursa — synovial bursa directly between the skin and the fascia in front of the knee", "e": "bursa (L. bursa: pouch) + subcutanea (L. sub: under + cutis: skin) + prepatellaris (L. pre/prae: before, in front of + patella: kneecap, small pan, from patina: dish)", "p": 114}, {"t": "B. subfascialis prepatellaris", "m": "Subfascial prepatellar bursa — synovial bursa between the investing fascia of the knee and the tendon of the quadratus femoris muscle", "e": "bursa (L. bursa: pouch) + subfascialis (L. sub: under + fascia: band, bandage) + prepatellaris (L. prae: before + patella: kneecap)", "p": 114}, {"t": "B. subtendinea prepatellaris", "m": "Subtendinous prepatellar bursa — synovial bursa directly on the knee joint below the tendon of the quadratus femoris", "e": "bursa (L. bursa: pouch) + subtendinea (L. sub: under + tendo: tendon) + prepatellaris (L. prae: before + patella: kneecap)", "p": 114}, {"t": "B. suprapatellaris", "m": "Suprapatellar bursa — synovial bursa between the quadriceps tendon and the femur, almost always communicates with the joint cavity", "e": "bursa (L. bursa: pouch) + suprapatellaris (L. supra: above + patella: kneecap)", "p": 114}, {"t": "B. subcutanea infrapatellaris", "m": "Subcutaneous infrapatellar bursa — synovial bursa directly between the ligamentum patellae and the skin", "e": "bursa (L. bursa: pouch) + subcutanea (L. sub: under + cutis: skin) + infrapatellaris (L. infra: below + patella: kneecap)", "p": 114}, {"t": "B. infrapatellaris profunda", "m": "Deep infrapatellar bursa — synovial bursa between the ligamentum patellae and the tibia", "e": "bursa (L. bursa: pouch) + infrapatellaris (L. infra: below + patella: kneecap) + profunda (L. profundus: deep, from pro: forward + fundus: bottom)", "p": 114}, {"t": "B. subcutanea tuberositas tibiae", "m": "Subcutaneous bursa of tibial tuberosity — synovial bursa between the tibial tuberosity and the skin, mostly involved in kneeling", "e": "bursa (L. bursa: pouch) + subcutanea (L. sub: under + cutis: skin) + tuberositas (L. tuberositas: bumpiness, from tuber: swelling, lump) + tibiae (L. tibia: shinbone, flute, genitive)", "p": 114}, {"t": "Bb. subtendineae m. sartorii", "m": "Subtendinous bursae of sartorius muscle — synovial bursae between the sartorius tendon and the tendons of the gracilis and semitendinosus situated below it", "e": "bursae (L. bursa: pouch, plural) + subtendineae (L. sub: under + tendo: tendon, plural) + musculus (L. musculus: muscle) + sartorii (L. sartor: tailor, from sarcire: to patch or mend; referring to the cross-legged sitting position of tailors, genitive)", "p": 114}, {"t": "ligamentum patellae", "m": "Ligament of the patella (patellar ligament) — referenced as a structure adjacent to infrapatellar bursae", "e": "ligamentum (L. ligamentum: band, tie, from ligare: to bind) + patellae (L. patella: kneecap, small pan, genitive)", "p": 114}, {"t": "linea aspera", "m": "Rough line on the femur — referenced as the inferior extent of the intermuscular gluteal bursae", "e": "linea (L. linea: line, from linum: flax, thread) + aspera (L. asper: rough, uneven)", "p": 114}, {"t": "B. anserina", "m": "Anserine bursa — synovial bursa on the tibial collateral ligament below the tendons of the semitendinosus, gracilis and sartorius muscles", "e": "B. (L. bursa: purse, sac) + anserina (L. anserinus: of a goose, from anser = goose; refers to the goose-foot shape of the conjoined tendons)", "p": 116}, {"t": "B. subtendinea m. bicipitis femoris inferior", "m": "Inferior subtendinous bursa of biceps femoris muscle — synovial bursa located partially on the fibular collateral ligament below the tendon of insertion of the biceps femoris", "e": "B. (L. bursa: purse, sac) + subtendinea (L. sub: under + tendo/tendinis: tendon, from tendere = to stretch) + m. (L. musculus: muscle, lit. little mouse) + bicipitis (L. biceps/bicipitis: two-headed, from bi- = two + caput = head) + femoris (L. femur/femoris: thigh) + inferior (L. inferior: lower)", "p": 116}, {"t": "Recessus subpopliteus", "m": "Subpopliteal recess — synovial bursa on the lateral femoral condyle below the tendon of origin of the popliteal muscle", "e": "recessus (L. recessus: recess, withdrawal, from recedere = to recede) + subpopliteus (L. sub: under + popliteus: of the back of the knee, from poples/poplitis = back of the knee)", "p": 116}, {"t": "bursa m. poplitei", "m": "Bursa of the popliteal muscle", "e": "bursa (L. bursa: purse, sac) + m. (L. musculus: muscle) + poplitei (L. popliteus: of the back of the knee, from poples/poplitis = back of the knee)", "p": 116}, {"t": "B. subtendinea m. gastrocnemii lateralis", "m": "Lateral subtendinous bursa of gastrocnemius muscle — synovial bursa between the lateral condyle of the femur and the lateral gastrocnemius tendon", "e": "B. (L. bursa: purse, sac) + subtendinea (L. sub: under + tendinis: of a tendon) + m. (L. musculus: muscle) + gastrocnemii (Gk. gastroknēmia: calf of the leg, from gastēr = belly + knēmē = leg) + lateralis (L. lateralis: of the side, from latus = side)", "p": 116}, {"t": "B. subtendinea m. gastrocnemii medialis", "m": "Medial subtendinous bursa of gastrocnemius muscle — synovial bursa between the medial condyle of the femur and the medial gastrocnemius tendon", "e": "B. (L. bursa: purse, sac) + subtendinea (L. sub: under + tendinis: of a tendon) + m. (L. musculus: muscle) + gastrocnemii (Gk. gastroknēmia: calf of the leg, from gastēr = belly + knēmē = leg) + medialis (L. medialis: of the middle, from medius = middle)", "p": 116}, {"t": "B. m. semimembranosi", "m": "Bursa of semimembranosus muscle — synovial bursa between the semimembranosus tendon and the upper margin of the tibia", "e": "B. (L. bursa: purse, sac) + m. (L. musculus: muscle) + semimembranosi (L. semi: half + membrana: membrane, from membrum = limb; referring to the membranous proximal tendon)", "p": 116}, {"t": "B. subcutanea malleoli lateralis", "m": "Subcutaneous bursa of lateral malleolus — synovial bursa between the skin and the lateral malleolus", "e": "B. (L. bursa: purse, sac) + subcutanea (L. sub: under + cutis: skin) + malleoli (L. malleolus: small hammer, diminutive of malleus = hammer; refers to the bony prominence) + lateralis (L. lateralis: of the side, from latus = side)", "p": 116}, {"t": "B. subcutanea malleoli medialis", "m": "Subcutaneous bursa of medial malleolus — synovial bursa between the skin and the medial malleolus", "e": "B. (L. bursa: purse, sac) + subcutanea (L. sub: under + cutis: skin) + malleoli (L. malleolus: small hammer, diminutive of malleus = hammer) + medialis (L. medialis: of the middle, from medius = middle)", "p": 116}, {"t": "Vag. tendinis m. tibialis anterioris", "m": "Tendon sheath of tibialis anterior muscle — begins just below the extensor retinaculum", "e": "Vag. (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon, from tendere = to stretch) + m. (L. musculus: muscle) + tibialis (L. tibialis: of the tibia, from tibia = shinbone, flute) + anterioris (L. anterior: front, from ante = before)", "p": 116}, {"t": "Vag. tendinis m. extensoris hallucis longi", "m": "Tendon sheath of extensor hallucis longus muscle — sheath extending below the extensor retinaculum and further distal", "e": "Vag. (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + extensoris (L. extensor: one that stretches out, from extendere = to extend) + hallucis (L. hallux/hallucis: great toe) + longi (L. longus: long)", "p": 116}, {"t": "Vag. tendinum m. extensoris digitorum pedis longi", "m": "Tendon sheath of extensor digitorum longus muscle — sheath extending below the extensor retinaculum and further distal", "e": "Vag. (L. vagina: sheath, scabbard) + tendinum (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + extensoris (L. extensor: one that stretches out, from extendere = to extend) + digitorum (L. digitus: finger, toe) + pedis (L. pes/pedis: foot) + longi (L. longus: long)", "p": 116}, {"t": "Vag. tendinum m. flexoris digitorum pedis longi", "m": "Tendon sheath of flexor digitorum longus muscle — lies behind and below the medial malleolus covered by the flexor retinaculum", "e": "Vag. (L. vagina: sheath, scabbard) + tendinum (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + flexoris (L. flexor: one that bends, from flectere = to bend) + digitorum (L. digitus: finger, toe) + pedis (L. pes/pedis: foot) + longi (L. longus: long)", "p": 116}, {"t": "Vag. tendinis m. tibialis posterioris", "m": "Tendon sheath of tibialis posterior muscle — resides below the flexor retinaculum and begins at the point where it is crossed over by the flexor digitorum longus", "e": "Vag. (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + tibialis (L. tibialis: of the tibia, from tibia = shinbone) + posterioris (L. posterior: behind, from post = after, behind)", "p": 116}, {"t": "Vag. tendinis m. flexoris hallucis longi", "m": "Tendon sheath of flexor hallucis longus muscle — extends up to the proximal end of the sole, where it crosses under the tendon of the flexor digitorum longus", "e": "Vag. (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + flexoris (L. flexor: one that bends, from flectere = to bend) + hallucis (L. hallux/hallucis: great toe) + longi (L. longus: long)", "p": 116}, {"t": "Vag. tendinum mm. peroneorum (fibularium) communis", "m": "Common tendon sheath for peroneal muscles — lies below the peroneal retinaculum and extends to the cuboid bone", "e": "Vag. (L. vagina: sheath, scabbard) + tendinum (L. tendo/tendinis: tendon) + mm. (L. musculi: muscles) + peroneorum (Gk. peronē: fibula, pin, brooch; hence peroneal = of the fibula) + fibularium (L. fibula: brooch, clasp; the smaller bone of the leg) + communis (L. communis: common, shared)", "p": 116}, {"t": "B. subtendinea m. tibialis anterioris", "m": "Subtendinous bursa of tibialis anterior muscle — synovial bursa between the tibialis anterior tendon and the medial cuneiform bone", "e": "B. (L. bursa: purse, sac) + subtendinea (L. sub: under + tendinis: of a tendon) + m. (L. musculus: muscle) + tibialis (L. tibialis: of the tibia, from tibia = shinbone) + anterioris (L. anterior: front, from ante = before)", "p": 116}, {"t": "B. sucutanea calcanea", "m": "Subcutaneous calcaneal bursa — synovial bursa between the skin and the posterior surface of the calcaneus", "e": "B. (L. bursa: purse, sac) + subcutanea (L. sub: under + cutis: skin) + calcanea (L. calcaneus: heel bone, from calx/calcis = heel)", "p": 116}, {"t": "B. tendinis calcanei [Achilles]", "m": "Bursa of calcaneal (Achilles) tendon — synovial bursa between the calcaneus and the Achilles tendon", "e": "B. (L. bursa: purse, sac) + tendinis (L. tendo/tendinis: tendon, from tendere = to stretch) + calcanei (L. calcaneus: heel bone, from calx/calcis = heel) + Achilles (Gk. Achilleus: the Greek hero Achilles, after whom the tendon is named)", "p": 116}, {"t": "Vag. tendinis m. peronei (fibularis) longi plantaris", "m": "Tendon sheath of peroneus longus muscle at the sole of the foot", "e": "Vag. (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon) + m. (L. musculus: muscle) + peronei (Gk. peronē: fibula, pin) + fibularis (L. fibula: brooch, clasp; the smaller bone of the leg) + longi (L. longus: long) + plantaris (L. plantaris: of the sole, from planta = sole of the foot)", "p": 116}, {"t": "Vagg. tendinum digitorum pedis", "m": "Tendon sheaths for the flexors of the toes", "e": "Vagg. (L. vaginae: sheaths, plural of vagina = sheath, scabbard) + tendinum (L. tendo/tendinis: tendon) + digitorum (L. digitus: finger, toe) + pedis (L. pes/pedis: foot)", "p": 116}, {"t": "Apparatus digestorius", "m": "Digestive system", "e": "apparatus (L. apparātus: equipment, preparation, from apparāre = to prepare) + digestorius (L. digestōrius: of digestion, from digerere = to separate, distribute, digest)", "p": 118}, {"t": "Systema alimentarium", "m": "Digestive system (alternative term)", "e": "systema (Gk. sústēma: organized whole, from sun = together + histanai = to set) + alimentarium (L. alimentārius: of nourishment, from alere = to nourish)", "p": 118}, {"t": "Cavitas oris", "m": "Oral cavity", "e": "cavitas (L. cavitās: hollowness, cavity, from cavus = hollow) + oris (L. os/oris: mouth)", "p": 118}, {"t": "Vestibulum oris", "m": "Vestibule of mouth — space between the rows of teeth and the lips or cheeks", "e": "vestibulum (L. vestibulum: entrance hall, forecourt) + oris (L. os/oris: mouth)", "p": 118}, {"t": "Rima oris", "m": "Oral fissure — mouth opening between the lips", "e": "rima (L. rīma: cleft, slit, fissure) + oris (L. os/oris: mouth)", "p": 118}, {"t": "Labia oris", "m": "Lips", "e": "labia (L. labium: lip, pl. labia) + oris (L. os/oris: mouth)", "p": 118}, {"t": "Labium superius", "m": "Upper lip", "e": "labium (L. labium: lip) + superius (L. superius: upper, from super = above)", "p": 118}, {"t": "Labium inferius", "m": "Lower lip", "e": "labium (L. labium: lip) + inferius (L. inferius: lower, from inferus = below)", "p": 118}, {"t": "Commissura labiorum", "m": "Commissure of lips — transition of upper lip into lower lip at the angle of the mouth", "e": "commissura (L. commissūra: joining, seam, from committere = to join) + labiorum (L. labium: lip, genitive plural)", "p": 118}, {"t": "Angulus oris", "m": "Angle of mouth", "e": "angulus (L. angulus: angle, corner) + oris (L. os/oris: mouth)", "p": 118}, {"t": "Bucca", "m": "Cheek — lateral wall of vestibule of mouth", "e": "bucca (L. bucca: cheek, mouth cavity)", "p": 118}, {"t": "Corpus adiposum buccae", "m": "Buccal fat pad — encapsulated body of fat between the buccinator and masseter muscles", "e": "corpus (L. corpus: body) + adiposum (L. adipōsus: fatty, from adeps = fat) + buccae (L. bucca: cheek, genitive)", "p": 118}, {"t": "Cavitas oris propria", "m": "Oral cavity proper — true oral cavity enclosed anteriorly and laterally by the teeth and extending as far as the isthmus of fauces", "e": "cavitas (L. cavitās: cavity, from cavus = hollow) + oris (L. os/oris: mouth) + propria (L. proprius: one's own, proper)", "p": 118}, {"t": "Palatum", "m": "Palate — partition between oral and nasal cavities", "e": "palatum (L. palātum: palate, roof of the mouth)", "p": 118}, {"t": "Palatum durum", "m": "Hard palate — hard, bony part of the palate", "e": "palatum (L. palātum: palate) + durum (L. dūrus: hard)", "p": 118}, {"t": "Palatum molle", "m": "Soft palate — soft, posterior part of the palate", "e": "palatum (L. palātum: palate) + molle (L. mollis: soft)", "p": 118}, {"t": "Velum palatinum", "m": "Soft palate (alternative term)", "e": "velum (L. vēlum: veil, curtain, sail) + palatinum (L. palātīnus: of the palate, from palātum = palate)", "p": 118}, {"t": "Raphe palati", "m": "Palatine raphe — median mucosal ridge at the junction of the right and left bony palatal processes", "e": "raphe (Gk. rhaphē: seam, suture, from rhaptein = to sew) + palati (L. palātum: palate, genitive)", "p": 118}, {"t": "Tunica mucosa oris", "m": "Oral mucosa — mucous membrane of oral cavity consisting of stratified, nonkeratinized squamous epithelium throughout and underlying mixed glands", "e": "tunica (L. tunica: coat, covering, membrane) + mucosa (L. mūcōsus: mucous, from mūcus = mucus) + oris (L. os/oris: mouth)", "p": 118}, {"t": "Frenulum labii superioris", "m": "Frenulum of upper lip — median mucosal fold between the gums and upper lip", "e": "frenulum (L. frēnulum: small bridle, diminutive of frēnum = bridle, rein) + labii (L. labium: lip, genitive) + superioris (L. superior: upper, genitive)", "p": 118}, {"t": "Frenulum labii inferioris", "m": "Frenulum of lower lip — median mucosal fold between the gums and lower lip", "e": "frenulum (L. frēnulum: small bridle, diminutive of frēnum = bridle) + labii (L. labium: lip, genitive) + inferioris (L. inferior: lower, genitive)", "p": 118}, {"t": "Gingivae", "m": "Gums — mucous membrane united firmly with the teeth and jaw bones", "e": "gingivae (L. gingīva: gum of the mouth, pl. gingīvae)", "p": 118}, {"t": "Margo gingivalis", "m": "Gingival (gum) margin", "e": "margo (L. margō: border, edge, margin) + gingivalis (L. gingīvālis: of the gum, from gingīva = gum)", "p": 118}, {"t": "Papilla gingivalis", "m": "Gingival (interdental) papilla", "e": "papilla (L. papilla: nipple, teat, small projection) + gingivalis (L. gingīvālis: of the gum, from gingīva = gum)", "p": 118}, {"t": "Papilla interdentalis", "m": "Interdental papilla (alternative term)", "e": "papilla (L. papilla: nipple, small projection) + interdentalis (L. inter = between + dentālis: of the tooth, from dens/dentis = tooth)", "p": 118}, {"t": "Sulcus gingivalis", "m": "Gingival sulcus — shallow furrow between the gum margin and the tooth", "e": "sulcus (L. sulcus: furrow, groove) + gingivalis (L. gingīvālis: of the gum, from gingīva = gum)", "p": 118}, {"t": "Caruncula sublingualis", "m": "Sublingual papilla — small mucosal eminence on either side of the frenulum, receiving the opening of the submandibular duct and the major sublingual duct", "e": "caruncula (L. caruncula: small fleshy protuberance, diminutive of caro/carnis = flesh) + sublingualis (L. sub = under + linguālis: of the tongue, from lingua = tongue)", "p": 118}, {"t": "Plica sublingualis", "m": "Sublingual fold — mucosal fold overlying the sublingual gland and extending posterolaterally from the sublingual papilla", "e": "plica (L. plica: fold, from plicāre = to fold) + sublingualis (L. sub = under + linguālis: of the tongue, from lingua = tongue)", "p": 118}, {"t": "Papilla ductus parotidei", "m": "Parotid papilla — small mucosal elevation at the opening of the parotid duct lateral to the second upper molar tooth", "e": "papilla (L. papilla: small projection, nipple) + ductus (L. ductus: duct, canal, from ducere = to lead) + parotidei (Gk. parotis: near the ear, from para = beside + ous/otos = ear; genitive parotidei)", "p": 118}, {"t": "Plicae palatinae transversae", "m": "Transverse palatine folds — mucosal folds running transversely on the anterior part of the hard palate", "e": "plicae (L. plica: fold, pl. plicae) + palatinae (L. palātīnus: of the palate, from palātum = palate) + transversae (L. transversus: transverse, lying across, from trans = across + vertere = to turn)", "p": 118}, {"t": "Papilla incisiva", "m": "Incisive papilla — small mucosal elevation over the incisive foramen at the anterior end of the palatine raphe", "e": "papilla (L. papilla: small projection) + incisiva (L. incīsīvus: of cutting, from incīdere = to cut into, related to incisors)", "p": 118}, {"t": "Glandulae oris", "m": "The glands of the mouth", "e": "glandulae (L. glandula: small gland, diminutive of glans = acorn, gland; pl. glandulae) + oris (L. os/oris: mouth)", "p": 118}, {"t": "Glandulae salivariae minores", "m": "Small glands of the oral cavity", "e": "glandulae (L. glandula: small gland, pl.) + salivariae (L. salīvārius: of saliva, from salīva = saliva) + minores (L. minor: smaller, comparative of parvus = small)", "p": 118}, {"t": "Gll. labiales", "m": "Labial glands — small salivary glands at the inner aspect of the lips", "e": "glandulae (L. glandula: small gland, abbreviated Gll.) + labiales (L. labiālis: of the lip, from labium = lip)", "p": 118}, {"t": "Gll. buccales", "m": "Buccal glands — small mucous salivary glands at the inner aspect of the cheeks", "e": "glandulae (L. glandula: small gland, abbreviated Gll.) + buccales (L. buccālis: of the cheek, from bucca = cheek)", "p": 118}, {"t": "Gll. molares", "m": "Molar glands — salivary glands corresponding to the buccal glands situated beneath the mucosal at the level of the molar teeth", "e": "glandulae (L. glandula: small gland, abbreviated Gll.) + molares (L. molāris: of a millstone, molar, from mola = millstone)", "p": 118}, {"t": "Gll. palatinae", "m": "Palatine glands — salivary glands situated beneath the mucosa of the palate", "e": "glandulae (L. glandula: small gland, abbreviated Gll.) + palatinae (L. palātīnus: of the palate, from palātum = palate)", "p": 118}, {"t": "Gll. linguales", "m": "Lingual glands — numerous mucous, serous and mixed glands primarily in the lateral and posterior areas of the tongue", "e": "glandulae (L. glandula: small gland, abbreviated Gll.) + linguales (L. linguālis: of the tongue, from lingua = tongue)", "p": 118}, {"t": "Gl. lingualis anterior", "m": "Anterior lingual glands — mixed glands near the apex of the tongue providing several drainage ducts on the undersurface of the tongue", "e": "glandula (L. glandula: small gland, abbreviated Gl.) + lingualis (L. linguālis: of the tongue, from lingua = tongue) + anterior (L. anterior: in front, fore, from ante = before)", "p": 118}, {"t": "Gl. apicis linguae", "m": "Anterior lingual glands (alternative term, Nuhn's glands)", "e": "glandula (L. glandula: small gland, abbreviated Gl.) + apicis (L. apex/apicis: tip, apex, genitive) + linguae (L. lingua: tongue, genitive)", "p": 118}, {"t": "Glandulae salivariae majores", "m": "Major salivary glands", "e": "glandulae (L. glandula: small acorn, gland) + salivariae (L. salivarius: of saliva, from saliva = spittle) + majores (L. major: greater, larger)", "p": 120}, {"t": "Glandula sublingualis", "m": "Sublingual gland", "e": "glandula (L. glandula: small acorn, gland) + sublingualis (L. sub: under + lingua: tongue)", "p": 120}, {"t": "diaphragma oris", "m": "mylohyoid muscle (mouth diaphragm)", "e": "diaphragma (Gk. diaphragma: partition, midriff) + oris (L. os/oris: mouth)", "p": 120}, {"t": "Ductus sublingualis major", "m": "Major sublingual duct", "e": "ductus (L. ductus: leading, from ducere: to lead) + sublingualis (L. sub: under + lingua: tongue) + major (L. major: greater, larger)", "p": 120}, {"t": "sublingual caruncle", "m": "sublingual caruncle", "e": "sublingual (L. sub: under + lingua: tongue) + caruncle (L. caruncula: small fleshy mass, diminutive of caro: flesh)", "p": 120}, {"t": "Ductus sublinguales minores", "m": "Minor sublingual ducts", "e": "ductus (L. ductus: leading, from ducere: to lead) + sublinguales (L. sub: under + lingua: tongue) + minores (L. minor: smaller, lesser)", "p": 120}, {"t": "Glandula submandibularis", "m": "Submandibular gland", "e": "glandula (L. glandula: small acorn, gland) + submandibularis (L. sub: under + mandibula: jaw, from mandere: to chew)", "p": 120}, {"t": "Ductus submandibularis", "m": "Submandibular duct", "e": "ductus (L. ductus: leading, from ducere: to lead) + submandibularis (L. sub: under + mandibula: jaw, from mandere: to chew)", "p": 120}, {"t": "Glandula parotidea", "m": "Parotid gland", "e": "glandula (L. glandula: small acorn, gland) + parotidea (Gk. para: beside + ous/otos: ear)", "p": 120}, {"t": "Pars superficialis", "m": "Superficial part", "e": "pars (L. pars: part, portion) + superficialis (L. superficialis: of the surface, from super: above + facies: face, surface)", "p": 120}, {"t": "Pars produnda", "m": "Deep part", "e": "pars (L. pars: part, portion) + profunda (L. profundus: deep, from pro: forward + fundus: bottom)", "p": 120}, {"t": "Glandula parotidea accessoria", "m": "Accessory parotid gland", "e": "glandula (L. glandula: small acorn, gland) + parotidea (Gk. para: beside + ous/otos: ear) + accessoria (L. accessorius: additional, from accedere: to come near)", "p": 120}, {"t": "Ductus parotideus", "m": "Parotid duct", "e": "ductus (L. ductus: leading, from ducere: to lead) + parotideus (Gk. para: beside + ous/otos: ear)", "p": 120}, {"t": "Dentes", "m": "Teeth", "e": "dentes (L. dens/dentis: tooth)", "p": 120}, {"t": "Corona dentis", "m": "Crown of tooth", "e": "corona (L. corona: crown, wreath) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "Cuspis dentis", "m": "Cusp of tooth", "e": "cuspis (L. cuspis: point, tip) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "tuberculum", "m": "tubercle/cusp", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber: lump, swelling)", "p": 120}, {"t": "Apex cuspidis", "m": "Apex of cusp", "e": "apex (L. apex: tip, summit) + cuspidis (L. cuspis/cuspidis: point, tip)", "p": 120}, {"t": "Tuberculum dentis", "m": "Dental tubercle", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber: lump) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "Crista transversalis", "m": "Transverse ridge", "e": "crista (L. crista: crest, ridge) + transversalis (L. transversalis: transverse, from trans: across + vertere: to turn)", "p": 120}, {"t": "Crista triangularis", "m": "Triangular ridge", "e": "crista (L. crista: crest, ridge) + triangularis (L. triangularis: triangular, from tri: three + angulus: angle)", "p": 120}, {"t": "Corona clinica", "m": "Clinical crown", "e": "corona (L. corona: crown, wreath) + clinica (Gk. klinike: of a bed/clinical, from kline: bed)", "p": 120}, {"t": "Cervix dentis", "m": "Neck of tooth", "e": "cervix (L. cervix: neck) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "collum", "m": "neck (of tooth)", "e": "collum (L. collum: neck)", "p": 120}, {"t": "Radix dentis", "m": "Root of tooth", "e": "radix (L. radix: root) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "Apex radicis dentis", "m": "Apex of root of tooth", "e": "apex (L. apex: tip, summit) + radicis (L. radix/radicis: root) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "Radix clinica", "m": "Clinical root", "e": "radix (L. radix: root) + clinica (Gk. klinike: of a bed/clinical, from kline: bed)", "p": 120}, {"t": "Facies occlusalis", "m": "Occlusal (masticatory) surface", "e": "facies (L. facies: face, surface) + occlusalis (L. occludere: to shut, close, from ob: against + claudere: to close)", "p": 120}, {"t": "masticatoria", "m": "masticatory", "e": "masticatoria (Gk. mastichao / L. masticare: to chew, from Gk. mastax: jaw, mouth)", "p": 120}, {"t": "Facies vestibularis", "m": "Vestibular (facial) surface", "e": "facies (L. facies: face, surface) + vestibularis (L. vestibulum: entrance, forecourt)", "p": 120}, {"t": "facilis", "m": "facial (surface)", "e": "facilis (L. facies: face; here used as facial)", "p": 120}, {"t": "Facies buccalis dentis", "m": "Buccal surface — tooth surface facing the cheek", "e": "facies (L. facies: face, surface) + buccalis (L. bucca: cheek) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "Facies labialis dentis", "m": "Labial surface — tooth surface facing the lips", "e": "facies (L. facies: face, surface) + labialis (L. labium: lip) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "Facies lingualis", "m": "Lingual surface — tooth surface facing the tongue", "e": "facies (L. facies: face, surface) + lingualis (L. lingua: tongue)", "p": 120}, {"t": "palatalis dentis", "m": "palatine surface — tooth surface facing the palate", "e": "palatalis (L. palatum: palate) + dentis (L. dens/dentis: tooth)", "p": 120}, {"t": "Facies approximalis", "m": "Approximal surface — tooth surface facing the adjacent tooth", "e": "facies (L. facies: face, surface) + approximalis (L. approximare: to come near, from ad: to + proximus: nearest)", "p": 120}, {"t": "Facies mesialis", "m": "Mesial surface — vertical contact surface of a tooth turned away from the last molar", "e": "facies (L. facies: face, surface) + mesialis (Gk. mesos: middle)", "p": 120}, {"t": "Facies distalis", "m": "Distal surface — vertical contact surface of a tooth facing away from the first incisor", "e": "facies (L. facies: face, surface) + distalis (L. distare: to be distant, from dis: apart + stare: to stand)", "p": 120}, {"t": "Area contingens", "m": "Contingent area — direct contact surface of adjacent teeth", "e": "area (L. area: open space, surface area) + contingens (L. contingere: to touch, from con: together + tangere: to touch)", "p": 120}, {"t": "Cingulum", "m": "Cingulum — ridge near the neck of a tooth connecting both marginal crests at the lingual surface of incisor and canine teeth", "e": "cingulum (L. cingulum: girdle, belt, from cingere: to encircle)", "p": 120}, {"t": "Crista marginalis", "m": "Marginal crest — lateral marginal ridge on the lingual surface of the incisor and canine teeth", "e": "crista (L. crista: crest, ridge) + marginalis (L. marginalis: of the margin, from margo: edge, border)", "p": 120}, {"t": "Margo incisalis", "m": "Incisal margin — occlusal edge of incisor and canine teeth", "e": "margo (L. margo: edge, border) + incisalis (L. incidere: to cut into, from in: into + caedere: to cut)", "p": 120}, {"t": "Cavitas dentis", "m": "Pulp cavity of tooth — cavity in the dentin, becomes continuous with the root canal towards the root", "e": "cavitas (L. cavitās: hollow space, from cavus = hollow) + dentis (L. dens/dentis: tooth)", "p": 122}, {"t": "Cavitas coronae", "m": "Pulp chamber in the crown — crown portion of the pulp cavity", "e": "cavitas (L. cavitās: hollow space, from cavus = hollow) + coronae (L. corona: crown, wreath)", "p": 122}, {"t": "Canalis radicis dentis", "m": "Root canal of tooth — canal between the pulp cavity and the apical foramen", "e": "canalis (L. canālis: channel, pipe) + radicis (L. radix/radicis: root) + dentis (L. dens/dentis: tooth)", "p": 122}, {"t": "Foramen apicis radicis dentalis", "m": "Apical foramen of root of tooth — opening of the root canal at the apex of the root", "e": "foramen (L. forāmen: opening, hole, from forare = to bore) + apicis (L. apex/apicis: tip, point) + radicis (L. radix/radicis: root) + dentalis (L. dentālis: of the tooth, from dens = tooth)", "p": 122}, {"t": "Pulpa dentis", "m": "Pulp of tooth — contents of the pulp cavity consisting of loose, finely fibered connective tissue, blood vessels and nerves", "e": "pulpa (L. pulpa: flesh, soft tissue) + dentis (L. dens/dentis: tooth)", "p": 122}, {"t": "Pulpa coronalis", "m": "Crown pulp — pulp within the crown portion of the pulp cavity", "e": "pulpa (L. pulpa: flesh, soft tissue) + coronalis (L. corōnālis: of the crown, from corona = crown)", "p": 122}, {"t": "Pulpa radicularis", "m": "Root pulp — pulp within the root canal portion of the pulp cavity", "e": "pulpa (L. pulpa: flesh, soft tissue) + radicularis (L. radiculāris: of the small root, from radicula = small root, diminutive of radix = root)", "p": 122}, {"t": "Papilla dentis", "m": "Dental papilla — a mass of mesenchyme present in the bell stage of tooth development", "e": "papilla (L. papilla: nipple-like projection, diminutive of papula = pimple) + dentis (L. dens/dentis: tooth)", "p": 122}, {"t": "Dentinum", "m": "Dentine — predominant mass of a tooth consisting of inorganic and organic material (especially collagenous fibers)", "e": "dentinum (L./NL. dentinum: dentine substance, from dens/dentis = tooth)", "p": 122}, {"t": "substantia eburnea", "m": "Dentine (bracketed synonym) — ivory-like substance of the tooth", "e": "substantia (L. substantia: substance, matter, from sub = under + stare = to stand) + eburnea (L. eburneus: of ivory, from ebur = ivory)", "p": 122}, {"t": "Enamelum", "m": "Enamel — the extremely hard substance surrounding the crown of the tooth like a mantle", "e": "enamelum (NL. enamelum: enamel, from Old French esmail = enamel, of Germanic origin)", "p": 122}, {"t": "substantia adamantina", "m": "Enamel (bracketed synonym) — adamantine/very hard substance", "e": "substantia (L. substantia: substance, matter) + adamantina (Gk. adamantinos: of adamant, extremely hard, from adamas = unconquerable, hardest metal)", "p": 122}, {"t": "Periodontium", "m": "Periodontium — tissues that invest and support the tooth within the alveolus", "e": "peri- (Gk. peri: around) + odontium (Gk. odous/odontos: tooth)", "p": 122}, {"t": "Periodontium protectoris", "m": "The outer part of the periodontium with the external border epithelium", "e": "peri- (Gk. peri: around) + odontium (Gk. odous/odontos: tooth) + protectoris (L. protector: one who protects, from protegere = to protect, cover in front)", "p": 122}, {"t": "gingiva", "m": "Gingiva (bracketed term within Periodontium protectoris) — the gum", "e": "gingiva (L. gingiva: gum of the mouth)", "p": 122}, {"t": "Periodontium insertionis", "m": "Portion of the periodontium touching the tooth, consisting of the inner border epithelium and the periodontal ligament", "e": "peri- (Gk. peri: around) + odontium (Gk. odous/odontos: tooth) + insertionis (L. insertio/insertionis: insertion, attachment, from inserere = to insert)", "p": 122}, {"t": "Desmodontium", "m": "Periodontal ligament — all connective tissue fibers anchored in the cementum and extending partly into the gum and partly into the alveolar wall", "e": "desmo- (Gk. desmos: bond, ligament, from dein = to bind) + odontium (Gk. odous/odontos: tooth)", "p": 122}, {"t": "Cementum", "m": "Cementum — substance similar to bone surrounding the tooth from the enamel border to the apex of the root", "e": "cementum (L. caementum: rough stone, mortar, from caedere = to cut; adopted in anatomy for tooth cement)", "p": 122}, {"t": "Os alveolare", "m": "Alveolar bone — bony wall of the alveolus", "e": "os (L. os/ossis: bone) + alveolare (L. alveolāris: of the alveolus, from alveolus = small hollow, diminutive of alveus = hollow)", "p": 122}, {"t": "Arcus dentalis superior", "m": "Superior dental arch — curved row of teeth of the maxilla", "e": "arcus (L. arcus: arch, bow) + dentalis (L. dentālis: of the teeth, from dens = tooth) + superior (L. superior: upper, higher)", "p": 122}, {"t": "Arcus dentalis inferior", "m": "Inferior dental arch — curved row of teeth of the mandible", "e": "arcus (L. arcus: arch, bow) + dentalis (L. dentālis: of the teeth, from dens = tooth) + inferior (L. inferior: lower)", "p": 122}, {"t": "Dentes incisivi", "m": "Incisor teeth — cutting teeth located on both sides of the midline at the 1st and 2nd positions of the dental arch", "e": "dentes (L. dens/dentes: teeth) + incisivi (L. incisivus: cutting, from incidere = to cut into, from in + caedere = to cut)", "p": 122}, {"t": "Dentes canini", "m": "Canine teeth — teeth located at the 3rd position of the dental arch", "e": "dentes (L. dens/dentes: teeth) + canini (L. caninus: of the dog, from canis = dog; named for fang-like shape)", "p": 122}, {"t": "Dentes premolares", "m": "Premolar teeth — teeth occupying the 4th and 5th positions of the dental arch", "e": "dentes (L. dens/dentes: teeth) + pre- (L. prae: before, in front of) + molares (L. molāris: millstone tooth, from mola = millstone, from molere = to grind)", "p": 122}, {"t": "Dentes molares", "m": "Molar teeth — teeth located at the 6th, 7th and 8th positions of the dental arch", "e": "dentes (L. dens/dentes: teeth) + molares (L. molāris: millstone tooth, from mola = millstone, from molere = to grind)", "p": 122}, {"t": "Dens serotinus", "m": "Wisdom tooth — tooth located at the 8th position of the dental arch", "e": "dens (L. dens: tooth) + serotinus (L. serotinus: late-coming, from serus = late; referring to late eruption)", "p": 122}, {"t": "molaris tertius", "m": "Wisdom tooth (bracketed synonym) — third molar", "e": "molaris (L. molāris: millstone tooth, from mola = millstone) + tertius (L. tertius: third)", "p": 122}, {"t": "Dentes decidui", "m": "Deciduous (milk) teeth", "e": "dentes (L. dens/dentes: teeth) + decidui (L. deciduus: falling off, shed, from decidere = to fall down, from de = down + cadere = to fall)", "p": 122}, {"t": "Dentes permanentes", "m": "Permanent teeth — teeth that develop after the deciduous teeth", "e": "dentes (L. dens/dentes: teeth) + permanentes (L. permanens: remaining, lasting, from per = through + manere = to remain)", "p": 122}, {"t": "Diastema", "m": "Diastema — space between adjacent teeth", "e": "diastema (Gk. diastēma: interval, space, from dia = between/through + histanai = to set, place)", "p": 122}, {"t": "Lingua", "m": "Tongue", "e": "lingua (L. lingua: tongue, language)", "p": 122}, {"t": "Corpus linguae", "m": "Body of tongue — portion of the tongue situated between the apex and root", "e": "corpus (L. corpus: body) + linguae (L. lingua: tongue, genitive form)", "p": 122}, {"t": "Radix linguae", "m": "Root of tongue — anchoring region of the tongue at the mandible and hyoid bone; also the posterior, vertical segment of the tongue", "e": "radix (L. radix: root) + linguae (L. lingua: tongue, genitive form)", "p": 122}, {"t": "Dorsum linguae", "m": "Dorsum of tongue", "e": "dorsum (L. dorsum: back, upper surface) + linguae (L. lingua: tongue, genitive form)", "p": 122}, {"t": "Pars presulcalis", "m": "Anterior, oral portion of tongue — the part of the dorsum of the tongue situated anterior to the sulcus terminalis", "e": "pars (L. pars: part) + pre- (L. prae: before, in front of) + sulcalis (L. sulcālis: of the groove/furrow, from sulcus = groove)", "p": 122}, {"t": "Pars postsulcalis", "m": "Posterior, pharyngeal part of tongue — the vertical portion of the dorsum of the tongue between the sulcus terminalis and the epiglottis", "e": "pars (L. pars: part) + post- (L. post: after, behind) + sulcalis (L. sulcālis: of the groove/furrow, from sulcus = groove)", "p": 122}, {"t": "Facies inferior linguae", "m": "Inferior surface of tongue", "e": "facies (L. faciēs: face, surface) + inferior (L. inferior: lower) + linguae (L. lingua: tongue, genitive form)", "p": 122}, {"t": "Plica fimbriata", "m": "Fimbriated fold — serrated fold lateral to the frenulum; a remnant of the inferior tongue", "e": "plica (L. plica: fold, from plicare = to fold) + fimbriata (L. fimbriatus: fringed, having fringe, from fimbriae = fringe, threads)", "p": 122}, {"t": "Margo linguae", "m": "Lateral margin of tongue bordering the teeth", "e": "margo (L. margo: margin, edge, border) + linguae (L. lingua: tongue, genitive form)", "p": 122}, {"t": "Apex linguae", "m": "Apex of tongue", "e": "apex (L. apex: tip, point, summit) + linguae (L. lingua: tongue, genitive form)", "p": 122}, {"t": "Tunica mucosa linguae", "m": "Mucous membrane of tongue", "e": "tunica (L. tunica: covering, coat) + mucosa (L. mucosus: slimy, from mucus = slime) + linguae (L. lingua: tongue, genitive form)", "p": 124}, {"t": "Frenulum linguae", "m": "Frenulum of tongue — mucosal fold extending from the floor of the mouth to the inferior side of the tongue", "e": "frenulum (L. frenulum: little bridle, diminutive of frenum = bridle) + linguae (L. lingua: tongue, genitive form)", "p": 124}, {"t": "Papillae linguales", "m": "Lingual papillae — collective term for five different types of mucosal formations", "e": "papillae (L. papilla: nipple, teat, plural form) + linguales (L. lingualis: of the tongue, from lingua = tongue)", "p": 124}, {"t": "Papillae filiformes", "m": "Filiform papillae — fine, almost threadlike epithelial elevations on a connective tissue core", "e": "papillae (L. papilla: nipple, teat, plural form) + filiformes (L. filiformis: thread-shaped, from filum = thread + forma = shape)", "p": 124}, {"t": "Papillae conicae", "m": "Conical papillae — special form of filiform papilla, somewhat larger, longer with conical apices which bend backwards", "e": "papillae (L. papilla: nipple, teat, plural form) + conicae (L. conicus: cone-shaped, from Gk. konikos = of a cone, from konos = cone)", "p": 124}, {"t": "Papillae fungiformes", "m": "Fungiform papillae — mushroom-like papillae which are not pointed at the tip, but terminate with a small plateau", "e": "papillae (L. papilla: nipple, teat, plural form) + fungiformes (L. fungiformis: mushroom-shaped, from fungus = mushroom + forma = shape)", "p": 124}, {"t": "Papillae vallatae", "m": "Vallate (circumvallate) papillae — 7–12 large papillae located in front of the sulcus terminalis, circular in cross-section surrounded by a moat containing taste buds", "e": "papillae (L. papilla: nipple, teat, plural form) + vallatae (L. vallatus: surrounded by a wall, from vallum = rampart, wall)", "p": 124}, {"t": "Papilla lentiformes", "m": "Lenticular papillae — short fungiform papillae", "e": "papilla (L. papilla: nipple, teat) + lentiformes (L. lentiformis: lens-shaped, from lens/lentis = lentil, lens + forma = shape)", "p": 124}, {"t": "Papillae foliatae", "m": "Foliate papilla — several parallel folds containing taste buds at the posterolateral margin of the tongue", "e": "papillae (L. papilla: nipple, teat, plural form) + foliatae (L. foliatus: leaf-like, from folium = leaf)", "p": 124}, {"t": "Sulcus medianus linguae", "m": "Median groove of tongue — shallow, median longitudinal groove situated above the lingual septum", "e": "sulcus (L. sulcus: groove, furrow) + medianus (L. medianus: middle, from medius = middle) + linguae (L. lingua: tongue, genitive form)", "p": 124}, {"t": "Sulcus terminalis", "m": "Sulcus terminalis — bilateral groove passing obliquely forward from the foramen caecum, lying behind the row of vallate papillae", "e": "sulcus (L. sulcus: groove, furrow) + terminalis (L. terminalis: forming a boundary, from terminus = boundary, end)", "p": 124}, {"t": "Foramen caecum linguae", "m": "Foramen caecum linguae — pit situated at the apex of the sulcus terminalis, embryological remains of the thyroglossal duct", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + caecum (L. caecus: blind, hidden) + linguae (L. lingua: tongue, genitive form)", "p": 124}, {"t": "Ductus thyroglossalis", "m": "Thyroglossal duct — embryological connection between thyroid gland and tongue, extends downward from the base of the tongue as an epithelial cone", "e": "ductus (L. ductus: duct, channel, from ducere = to lead) + thyroglossalis (Gk. thyreos: shield + glossa: tongue, i.e. connecting thyroid to tongue)", "p": 124}, {"t": "Tonsilla lingualis", "m": "Lingual tonsil — accumulation of lymphatic tissue (lingual follicles) irregularly distributed over the root of the tongue", "e": "tonsilla (L. tonsilla: tonsil, almond-shaped mass) + lingualis (L. lingualis: of the tongue, from lingua = tongue)", "p": 124}, {"t": "Folliculi linguales", "m": "Lingual follicles — dome-shaped protrusions of the mucosa, 1–5 mm in diameter, caused by masses of lymphatic tissue, each with a central crypt", "e": "folliculi (L. folliculus: small sac, diminutive of follis = bag, plural form) + linguales (L. lingualis: of the tongue, from lingua = tongue)", "p": 124}, {"t": "Septum lingualis", "m": "Lingual septum — connective tissue plate with a special fibrous architecture located in the midsagittal plane", "e": "septum (L. septum: partition, wall, from saepire = to enclose) + lingualis (L. lingualis: of the tongue, from lingua = tongue)", "p": 124}, {"t": "Aponeurosis lingualis", "m": "Lingual aponeurosis — stout connective tissue framework of the tongue between the muscles and the mucosa", "e": "aponeurosis (Gk. aponeurosis: flat tendinous sheet, from apo = away from + neuron = sinew, tendon) + lingualis (L. lingualis: of the tongue, from lingua = tongue)", "p": 124}, {"t": "Musculi linguae", "m": "Tongue musculature — the eight tongue muscles innervated by the hypoglossal nerve (XII)", "e": "musculi (L. musculus: muscle, little mouse, plural form) + linguae (L. lingua: tongue, genitive form)", "p": 124}, {"t": "M. genioglossus", "m": "Genioglossus muscle — origin: mental spine of mandible; fan-shaped distribution within the tongue from apex to base; pulls the tongue forward or towards the chin", "e": "musculus (L. musculus: muscle) + genio (Gk. geneion: chin, from genys = jaw) + glossus (Gk. glossa: tongue)", "p": 124}, {"t": "M. hyoglossus", "m": "Hyoglossus muscle — origin: body and greater horn of hyoid bone; draws the base of the tongue backward and downward", "e": "musculus (L. musculus: muscle) + hyo (Gk. hyoeides: U-shaped, referring to hyoid bone, from letter upsilon) + glossus (Gk. glossa: tongue)", "p": 124}, {"t": "M. chondroglossus", "m": "Chondroglossus muscle — origin: lesser horn of hyoid; same as hyoglossus", "e": "musculus (L. musculus: muscle) + chondro (Gk. chondros: cartilage, grain) + glossus (Gk. glossa: tongue)", "p": 124}, {"t": "M. styloglossus", "m": "Styloglossus muscle — origin: styloid process; radiates to the lateral parts of the tongue and interweaves with the hyoglossus; draws the tongue backward and upward", "e": "musculus (L. musculus: muscle) + stylo (Gk. stylos: pillar, post, referring to styloid process) + glossus (Gk. glossa: tongue)", "p": 124}, {"t": "M. longitudinalis superior", "m": "Superior longitudinal muscle of tongue — longitudinal bundles of muscle just below the mucosa extending from the apex of the tongue to the region of the hyoid bone", "e": "musculus (L. musculus: muscle) + longitudinalis (L. longitudinalis: lengthwise, from longitudo = length, from longus = long) + superior (L. superior: upper, higher)", "p": 124}, {"t": "M. longitudinalis inferior", "m": "Inferior longitudinal muscle of tongue — longitudinal fibrous system close to the inferior surface of the tongue, passing from the base to the apex", "e": "musculus (L. musculus: muscle) + longitudinalis (L. longitudinalis: lengthwise, from longitudo = length, from longus = long) + inferior (L. inferior: lower)", "p": 124}, {"t": "M. transversus linguae", "m": "Transverse muscle of tongue — transversely oriented muscle fibers extending between the longitudinal system of fibers; origin: lingual septum; insertion: mucous membrane along lateral margins of tongue", "e": "musculus (L. musculus: muscle) + transversus (L. transversus: crosswise, from trans = across + vertere = to turn) + linguae (L. lingua: tongue, genitive form)", "p": 124}, {"t": "M. verticalis linguae", "m": "Vertical muscle of tongue — vertical muscle fibers coursing from the back of the tongue to the inferior surface", "e": "musculus (L. musculus: muscle) + verticalis (L. verticalis: vertical, from vertex = summit, highest point, from vertere = to turn) + linguae (L. lingua: tongue, genitive form)", "p": 124}, {"t": "Palatum molle (velum palatinum)", "m": "Soft palate — the dorsal portion projects downward in front of the posterior pharyngeal wall", "e": "palatum (L. palātum: palate, roof of the mouth) + molle (L. mollis: soft) + velum (L. vēlum: veil, curtain) + palatinum (L. palatīnus: of the palate)", "p": 126}, {"t": "Uvula palatina", "m": "Uvula — conical process projecting downward from the posterior margin of the soft palate", "e": "uvula (L. ūvula: little grape, diminutive of uva = grape) + palatina (L. palatīna: of the palate)", "p": 126}, {"t": "Arcus palatoglossus", "m": "Palatoglossal arch — mucosal fold overlying the palatoglossal muscle extending from the palate to the tongue in front of the tonsillar fossa", "e": "arcus (L. arcus: arch, bow) + palato- (L. palātum: palate) + glossus (Gk. glōssa: tongue)", "p": 126}, {"t": "Arcus palatopharyngeus", "m": "Palatopharyngeal arch — mucosal fold overlying the palatopharyngeal muscle extending between the palate and pharyngeal wall behind the tonsillar fossa", "e": "arcus (L. arcus: arch, bow) + palato- (L. palātum: palate) + pharyngeus (Gk. pharynx/pharyngos: throat)", "p": 126}, {"t": "Plica salpingopalatina [[plica palatotubalis]]", "m": "Salpingopalatine fold — fold extending from the anterior lip of the auditory tube to the soft palate in front of the tubal elevation", "e": "plica (L. plica: fold, from plicāre = to fold) + salpingo- (Gk. salpinx/salpingos: trumpet, tube) + palatina (L. palatīnus: of the palate) + tuba (L. tuba: tube, trumpet) + lis (L. suffix: relating to)", "p": 126}, {"t": "Tonsilla palatina", "m": "Palatine tonsil — tonsil situated between the palatoglossal and palatopharyngeal arches", "e": "tonsilla (L. tonsilla: tonsil, almond-shaped gland) + palatina (L. palatīna: of the palate)", "p": 126}, {"t": "Fossulae tonsillae", "m": "Tonsillar pits — pit-like openings of the tonsillar crypts visible on the surface", "e": "fossulae (L. fossula: small pit, diminutive of fossa = ditch, pit) + tonsillae (L. tonsilla: tonsil)", "p": 126}, {"t": "Cryptae tonsillares", "m": "Tonsillar crypts — epithelial invaginations extending into the tonsil from the tonsillar pits", "e": "cryptae (Gk./L. crypta: hidden recess, from Gk. kryptē = vault) + tonsillares (L. tonsillāris: of the tonsil)", "p": 126}, {"t": "Capsula tonsillaris", "m": "Capsule of tonsil — fibrous capsule covering the organ", "e": "capsula (L. capsula: small box/container, diminutive of capsa = box) + tonsillaris (L. tonsillāris: of the tonsil)", "p": 126}, {"t": "Plica triangularis", "m": "Triangular fold — triangular fold emanating from the palatoglossal arch in front of the tonsil", "e": "plica (L. plica: fold) + triangularis (L. triangulāris: triangular, from tri- = three + angulus = angle)", "p": 126}, {"t": "Plica semilunaris", "m": "Semilunar fold — arched fold between the palatoglossal and palatopharyngeal arches forming the upper boundary of the tonsillar fossa", "e": "plica (L. plica: fold) + semi- (L. semi-: half) + lunaris (L. lūnāris: of the moon, from lūna = moon)", "p": 126}, {"t": "Fossa tonsillaris", "m": "Tonsillar fossa — recess for the tonsil bordered by the palatoglossal and palatopharyngeal arches as well as by the triangular and semilunar folds", "e": "fossa (L. fossa: ditch, pit, hollow) + tonsillaris (L. tonsillāris: of the tonsil)", "p": 126}, {"t": "Fossa supratonsillaris", "m": "Supratonsillar fossa — superior portion of tonsillar fossa not occupied by the tonsil", "e": "fossa (L. fossa: ditch, pit) + supra- (L. suprā: above) + tonsillaris (L. tonsillāris: of the tonsil)", "p": 126}, {"t": "Musculi palati et faucium", "m": "Muscles of palate and fauces", "e": "musculi (L. musculus: muscle, diminutive of mus = mouse) + palati (L. palātum: palate, genitive) + et (L. et: and) + faucium (L. fauces: throat, narrow passage, genitive plural)", "p": 126}, {"t": "Aponeurosis palatina", "m": "Palatine aponeurosis — formed primarily by the tendon of the tensor veli palatini muscle", "e": "aponeurosis (Gk. aponeurōsis: from apo- = away from + neuron = sinew, tendon) + palatina (L. palatīna: of the palate)", "p": 126}, {"t": "M. levator veli palatini", "m": "Levator veli palatini — origin: petrous portion of temporal bone in front of lower opening of carotid canal; insertion: palatine aponeurosis", "e": "musculus (L. musculus: muscle) + levator (L. levātor: lifter, from levāre = to lift) + veli (L. vēlum: veil, curtain, genitive) + palatini (L. palatīnus: of the palate, genitive)", "p": 126}, {"t": "M. tensor veli palatini", "m": "Tensor veli palatini — origin: spine of sphenoid, scaphoid fossa and anterior lip of cartilaginous auditory tube; insertion: after looping around the pterygoid hamulus, radiates into the palatine aponeurosis", "e": "musculus (L. musculus: muscle) + tensor (L. tensor: stretcher, from tendere = to stretch) + veli (L. vēlum: veil, genitive) + palatini (L. palatīnus: of the palate, genitive)", "p": 126}, {"t": "M. uvulae", "m": "Uvulae muscle — origin: palatine aponeurosis; insertion: connective tissue of uvulae", "e": "musculus (L. musculus: muscle) + uvulae (L. ūvula: little grape, genitive)", "p": 126}, {"t": "M. palatoglossus", "m": "Palatoglossus — origin: transversus linguae muscle; insertion: palatine aponeurosis; action: elevates base of tongue, depresses palate, narrows isthmus of fauces", "e": "musculus (L. musculus: muscle) + palato- (L. palātum: palate) + glossus (Gk. glōssa: tongue)", "p": 126}, {"t": "M. palatopharyngeus [[m. pharyngopalatinus]]", "m": "Palatopharyngeus — origin: palatine aponeurosis, pterygoid hamulus and medial plate of pterygoid process; insertion: lateral wall of pharynx and thyroid cartilage; action: lowers the palate and constricts the isthmus of fauces", "e": "musculus (L. musculus: muscle) + palato- (L. palātum: palate) + pharyngeus (Gk. pharynx/pharyngos: throat) + pharyngo- (Gk. pharynx: throat) + palatinus (L. palatīnus: of the palate)", "p": 126}, {"t": "Cavitas pharyngis", "m": "Pharyngeal cavity — space enclosed by the pharyngeal walls", "e": "cavitas (L. cavitās: hollowness, cavity, from cavus = hollow) + pharyngis (Gk. pharynx/pharyngos: throat, genitive)", "p": 126}, {"t": "Fornix pharyngis", "m": "Pharyngeal fornix — roof of the pharyngeal cavity beneath the sphenoid bone", "e": "fornix (L. fornix: arch, vault) + pharyngis (Gk. pharynx/pharyngos: throat, genitive)", "p": 126}, {"t": "Pars nasalis pharyngis", "m": "Nasopharynx — portion of the pharyngeal cavity located behind the choanae", "e": "pars (L. pars: part, portion) + nasalis (L. nāsālis: of the nose, from nāsus = nose) + pharyngis (Gk. pharynx/pharyngos: throat, genitive)", "p": 126}, {"t": "Tonsilla pharyngealis (adenoidea)", "m": "Nasopharyngeal tonsil (adenoids) — lies at the pharyngeal fornix", "e": "tonsilla (L. tonsilla: tonsil) + pharyngealis (Gk. pharynx/pharyngos: throat + L. -ālis: suffix relating to) + adenoidea (Gk. adēn: gland + eidos: form, resembling)", "p": 126}, {"t": "Fossulae tonsillares", "m": "Tonsillar pits — openings of crypts visible on surface of tonsil", "e": "fossulae (L. fossula: small pit, diminutive of fossa = ditch) + tonsillares (L. tonsillāris: of the tonsil)", "p": 126}, {"t": "Bursa pharyngealis", "m": "Pharyngeal bursa — blind pouch in the roof of the pharynx", "e": "bursa (Gk. byrsa: pouch, bag, purse) + pharyngealis (Gk. pharynx: throat + L. -alis: pertaining to)", "p": 128}, {"t": "Ostium pharyngeum tubae auditivae", "m": "Pharyngeal opening of auditory tube — opening found in the nasopharynx", "e": "ostium (L. ostium: opening, door, mouth) + pharyngeum (Gk. pharynx: throat + L. -eum: pertaining to) + tubae (L. tuba: tube, pipe) + auditivae (L. audire: to hear + -ivus: relating to)", "p": 128}, {"t": "Plica salpingopharyngea", "m": "Salpingopharyngeal fold — mucosal fold overlying the salpingopharyngeal muscle", "e": "plica (L. plica: fold, from plicare: to fold) + salpingopharyngea (Gk. salpinx: trumpet/tube + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "Pars oralis pharyngis", "m": "Oropharynx — portion of the pharyngeal cavity located behind the oral cavity", "e": "pars (L. pars: part, portion) + oralis (L. os/oris: mouth + -alis: pertaining to) + pharyngis (Gk. pharynx: throat, genitive form)", "p": 128}, {"t": "Fossa glossoepiglottica", "m": "Vallecula epiglottica — fossa between the median and lateral glossoepiglottic folds", "e": "fossa (L. fossa: ditch, hollow, pit) + glosso (Gk. glossa: tongue) + epiglottica (Gk. epi: upon + glottis: opening of larynx + L. -ica: pertaining to)", "p": 128}, {"t": "Plica glossoepiglottica mediana", "m": "Median glossoepiglottic fold — unpaired mucosal fold located in the median plane between the base of the tongue and the epiglottis", "e": "plica (L. plica: fold) + glossoepiglottica (Gk. glossa: tongue + epi: upon + glottis: opening of larynx) + mediana (L. medianus: middle, from medius: middle)", "p": 128}, {"t": "Plica glossoepiglottica lateralis", "m": "Lateral glossoepiglottic fold — bilateral mucosal fold between the base of the tongue and the epiglottis", "e": "plica (L. plica: fold) + glossoepiglottica (Gk. glossa: tongue + epi: upon + glottis: opening of larynx) + lateralis (L. lateralis: of the side, from latus: side)", "p": 128}, {"t": "Pars laryngea pharyngis", "m": "Laryngopharynx — portion of the pharyngeal cavity situated behind the larynx", "e": "pars (L. pars: part, portion) + laryngea (Gk. larynx: upper part of windpipe + L. -ea: pertaining to) + pharyngis (Gk. pharynx: throat, genitive form)", "p": 128}, {"t": "Recessus piriformis", "m": "Piriform recess — channel between the aryepiglottic fold and the thyrohyoid membrane or thyroid cartilage", "e": "recessus (L. recessus: recess, withdrawal, from recedere: to recede) + piriformis (L. pirum: pear + forma: shape, thus pear-shaped)", "p": 128}, {"t": "Plica nervi laryngei", "m": "Plica nervi laryngei — mucosal fold in the piriform recess produced by the underlying internal branch of the superior laryngeal nerve and the superior laryngeal artery", "e": "plica (L. plica: fold) + nervi (L. nervus: nerve, sinew, genitive form) + laryngei (Gk. larynx: upper windpipe + L. -ei: genitive, pertaining to)", "p": 128}, {"t": "Fascia pharyngobasilaris", "m": "Pharyngobasilar fascia — membranous wall of the uppermost muscle free portion of the pharynx", "e": "fascia (L. fascia: band, bandage, bundle) + pharyngo (Gk. pharynx: throat) + basilaris (Gk. basis: base + L. -aris: pertaining to)", "p": 128}, {"t": "Tela submucosa", "m": "Submucosa — connective tissue layer between the mucosa and muscularis", "e": "tela (L. tela: web, tissue) + submucosa (L. sub: under + mucosa: from mucus: slime, pertaining to mucus)", "p": 128}, {"t": "Tunica mucosa", "m": "Mucosa — pharyngeal mucous membrane lined by stratified squamous or pseudostratified ciliated columnar epithelium", "e": "tunica (L. tunica: coat, covering, layer) + mucosa (L. mucus: slime + -osa: full of, pertaining to)", "p": 128}, {"t": "Gll. pharyngis", "m": "Pharyngeal glands — small subepithelial mixed salivary glands", "e": "glandulae (L. glandula: small gland, diminutive of glans: acorn) + pharyngis (Gk. pharynx: throat, genitive form)", "p": 128}, {"t": "Tunica muscularis pharyngis", "m": "Muscularis of pharynx — muscular layer of pharyngeal wall", "e": "tunica (L. tunica: coat, covering, layer) + muscularis (L. musculus: muscle + -aris: pertaining to) + pharyngis (Gk. pharynx: throat, genitive form)", "p": 128}, {"t": "Raphe pharyngis", "m": "Pharyngeal raphe — connective tissue band between the right and left pharyngeal muscles, extending posteriorly in the midline", "e": "raphe (Gk. rhaphe: seam, suture, from rhaptein: to sew) + pharyngis (Gk. pharynx: throat, genitive form)", "p": 128}, {"t": "Raphe pterygomandibularis", "m": "Pterygomandibular raphe — tendinous seam between the buccinator muscle and the superior pharyngeal constrictor, extending from pterygoid hamulus to mandible", "e": "raphe (Gk. rhaphe: seam, suture) + pterygomandibularis (Gk. pteryx: wing + L. mandibula: jaw + -aris: pertaining to)", "p": 128}, {"t": "M. constrictor pharyngis superior", "m": "Superior pharyngeal constrictor muscle — uppermost constrictor of the pharynx consisting of four parts", "e": "musculus (L. musculus: muscle) + constrictor (L. constringere: to bind together, constrict) + pharyngis (Gk. pharynx: throat, genitive) + superior (L. superior: upper, higher)", "p": 128}, {"t": "Pars pterygopharyngea", "m": "Pterygopharyngeal part — part of superior pharyngeal constrictor originating from pterygoid process and pterygoid hamulus", "e": "pars (L. pars: part) + pterygopharyngea (Gk. pteryx: wing + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "Pars buccopharyngea", "m": "Buccopharyngeal part — part of superior pharyngeal constrictor originating from pterygomandibular raphe", "e": "pars (L. pars: part) + buccopharyngea (L. bucca: cheek + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "Pars mylopharyngea", "m": "Mylopharyngeal part — part of superior pharyngeal constrictor originating from posterior end of mylohyoid line of mandible", "e": "pars (L. pars: part) + mylopharyngea (Gk. myle: mill, molar + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "Pars glossopharyngea", "m": "Glossopharyngeal part — part of superior pharyngeal constrictor originating from intrinsic muscles of tongue", "e": "pars (L. pars: part) + glossopharyngea (Gk. glossa: tongue + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "M. stylopharyngeus", "m": "Stylopharyngeus — muscle originating from styloid process, between superior and middle pharyngeal constrictors, innervated by glossopharyngeal nerve", "e": "musculus (L. musculus: muscle) + stylo (Gk. stylos: pillar, styloid process) + pharyngeus (Gk. pharynx: throat + L. -eus: pertaining to)", "p": 128}, {"t": "M. salpingopharyngeus", "m": "Salpingopharyngeus — muscle originating from dorsomedial lip of auditory tube cartilage, forming part of longitudinal musculature of pharyngeal wall", "e": "musculus (L. musculus: muscle) + salpingo (Gk. salpinx: trumpet, tube) + pharyngeus (Gk. pharynx: throat + L. -eus: pertaining to)", "p": 128}, {"t": "M. constrictor pharyngis medius", "m": "Middle pharyngeal constrictor muscle — more centrally located pharyngeal constrictor arising from the hyoid bone", "e": "musculus (L. musculus: muscle) + constrictor (L. constringere: to bind, constrict) + pharyngis (Gk. pharynx: throat, genitive) + medius (L. medius: middle)", "p": 128}, {"t": "Pars chondropharyngea", "m": "Chondropharyngeal part — part of middle pharyngeal constrictor originating from lesser horn of hyoid", "e": "pars (L. pars: part) + chondropharyngea (Gk. chondros: cartilage + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "Pars ceratopharyngea", "m": "Ceratopharyngeal part — part of middle pharyngeal constrictor originating from greater horn of hyoid", "e": "pars (L. pars: part) + ceratopharyngea (Gk. keras/ceratos: horn + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "M. constrictor pharyngis inferior", "m": "Inferior pharyngeal constrictor muscle — lowermost constrictor originating from larynx", "e": "musculus (L. musculus: muscle) + constrictor (L. constringere: to bind, constrict) + pharyngis (Gk. pharynx: throat, genitive) + inferior (L. inferior: lower)", "p": 128}, {"t": "Pars thyropharyngea", "m": "Thyropharyngeal part — part of inferior pharyngeal constrictor originating from oblique line of thyroid cartilage", "e": "pars (L. pars: part) + thyropharyngea (Gk. thyreos: shield + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "Pars cricopharyngea", "m": "Cricopharyngeal part — part of inferior pharyngeal constrictor originating from cricoid cartilage", "e": "pars (L. pars: part) + cricopharyngea (Gk. krikos: ring + Gk. pharynx: throat + L. -ea: pertaining to)", "p": 128}, {"t": "Fascia buccopharyngealis", "m": "Buccopharyngeal fascia — continuation of the buccopharyngeal fascia into the loose tissue connecting the pharynx to the deep cervical fascia", "e": "fascia (L. fascia: band, binding) + bucco (L. bucca: cheek) + pharyngealis (Gk. pharynx: throat + L. -alis: pertaining to)", "p": 128}, {"t": "Spatium peripharyngeum", "m": "Peripharyngeal space — connective tissue space associated with the pharynx", "e": "spatium (L. spatium: space, extent) + peri (Gk. peri: around, about) + pharyngeum (Gk. pharynx: throat + L. -eum: pertaining to)", "p": 128}, {"t": "Spatium retropharyngeum", "m": "Retropharyngeal space — portion of the peripharyngeal space between the pharynx and the prevertebral layer of the cervical fascia", "e": "spatium (L. spatium: space) + retro (L. retro: behind, backward) + pharyngeum (Gk. pharynx: throat + L. -eum: pertaining to)", "p": 128}, {"t": "Spatium lateropharyngeum", "m": "Lateropharyngeal space — portion of the peripharyngeal space lateral to the pharynx", "e": "spatium (L. spatium: space) + latero (L. latus: side) + pharyngeum (Gk. pharynx: throat + L. -eum: pertaining to)", "p": 128}, {"t": "Recessus pharyngeus", "m": "Pharyngeal recess — lateral recess of the nasopharyngeal space behind the auditory tube", "e": "recessus (L. recessus: recess, withdrawal, from recedere: to recede) + pharyngeus (Gk. pharynx: throat + L. -eus: pertaining to)", "p": 128}, {"t": "Tonsilla tubaria", "m": "Tubal tonsil — submucosal lymphatic tissue near the opening of the auditory tube", "e": "tonsilla (L. tonsilla: tonsil, almond-shaped mass) + tubaria (L. tuba: tube + -aria: pertaining to)", "p": 128}, {"t": "Tuba auditiva", "m": "Auditory tube (Eustachian tube)", "e": "tuba (L. tuba: tube, trumpet) + auditiva (L. auditivus: of hearing, from audire = to hear)", "p": 129}, {"t": "Musculi pharyngis", "m": "Pharyngeal muscles", "e": "musculi (L. musculus: muscle, little mouse) + pharyngis (Gk. pharynx: throat)", "p": 129}, {"t": "Basis linguae", "m": "Base of tongue", "e": "basis (Gk./L. basis: base, foundation) + linguae (L. lingua: tongue)", "p": 129}, {"t": "Aditus laryngis", "m": "Laryngeal opening", "e": "aditus (L. aditus: entrance, access, from adire = to go toward) + laryngis (Gk. larynx: larynx, upper windpipe)", "p": 129}, {"t": "Canalis alimentarius", "m": "Digestive tract (alimentary canal)", "e": "canalis (L. canālis: channel, canal, from canna = reed, tube) + alimentarius (L. alimentārius: pertaining to nourishment, from alere = to nourish)", "p": 130}, {"t": "Oesophagus", "m": "Esophagus — 23–26 cm long passage extending from below the cricoid cartilage at the level of C6 to the cardiac part of the stomach", "e": "oesophagus (Gk. oisophagos: gullet, from oisein = to carry + phagein = to eat)", "p": 130}, {"t": "Pars cervicalis", "m": "Cervical part — the segment of the esophagus situated in front of the cervical vertebral column (from C6–T1)", "e": "pars (L. pars: part, portion) + cervicalis (L. cervicālis: of the neck, from cervix = neck)", "p": 130}, {"t": "Pars thoracica", "m": "Thoracic part — the portion of the esophagus extending from T1 to the passageway through the diaphragm (about T11)", "e": "pars (L. pars: part, portion) + thoracica (Gk./L. thoracicus: of the thorax/chest, from Gk. thorax = breastplate, chest)", "p": 130}, {"t": "Tunica adventitia", "m": "Tunica adventitia — loose connective tissue investment which binds the esophagus to the surrounding tissues and permits its movement", "e": "tunica (L. tunica: coat, covering, garment) + adventitia (L. adventitius: coming from outside, foreign, from advenire = to come to)", "p": 130}, {"t": "Tunica muscularis", "m": "Tunica muscularis — two layers of muscle, inner circular and outer longitudinal, occupying the esophageal wall and consisting of skeletal muscle in the upper third, smooth muscle in the lower third", "e": "tunica (L. tunica: coat, covering, garment) + muscularis (L. musculāris: of muscle, from musculus = muscle, literally little mouse)", "p": 130}, {"t": "Tendo cricoesophageus", "m": "Cricoesophageal tendon — tendon that attaches the longitudinal muscle fibers of the esophagus to the posterior wall of the cricoid cartilage", "e": "tendo (L. tendo: tendon, from tendere = to stretch) + cricoesophageus (Gk. krikos = ring + Gk. oisophagos = gullet/esophagus)", "p": 130}, {"t": "M. bronchoesophageus", "m": "Bronchoesophageal muscle — smooth muscle fibers from the left main bronchus to the esophagus", "e": "musculus (L. musculus: muscle) + broncho (Gk. bronchos: windpipe, airway) + esophageus (Gk. oisophagos: gullet, esophagus)", "p": 130}, {"t": "M. pleuroesophageus", "m": "Pleuroesophageal muscle — smooth muscle tract between the esophagus and the left mediastinal pleura", "e": "musculus (L. musculus: muscle) + pleuro (Gk. pleura: rib, side, pleural membrane) + esophageus (Gk. oisophagos: gullet, esophagus)", "p": 130}, {"t": "Lamina muscularis mucosae", "m": "Lamina muscularis mucosae — distinct layer of smooth muscle between the submucosa and lamina propria", "e": "lamina (L. lamina: thin plate, layer) + muscularis (L. musculāris: of muscle, from musculus = muscle) + mucosae (L. mucosus: slimy, mucous, genitive form)", "p": 130}, {"t": "Gll. esophageae", "m": "Esophageal glands — discrete mixed glands scattered throughout the submucosa", "e": "glandulae (L. glandula: gland, diminutive of glans = acorn) + esophageae (Gk. oisophagos: gullet, esophagus, adjectival form)", "p": 130}, {"t": "Gaster", "m": "Stomach — extends from the end of the esophagus to the pylorus", "e": "gaster (Gk. gastēr: stomach, belly)", "p": 130}, {"t": "Ventriculus", "m": "Stomach — extends from the end of the esophagus to the pylorus", "e": "ventriculus (L. ventriculus: little belly, stomach, diminutive of venter = belly)", "p": 130}, {"t": "Paries anterior", "m": "Anterior surface of stomach", "e": "paries (L. paries: wall) + anterior (L. anterior: front, former, from ante = before)", "p": 130}, {"t": "Paries posterior", "m": "Posterior surface of stomach", "e": "paries (L. paries: wall) + posterior (L. posterior: behind, later, from post = after)", "p": 130}, {"t": "Curvatura gastrica major", "m": "Greater curvature of stomach — large curvature of the stomach profile directed toward the left and downward", "e": "curvatura (L. curvatura: curvature, bending, from curvare = to bend) + gastrica (Gk. gastēr: stomach, adjectival form) + major (L. maior: greater, larger)", "p": 130}, {"t": "Curvatura ventricularis major", "m": "Greater curvature of stomach — large curvature of the stomach profile directed toward the left and downward", "e": "curvatura (L. curvatura: curvature, bending) + ventricularis (L. ventriculus: little belly, adjectival form) + major (L. maior: greater, larger)", "p": 130}, {"t": "Curvatura gastrica minor", "m": "Lesser curvature of stomach — small curvature of stomach directed toward the right and upward", "e": "curvatura (L. curvatura: curvature, bending) + gastrica (Gk. gastēr: stomach, adjectival form) + minor (L. minor: lesser, smaller)", "p": 130}, {"t": "Curvatura ventricularis minor", "m": "Lesser curvature of stomach — small curvature of stomach directed toward the right and upward", "e": "curvatura (L. curvatura: curvature, bending) + ventricularis (L. ventriculus: little belly, adjectival form) + minor (L. minor: lesser, smaller)", "p": 130}, {"t": "Incisura angularis", "m": "Angular notch — radiographically evident notch at the deepest point of the lesser curvature", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + angularis (L. angularis: of an angle, from angulus = angle, corner)", "p": 130}, {"t": "Pars cardiaca", "m": "Cardiac part of stomach — the portion of the stomach into which the esophagus opens", "e": "pars (L. pars: part, portion) + cardiaca (Gk. kardiakos: of the heart/cardiac orifice, from kardia = heart)", "p": 130}, {"t": "Ostium cardiacum", "m": "Cardiac orifice — opening of the esophagus into the cardiac stomach", "e": "ostium (L. ostium: opening, door, mouth, from os = mouth) + cardiacum (Gk. kardiakos: of the heart/cardiac region, from kardia = heart)", "p": 130}, {"t": "Cardia", "m": "Cardiac orifice — opening of the esophagus into the cardiac stomach", "e": "cardia (Gk. kardia: heart; also used for the cardiac opening of the stomach)", "p": 130}, {"t": "Fundus gastricus", "m": "Fundic stomach — fundus (dome) of the stomach located beneath the diaphragm", "e": "fundus (L. fundus: bottom, base, foundation) + gastricus (Gk. gastēr: stomach, adjectival form)", "p": 130}, {"t": "Fundus ventricularis", "m": "Fundic stomach — fundus (dome) of the stomach located beneath the diaphragm", "e": "fundus (L. fundus: bottom, base, foundation) + ventricularis (L. ventriculus: little belly, adjectival form)", "p": 130}, {"t": "Fornix gastricus", "m": "Fornix of stomach — forms the upper boundary of the lower diaphragm", "e": "fornix (L. fornix: arch, vault) + gastricus (Gk. gastēr: stomach, adjectival form)", "p": 130}, {"t": "Fornix ventricularis", "m": "Fornix of stomach — forms the upper boundary of the lower diaphragm", "e": "fornix (L. fornix: arch, vault) + ventricularis (L. ventriculus: little belly, adjectival form)", "p": 130}, {"t": "Incisura cardiaca", "m": "Cardiac notch — acute angle between the esophagus and the stomach wall", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + cardiaca (Gk. kardiakos: of the cardiac region, from kardia = heart)", "p": 130}, {"t": "Corpus gastricum", "m": "Body of stomach — portion of stomach situated between the cardia/fundus and pylorus", "e": "corpus (L. corpus: body) + gastricum (Gk. gastēr: stomach, adjectival form)", "p": 130}, {"t": "Corpus ventriculare", "m": "Body of stomach — portion of stomach situated between the cardia/fundus and pylorus", "e": "corpus (L. corpus: body) + ventriculare (L. ventriculus: little belly, adjectival form)", "p": 130}, {"t": "Canalis gastricus", "m": "Gastric canal — channel formed by the longitudinal mucosal folds along the lesser curvature of the stomach", "e": "canalis (L. canālis: channel, canal, from canna = reed, tube) + gastricus (Gk. gastēr: stomach, adjectival form)", "p": 130}, {"t": "Canalis ventricularis", "m": "Gastric canal — channel formed by the longitudinal mucosal folds along the lesser curvature of the stomach", "e": "canalis (L. canālis: channel, canal) + ventricularis (L. ventriculus: little belly, adjectival form)", "p": 130}, {"t": "Pars pylorica", "m": "Pyloric part of stomach — distal segment of the stomach beginning with the angular notch and ending with the pylorus", "e": "pars (L. pars: part, portion) + pylorica (Gk. pyloros: gatekeeper, from pyle = gate + ouros = guard, watcher)", "p": 130}, {"t": "Antrum pyloricum", "m": "Pyloric antrum — initial segment of the pyloric stomach beginning at the angular notch", "e": "antrum (Gk./L. antrum: cave, cavity, from Gk. antron = cave) + pyloricum (Gk. pyloros: gatekeeper, from pyle = gate + ouros = guard)", "p": 130}, {"t": "Canalis pyloricus", "m": "Pyloric canal — lower terminal segment of the stomach, about 2–3 cm long", "e": "canalis (L. canālis: channel, canal, from canna = reed, tube) + pyloricus (Gk. pyloros: gatekeeper, from pyle = gate + ouros = guard)", "p": 130}, {"t": "Ostium pyloricum", "m": "Pyloric opening — lumen of the pylorus connecting the stomach with the duodenum", "e": "ostium (L. ostium: opening, door, entrance) + pyloricum (Gk. pylōrikos: of the gatekeeper, from pylōros = gatekeeper, from pylē = gate + ouros = guard)", "p": 132}, {"t": "Tunica serosa", "m": "Serous membrane — serous, peritoneal covering containing simple squamous epithelium (stomach)", "e": "tunica (L. tunica: coat, covering, layer) + serosa (L. serosus: watery, from serum = whey, fluid)", "p": 132}, {"t": "Tela subserosa", "m": "Connective tissue component of the serosa underlying the epithelium (stomach)", "e": "tela (L. tela: web, tissue) + sub (L. sub: under, beneath) + serosa (L. serosus: watery, from serum = whey, fluid)", "p": 132}, {"t": "Stratum longitudinale", "m": "Longitudinal layer — external layer of longitudinal muscle fibers situated primarily along the greater and lesser curvatures", "e": "stratum (L. stratum: layer, from sternere = to spread, lay down) + longitudinale (L. longitudinalis: lengthwise, from longitudo = length, from longus = long)", "p": 132}, {"t": "Stratum circulare", "m": "Circular layer — middle layer of circular muscle (stomach)", "e": "stratum (L. stratum: layer, from sternere = to spread, lay down) + circulare (L. circularis: circular, from circulus = circle)", "p": 132}, {"t": "M. sphincter pyloricus", "m": "Pyloric sphincter — thick layer of circular muscle around the pylorus", "e": "musculus (L. musculus: muscle) + sphincter (Gk. sphinktēr: that which binds tight, from sphingein = to squeeze) + pyloricus (Gk. pylōrikos: of the gatekeeper, from pylōros = gatekeeper)", "p": 132}, {"t": "Fibrae obliquae", "m": "Oblique fibers — inner layer of obliquely coursing fibers of the tunica muscularis", "e": "fibrae (L. fibra: fiber, thread; pl. fibrae) + obliquae (L. obliquus: oblique, slanting, indirect)", "p": 132}, {"t": "Plicae gastricae", "m": "Gastric folds — mucosal folds extending primarily in a longitudinal direction", "e": "plicae (L. plica: fold, from plicare = to fold; pl. plicae) + gastricae (Gk. gastrikos: of the stomach, from gastēr = stomach)", "p": 132}, {"t": "Areae gastricae", "m": "Gastric (mamillated) areas — mamillated areas on the mucosal surface bounded by shallow grooves with diameter of 1–6 mm", "e": "areae (L. area: open space, area; pl. areae) + gastricae (Gk. gastrikos: of the stomach, from gastēr = stomach)", "p": 132}, {"t": "Plicae villosae", "m": "Villous folds — epithelial ridges invisible to the naked eye between the openings of glands", "e": "plicae (L. plica: fold, from plicare = to fold; pl. plicae) + villosae (L. villosus: shaggy, hairy, from villus = shaggy hair, tuft)", "p": 132}, {"t": "Foveolae gastricae", "m": "Gastric pits (foveolae) — openings of the gastric glands between the villous folds", "e": "foveolae (L. foveola: small pit, diminutive of fovea = pit, depression; pl. foveolae) + gastricae (Gk. gastrikos: of the stomach, from gastēr = stomach)", "p": 132}, {"t": "Glandula gastrica propria", "m": "Gastric glands proper — tubular glands in the fundus and body of the stomach made up of 4 cell types", "e": "glandula (L. glandula: small gland, diminutive of glans = acorn) + gastrica (Gk. gastrikos: of the stomach, from gastēr = stomach) + propria (L. proprius: own, proper, characteristic)", "p": 132}, {"t": "Glandula pylorica", "m": "Pyloric glands — mucoid glands in the pyloric part of the stomach consisting of two cell types", "e": "glandula (L. glandula: small gland, diminutive of glans = acorn) + pylorica (Gk. pylōrikos: of the gatekeeper, from pylōros = gatekeeper, from pylē = gate + ouros = guard)", "p": 132}, {"t": "Folliculi lymphatici gastrici", "m": "Lymphatic nodules (follicles) — small aggregations of lymphatic tissue in the lamina propria (stomach)", "e": "folliculi (L. folliculus: small bag, sac, diminutive of follis = bellows, bag; pl. folliculi) + lymphatici (L. lymphaticus: of lymph, from lympha = clear water) + gastrici (Gk. gastrikos: of the stomach, from gastēr = stomach)", "p": 132}, {"t": "Intestinum tenue", "m": "Small intestine — comprises the duodenum, jejunum and ileum", "e": "intestinum (L. intestinum: intestine, from intus = within) + tenue (L. tenuis: thin, slender, fine)", "p": 132}, {"t": "Tela sumucosa", "m": "Displaceable layer between the muscularis mucosae and the muscularis consisting primarily of collagenous connective tissue bearing blood vessels and nerves (small intestine)", "e": "tela (L. tela: web, tissue) + sub (L. sub: under, beneath) + mucosa (L. mucosus: mucous, slimy, from mucus = slime)", "p": 132}, {"t": "Plicae circulares", "m": "Circular folds [Valves of Kerckring] — permanent folds of mucosa and submucosa spanning nearly 2/3 of the intestinal lumen and projecting up to 8 mm high, perpendicular to the intestinal axis", "e": "plicae (L. plica: fold, from plicare = to fold; pl. plicae) + circulares (L. circularis: circular, from circulus = circle)", "p": 132}, {"t": "Villi intestinales", "m": "Intestinal villi — fingerlike projections about 0.5–1.5 mm in length", "e": "villi (L. villus: shaggy hair, tuft, projection; pl. villi) + intestinales (L. intestinalis: of the intestine, from intestinum = intestine)", "p": 132}, {"t": "Gll. intestinales", "m": "Intestinal glands — cryptlike glands", "e": "glandulae (L. glandula: small gland, diminutive of glans = acorn; abbreviated Gll.) + intestinales (L. intestinalis: of the intestine, from intestinum = intestine, from intus = within)", "p": 132}, {"t": "Folliculi lymphatici solitarii", "m": "Solitary lymphatic follicles — solitary lymphatic nodules in the lamina propria", "e": "folliculi (L. folliculus: small bag, sac, diminutive of follis = bellows; pl. folliculi) + lymphatici (L. lymphaticus: of lymph, from lympha = clear water) + solitarii (L. solitarius: alone, solitary, from solus = alone)", "p": 132}, {"t": "Folliculi lymphatici aggregati", "m": "Aggregated lymphatic follicles [Peyer's patches] — aggregation of several lymphatic nodules in the ileum", "e": "folliculi (L. folliculus: small bag, sac, diminutive of follis = bellows; pl. folliculi) + lymphatici (L. lymphaticus: of lymph, from lympha = clear water) + aggregati (L. aggregatus: gathered together, from ad = to + gregare = to collect, from grex = flock)", "p": 132}, {"t": "Duodenum", "m": "Initial segment of the small intestine, about 25–30 mm long, between the pylorus and the duodenojejunal flexure", "e": "duodenum (L. duodēnum: of twelve, from duodecim = twelve, referring to its length of approximately twelve finger-breadths)", "p": 134}, {"t": "Pars superior", "m": "Superior part. Horizontal beginning part of the duodenum", "e": "pars (L. pars: part, portion) + superior (L. superior: upper, higher, comparative of superus)", "p": 134}, {"t": "Ampulla bulbus duodeni", "m": "Functional dilatation at the beginning of the duodenum", "e": "ampulla (L. ampulla: a flask, rounded vessel) + bulbus (L. bulbus, from Gk. bolbos: bulb, rounded swelling) + duodeni (L. genitive of duodenum: of the twelve-fingered gut)", "p": 134}, {"t": "Pars descendens", "m": "Descending part. Lateral, vertical segment", "e": "pars (L. pars: part, portion) + descendens (L. dēscendēns: descending, from dē = down + scandere = to climb)", "p": 134}, {"t": "Pars horizontalis", "m": "Horizontal (inferior) part. Horizontal segment below the head of the pancreas", "e": "pars (L. pars: part, portion) + horizontalis (L. horizontālis: horizontal, from Gk. horizōn = bounding circle, horizon)", "p": 134}, {"t": "Pars ascendens", "m": "Ascending part. Segment of duodenum lying to the left of the head of the pancreas and ascending up to the duodenojejunal flexure", "e": "pars (L. pars: part, portion) + ascendens (L. ascendēns: ascending, from ad = to + scandere = to climb)", "p": 134}, {"t": "Flexura duodeni superior", "m": "Superior duodenal flexure. Flexure between the superior and horizontal parts of the duodenum medial to the gallbladder", "e": "flexura (L. flexūra: a bending, from flectere = to bend) + duodeni (L. genitive of duodenum) + superior (L. superior: upper, higher)", "p": 134}, {"t": "Flexura duodeni inferior", "m": "Inferior duodenal flexure. Flexure between the descending and horizontal parts of the duodenum", "e": "flexura (L. flexūra: a bending, from flectere = to bend) + duodeni (L. genitive of duodenum) + inferior (L. inferior: lower, comparative of inferus)", "p": 134}, {"t": "Flexura duodenojejunalis", "m": "Duodenojejunal flexure. Flexure between the duodenum and jejunum", "e": "flexura (L. flexūra: a bending, from flectere = to bend) + duodeno (L. from duodenum) + jejunalis (L. from jejunum: empty, fasting gut, from jejunus = empty, hungry)", "p": 134}, {"t": "Musculus suspensorius duodeni", "m": "Suspensory muscle of duodenum. Bundle of smooth muscle which attaches the duodenojejunal flexure to the diaphragm or to the celiac trunk", "e": "musculus (L. musculus: muscle, little mouse) + suspensorius (L. suspensōrius: suspending, from suspendere = to hang up) + duodeni (L. genitive of duodenum)", "p": 134}, {"t": "Plicae longitudinales duodeni", "m": "Longitudinal folds of duodenum. Longitudinal mucosal folds on the left side of the posterior wall of the descending part of the duodenum produced by the pancreatic and bile ducts", "e": "plicae (L. plicae: folds, from plicare = to fold) + longitudinales (L. longitudināles: longitudinal, from longitudo = length, from longus = long) + duodeni (L. genitive of duodenum)", "p": 134}, {"t": "Papilla duodeni major", "m": "Greater duodenal papilla. Elevation at the end of the longitudinal fold at the openings of the common bile duct and pancreatic duct", "e": "papilla (L. papilla: nipple, teat, small elevation) + duodeni (L. genitive of duodenum) + major (L. major: greater, larger, comparative of magnus)", "p": 134}, {"t": "Papilla duodeni minor", "m": "Lesser duodenal papilla. Elevation located superior to the greater duodenal papilla, usually at the opening of the accessory pancreatic duct", "e": "papilla (L. papilla: nipple, teat, small elevation) + duodeni (L. genitive of duodenum) + minor (L. minor: lesser, smaller, comparative of parvus)", "p": 134}, {"t": "Glandulae duodenales", "m": "Duodenal glands (Brunner's glands). Mucous glands located predominantly in the submucosa of the duodenum", "e": "glandulae (L. glandulae: small glands, from glans = acorn, gland) + duodenales (L. duodenāles: of the duodenum, from duodenum)", "p": 134}, {"t": "Jejunum", "m": "Middle segment of the small intestine. It extends about 2.5 meters from the duodenojejunal flexure", "e": "jejunum (L. jejūnum: empty gut, from jejunus = empty, fasting, hungry)", "p": 134}, {"t": "Ileum", "m": "Terminal segment of small intestine, about 3.5 mm long", "e": "ileum (L. ileum, from Gk. eilein = to roll, twist; referring to the coiled nature)", "p": 134}, {"t": "Intestinum crassum", "m": "Large intestine. About 1.5–1.8 m long; it extends from the cecum to the anus and consists of tenia, haustra and appendices epiploicae", "e": "intestinum (L. intestīnum: intestine, from intus = within) + crassum (L. crassum: thick, coarse, from crassus = thick)", "p": 134}, {"t": "Caecum", "m": "Initial portion of the large intestine, ca. 7 cm long, located below the opening of the ileum", "e": "caecum (L. caecum: blind, from caecus = blind; referring to the blind-ended pouch)", "p": 134}, {"t": "Valva ileocaecalis", "m": "Ileocecal valve. Two-lipped valve at the entrance of the ileum into the large intestine", "e": "valva (L. valva: leaf of a door, valve, from volvere = to turn) + ileocaecalis (L. ileo- from ileum + caecalis from caecum = blind gut)", "p": 134}, {"t": "Valva ilealis", "m": "Ileocecal valve (alternative name)", "e": "valva (L. valva: leaf of a door, valve) + ilealis (L. ileālis: of the ileum, from ileum)", "p": 134}, {"t": "Papilla ilealis", "m": "Papilla ilealis", "e": "papilla (L. papilla: nipple, small projection) + ilealis (L. ileālis: of the ileum, from ileum)", "p": 134}, {"t": "Ostium valvae ilealis", "m": "Opening of ileocecal valve. Transverse, slitlike aperture of ileum at entrance into the large intestine in the cadaver", "e": "ostium (L. ostium: opening, door, mouth, from os = mouth) + valvae (L. genitive of valva: of the valve) + ilealis (L. ileālis: of the ileum)", "p": 134}, {"t": "Frenulum valvae ilealis", "m": "Fold formed by the union of the lips of the ileocecal valve", "e": "frenulum (L. frenulum: little bridle, from frenum = bridle, rein) + valvae (L. genitive of valva: of the valve) + ilealis (L. ileālis: of the ileum)", "p": 134}, {"t": "Ostium papillae ilealis", "m": "Ostium papillae ilealis", "e": "ostium (L. ostium: opening, mouth) + papillae (L. genitive of papilla: of the nipple) + ilealis (L. ileālis: of the ileum)", "p": 134}, {"t": "Appendix vermiformis", "m": "Vermiform appendix. Appendage of the cecum, usually 9 cm long, with abundant lymphatic tissue", "e": "appendix (L. appendix: appendage, addition, from appendere = to hang upon) + vermiformis (L. vermifōrmis: worm-shaped, from vermis = worm + forma = shape)", "p": 134}, {"t": "Ostium appendicis vermiformis", "m": "Opening of vermiform appendix into the cecum", "e": "ostium (L. ostium: opening, mouth) + appendicis (L. genitive of appendix: of the appendage) + vermiformis (L. vermifōrmis: worm-shaped, from vermis = worm + forma = shape)", "p": 134}, {"t": "Folliculi lymphatici aggregati appendicis vermiformis", "m": "Aggregated lymphatic nodules of vermiform appendix. Lymphatic tissue within the wall of the appendix", "e": "folliculi (L. folliculi: small sacs, from folliculus = little bag) + lymphatici (L. lymphātici: of lymph, from lympha = water, clear fluid) + aggregati (L. aggregāti: aggregated, from aggregare = to add to a flock) + appendicis (L. genitive of appendix) + vermiformis (L. worm-shaped)", "p": 134}, {"t": "Colon", "m": "Portion of large intestine extending from the ileocecal valve to the rectum", "e": "colon (L. colon, from Gk. kolon: the large intestine, member, limb)", "p": 134}, {"t": "Colon ascendens", "m": "Ascending colon. Segment of large intestine ascending retroperitoneally on the right side", "e": "colon (L./Gk. kolon: large intestine) + ascendens (L. ascendēns: ascending, from ad = to + scandere = to climb)", "p": 134}, {"t": "Flexura coli dextra", "m": "Right colic flexure. Flexure between the ascending and transverse colon", "e": "flexura (L. flexūra: a bending, from flectere = to bend) + coli (L. genitive of colon) + dextra (L. dextra: right, from dexter = right-hand)", "p": 134}, {"t": "Colon transversum", "m": "Transverse colon. Transverse segment of large intestine situated intraperitoneally between the right and left colic flexures", "e": "colon (L./Gk. kolon: large intestine) + transversum (L. transversum: transverse, lying across, from trans = across + vertere = to turn)", "p": 134}, {"t": "Flexura coli sinistra", "m": "Left colic flexure. Flexure between the transverse and descending colon below the left subphrenic space", "e": "flexura (L. flexūra: a bending, from flectere = to bend) + coli (L. genitive of colon) + sinistra (L. sinistra: left, from sinister = left)", "p": 134}, {"t": "Colon descendens", "m": "Descending colon. Segment of large intestine extending retroperitoneally on the left side between the left colic flexure and sigmoid colon", "e": "colon (L./Gk. kolon: large intestine) + descendens (L. dēscendēns: descending, from dē = down + scandere = to climb)", "p": 134}, {"t": "Colon sigmoideum", "m": "Sigmoid colon. Portion of colon lying intraperitoneally between the descending colon and the rectum", "e": "colon (L./Gk. kolon: large intestine) + sigmoideum (L./Gk. sigmoeidēs: sigma-shaped, from sigma = Greek letter S + eidos = form, shape)", "p": 134}, {"t": "Plicae semilunares coli", "m": "Semilunar folds of colon. Crescentic contraction folds between two haustra comprising all layers of the intestinal wall", "e": "plicae (L. plicae: folds, from plicare = to fold) + semilunares (L. sēmilūnāres: half-moon shaped, from semi = half + luna = moon) + coli (L. genitive of colon)", "p": 134}, {"t": "Haustra coli", "m": "Haustra (sacculationes) coli. Outpocketings between two semilunar folds", "e": "haustra (L. haustra: drawers, buckets on a waterwheel, from haurire = to draw water; referring to the sacculations) + coli (L. genitive of colon)", "p": 134}, {"t": "Sacculationes coli", "m": "Haustra (sacculationes) coli. Outpocketings between two semilunar folds", "e": "sacculationes (L. sacculātiōnes: little sac formations, from sacculus = small sac, from saccus = bag) + coli (L. genitive of colon)", "p": 134}, {"t": "Appendices epiploicae", "m": "Appendices epiploicae (omentales). Serosa-covered appendages containing adipose tissue, located on the free and omental tenia", "e": "appendices (L. appendices: appendages, from appendere = to hang upon) + epiploicae (L./Gk. epiploikē: of the omentum, from Gk. epiploon = omentum, from epi = upon + plein = to float)", "p": 134}, {"t": "Appendices omentales", "m": "Alternative name for appendices epiploicae. Serosa-covered appendages containing adipose tissue", "e": "appendices (L. appendices: appendages, from appendere = to hang upon) + omentales (L. omentāles: of the omentum, from omentum = fat skin, caul)", "p": 134}, {"t": "Taeniae coli", "m": "About 1 cm wide, thickened bands of longitudinal muscle fibers", "e": "taeniae (L. taenia, from Gk. tainia: band, ribbon, tape) + coli (L. colon, from Gk. kōlon: large intestine, genitive = of the colon)", "p": 136}, {"t": "Taenia mesocolica", "m": "Tenia located at the attachment of the mesocolon in the posteromedial part of the ascending and descending colon", "e": "taenia (L. taenia, from Gk. tainia: band, ribbon) + mesocolica (Gk. mesos: middle + Gk. kōlon: colon; adjectival = of the mesocolon)", "p": 136}, {"t": "Taenia omentalis", "m": "Tenia of transverse colon located at the attachment of the greater omentum in the posteromedial part of the ascending and descending colon", "e": "taenia (L. taenia, from Gk. tainia: band, ribbon) + omentalis (L. omentum: fatty membrane/apron of the gut + -alis: adjectival suffix = of the omentum)", "p": 136}, {"t": "Taenia libera", "m": "Free tenia located between the tenia mesocolica and tenia omentalis", "e": "taenia (L. taenia, from Gk. tainia: band, ribbon) + libera (L. liber: free)", "p": 136}, {"t": "Glandulae intestinales", "m": "Intestinal glands — tubular glands of the colonic mucosa", "e": "glandulae (L. glandula: small gland, diminutive of glans = acorn) + intestinales (L. intestīnālis: of the intestine, from intestīnum = intestine, from intus = within)", "p": 136}, {"t": "Nodi lymphatici solitarii", "m": "Solitary lymphatic nodules — individual lymphatic nodules dispersed throughout the lamina propria", "e": "nodi (L. nodus: node, knot, plural = nodi) + lymphatici (L. lymphaticus: of lymph, from lympha = clear water) + solitarii (L. solitārius: solitary, alone, from solus = alone)", "p": 136}, {"t": "Flexura sacralis", "m": "Sacral flexure — anteriorly concave bend in the rectum that conforms with the sacrum", "e": "flexura (L. flexūra: a bending, from flectere = to bend) + sacralis (L. sacrālis: of the sacrum, from sacrum = sacred bone)", "p": 136}, {"t": "Flexura perinealis", "m": "Perineal flexure — anteriorly convex bend in the rectum located just above the anus", "e": "flexura (L. flexūra: a bending, from flectere = to bend) + perinealis (L./Gk. perineālis: of the perineum, from Gk. perinaion = perineum, from peri = around + inaō = to evacuate)", "p": 136}, {"t": "Ampulla recti", "m": "Dilated portion of the rectum above the anal canal", "e": "ampulla (L. ampulla: flask, dilated vessel) + recti (L. rectum: straight intestine, from rectus = straight, genitive = of the rectum)", "p": 136}, {"t": "M. sphincter ani internus", "m": "Internal anal sphincter — thickened muscular ring of the circular layer at the anus, ca. 1–2 cm in height", "e": "m. (abbreviation of musculus, L. musculus: muscle, little mouse) + sphincter (Gk. sphinktēr: that which binds tight, from sphingein = to squeeze) + ani (L. anus: ring, anus, genitive = of the anus) + internus (L. internus: internal, from inter = within)", "p": 136}, {"t": "M. rectococcygeus", "m": "Thin plate of smooth muscle extending from the 2nd to 3rd coccygeal vertebrae to the rectum", "e": "m. (L. musculus: muscle) + recto- (L. rectum: straight intestine) + coccygeus (Gk. kokkyx: cuckoo, coccyx [tailbone], adjectival = of the coccyx)", "p": 136}, {"t": "M. rectourethralis", "m": "Smooth muscle fibers extending from the membranous part of the urethra to the rectum", "e": "m. (L. musculus: muscle) + recto- (L. rectum: straight intestine) + urethralis (Gk. ourēthra: urethra, from ourein = to urinate, adjectival = of the urethra)", "p": 136}, {"t": "Plicae transversae recti", "m": "Transverse rectal folds — usually three lateral transverse folds; the middle is the largest (Kohlrausch) and projects about 6 mm above the anus from the right side, the others from the left", "e": "plicae (L. plica: fold, from plicare = to fold) + transversae (L. transversus: lying across, from trans = across + vertere = to turn) + recti (L. rectum: straight intestine, genitive = of the rectum)", "p": 136}, {"t": "Canalis analis", "m": "Anal canal — terminal segment of the digestive tube beginning with the anal columns", "e": "canalis (L. canālis: channel, canal, from canna = reed, tube) + analis (L. ānālis: of the anus, from anus = ring, anus)", "p": 136}, {"t": "Columnae anales", "m": "Anal columns — six to ten longitudinal folds provided with abundant venous plexuses", "e": "columnae (L. columna: column, pillar, plural = columnae) + anales (L. ānālis: of the anus, from anus = ring, anus)", "p": 136}, {"t": "Sinus anales", "m": "Anal sinuses — recesses between the anal columns", "e": "sinus (L. sinus: curve, hollow, bay, recess) + anales (L. ānālis: of the anus, from anus = ring, anus)", "p": 136}, {"t": "Valvulae anales", "m": "Anal valves — small transverse folds bordering the anal sinuses distally", "e": "valvulae (L. valvula: small valve, diminutive of valva = leaf of a door, valve) + anales (L. ānālis: of the anus, from anus = ring, anus)", "p": 136}, {"t": "Linea anorectalis", "m": "Anorectal line — upper border of anal canal formed by the puborectal muscle at the level of the levator sling just above the anal columns", "e": "linea (L. linea: line, from linum = thread) + ano- (L. anus: ring, anus) + rectalis (L. rectus: straight, from rectum = straight intestine, adjectival = of the rectum)", "p": 136}, {"t": "Pecten analis", "m": "Anal pecten — a lighter stripe between the anal valves and the anocutaneous line; firmly connected with the underlying tissues by fibrous longitudinal muscles", "e": "pecten (L. pecten: comb, from pectere = to comb; here used for a comb-like stripe) + analis (L. ānālis: of the anus, from anus = ring, anus)", "p": 136}, {"t": "Linea anocutanea", "m": "Anocutaneous line — lower border of anal pecten at the level of the lower margin of the internal anal sphincter", "e": "linea (L. linea: line) + ano- (L. anus: ring, anus) + cutanea (L. cutāneus: of the skin, from cutis = skin)", "p": 136}, {"t": "M. sphincter ani externus", "m": "External anal sphincter — circular layer of skeletal muscle lying on the internal anal sphincter", "e": "m. (L. musculus: muscle) + sphincter (Gk. sphinktēr: that which binds tight, from sphingein = to squeeze) + ani (L. anus: ring, anus, genitive = of the anus) + externus (L. externus: external, from exter = outside)", "p": 136}, {"t": "Caput pancreatis", "m": "Head of pancreas — nestled within the loop of the duodenum", "e": "caput (L. caput: head) + pancreatis (Gk. pankreas, gen. pankreatos: pancreas, from pan = all + kreas = flesh)", "p": 138}, {"t": "Incisura pancreatis", "m": "Pancreatic notch — groove between the uncinate process and the remaining part of the head of the pancreas", "e": "incisura (L. incisūra: notch, incision, from incidere = to cut into) + pancreatis (Gk. pankreas, gen. pankreatos: pancreas, from pan = all + kreas = flesh)", "p": 138}, {"t": "Corpus pancreatis", "m": "Body of pancreas — part of the pancreas lying mainly in front of the vertebral column", "e": "corpus (L. corpus: body) + pancreatis (Gk. pankreas, gen. pankreatos: pancreas, from pan = all + kreas = flesh)", "p": 138}, {"t": "Facies inferior", "m": "Inferior surface — anteroinferiorly directed inferior surface of the pancreas", "e": "facies (L. faciēs: face, surface) + inferior (L. inferior: lower)", "p": 138}, {"t": "Margo inferioris", "m": "Inferior margin — inferior margin of the pancreas situated between the lower anterior and posterior surfaces", "e": "margo (L. margō: edge, margin, border) + inferioris (L. inferior, gen. inferioris: lower)", "p": 138}, {"t": "Tuber omentale", "m": "Tuber omentale — prominence on the body of pancreas near the head projecting into the omental bursa", "e": "tuber (L. tuber: swelling, bump, knob) + omentale (L. omentālis: of the omentum, from omentum = fat skin/membrane covering the intestines)", "p": 138}, {"t": "Cauda pancreatis", "m": "Tail of pancreas — upper left tail of the pancreas that lies in contact with the spleen", "e": "cauda (L. cauda: tail) + pancreatis (Gk. pankreas, gen. pankreatos: pancreas, from pan = all + kreas = flesh)", "p": 138}, {"t": "Capsula pancreatis", "m": "Capsule of pancreas", "e": "capsula (L. capsula: small box, capsule, diminutive of capsa = box, case) + pancreatis (Gk. pankreas, gen. pankreatos: pancreas, from pan = all + kreas = flesh)", "p": 138}, {"t": "Pars exocrina pancreatis", "m": "Exocrine pancreas — the bulk of the pancreas where pancreatic juice is produced", "e": "pars (L. pars: part, portion) + exocrina (Gk. exō = outside + krinein = to separate, secrete) + pancreatis (Gk. pankreas, gen. pankreatos: pancreas, from pan = all + kreas = flesh)", "p": 138}, {"t": "Lobulus pancreaticus", "m": "Pancreatic lobule — the macroscopically visible lobule of the pancreas", "e": "lobulus (L. lobulus: small lobe, diminutive of lobus = lobe) + pancreaticus (Gk. pankreatikos: of the pancreas, from pankreas = pancreas)", "p": 138}, {"t": "Ductus pancreaticus", "m": "Pancreatic duct — main excretory duct of the pancreas opening on the greater duodenal papilla together with the bile duct", "e": "ductus (L. ductus: duct, channel, from ducere = to lead) + pancreaticus (Gk. pankreatikos: of the pancreas, from pankreas = pancreas)", "p": 138}, {"t": "M. sphincter ductus pancreatici", "m": "Sphincter muscle of pancreatic duct — circular muscle before the duct opening", "e": "musculus (L. musculus: muscle, little mouse) + sphincter (Gk. sphinktēr: that which binds tight, from sphingein = to bind tight) + ductus (L. ductus: duct, channel, from ducere = to lead) + pancreatici (Gk. pankreatikos, gen.: of the pancreas)", "p": 138}, {"t": "Ductus pancreaticus accessorius", "m": "Accessory pancreatic duct — additional excretory duct usually found draining into the minor duodenal papilla above the major duodenal papilla", "e": "ductus (L. ductus: duct, channel, from ducere = to lead) + pancreaticus (Gk. pankreatikos: of the pancreas) + accessorius (L. accessōrius: additional, supplementary, from accedere = to come near, to add to)", "p": 138}, {"t": "Pancreas accessorium", "m": "Accessory pancreas — pancreatic tissue dispersed within the wall of the stomach or duodenum", "e": "pancreas (Gk. pankreas: pancreas, from pan = all + kreas = flesh) + accessorium (L. accessōrius: additional, supplementary, from accedere = to come near, to add to)", "p": 138}, {"t": "Pars endocrina pancreatis", "m": "Endocrine pancreas — part of the pancreas consisting of about 1 million Langerhans' islets, which produce glucagon and insulin", "e": "pars (L. pars: part, portion) + endocrina (Gk. endon = within + krinein = to separate, secrete) + pancreatis (Gk. pankreas, gen. pankreatos: pancreas, from pan = all + kreas = flesh)", "p": 138}, {"t": "Hepar", "m": "Liver — divided into segments on the basis of branchings of its blood vessels and biliary ducts", "e": "hepar (Gk. hēpar: liver)", "p": 138}, {"t": "Facies diaphragmatica", "m": "Diaphragmatic surface — surface of liver facing the diaphragm", "e": "facies (L. faciēs: face, surface) + diaphragmatica (Gk. diaphragma: partition, midriff, from dia = through + phrassein = to fence)", "p": 138}, {"t": "Impressio cardiaca", "m": "Cardiac impression — flat impression made by the heart on the left side of the liver in front of the inferior vena cava", "e": "impressio (L. impressiō: impression, from imprimere = to press into) + cardiaca (Gk. kardiakos: of the heart, from kardia = heart)", "p": 138}, {"t": "Pars anterior", "m": "Anterior part — the anteriorly directed portion of the diaphragmatic liver surface", "e": "pars (L. pars: part, portion) + anterior (L. anterior: front, former, from ante = before)", "p": 138}, {"t": "Pars dextra", "m": "Right part — portion of the diaphragmatic surface directed toward the right side of the body", "e": "pars (L. pars: part, portion) + dextra (L. dexter: right, on the right side)", "p": 138}, {"t": "Pars posterior", "m": "Posterior part — the posteriorly directed portion of the diaphragmatic surface", "e": "pars (L. pars: part, portion) + posterior (L. posterior: behind, later, from post = after)", "p": 138}, {"t": "Area nuda", "m": "Bare area — portion of the diaphragmatic surface not covered by peritoneum", "e": "area (L. area: open space, area) + nuda (L. nudus: bare, naked, uncovered)", "p": 138}, {"t": "Pars affixa", "m": "Bare area (alternative term) — portion of the diaphragmatic surface not covered by peritoneum", "e": "pars (L. pars: part, portion) + affixa (L. affixus: attached, fixed to, from affigere = to fasten to)", "p": 138}, {"t": "Sulcus venae cavae", "m": "Groove for vena cava — deep groove for reception of the inferior vena cava", "e": "sulcus (L. sulcus: furrow, groove) + venae (L. vena, gen. venae: vein) + cavae (L. cavus, gen. cavae: hollow)", "p": 138}, {"t": "Fissura ligamenti venosi", "m": "Fissure for lig. venosum — groove for the venous ligament extending from the liver hilum to the inferior vena cava between the caudate lobe and left lobe", "e": "fissura (L. fissūra: cleft, fissure, from findere = to split) + ligamenti (L. ligamentum, gen. ligamenti: ligament, band, from ligare = to bind) + venosi (L. venosus, gen. venosi: venous, full of veins, from vena = vein)", "p": 138}, {"t": "Facies visceralis", "m": "Visceral surface — posteroinferior, partially concave surface of liver facing the viscera", "e": "facies (L. faciēs: face, surface) + visceralis (L. viscerālis: of the viscera, from viscera = internal organs)", "p": 140}, {"t": "Fossa vesicae biliaris", "m": "Fossa of gallbladder — fossa on the visceral surface of the liver that lodges the gallbladder", "e": "fossa (L. fossa: pit, trench, from fodere = to dig) + vesicae (L. vesīca: bladder, sac) + biliaris (L. biliāris: of bile, from bilis = bile)", "p": 140}, {"t": "Fissura ligamenti teretis", "m": "Fissure for round ligament — fissure on the visceral surface of the liver that lodges the ligamentum teres hepatis", "e": "fissura (L. fissūra: cleft, crack, from findere = to split) + ligamenti (L. ligāmentum: ligament, band, from ligāre = to bind) + teretis (L. teres: round, cylindrical)", "p": 140}, {"t": "Lig. teres hepatis", "m": "Round ligament of liver — connective tissue remains of the umbilical vein", "e": "lig. (L. ligāmentum: ligament, band) + teres (L. teres: round, cylindrical) + hepatis (Gk. hēpar/hēpatos: liver)", "p": 140}, {"t": "Ligamentum venosum", "m": "Ligamentum venosum — venous ligament of liver, the fibrous remains of the ductus venosus", "e": "ligamentum (L. ligāmentum: ligament, band, from ligāre = to bind) + venosum (L. venōsus: of a vein, from vena = vein)", "p": 140}, {"t": "Porta hepatis", "m": "Hilum of liver — fissure between the caudate and quadrate lobes in which run the hepatic artery proper, portal vein and hepatic duct", "e": "porta (L. porta: gate, entrance) + hepatis (Gk. hēpar/hēpatos: liver)", "p": 140}, {"t": "Impressio oesophagea", "m": "Esophageal impression — groove on the left lobe where the liver is indented by the esophagus", "e": "impressio (L. impressiō: impression, indentation, from imprimere = to press into) + oesophagea (Gk. oisophagos: esophagus, from oisein = to carry + phagein = to eat)", "p": 140}, {"t": "Impressio gastrica", "m": "Gastric impression — impression caused by contact of the stomach with the visceral surface of the left lobe of the liver", "e": "impressio (L. impressiō: impression, indentation) + gastrica (Gk. gastrikos: of the stomach, from gastēr = stomach)", "p": 140}, {"t": "Impressio duodenalis", "m": "Duodenal impression — impression caused by contact of the duodenum with the right side of the visceral surface of the liver next to the neck of the gallbladder", "e": "impressio (L. impressiō: impression, indentation) + duodenalis (L. duodēnālis: of the duodenum, from duodeni = twelve each, referring to its length of twelve finger-breadths)", "p": 140}, {"t": "Impressio colica", "m": "Colic impression — impression caused by contact of the colon with the visceral surface of the right lobe of liver to the right of the gallbladder", "e": "impressio (L. impressiō: impression, indentation) + colica (Gk. kolikos: of the colon, from kolon = large intestine)", "p": 140}, {"t": "Impressio renalis", "m": "Renal impression — impression caused by contact of the right kidney with the visceral surface of the right lobe", "e": "impressio (L. impressiō: impression, indentation) + renalis (L. renālis: of the kidney, from ren = kidney)", "p": 140}, {"t": "Impressio suprarenalis", "m": "Suprarenal impression — impression caused by contact of the right suprarenal gland with the bare area on the right side near the inferior vena cava", "e": "impressio (L. impressiō: impression, indentation) + suprarenalis (L. suprā = above + renālis = of the kidney, from ren = kidney)", "p": 140}, {"t": "Appendix fibrosa hepatis", "m": "Appendix fibrosa hepatis — connective tissue band occasionally present at the upper end of the left lobe of the liver", "e": "appendix (L. appendix: appendage, from appendere = to hang upon) + fibrosa (L. fibrōsus: fibrous, from fibra = fibre) + hepatis (Gk. hēpar/hēpatos: liver)", "p": 140}, {"t": "Margo inferior", "m": "Inferior margin — border between the diaphragmatic and visceral surfaces of the liver", "e": "margo (L. margō: edge, border, margin) + inferior (L. inferior: lower, from inferus = below)", "p": 140}, {"t": "Incisura lig. teretis", "m": "Incisura lig. teretis — notch for round ligament at the lower border of the liver", "e": "incisura (L. incisūra: notch, incision, from incīdere = to cut into) + lig. (L. ligāmentum: ligament) + teretis (L. teres: round, cylindrical)", "p": 140}, {"t": "Lobi hepatis", "m": "Lobes of liver — the four macroscopically visible lobes of the liver", "e": "lobi (L. lobus: lobe, from Gk. lobos = lobe) + hepatis (Gk. hēpar/hēpatos: liver)", "p": 140}, {"t": "Lobus hepatis dexter", "m": "Right lobe of liver — its border to the left lobe corresponds to the line connecting the inferior vena cava and fundus of the gallbladder", "e": "lobus (L. lobus: lobe, from Gk. lobos = lobe) + hepatis (Gk. hēpar/hēpatos: liver) + dexter (L. dexter: right)", "p": 140}, {"t": "Segmentum anterius", "m": "Anterior segment of liver", "e": "segmentum (L. segmentum: segment, section, from secāre = to cut) + anterius (L. anterior: front, from ante = before)", "p": 140}, {"t": "Segmentum posterius", "m": "Posterior segment of liver", "e": "segmentum (L. segmentum: segment, section, from secāre = to cut) + posterius (L. posterior: behind, from post = after)", "p": 140}, {"t": "Lobus hepatis sinister", "m": "Left lobe of liver — its right border corresponds to a line connecting the inferior vena cava and fundus of gallbladder", "e": "lobus (L. lobus: lobe, from Gk. lobos = lobe) + hepatis (Gk. hēpar/hēpatos: liver) + sinister (L. sinister: left)", "p": 140}, {"t": "Segmentum mediale", "m": "Medial segment", "e": "segmentum (L. segmentum: segment, section) + mediale (L. mediālis: middle, from medius = middle)", "p": 140}, {"t": "Pars quadrata", "m": "Quadrate part — part belonging to the quadrate lobe", "e": "pars (L. pars: part, portion) + quadrata (L. quadrātus: square, four-sided, from quattuor = four)", "p": 140}, {"t": "Segmentum laterale", "m": "Lateral segment", "e": "segmentum (L. segmentum: segment, section) + laterale (L. laterālis: of the side, from latus = side)", "p": 140}, {"t": "Lobus quadratus", "m": "Quadrate lobe — liver lobe situated between the gallbladder, round ligament and hilum", "e": "lobus (L. lobus: lobe, from Gk. lobos = lobe) + quadratus (L. quadrātus: square, four-sided, from quattuor = four)", "p": 140}, {"t": "Lobus caudatus", "m": "Caudate lobe — liver lobe situated between the inferior vena cava, hilum and ligamentum venosum", "e": "lobus (L. lobus: lobe, from Gk. lobos = lobe) + caudatus (L. caudātus: having a tail, from cauda = tail)", "p": 140}, {"t": "Processus papillaris", "m": "Papillary process — portion of caudate lobe projecting caudally", "e": "processus (L. prōcessus: projection, going forward, from prōcēdere = to go forward) + papillaris (L. papillāris: of a papilla, from papilla = nipple, small projection)", "p": 140}, {"t": "Processus caudatus", "m": "Caudate process — parenchymal connection between the caudate and right lobes cranial to the hilum", "e": "processus (L. prōcessus: projection, going forward) + caudatus (L. caudātus: having a tail, from cauda = tail)", "p": 140}, {"t": "Tunica fibrosa", "m": "Tunica fibrosa — immobile connective tissue capsule of liver; thick, especially in the bare area not covered by peritoneum", "e": "tunica (L. tunica: coat, covering, layer) + fibrosa (L. fibrōsus: fibrous, from fibra = fibre)", "p": 140}, {"t": "Lig. venae cavae", "m": "Ligament of vena cava — connective tissue bridging over the inferior vena cava", "e": "lig. (L. ligāmentum: ligament, band, from ligāre = to bind) + venae (L. vena: vein) + cavae (L. cavus: hollow, from cavus = hollow)", "p": 140}, {"t": "Lobuli hepatis", "m": "Hepatic lobules — they measure 1–2 mm in size", "e": "lobuli (L. lobulus: small lobe, diminutive of lobus) + hepatis (Gk. hēpar/hēpatos: liver)", "p": 142}, {"t": "Capsula fibrosa perivascularis", "m": "Perivascular fibrous capsule — connective tissue sheath accompanying the liver vessels and biliary ducts until their terminal branches", "e": "capsula (L. capsula: small box/case, diminutive of capsa) + fibrosa (L. fibrosus: fibrous, from fibra = fiber) + peri- (Gk. peri: around) + vascularis (L. vascularis: of vessels, from vasculum = small vessel)", "p": 142}, {"t": "Arteriae interlobulares", "m": "Interlobular arteries — branches of the hepatic artery proper between the liver lobules", "e": "arteriae (Gk. artēria: artery, windpipe) + inter- (L. inter: between) + lobulares (L. lobularis: of lobules, from lobulus = small lobe)", "p": 142}, {"t": "Venae interlobulares", "m": "Interlobular veins — branches of the portal veins between the liver lobules", "e": "venae (L. vena: vein) + inter- (L. inter: between) + lobulares (L. lobularis: of lobules, from lobulus = small lobe)", "p": 142}, {"t": "Venae centrales", "m": "Central veins — efferent veins in the center of the liver lobule", "e": "venae (L. vena: vein) + centrales (L. centralis: central, from centrum = center, from Gk. kentron = center)", "p": 142}, {"t": "Ductuli interlobulares", "m": "Interlobular ductules — biliary drainage channels between the liver lobules", "e": "ductuli (L. ductulus: small duct, diminutive of ductus, from ducere = to lead) + inter- (L. inter: between) + lobulares (L. lobularis: of lobules, from lobulus = small lobe)", "p": 142}, {"t": "Ductus hepaticus communis", "m": "Common hepatic duct — duct between the cystic duct and the junction of right and left hepatic ducts", "e": "ductus (L. ductus: duct, from ducere = to lead) + hepaticus (Gk. hēpatikos: of the liver, from hēpar = liver) + communis (L. communis: common, shared)", "p": 142}, {"t": "Ductus hepaticus dexter", "m": "Right hepatic duct — duct arising from the right lobe of liver", "e": "ductus (L. ductus: duct, from ducere = to lead) + hepaticus (Gk. hēpatikos: of the liver, from hēpar = liver) + dexter (L. dexter: right)", "p": 142}, {"t": "Ramus anterior", "m": "Anterior branch — anterior branch of the right hepatic duct", "e": "ramus (L. ramus: branch) + anterior (L. anterior: front, former, from ante = before)", "p": 142}, {"t": "Ramus posterior", "m": "Posterior branch — posterior branch of the right hepatic duct", "e": "ramus (L. ramus: branch) + posterior (L. posterior: behind, later, from post = after)", "p": 142}, {"t": "Ductus hepaticus sinister", "m": "Left hepatic duct — duct arising from the left lobe of the liver", "e": "ductus (L. ductus: duct, from ducere = to lead) + hepaticus (Gk. hēpatikos: of the liver, from hēpar = liver) + sinister (L. sinister: left)", "p": 142}, {"t": "Ramus lateralis", "m": "Lateral branch — lateral branch of the left hepatic duct", "e": "ramus (L. ramus: branch) + lateralis (L. lateralis: of the side, from latus = side)", "p": 142}, {"t": "Ramus medialis", "m": "Medial branch — medial branch of the left hepatic duct", "e": "ramus (L. ramus: branch) + medialis (L. medialis: of the middle, from medius = middle)", "p": 142}, {"t": "Ductus lobi caudati dexter", "m": "Right duct of caudate lobe — branch coming from the right half of the caudate lobe and usually leading into right hepatic duct", "e": "ductus (L. ductus: duct, from ducere = to lead) + lobi (L. lobus: lobe, from Gk. lobos = rounded projection) + caudati (L. caudatus: tailed, having a tail, from cauda = tail) + dexter (L. dexter: right)", "p": 142}, {"t": "Ductus lobi caudati sinister", "m": "Left duct of caudate lobe — branch arising from the left half of the caudate lobe and emptying usually into the left hepatic duct", "e": "ductus (L. ductus: duct, from ducere = to lead) + lobi (L. lobus: lobe, from Gk. lobos = rounded projection) + caudati (L. caudatus: tailed, having a tail, from cauda = tail) + sinister (L. sinister: left)", "p": 142}, {"t": "Vesica biliaris", "m": "Gallbladder", "e": "vesica (L. vesīca: bladder, sac) + biliaris (L. biliāris: of bile, from bilis = bile)", "p": 144}, {"t": "Fundus vesicae biliaris", "m": "Fundus of gallbladder — caudally directed rounded end of gallbladder", "e": "fundus (L. fundus: bottom, base) + vesicae (L. vesīca: bladder, sac, genitive) + biliaris (L. biliāris: of bile, from bilis = bile)", "p": 144}, {"t": "Corpus ves. biliaris", "m": "Body of gallbladder — portion of gallbladder between the fundus and neck", "e": "corpus (L. corpus: body) + vesicae (L. vesīca: bladder, sac, abbreviated) + biliaris (L. biliāris: of bile, from bilis = bile)", "p": 144}, {"t": "Collum vesicae biliaris", "m": "Neck of gallbladder — the portion of the gallbladder continuous with the cystic duct", "e": "collum (L. collum: neck) + vesicae (L. vesīca: bladder, sac, genitive) + biliaris (L. biliāris: of bile, from bilis = bile)", "p": 144}, {"t": "Plicae mucosae", "m": "Mucosal folds that project into the lumen, thus producing a loculate relief pattern", "e": "plicae (L. plica: fold, from plicare = to fold, plural) + mucosae (L. mucōsus: mucous, from mucus = slime, genitive/plural)", "p": 144}, {"t": "Ductus cysticus", "m": "Cystic duct — duct that drains the gallbladder and joins the common hepatic duct to form the common bile duct", "e": "ductus (L. ductus: duct, leading, from ducere = to lead) + cysticus (Gk. kystikos: of the bladder, from kystis = bladder)", "p": 144}, {"t": "Plica spiralis", "m": "Spiral fold — a spiral elevation in the neck of the gallbladder and the cystic duct", "e": "plica (L. plica: fold, from plicare = to fold) + spiralis (L. spīrālis: spiral, from spīra = coil, from Gk. speira = coil)", "p": 144}, {"t": "Ductus choledochus", "m": "Bile duct — duct formed by the union of the cystic duct and common hepatic duct; passes into the greater duodenal papilla", "e": "ductus (L. ductus: duct, from ducere = to lead) + choledochus (Gk. choledochos: bile-receiving, from chole = bile + dechesthai = to receive)", "p": 144}, {"t": "M. sphincter ductus choledochi", "m": "Sphincter muscle of bile duct — thickened, annular muscle that forms sphincter directly before the hepatopancreatic ampulla", "e": "musculus (L. musculus: muscle, abbreviated M.) + sphincter (Gk. sphinktēr: that which binds tight, from sphingein = to bind) + ductus (L. ductus: duct) + choledochi (Gk. choledochos: bile-receiving, genitive)", "p": 144}, {"t": "Ampulla hepatopancreatica", "m": "Hepatopancreatic ampulla — dilatation in the wall of the duodenum immediately after the opening of the pancreatic duct into the bile duct", "e": "ampulla (L. ampulla: flask, jug, dilated vessel) + hepato- (Gk. hēpar/hēpatos: liver) + pancreatica (Gk. pankreas: pancreas, from pan = all + kreas = flesh)", "p": 144}, {"t": "M. sphincter ampullae hepatopancreaticae", "m": "Sphincter of Oddi — thickened annular sheath of muscle that invests the ampulla", "e": "musculus (L. musculus: muscle, abbreviated M.) + sphincter (Gk. sphinktēr: that which binds tight) + ampullae (L. ampulla: flask, dilated vessel, genitive) + hepato- (Gk. hēpar/hēpatos: liver) + pancreaticae (Gk. pankreas: pancreas, genitive)", "p": 144}, {"t": "Gll. biliares", "m": "Biliary glands — mucous glands in the wall of the biliary excretory ducts", "e": "glandulae (L. glandula: small gland, abbreviated Gll., plural) + biliares (L. biliāris: of bile, from bilis = bile, plural)", "p": 144}, {"t": "Systema respiratorium", "m": "Respiratory system", "e": "systema (Gk. systēma: system, organized whole, from syn = together + histanai = to set) + respiratorium (L. respirātōrius: of breathing, from respirare = to breathe again, re + spirare = to breathe)", "p": 144}, {"t": "Nasus externus", "m": "External nose", "e": "nasus (L. nāsus: nose) + externus (L. externus: external, outer, from exter = outside)", "p": 144}, {"t": "Radix nasi", "m": "Root of nose — upper portion of the nose which lies between the two orbits", "e": "radix (L. rādix: root) + nasi (L. nāsus: nose, genitive)", "p": 144}, {"t": "Dorsum nasi", "m": "Dorsum (bridge) of nose", "e": "dorsum (L. dorsum: back, upper surface) + nasi (L. nāsus: nose, genitive)", "p": 144}, {"t": "Apex nasi", "m": "Tip of nose", "e": "apex (L. apex: tip, point, summit) + nasi (L. nāsus: nose, genitive)", "p": 144}, {"t": "Alae nasi", "m": "Alae (wings) of nose — winglike structures forming the lateral borders of the nares", "e": "alae (L. āla: wing, plural) + nasi (L. nāsus: nose, genitive)", "p": 144}, {"t": "Cartilagines nasi", "m": "Nasal cartilages — pieces of cartilage which form the non-osseous supporting skeleton of the nose", "e": "cartilagines (L. cartilāgo: cartilage, plural) + nasi (L. nāsus: nose, genitive)", "p": 144}, {"t": "Cartilago nasi lateralis", "m": "Lateral nasal cartilage — no longer classified as independent perpendicular left and right plates of cartilage, but as part of the nasal septum with which each is partially fused", "e": "cartilago (L. cartilāgo: cartilage) + nasi (L. nāsus: nose, genitive) + lateralis (L. laterālis: lateral, of the side, from latus = side)", "p": 144}, {"t": "Cartilago alaris major", "m": "Greater alar cartilage — hook-shaped cartilage surrounding the nares and forming the tip of the nose", "e": "cartilago (L. cartilāgo: cartilage) + alaris (L. ālāris: of the wing, from āla = wing) + major (L. maior: greater, larger)", "p": 144}, {"t": "Cartilagines alares minores", "m": "Lesser alar cartilages — single, small plates of cartilage which supplement the greater alar cartilage", "e": "cartilagines (L. cartilāgo: cartilage, plural) + alares (L. ālāris: of the wing, from āla = wing, plural) + minores (L. minor: smaller, lesser, plural)", "p": 144}, {"t": "Cartilagines nasales accessoriae", "m": "Accessory nasal cartilages — small pieces of cartilage occasionally present between the cartilaginous nasal septum and greater alar cartilage that supplement the cartilaginous nasal skeleton", "e": "cartilagines (L. cartilāgo: cartilage, plural) + nasales (L. nāsālis: nasal, of the nose, from nāsus = nose, plural) + accessoriae (L. accessōrius: additional, supplementary, from accedere = to come near, plural)", "p": 144}, {"t": "Cartilago septi nasi", "m": "Cartilaginous nasal septum — large independent piece of cartilage in the wall of the nasal septum between the perpendicular plate of the ethmoid and the vomer", "e": "cartilago (L. cartilāgo: cartilage) + septi (L. septum: partition, wall, genitive, from saepire = to enclose) + nasi (L. nāsus: nose, genitive)", "p": 144}, {"t": "Processus lateralis", "m": "Lateral process — dorsolateral cartilaginous ridge of the nasal septum fused above with the lateral nasal cartilage", "e": "processus (L. prōcessus: process, projection, from procedere = to go forward) + lateralis (L. laterālis: lateral, of the side, from latus = side)", "p": 144}, {"t": "Processus posterior", "m": "Posterior process — variably long process between the vomer and the perpendicular plate; can extend as far as the sphenoid", "e": "processus (L. prōcessus: process, projection, from procedere = to go forward) + posterior (L. posterior: behind, later, from post = after)", "p": 144}, {"t": "Cartilago vomeronasalis", "m": "Vomeronasal cartilage (Jacobson's cartilage) — narrow strip of cartilage on the lower end of the nasal septum between the cartilaginous nasal septum and the vomer", "e": "cartilago (L. cartilāgo: cartilage) + vomero- (L. vōmer: plowshare, the vomer bone) + nasalis (L. nāsālis: nasal, of the nose, from nāsus = nose)", "p": 144}, {"t": "Pars mobilis septi nasi", "m": "Mobile part of nasal septum — anterioinferior, very mobile part of the nasal septum which contains the medial crus of the greater alar cartilage", "e": "pars (L. pars: part) + mobilis (L. mōbilis: movable, from movere = to move) + septi (L. septum: partition, wall, genitive) + nasi (L. nāsus: nose, genitive)", "p": 144}, {"t": "Cavitas nasalis", "m": "Nasal cavity", "e": "cavitas (L. cavitās: hollowness, cavity, from cavus = hollow) + nasalis (L. nāsālis: of the nose, from nāsus = nose)", "p": 146}, {"t": "Nares", "m": "Nasal openings (nostrils)", "e": "nares (L. nārēs: nostrils, plural of naris = nostril)", "p": 146}, {"t": "Pars membranacea", "m": "Membranous part — connective tissue portion of nasal septum at the tip of the nose", "e": "pars (L. pars: part, portion) + membranacea (L. membrānāceus: membranous, from membrāna = membrane, from membrum = limb)", "p": 146}, {"t": "Pars cartilagina", "m": "Cartilaginous part — portion of the nasal septum situated between the membranous and bony parts", "e": "pars (L. pars: part, portion) + cartilagina (L. cartilāgina: of cartilage, from cartilāgo = cartilage, gristle)", "p": 146}, {"t": "Pars ossea", "m": "Bony part of nasal septum — perpendicular plate of ethmoid and vomer", "e": "pars (L. pars: part, portion) + ossea (L. osseus: bony, of bone, from os = bone)", "p": 146}, {"t": "Septum nasale", "m": "Nasal septum — nasal partition comprised of bony, cartilaginous and membranous parts", "e": "septum (L. saeptum: partition, enclosure, from saepire = to enclose) + nasale (L. nāsāle: nasal, of the nose, from nāsus = nose)", "p": 146}, {"t": "Organum vomeronasale", "m": "Vomeronasal (Jacobson's) organ — blind sac occasionally present above the incisive canal", "e": "organum (L./Gk. organum: organ, instrument, from Gk. organon = tool) + vomeronasale (L. vomer = ploughshare bone + nāsāle = nasal, from nāsus = nose)", "p": 146}, {"t": "Vestibulum nasi", "m": "Vestibule of nose — anterior segment of nasal cavity extending up to the limen nasi", "e": "vestibulum (L. vestibulum: entrance court, forecourt) + nasi (L. nāsī: of the nose, genitive of nāsus = nose)", "p": 146}, {"t": "Limen nasi", "m": "Limen nasi — ridge at the end of the vestibule produced by the margin of the alar cartilage", "e": "limen (L. līmen: threshold, boundary) + nasi (L. nāsī: of the nose, genitive of nāsus = nose)", "p": 146}, {"t": "Sulcus olfactorius", "m": "Olfactory sulcus — groove on the olfactory area passing between the root of the middle nasal concha and the bridge of the nose", "e": "sulcus (L. sulcus: groove, furrow, trench) + olfactorius (L. olfactōrius: of smelling, from olfacere = to smell, from olere = to emit smell + facere = to make)", "p": 146}, {"t": "Tunica mucosa nasi", "m": "Nasal mucous membrane — consisting primarily of pseudostratified ciliated columnar epithelium with goblet cells", "e": "tunica (L. tunica: covering, coat, layer) + mucosa (L. mūcōsus: mucous, slimy, from mūcus = mucus) + nasi (L. nāsī: of the nose, genitive of nāsus = nose)", "p": 146}, {"t": "Regio respiratoria", "m": "Respiratory region — part of the nasal mucosa with ciliated epithelium", "e": "regio (L. regiō: region, area, district) + respiratoria (L. respīrātōrius: respiratory, from respīrāre = to breathe, from re- = again + spīrāre = to breathe)", "p": 146}, {"t": "Regio olfactoria", "m": "Olfactory region — area about the size of a nickel containing olfactory cells", "e": "regio (L. regiō: region, area, district) + olfactoria (L. olfactōrius: of smelling, from olfacere = to smell)", "p": 146}, {"t": "Glandulae nasales", "m": "Nasal (olfactory) glands — predominantly serous, tubular glands", "e": "glandulae (L. glandula: small gland, diminutive of glans = acorn) + nasales (L. nāsāles: nasal, of the nose, from nāsus = nose)", "p": 146}, {"t": "Plexus cavernosi concharum", "m": "Cavernous plexus of concha — venous plexuses especially prevalent in the region of the inferior concha and posterior nasal cavity", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + cavernosi (L. cavernōsus: cavernous, full of cavities, from caverna = cave) + concharum (L. genitive plural of concha = shell)", "p": 146}, {"t": "Agger nasi", "m": "Agger nasi — ridge-like elevations comprising the remains of an earlier accessory concha directly in front of the middle nasal concha", "e": "agger (L. agger: mound, rampart, heap) + nasi (L. nāsī: of the nose, genitive of nāsus = nose)", "p": 146}, {"t": "Atrium meatus medii", "m": "Atrium of middle meatus — area at the beginning of the middle meatus in front of the middle and above the inferior concha", "e": "atrium (L. ātrium: entrance hall, forecourt of a Roman house) + meatus (L. meātus: passage) + medii (L. medius: middle, genitive form)", "p": 146}, {"t": "Apertum ductus nasolacrimalis", "m": "Aperture of nasolacrimal duct — opening of the nasolacrimal duct provided with a flap-like mucosal fold", "e": "apertum (L. apertus: open, opening, from aperire = to open) + ductus (L. ductus: duct, channel, from ducere = to lead) + nasolacrimalis (L. nāsus = nose + lacrima = tear + -alis = pertaining to)", "p": 146}, {"t": "Ductus incisivus", "m": "Incisive duct — blind sac occasionally present on the floor of the nasal cavity near the septum, about 2 cm behind the external nasal opening", "e": "ductus (L. ductus: duct, channel, from ducere = to lead) + incisivus (L. incīsīvus: cutting, incisive, from incidere = to cut into, from in- = into + caedere = to cut)", "p": 146}, {"t": "Sinus paranasales", "m": "Paranasal sinuses", "e": "sinus (L. sinus: cavity, hollow, bay) + para- (Gk. para: beside, near) + nasales (L. nasalis: of the nose, from nasus = nose)", "p": 148}, {"t": "Sinus ethmoidales", "m": "Ethmoidal sinus — system of cavities with pea-sized air cells between the nasal cavity and orbit", "e": "sinus (L. sinus: cavity, hollow) + ethmoidales (Gk. ethmos: sieve + eidos: form; sieve-like)", "p": 148}, {"t": "Sinus anteriores", "m": "Anterior sinus — anterior group of ethmoidal air cells which opens below the middle nasal concha", "e": "sinus (L. sinus: cavity, hollow) + anteriores (L. anterior: in front, former, from ante = before)", "p": 148}, {"t": "Sinus medii", "m": "Middle sinus — middle group of ethmoidal air cells which opens below the middle nasal concha", "e": "sinus (L. sinus: cavity, hollow) + medii (L. medius: middle, in the middle)", "p": 148}, {"t": "Sinus posteriores", "m": "Posterior sinus — posterior group of ethmoidal air cells which opens below the superior nasal concha", "e": "sinus (L. sinus: cavity, hollow) + posteriores (L. posterior: behind, coming after, from post = after)", "p": 148}, {"t": "Cartilagines et articulationes laryngeales", "m": "Laryngeal cartilages and joints", "e": "cartilagines (L. cartilago: cartilage, gristle) + et (L. et: and) + articulationes (L. articulatio: joint, articulation, from articulare = to divide into joints) + laryngeales (Gk. larynx: upper windpipe, throat)", "p": 148}, {"t": "Cartilago thyroidea", "m": "Thyroid cartilage — largest laryngeal cartilage that partially encloses the others", "e": "cartilago (L. cartilago: cartilage, gristle) + thyroidea (Gk. thyreos: oblong shield + eidos: form; shield-shaped)", "p": 148}, {"t": "Prominentia laryngea", "m": "Laryngeal prominence — prominence in the midline of the neck produced by the thyroid cartilage (Adam's apple)", "e": "prominentia (L. prominentia: projection, prominence, from prominere = to jut out) + laryngea (Gk. larynx: upper windpipe, throat)", "p": 148}, {"t": "Lamina dextra", "m": "Right lamina — lateral plate of the thyroid cartilage", "e": "lamina (L. lamina: thin plate, layer) + dextra (L. dexter: right, on the right side)", "p": 148}, {"t": "Lamina sinistra", "m": "Left lamina — lateral plate of the thyroid cartilage", "e": "lamina (L. lamina: thin plate, layer) + sinistra (L. sinister: left, on the left side)", "p": 148}, {"t": "Incisura thyroidea superior", "m": "Superior thyroid notch — deep median notch in the upper portion of the thyroid cartilage, between the right and left thyroid laminae", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + thyroidea (Gk. thyreos: oblong shield + eidos: form) + superior (L. superior: upper, higher)", "p": 148}, {"t": "Incisura thyroidea inferior", "m": "Inferior thyroid notch — shallow median notch at the lower margin of the thyroid cartilage", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + thyroidea (Gk. thyreos: oblong shield + eidos: form) + inferior (L. inferior: lower)", "p": 148}, {"t": "Tuberculum thyroideum superius", "m": "Superior thyroid tubercle — small lateral prominence on the outside of the thyroid lamina at the upper end of the oblique line", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = swelling) + thyroideum (Gk. thyreos: oblong shield + eidos: form) + superius (L. superior: upper, higher)", "p": 148}, {"t": "Tuberculum thyroideum inferius", "m": "Inferior thyroid tubercle — small lateral prominence at the lower end of the oblique line", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = swelling) + thyroideum (Gk. thyreos: oblong shield + eidos: form) + inferius (L. inferior: lower)", "p": 148}, {"t": "Foramen thyroideum", "m": "Thyroid foramen — hole occasionally present laterally below the superior tubercle for passage of the superior laryngeal artery and vein", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + thyroideum (Gk. thyreos: oblong shield + eidos: form)", "p": 148}, {"t": "Membrana thyrohydoidea", "m": "Thyrohyoid membrane — membrane rich in elastic fibers between the upper posterior margin of the hyoid bone and the thyroid cartilage", "e": "membrana (L. membrana: membrane, thin skin) + thyro- (Gk. thyreos: oblong shield) + hyoidea (Gk. hyoeides: shaped like the letter upsilon, U-shaped; from hy = letter upsilon + eidos = form)", "p": 148}, {"t": "Lig. thyrohyoideum medianum", "m": "Median thyrohyoid membrane — median reinforcement of the thyrohyoid membrane with abundant elastic fibers", "e": "ligamentum (L. ligamentum: band, tie, from ligare = to bind) + thyro- (Gk. thyreos: oblong shield) + hyoideum (Gk. hyoeides: U-shaped) + medianum (L. medianus: middle, from medius = middle)", "p": 148}, {"t": "Corpus adiposum prae-epiglotticum", "m": "Pre-epiglottic fat body — space-filling adipose body between epiglottis, thyronhyoid membrane and hyo-epiglottic ligament", "e": "corpus (L. corpus: body) + adiposum (L. adiposus: fatty, from adeps = fat) + prae- (L. prae: before, in front of) + epiglotticum (Gk. epi: upon + glottis: opening of the larynx, from glossa = tongue)", "p": 148}, {"t": "Ligamentum thyrohyoideum laterale", "m": "Lateral thyrohyoid ligament — ligament extending from the superior horn to the posterior end of the greater horn of the hyoid bone, providing lateral reinforcement for the thyrohyoid membrane", "e": "ligamentum (L. ligamentum: band, tie, from ligare = to bind) + thyro- (Gk. thyreos: oblong shield) + hyoideum (Gk. hyoeides: U-shaped) + laterale (L. lateralis: of the side, from latus = side)", "p": 148}, {"t": "Cartilago triticea", "m": "Cartilago triticea — elastic cartilage, the size of a grain of wheat, in the thyrohyoid ligament", "e": "cartilago (L. cartilago: cartilage, gristle) + triticea (L. triticum: wheat, from terere = to rub, thresh; hence wheat-grain sized)", "p": 148}, {"t": "Cartilago cricoidea", "m": "Cricoid cartilage — ring of cartilage lying at the upper end of the trachea that articulates with the thyroid cartilage", "e": "cartilago (L. cartilāgo: cartilage, gristle) + cricoidea (Gk. krikos: ring + eidos: form, shape — ring-shaped)", "p": 150}, {"t": "Arcus cartilaginis cricoideae", "m": "Arch of cricoid cartilage — anterior and lateral parts of cricoid cartilage", "e": "arcus (L. arcus: arch, bow) + cartilaginis (L. cartilāgo: cartilage, genitive form) + cricoideae (Gk. krikos: ring + eidos: form, shape)", "p": 150}, {"t": "Lamina cartilaginis cricoideae", "m": "Lamina of cricoid cartilage — tall posterior plate of the cricoid cartilage", "e": "lamina (L. lamina: thin plate, layer) + cartilaginis (L. cartilāgo: cartilage, genitive form) + cricoideae (Gk. krikos: ring + eidos: form, shape)", "p": 150}, {"t": "Facies articularis arytenoidea", "m": "Articular surface for arytenoid cartilage — oblique, oval articular facet for the arytenoid cartilage located laterally at the upper margin of the cricoid lamina", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint, from articulus: joint) + arytenoidea (Gk. arytaina: ladle, pitcher + eidos: form, shape)", "p": 150}, {"t": "Facies articularis thyroidea", "m": "Articular surface for thyroid cartilage — somewhat prominent articular facet for the thyroid cartilage situated inferiorly on the lateral margin of the lamina", "e": "facies (L. faciēs: face, surface) + articularis (L. articulāris: of a joint) + thyroidea (Gk. thyreos: oblong shield + eidos: form, shape)", "p": 150}, {"t": "Articulatio cricothyroidea", "m": "Cricothyroid joint — articulation between the thyroid and cricoid cartilages, permits tilting as well as horizontal and vertical gliding movements", "e": "articulatio (L. articulātiō: joint, from articulus: joint) + cricothyroidea (Gk. krikos: ring + thyreos: oblong shield + eidos: form, shape)", "p": 150}, {"t": "Capsula articularis cricothyroidea", "m": "Cricothyroid joint capsule — thin articular capsule", "e": "capsula (L. capsula: small box, diminutive of capsa: box) + articularis (L. articulāris: of a joint) + cricothyroidea (Gk. krikos: ring + thyreos: shield + eidos: form)", "p": 150}, {"t": "Lig. ceratocricoideum", "m": "Ceratocricoid ligament — capsular reinforcement for limitation of shearing movements", "e": "ligamentum (L. ligāmentum: band, tie, from ligāre: to bind) + ceratocricoideum (Gk. keras/keratos: horn + krikos: ring + eidos: form)", "p": 150}, {"t": "Lig. cricothyroideum medianum", "m": "Median cricothyroid ligament — strong vertical ligament in the midline between the thyroid and cricoid cartilages", "e": "ligamentum (L. ligāmentum: band, from ligāre: to bind) + cricothyroideum (Gk. krikos: ring + thyreos: shield + eidos: form) + medianum (L. mediānus: middle, from medius: middle)", "p": 150}, {"t": "Lig. cricotracheale", "m": "Cricotracheal ligament — elastic membrane between the cricoid cartilage and the first tracheal cartilage", "e": "ligamentum (L. ligāmentum: band, from ligāre: to bind) + cricotracheale (Gk. krikos: ring + trachy: rough — referring to trachea)", "p": 150}, {"t": "Cartilago anytenoidea", "m": "Arytenoid cartilage — pyramid-like cartilage on the cricoid cartilage", "e": "cartilago (L. cartilāgo: cartilage) + anytenoidea (Gk. arytaina: ladle, pitcher + eidos: form, shape)", "p": 150}, {"t": "Basis cartilaginis arytenoideae", "m": "Base of arytenoid — undersurface of arytenoid cartilage", "e": "basis (Gk./L. basis: base, foundation) + cartilaginis (L. cartilāgo: cartilage, genitive form) + arytenoideae (Gk. arytaina: ladle + eidos: form, genitive form)", "p": 150}, {"t": "Processus vocalis", "m": "Vocal process — anteriorly directed process for attachment of the vocal ligament", "e": "processus (L. prōcessus: projection, from prōcēdere: to go forward) + vocalis (L. vōcālis: of the voice, from vox: voice)", "p": 150}, {"t": "Crista arcuata", "m": "Arcuate crest — cartilaginous ridge which begins between the oblong and triangular foveae, arches around the triangular fovea and ends at the colliculus", "e": "crista (L. crista: crest, ridge) + arcuata (L. arcuātus: arched, bow-shaped, from arcus: arch)", "p": 150}, {"t": "Colliculus", "m": "Colliculus — small projection at the end of the arcuate crest", "e": "colliculus (L. colliculus: small hill, diminutive of collis: hill)", "p": 150}, {"t": "Fovea oblonga", "m": "Oblong fovea — depression on the anteroinferior surface of the arytenoid cartilage for attachment of the thyroarytenoid muscle", "e": "fovea (L. fovea: pit, small depression) + oblonga (L. oblongus: oblong, longer than wide, from ob: against + longus: long)", "p": 150}, {"t": "Fovea triangularis", "m": "Triangular fovea — gland-filled depression above the oblong fovea", "e": "fovea (L. fovea: pit, small depression) + triangularis (L. triangulāris: triangular, from triangulus: three-angled, from tri: three + angulus: angle)", "p": 150}, {"t": "Apex cartilaginis arytenoideae", "m": "Apex of arytenoid cartilage — arches posteriorly from the arytenoid cartilage", "e": "apex (L. apex: tip, top, point) + cartilaginis (L. cartilāgo: cartilage, genitive form) + arytenoideae (Gk. arytaina: ladle + eidos: form, genitive)", "p": 150}, {"t": "Processus muscularis", "m": "Muscular process — short process that projects posterolaterally from the arytenoid cartilage for attachment of the posterior and lateral cricoarytenoid muscles", "e": "processus (L. prōcessus: projection, from prōcēdere: to go forward) + muscularis (L. musculāris: of muscle, from musculus: muscle)", "p": 150}, {"t": "Articulatio cricoarytenoidea", "m": "Cricoarytenoid joint — cylindrical joint between the cricoid and arytenoid cartilages, permits oscillating movements around an obliquely placed cylindrical axis and gliding movements parallel to the axis", "e": "articulatio (L. articulātiō: joint) + cricoarytenoidea (Gk. krikos: ring + arytaina: ladle + eidos: form)", "p": 150}, {"t": "Capsula articularis cricoarytenoidea", "m": "Articular capsule of cricoarytenoid joint — thin-walled, flaccid capsule of joint between cricoid and arytenoid cartilages", "e": "capsula (L. capsula: small box) + articularis (L. articulāris: of a joint) + cricoarytenoidea (Gk. krikos: ring + arytaina: ladle + eidos: form)", "p": 150}, {"t": "Lig. cricoarytenoideum", "m": "Cricoarytenoid ligament — important elastic ligament for the closure of the rima glottidis, passes posteriorly from the cricoid lamina to the medial part of the arytenoid", "e": "ligamentum (L. ligāmentum: band, from ligāre: to bind) + cricoarytenoideum (Gk. krikos: ring + arytaina: ladle + eidos: form)", "p": 150}, {"t": "Lig. cricopharyngeum", "m": "Cricopharyngeal ligament — fiber tract beginning at the corniculate cartilage, after attachment to the posterior side of the cricoid passes beneath the overlying pharyngeal mucosa", "e": "ligamentum (L. ligāmentum: band, from ligāre: to bind) + cricopharyngeum (Gk. krikos: ring + pharynx: throat)", "p": 150}, {"t": "Cartilago sesamoidea", "m": "Sesamoid cartilage — piece of elastic cartilage occasionally present in the anterior end of the vocal ligament and near the arytenoid cartilage", "e": "cartilago (L. cartilāgo: cartilage) + sesamoidea (Gk. sēsamon: sesame seed + eidos: form, shape — resembling a sesame seed)", "p": 150}, {"t": "Cartilago corniculata", "m": "Corniculate cartilage — small elastic cartilage at the apex of the arytenoid cartilage, produces the corniculate tubercle", "e": "cartilago (L. cartilāgo: cartilage) + corniculata (L. corniculātus: horned, from corniculum: small horn, from cornu: horn)", "p": 150}, {"t": "Tuberculum corniculatum", "m": "Corniculate tubercle — mucosa-covered prominence over the corniculate cartilage directly above the apex of the arytenoid cartilage", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber: swelling, lump) + corniculatum (L. corniculātus: horned, from cornu: horn)", "p": 150}, {"t": "Rima glottidis", "m": "Rima glottidis — the closure of which is assisted by the cricoarytenoid ligament", "e": "rima (L. rima: slit, fissure, cleft) + glottidis (Gk. glōttis: the mouth of the windpipe, from glōssa/glōtta: tongue, genitive form)", "p": 150}, {"t": "Cartilago cuneiformis", "m": "Cuneiform cartilage — variably small cartilage beneath a small group of glands in the aryepiglottic fold", "e": "cartilago (L. cartilāgo: cartilage, gristle) + cuneiformis (L. cuneus: wedge + forma: shape, thus wedge-shaped)", "p": 152}, {"t": "Tuberculum cuneiforme", "m": "Cuneiform tubercle — prominence in the aryepiglottic fold caused by the cuneiform cartilage", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber: bump) + cuneiforme (L. cuneus: wedge + forma: shape)", "p": 152}, {"t": "Epiglottis", "m": "Epiglottis — elastic cartilage shaped like a shoehorn", "e": "epiglottis (Gk. epi: upon, over + glōttis: opening of the larynx, from glōtta: tongue)", "p": 152}, {"t": "Petiolus epiglottidis", "m": "Stalk of epiglottis — downward pointing end of the epiglottic cartilage attached to the thyroid cartilage by connective tissue", "e": "petiolus (L. petiolus: little foot, stalk, diminutive of pes: foot) + epiglottidis (Gk. epi: upon + glōttis: opening of larynx, genitive form)", "p": 152}, {"t": "Tuberculum epiglotticum", "m": "Epiglottic tubercle — small prominence at the posterior surface of the mucosa above the stalk", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber: bump) + epiglotticum (Gk. epi: upon + glōttis: opening of larynx, adjectival form)", "p": 152}, {"t": "Cartilago epiglottica", "m": "Epiglottic cartilage — skeleton of epiglottis consisting of elastic cartilage", "e": "cartilago (L. cartilāgo: cartilage, gristle) + epiglottica (Gk. epi: upon + glōttis: opening of larynx, adjectival form)", "p": 152}, {"t": "Lig. thyroepiglotticum", "m": "Thyroepiglottic ligament — ligament attaching the stalk of the epiglottis to the posterior surface of the thyroid cartilage", "e": "lig. (abbreviation of ligamentum, L. ligamentum: band, tie, from ligare: to bind) + thyroepiglotticum (Gk. thyreos: shield-shaped + epi: upon + glōttis: opening of larynx)", "p": 152}, {"t": "Lig. hyoepiglotticum", "m": "Hyoepiglottic ligament — ligament between the hyoid and epiglottis", "e": "lig. (L. ligamentum: band, from ligare: to bind) + hyoepiglotticum (Gk. hyoeides: U-shaped, hyoid + epi: upon + glōttis: opening of larynx)", "p": 152}, {"t": "Musculi laryngis", "m": "Laryngeal musculature — muscles of the larynx", "e": "musculi (L. musculus: muscle, diminutive of mus: mouse, plural) + laryngis (Gk. larynx: upper part of windpipe, genitive form)", "p": 152}, {"t": "Pars aryepiglottica", "m": "Aryepiglottic part — now the aryepiglottic part of the arytenoid muscle", "e": "pars (L. pars: part, portion) + aryepiglottica (Gk. arytaina: ladle-shaped + epi: upon + glōttis: opening of larynx, adjectival form)", "p": 152}, {"t": "M. cricothyroideus", "m": "Cricothyroid muscle — tenses vocal ligament by lifting the cricoid cartilage forward and tilting back the lamina and the arytenoid cartilage", "e": "m. (abbreviation of musculus, L. musculus: muscle) + cricothyroideus (Gk. krikos: ring + thyreos: shield + eidos: form, shape)", "p": 152}, {"t": "Pars recta", "m": "Straight part — anterior, somewhat more steeply coursing fibers", "e": "pars (L. pars: part, portion) + recta (L. rectus: straight, upright, from regere: to keep straight)", "p": 152}, {"t": "Pars obliqua", "m": "Oblique part — posterior, more horizontally coursing fibers", "e": "pars (L. pars: part, portion) + obliqua (L. obliquus: slanting, diagonal, sideways)", "p": 152}, {"t": "M. cricoarytenoideus posterior", "m": "Posterior cricoarytenoid muscle — by swinging the vocal process upward and outward, it opens the rima glottidis; the only abductor of the vocal folds", "e": "m. (L. musculus: muscle) + cricoarytenoideus (Gk. krikos: ring + arytaina: ladle-shaped + eidos: form) + posterior (L. posterior: behind, coming after)", "p": 152}, {"t": "M. ceratocricoideus", "m": "Ceratocricoid muscle — anatomic variant; origin at inferior horn of thyroid cartilage, insertion at inferior margin of cricoid cartilage", "e": "m. (L. musculus: muscle) + ceratocricoideus (Gk. keras/ceratos: horn + krikos: ring + eidos: form, shape)", "p": 152}, {"t": "M. cricoarytenoideus lateralis", "m": "Lateral cricoarytenoid muscle — synergist in closing of rima glottidis", "e": "m. (L. musculus: muscle) + cricoarytenoideus (Gk. krikos: ring + arytaina: ladle-shaped + eidos: form) + lateralis (L. lateralis: of the side, from latus: side)", "p": 152}, {"t": "M. vocalis", "m": "Vocalis muscle — by its tension it alters the intrinsic vibrations of the vocal cord", "e": "m. (L. musculus: muscle) + vocalis (L. vocalis: of the voice, vocal, from vox/vocis: voice)", "p": 152}, {"t": "M. thyroepiglotticus", "m": "Thyroepiglottic muscle — now the thyroepiglottic part of the thyroarytenoid muscle", "e": "m. (L. musculus: muscle) + thyroepiglotticus (Gk. thyreos: shield + epi: upon + glōttis: opening of larynx)", "p": 152}, {"t": "M. thyroarytenoideus", "m": "Thyroarytenoid muscle — synergist in closure of rima glottidis", "e": "m. (L. musculus: muscle) + thyroarytenoideus (Gk. thyreos: shield + arytaina: ladle-shaped + eidos: form)", "p": 152}, {"t": "Pars thyroepiglottica", "m": "Thyroepiglottic part — anterior, inner surface of thyroid cartilage; insertion at epiglottis and quadrangular membrane", "e": "pars (L. pars: part, portion) + thyroepiglottica (Gk. thyreos: shield + epi: upon + glōttis: opening of larynx, adjectival form)", "p": 152}, {"t": "M. arytenoideus obliquus", "m": "Oblique arytenoid muscle — draws the arytenoid cartilages closer together; synergist in closure of rima glottidis", "e": "m. (L. musculus: muscle) + arytenoideus (Gk. arytaina: ladle-shaped + eidos: form) + obliquus (L. obliquus: slanting, diagonal)", "p": 152}, {"t": "M. arytenoideus transversus", "m": "Transverse arytenoid muscle — approximates arytenoid cartilages; synergist in closure of rima glottidis", "e": "m. (L. musculus: muscle) + arytenoideus (Gk. arytaina: ladle-shaped + eidos: form) + transversus (L. transversus: turned across, from trans: across + vertere: to turn)", "p": 152}, {"t": "Cavitas laryngis", "m": "Laryngeal cavity — cavity of the larynx", "e": "cavitas (L. cavitas: hollowness, cavity, from cavus: hollow) + laryngis (Gk. larynx: upper windpipe, genitive form)", "p": 152}, {"t": "Plica aryepiglottica", "m": "Aryepiglottic fold — mucosal fold over the aryepiglottic muscle extending from the apex of the arytenoid cartilage to the lateral margin of the epiglottis", "e": "plica (L. plica: fold, from plicare: to fold) + aryepiglottica (Gk. arytaina: ladle-shaped + epi: upon + glōttis: opening of larynx, adjectival form)", "p": 152}, {"t": "Incisura interarytenoidea", "m": "Interarytenoid notch — mucosa-covered slit between the two apices of the arytenoids", "e": "incisura (L. incisura: notch, cut, from incidere: to cut into) + interarytenoidea (L. inter: between + Gk. arytaina: ladle-shaped + eidos: form, adjectival form)", "p": 152}, {"t": "Vestibulum laryngis", "m": "Vestibule of larynx — upper part of laryngeal cavity extending as far as the vestibular folds", "e": "vestibulum (L. vestibulum: entrance hall, forecourt, antechamber) + laryngis (Gk. larynx: upper windpipe, genitive form)", "p": 152}, {"t": "Rima vestibuli", "m": "Rima vestibuli — interval between the two vestibular folds", "e": "rima (L. rima: cleft, slit, chink) + vestibuli (L. vestibulum: entrance hall, genitive form)", "p": 152}, {"t": "Plica vestibularis", "m": "Vestibular (ventricular) fold — fold produced by the vestibular ligament lying between the laryngeal ventricle and vestibule", "e": "plica (L. plica: fold, from plicare: to fold) + vestibularis (L. vestibulum: entrance hall + aris: adjectival suffix, pertaining to)", "p": 152}, {"t": "Plica ventricularis", "m": "Vestibular (ventricular) fold — fold produced by the vestibular ligament", "e": "plica (L. plica: fold, from plicare: to fold) + ventricularis (L. ventriculus: small belly, ventricle, diminutive of venter: belly + aris: adjectival suffix)", "p": 152}, {"t": "Cavitas laryngis intermedia", "m": "Intermediate laryngeal cavity — space between the vestibular and vocal folds", "e": "cavitas (L. cavitas: hollowness, cavity, from cavus: hollow) + laryngis (Gk. larynx: upper windpipe, genitive form) + intermedia (L. intermedius: lying between, from inter: between + medius: middle)", "p": 152}, {"t": "Ventriculus laryngis", "m": "Ventricle of larynx — lateral outpocketings between the vocal and vestibular folds", "e": "ventriculus (L. ventriculus: little belly, diminutive of venter = belly) + laryngis (Gk. larynx/laryngos: upper windpipe, larynx)", "p": 154}, {"t": "Sacculus laryngis", "m": "Saccule (appendix) of larynx — small blind sac directed upward from the ventricle", "e": "sacculus (L. sacculus: little sac, diminutive of saccus = bag) + laryngis (Gk. larynx/laryngos: upper windpipe, larynx)", "p": 154}, {"t": "appendix ventriculi laryngis", "m": "Appendix of the ventricle of the larynx", "e": "appendix (L. appendix: appendage, from appendere = to hang upon) + ventriculi (L. ventriculus: little belly, genitive form) + laryngis (Gk. larynx/laryngos: upper windpipe, larynx)", "p": 154}, {"t": "Glottis", "m": "Voice-producing part of the larynx consisting of the two vocal folds and the interval (Rima glottidis) between them", "e": "glottis (Gk. glōttis: aperture of the larynx, from glōtta = tongue)", "p": 154}, {"t": "Plica vocalis", "m": "Vocal fold — mucosal fold supported by the underlying vocal ligament and laterally by the vocalis muscle", "e": "plica (L. plica: fold, from plicare = to fold) + vocalis (L. vocalis: of the voice, from vox/vocis = voice)", "p": 154}, {"t": "Pars intermembranacea", "m": "Intermembranous part — portion of the rima glottidis extending from the thyroid cartilage to the apex of the vocal process", "e": "pars (L. pars: part, portion) + intermembranacea (L. inter = between + membrana = membrane + -acea = pertaining to)", "p": 154}, {"t": "Pars intercartilaginea", "m": "Intercartilaginous part — portion of rima glottidis between the arytenoid cartilages", "e": "pars (L. pars: part, portion) + intercartilaginea (L. inter = between + cartilago/cartilaginis = cartilage + -ea = pertaining to)", "p": 154}, {"t": "Plica interarytenoidea", "m": "Interarytenoid fold — mucosal fold between the arytenoid cartilages", "e": "plica (L. plica: fold, from plicare = to fold) + interarytenoidea (Gk. inter = between + arytaina = ladle/pitcher + eidos = form, shape)", "p": 154}, {"t": "Cavitas infraglottica", "m": "Infraglottic cavity — lowest portion of laryngeal cavity enclosed by the conus elasticus, extending from the rima glottidis to the trachea", "e": "cavitas (L. cavitas: hollow space, cavity, from cavus = hollow) + infraglottica (L. infra = below + Gk. glōttis = aperture of larynx)", "p": 154}, {"t": "Membrana fibroelastica laryngis", "m": "Fibroelastic membrane of larynx — submucosa of laryngeal wall provided with abundant elastic fibers", "e": "membrana (L. membrana: membrane, thin skin) + fibroelastica (L. fibra = fiber + Gk. elastikos = flexible, from elaunein = to drive) + laryngis (Gk. larynx/laryngos: upper windpipe)", "p": 154}, {"t": "membrana elastica laryngis", "m": "Elastic membrane of the larynx (alternate term)", "e": "membrana (L. membrana: membrane, thin skin) + elastica (Gk. elastikos: flexible, from elaunein = to drive) + laryngis (Gk. larynx/laryngos: upper windpipe)", "p": 154}, {"t": "Membrana quadrangularis", "m": "Quadrangular membrane — membrane spread out between the epiglottis, aryepiglottic fold and vestibular fold", "e": "membrana (L. membrana: membrane, thin skin) + quadrangularis (L. quadrangularis: four-angled, from quadri = four + angulus = angle)", "p": 154}, {"t": "Lig. vestibulare", "m": "Vestibular ligament — strengthens the lower margin of the quadrangular membrane", "e": "lig. (abbreviation of ligamentum: L. ligamentum = band, tie, from ligare = to bind) + vestibulare (L. vestibularis: of the vestibule, from vestibulum = entrance hall)", "p": 154}, {"t": "Conus elasticus", "m": "Conus elasticus (membrana cricovocalis) — reinforced fibroelastic membrane between the vocal ligament and cricoid", "e": "conus (Gk. kōnos: cone) + elasticus (Gk. elastikos: flexible, from elaunein = to drive)", "p": 154}, {"t": "membrana cricovocalis", "m": "Cricovocal membrane — alternate name for conus elasticus", "e": "membrana (L. membrana: membrane, thin skin) + cricovocalis (Gk. krikos = ring + L. vocalis = of the voice, from vox/vocis = voice)", "p": 154}, {"t": "Lig. vocale", "m": "Vocal ligament — lies between the vocal process of the arytenoid cartilage and the thyroid cartilage, forming the upper end of the conus elasticus", "e": "lig. (abbreviation of ligamentum: L. ligamentum = band, tie, from ligare = to bind) + vocale (L. vocalis: of the voice, from vox/vocis = voice)", "p": 154}, {"t": "Gll. laryngeales", "m": "Laryngeal glands — mixed glands occupying the submucosa of the laryngeal wall", "e": "gll. (abbreviation of glandulae: L. glandula = small gland, from glans = acorn) + laryngeales (Gk. larynx/laryngos: upper windpipe + L. -alis = pertaining to)", "p": 154}, {"t": "Nodi lymphatici laryngis", "m": "Lymph nodes of larynx — lymphatic nodules abundant in the submucosa of the ventricle", "e": "nodi (L. nodus: knot, node, plural nodi) + lymphatici (L. lymphaticus: of lymph, from lympha = clear water) + laryngis (Gk. larynx/laryngos: upper windpipe, genitive)", "p": 154}, {"t": "TRACHEA", "m": "Airway characterized by its cartilage-containing wall and its branches, the bronchi", "e": "trachea (Gk. tracheia: rough, from trachy = rough, as in tracheia arteria = rough artery)", "p": 154}, {"t": "Cartilagines tracheales", "m": "Tracheal cartilages — horseshoe-shaped cartilages of the tracheal wall", "e": "cartilagines (L. cartilago/cartilaginis: cartilage, gristle, plural cartilagines) + tracheales (Gk. tracheia: rough + L. -ales = pertaining to)", "p": 154}, {"t": "Musculus trachealis", "m": "Tracheal muscle — smooth muscle between the free ends of the horseshoe-shaped tracheal cartilages", "e": "musculus (L. musculus: muscle, little mouse) + trachealis (Gk. tracheia: rough + L. -alis = pertaining to)", "p": 154}, {"t": "Ligg. trachealia", "m": "Annular ligaments of trachea — connective tissue bridges between the tracheal cartilages", "e": "ligg. (abbreviation of ligamenta: L. ligamentum = band, tie, from ligare = to bind) + trachealia (Gk. tracheia: rough + L. -alia = pertaining to)", "p": 154}, {"t": "Paries membranaceus", "m": "Membranous wall — posterior wall of trachea", "e": "paries (L. paries: wall) + membranaceus (L. membranaceus: membranous, from membrana = membrane)", "p": 154}, {"t": "Bifurcatio tracheae", "m": "Bifurcation of trachea — asymmetrical division of trachea at level of T4", "e": "bifurcatio (L. bifurcatio: forking into two, from bi = two + furca = fork) + tracheae (Gk. tracheia: rough, genitive form)", "p": 154}, {"t": "trachealis", "m": "Of or pertaining to the trachea (used as qualifier in bifurcatio trachealis)", "e": "trachealis (Gk. tracheia: rough windpipe + L. -alis = pertaining to)", "p": 154}, {"t": "Carina tracheae", "m": "Ridge projecting into the lumen of the trachea at its bifurcation providing an aerodynamic effect", "e": "carina (L. carina: keel of a ship) + tracheae (Gk. tracheia: rough, genitive form)", "p": 154}, {"t": "Gll. tracheales", "m": "Tracheal glands — mixed glands in the submucosa", "e": "gll. (abbreviation of glandulae: L. glandula = small gland, from glans = acorn) + tracheales (Gk. tracheia: rough + L. -ales = pertaining to)", "p": 154}, {"t": "BRONCHI", "m": "Branches of trachea", "e": "bronchi (Gk. bronkhos: windpipe, throat, plural bronchi)", "p": 154}, {"t": "Arbor bronchialis", "m": "Bronchial tree — the entire branching system of the bronchi", "e": "arbor (L. arbor: tree) + bronchialis (Gk. bronkhos: windpipe + L. -alis = pertaining to)", "p": 154}, {"t": "Bronchus principalis dexter et sinister", "m": "Main bronchus (right and left) — right and left stem bronchi arising directly from the trachea", "e": "bronchus (Gk. bronkhos: windpipe, throat) + principalis (L. principalis: chief, principal, from princeps = first, chief) + dexter (L. dexter: right, on the right side) + et (L. et: and) + sinister (L. sinister: left, on the left side)", "p": 154}, {"t": "Bronchi lobares et segmentales", "m": "Lobar and segmental bronchi — bronchi for the five lobes of the lung and their 20 segments", "e": "bronchi (Gk. bronchos: windpipe, airway) + lobares (L. lobaris: of a lobe, from Gk. lobos = lobe) + et (L. et: and) + segmentales (L. segmentalis: of a segment, from secare = to cut)", "p": 156}, {"t": "Bronchus lobaris superior dexter", "m": "Right superior lobar bronchus — bronchus for the superior lobe of the right lung", "e": "bronchus (Gk. bronchos: windpipe) + lobaris (L. lobaris: of a lobe) + superior (L. superior: upper, higher) + dexter (L. dexter: right)", "p": 156}, {"t": "Bronchus segmentalis apicalis", "m": "Apical segmental bronchus (B I) — bronchus for the apical segment extending inferiorly as far as the 3rd rib", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + apicalis (L. apicalis: of the apex, from apex = tip, summit)", "p": 156}, {"t": "Bronchus segmentalis posterior", "m": "Posterior segmental bronchus (B II) — bronchus for the posterior segment extending forward about as far as the midaxillary line", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + posterior (L. posterior: behind, later)", "p": 156}, {"t": "Bronchus segmentalis anterior", "m": "Anterior segmental bronchus (B III) — bronchus for the anterior segment extending backward about as far as the midaxillary line", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + anterior (L. anterior: in front, former)", "p": 156}, {"t": "Bronchus lobaris medius dexter", "m": "Right middle lobar bronchus — lobar bronchus for the middle lobe of the right lung", "e": "bronchus (Gk. bronchos: windpipe) + lobaris (L. lobaris: of a lobe) + medius (L. medius: middle) + dexter (L. dexter: right)", "p": 156}, {"t": "Bronchus segmentalis lateralis", "m": "Lateral segmental bronchus (B IV) — bronchus for the lateral segment located on the dorsal surface of the middle lobe", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + lateralis (L. lateralis: of the side, from latus = side)", "p": 156}, {"t": "Bronchus segmentalis medialis", "m": "Medial segmental bronchus (B V) — segmental bronchus arising anteromedially from the middle lobe", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + medialis (L. medialis: of the middle, from medius = middle)", "p": 156}, {"t": "Bronchus lobaris inferior dexter", "m": "Right inferior lobar bronchus — lobar bronchus for the right inferior lobe extending posteriorly up to the 4th rib", "e": "bronchus (Gk. bronchos: windpipe) + lobaris (L. lobaris: of a lobe) + inferior (L. inferior: lower) + dexter (L. dexter: right)", "p": 156}, {"t": "Bronchus segmentalis superior", "m": "Superior segmental bronchus (B VI) — bronchus for the apical segment which borders only on the upper lobe", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + superior (L. superior: upper, higher)", "p": 156}, {"t": "Bronchus segmentalis subapicalis", "m": "Subapical segmental bronchus — occasionally present accessory bronchus", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + subapicalis (L. sub: below + apicalis: of the apex, from apex = tip)", "p": 156}, {"t": "Bronchus segmentalis basalis medialis", "m": "Medial basal segmental bronchus (B VII) — bronchus for the medial segment that does not reach the external surface of the lower lobe", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + basalis (L. basalis: of the base, from Gk. basis = base) + medialis (L. medialis: of the middle)", "p": 156}, {"t": "Bronchus segmentalis basalis anterior", "m": "Anterior basal segmental bronchus (B VIII) — bronchus for the wedge-shaped anterior end of the lower lobe", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + basalis (L. basalis: of the base) + anterior (L. anterior: in front)", "p": 156}, {"t": "Bronchus segmentalis basalis lateralis", "m": "Lateral basal segmental bronchus (B IX) — bronchus for the small lateral segment situated between the anterior and posterior segments", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + basalis (L. basalis: of the base) + lateralis (L. lateralis: of the side)", "p": 156}, {"t": "Bronchus segmentalis basalis posterior", "m": "Posterior basal segment bronchus (B X) — bronchus for the segment extending posteriorly up to the vertebral column", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + basalis (L. basalis: of the base) + posterior (L. posterior: behind)", "p": 156}, {"t": "Bronchus lobaris superior sinister", "m": "Left inferior lobar bronchus — lobar bronchus for the left upper lobe", "e": "bronchus (Gk. bronchos: windpipe) + lobaris (L. lobaris: of a lobe) + superior (L. superior: upper) + sinister (L. sinister: left)", "p": 156}, {"t": "Bronchus segmentalis apicoposterior", "m": "Apicoposterior segmental bronchus (B I + II) — bronchus for the left apical segment located posterosuperiorly", "e": "bronchus (Gk. bronchos: windpipe) + segmentalis (L. segmentalis: of a segment) + apicoposterior (L. apex/apico: tip + posterior: behind, combining apical and posterior)", "p": 156}, {"t": "Bronchus lingularis superior", "m": "Superior lingular bronchus (B IV) — bronchus for the second lowest segment of the left upper lobe extending posteriorly as far as the border of the lower lobe", "e": "bronchus (Gk. bronchos: windpipe) + lingularis (L. lingularis: of the lingula, from lingua = tongue, lingula = small tongue) + superior (L. superior: upper)", "p": 156}, {"t": "Bronchus lingularis inferior", "m": "Inferior lingular bronchus (B V) — bronchus for the mainly anterior lowest segment of the upper lobe", "e": "bronchus (Gk. bronchos: windpipe) + lingularis (L. lingularis: of the lingula, from lingua = tongue) + inferior (L. inferior: lower)", "p": 156}, {"t": "Bronchus lobaris inferior sinister", "m": "Left inferior lobar bronchus — lobar bronchus for the left lower lobe extending dorsally up to the 4th thoracic vertebra", "e": "bronchus (Gk. bronchos: windpipe) + lobaris (L. lobaris: of a lobe) + inferior (L. inferior: lower) + sinister (L. sinister: left)", "p": 156}, {"t": "Rami bronchiales segmentorum", "m": "Segmental bronchial branches — branches of individual segmental bronchi", "e": "rami (L. ramus: branch) + bronchiales (Gk. bronkhia: windpipe, airways) + segmentorum (L. segmentum: segment, from secare = to cut)", "p": 158}, {"t": "Gll. bronchiales", "m": "Bronchial glands — mixed glands located below the mucosa", "e": "gll. (L. glandulae: glands, from glans = acorn) + bronchiales (Gk. bronkhia: windpipe, airways)", "p": 158}, {"t": "Pulmones", "m": "Lungs — they occupy the greater portion of the thoracic space", "e": "pulmones (L. pulmo/pulmones: lungs)", "p": 158}, {"t": "Pulmo dexter", "m": "Right lung", "e": "pulmo (L. pulmo: lung) + dexter (L. dexter: right)", "p": 158}, {"t": "Pulmo sinister", "m": "Left lung", "e": "pulmo (L. pulmo: lung) + sinister (L. sinister: left)", "p": 158}, {"t": "Basis pulmonis", "m": "Base of lung — lower lung segment bordering on the diaphragm", "e": "basis (Gk./L. basis: base, foundation) + pulmonis (L. pulmo: lung, genitive form)", "p": 158}, {"t": "Apex pulmonis", "m": "Apex of lung — apical portion of the lung partially occupying the superior thoracic aperture", "e": "apex (L. apex: tip, summit) + pulmonis (L. pulmo: lung, genitive form)", "p": 158}, {"t": "Facies costalis", "m": "Costal surface — lung surface bordering the ribs", "e": "facies (L. facies: face, surface) + costalis (L. costalis: of the ribs, from costa = rib)", "p": 158}, {"t": "Pars vertebralis", "m": "Vertebral part — dorsal portion of medial surface of each lung adjacent to the vertebral column", "e": "pars (L. pars: part) + vertebralis (L. vertebralis: of the vertebra, from vertebra = joint, from vertere = to turn)", "p": 158}, {"t": "Facies mediastinalis", "m": "Mediastinal surface — lung surface bordering the mediastinum and lying in front of the vertebral part", "e": "facies (L. facies: face, surface) + mediastinalis (L. mediastinum: middle partition, from medius = middle)", "p": 158}, {"t": "Facies interlobaris", "m": "Interlobar surface — surface of lung tissue found in the spaces between the lobes", "e": "facies (L. facies: face, surface) + interlobaris (L. inter = between + lobus, from Gk. lobos = lobe)", "p": 158}, {"t": "Incisura cardiaca pulmonis sinistri", "m": "Cardiac notch — notch on the anterior margin of the left upper lobe produced by the cardiac impression", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + cardiaca (Gk. kardia: heart) + pulmonis (L. pulmo: lung, genitive) + sinistri (L. sinister: left, genitive form)", "p": 158}, {"t": "Hilum pulmonis", "m": "Hilum of lung — site of entry of bronchi and vessels on the medial surface", "e": "hilum (L. hilum: small thing, trifle; in anatomy a depression/entry point) + pulmonis (L. pulmo: lung, genitive form)", "p": 158}, {"t": "Radix pulmonis", "m": "Root of lung — consists of the main bronchus, blood vessels, lymph vessels/nodes and autonomic plexuses", "e": "radix (L. radix: root) + pulmonis (L. pulmo: lung, genitive form)", "p": 158}, {"t": "Pediculus pulmonis", "m": "Root of lung (pedicle) — consists of the main bronchus, blood vessels, lymph vessels/nodes and autonomic plexuses", "e": "pediculus (L. pediculus: little foot, stalk, from pes/pedis = foot) + pulmonis (L. pulmo: lung, genitive form)", "p": 158}, {"t": "Lingula pulmonis sinistri", "m": "Lingula of left lung — portion of the upper lobe of the left lung between the cardiac notch and the oblique fissure", "e": "lingula (L. lingula: little tongue, diminutive of lingua = tongue) + pulmonis (L. pulmo: lung, genitive) + sinistri (L. sinister: left, genitive form)", "p": 158}, {"t": "Culmen pulmonis sinistri", "m": "Culmen of left lung — upper lobe without lingula", "e": "culmen (L. culmen: summit, top) + pulmonis (L. pulmo: lung, genitive) + sinistri (L. sinister: left, genitive form)", "p": 158}, {"t": "Lobus superior", "m": "Upper lobe — extends posteriorly as far as the 4th rib", "e": "lobus (Gk. lobos: lobe) + superior (L. superior: upper, higher, comparative of superus = above)", "p": 158}, {"t": "Lobus medius pulmonis dextri", "m": "Middle lobe — present only in the right lung, lies in front of the midaxillary line between the 4th and 6th ribs", "e": "lobus (Gk. lobos: lobe) + medius (L. medius: middle) + pulmonis (L. pulmo: lung, genitive) + dextri (L. dexter: right, genitive form)", "p": 158}, {"t": "Lobus inferior", "m": "Lower lobe — extends mainly dorsal, its superior border courses obliquely posterosuperior to anteroinferior", "e": "lobus (Gk. lobos: lobe) + inferior (L. inferior: lower, comparative of inferus = below)", "p": 158}, {"t": "Fissura obliqua", "m": "Oblique fissure — oblique fissure between the lower and upper lobes of the left lung, and between the lower and upper lobes, as well as the middle lobe, of the right lung", "e": "fissura (L. fissura: cleft, fissure, from findere = to split) + obliqua (L. obliquus: slanting, oblique)", "p": 158}, {"t": "Fissura horizontalis pulmonis dextri", "m": "Horizontal fissure of right lung — fissure separating the middle and upper lobes at the level of the 4th rib", "e": "fissura (L. fissura: cleft, fissure, from findere = to split) + horizontalis (Gk. horizon: bounding circle, from horizein = to bound) + pulmonis (L. pulmo: lung, genitive) + dextri (L. dexter: right, genitive form)", "p": 158}, {"t": "Segmenta bronchopulmonalia", "m": "Bronchopulmonary segments — lung segments supplied by individual bronchi and arteries and separated by veins and connective tissue septa", "e": "segmenta (L. segmentum: segment, section, from secare = to cut) + bronchopulmonalia (Gk. bronchos: windpipe + L. pulmo: lung, thus bronchopulmonary)", "p": 160}, {"t": "Pulmo dexter, lobus superior", "m": "Upper lobe of right lung", "e": "pulmo (L. pulmo: lung) + dexter (L. dexter: right) + lobus (Gk. lobos: lobe) + superior (L. superior: upper, higher)", "p": 160}, {"t": "Segmentum apicale (S I)", "m": "Apical segment of upper lobe of right lung — inserted like a wedge between the anterior and posterior segments", "e": "segmentum (L. segmentum: segment, from secare = to cut) + apicale (L. apicalis: of the apex, from apex = tip, summit)", "p": 160}, {"t": "Segmentum posterius (S II)", "m": "Posterior segment of upper lobe of right lung — lies between the apical segment and the lower lobe", "e": "segmentum (L. segmentum: segment, from secare = to cut) + posterius (L. posterius: posterior, behind, from post = after)", "p": 160}, {"t": "Segmentum anterius (S III)", "m": "Anterior segment of upper lobe of right lung — lies between the apical segment and the middle lobe", "e": "segmentum (L. segmentum: segment, from secare = to cut) + anterius (L. anterius: anterior, in front, from ante = before)", "p": 160}, {"t": "Pulmo dexter, lobus medius", "m": "Middle lobe of right lung", "e": "pulmo (L. pulmo: lung) + dexter (L. dexter: right) + lobus (Gk. lobos: lobe) + medius (L. medius: middle)", "p": 160}, {"t": "Segmentum laterale (S IV)", "m": "Lateral segment of middle lobe — occupies the dorsal portion of the middle lobe and does not reach the hilum", "e": "segmentum (L. segmentum: segment, from secare = to cut) + laterale (L. lateralis: of the side, from latus = side)", "p": 160}, {"t": "Segmentum mediale (S V)", "m": "Medial segment of middle lobe — forms the medial and diaphragmatic surfaces of the middle lobe", "e": "segmentum (L. segmentum: segment, from secare = to cut) + mediale (L. medialis: of the middle, from medius = middle)", "p": 160}, {"t": "Lobus inferior pulmonis dextri", "m": "Lower lobe of right lung", "e": "lobus (Gk. lobos: lobe) + inferior (L. inferior: lower) + pulmonis (L. pulmo, pulmonis: lung) + dextri (L. dexter, dextri: right)", "p": 160}, {"t": "Pulmo dexter, lobus inferior", "m": "Lower lobe of right lung", "e": "pulmo (L. pulmo: lung) + dexter (L. dexter: right) + lobus (Gk. lobos: lobe) + inferior (L. inferior: lower)", "p": 160}, {"t": "Segmentum superius (S VI)", "m": "Superior segment — posterosuperiorly situated apical portion of lower lobe", "e": "segmentum (L. segmentum: segment, from secare = to cut) + superius (L. superius: upper, from super = above)", "p": 160}, {"t": "Segmentum subapicale", "m": "Subapical segment — accessory segment occasionally present below the superior segment", "e": "segmentum (L. segmentum: segment, from secare = to cut) + subapicale (L. sub = below + apicalis = of the apex, from apex = tip)", "p": 160}, {"t": "Segmentum basale mediale (cardiacum) (S VII)", "m": "Medial basal (cardiac) segment — does not reach the lateral surface of the lung and is only seen from the medial and inferior surfaces", "e": "segmentum (L. segmentum: segment) + basale (L. basalis: of the base, from Gk. basis = base) + mediale (L. medialis: medial, from medius = middle) + cardiacum (Gk. kardiakos: of the heart, from kardia = heart)", "p": 160}, {"t": "Segmentum basale anterius (S VIII)", "m": "Anterior basal segment — lies between the middle lobe and diaphragm", "e": "segmentum (L. segmentum: segment) + basale (L. basalis: of the base, from Gk. basis = base) + anterius (L. anterius: anterior, from ante = before)", "p": 160}, {"t": "Segmentum basale laterale (S IX)", "m": "Lateral basal segment — lies between the posterior and anterior basal segments", "e": "segmentum (L. segmentum: segment) + basale (L. basalis: of the base, from Gk. basis = base) + laterale (L. lateralis: of the side, from latus = side)", "p": 160}, {"t": "Segmentum basale posterius (S X)", "m": "Posterior basal segment — located between the vertebral column and lateral basal segment", "e": "segmentum (L. segmentum: segment) + basale (L. basalis: of the base, from Gk. basis = base) + posterius (L. posterius: posterior, from post = after/behind)", "p": 160}, {"t": "Lobus superior pulmonis sinistri", "m": "Upper lobe of left lung", "e": "lobus (Gk. lobos: lobe) + superior (L. superior: upper) + pulmonis (L. pulmo, pulmonis: lung) + sinistri (L. sinister, sinistri: left)", "p": 160}, {"t": "Pulmo sinister, lobus superior", "m": "Upper lobe of left lung", "e": "pulmo (L. pulmo: lung) + sinister (L. sinister: left) + lobus (Gk. lobos: lobe) + superior (L. superior: upper)", "p": 160}, {"t": "Segmentum apicoposterius (S I + II)", "m": "Apicoposterior segment — comprises two wedge-shaped segments (apical and posterior) which lie between the oblique fissure and the anterior segment of the upper lobe", "e": "segmentum (L. segmentum: segment) + apicoposterius (L. apex/apicis = tip + posterius = behind/posterior, from post = after)", "p": 160}, {"t": "Segmentum lingulare superius (S IV)", "m": "Superior lingular segment — lies predominantly on the inferior lingular segment", "e": "segmentum (L. segmentum: segment) + lingulare (L. lingularis: of the little tongue, from lingula = little tongue, diminutive of lingua = tongue) + superius (L. superius: upper, from super = above)", "p": 160}, {"t": "Segmentum lingulare inferius (S V)", "m": "Inferior lingular segment — lies between the superior lingular segment and the oblique fissure", "e": "segmentum (L. segmentum: segment) + lingulare (L. lingularis: of the little tongue, from lingula = diminutive of lingua = tongue) + inferius (L. inferius: lower, from inferus = below)", "p": 160}, {"t": "Lobus inferior pulmonis sinistri", "m": "Lower lobe of left lung", "e": "lobus (Gk. lobos: lobe) + inferior (L. inferior: lower) + pulmonis (L. pulmo, pulmonis: lung) + sinistri (L. sinister, sinistri: left)", "p": 160}, {"t": "Pulmo sinister, lobus inferior", "m": "Lower lobe of left lung", "e": "pulmo (L. pulmo: lung) + sinister (L. sinister: left) + lobus (Gk. lobos: lobe) + inferior (L. inferior: lower)", "p": 160}, {"t": "Bronchioli", "m": "Bronchioles — noncartilaginous segments of the respiratory tree directly following the bronchi", "e": "bronchioli (Gk. bronchos: windpipe + L. -ioli: diminutive plural suffix)", "p": 162}, {"t": "Bronchioli respiratorii", "m": "Respiratory bronchioles — last bronchiolar segment the wall of which already consists partially of alveoli", "e": "bronchioli (Gk. bronchos: windpipe + L. -ioli: diminutive plural) + respiratorii (L. respirare: to breathe again, re- = again + spirare = to breathe)", "p": 162}, {"t": "Ductuli alveolares", "m": "Alveolar ducts — terminal branches of the respiratory bronchioles the walls of which contain only alveoli", "e": "ductuli (L. ductus: duct, conduit, from ducere = to lead + -uli: diminutive plural) + alveolares (L. alveolus: small cavity, from alveus = hollow + -ares: adjective suffix)", "p": 162}, {"t": "Sacculi alveolares", "m": "Alveolar sacs — blind, expanded ends of the alveolar ducts", "e": "sacculi (L. saccus: sack, bag + -uli: diminutive plural) + alveolares (L. alveolus: small cavity, from alveus = hollow)", "p": 162}, {"t": "Alveoli pulmonis", "m": "Pulmonary alveoli — smallest outpocketings, 0.1–0.9 mm in diameter, the thin walls of which permit the exchange of gases", "e": "alveoli (L. alveolus: small cavity, pit, from alveus = hollow + -i: plural) + pulmonis (L. pulmo: lung, genitive pulmonis)", "p": 162}, {"t": "Regiones pleuropulmonales", "m": "Pleuropulmonary regions — regions connecting the pleura and lungs", "e": "regiones (L. regio: region, district, from regere = to rule + -ones: plural) + pleuropulmonales (Gk. pleura: rib, side + L. pulmo: lung + -ales: adjective suffix)", "p": 162}, {"t": "Fascia endothoracica", "m": "Endothoracic fascia — displaceable layer of loose connective tissue between the parietal pleura and chest wall", "e": "fascia (L. fascia: band, bandage, bundle) + endothoracica (Gk. endon: within + Gk. thorax: chest + -ica: adjective suffix)", "p": 162}, {"t": "Membrana suprapleuralis", "m": "Suprapleural membrane — thickened portion of the endothoracic fascia in the region of the pleural cupola", "e": "membrana (L. membrana: membrane, thin skin, from membrum = limb) + suprapleuralis (L. supra: above + Gk. pleura: rib, side + -alis: adjective suffix)", "p": 162}, {"t": "Fascia phrenicopleuralis", "m": "Phrenicopleural fascia — portion of the endothoracic fascia which connects the parietal pleura with the diaphragm", "e": "fascia (L. fascia: band, bandage) + phrenicopleuralis (Gk. phren: diaphragm, mind + Gk. pleura: rib, side + -alis: adjective suffix)", "p": 162}, {"t": "Cavitas pleuralis", "m": "Pleural cavity — capillary fissure-like space between the parietal and visceral pleura containing a small amount of serous fluid", "e": "cavitas (L. cavitas: hollow space, from cavus = hollow) + pleuralis (Gk. pleura: rib, side + -alis: adjective suffix)", "p": 162}, {"t": "Pleura", "m": "Pleura — serous membrane consisting of simple squamous epithelium and underlying connective tissue", "e": "pleura (Gk. pleura: rib, side; used to denote the membrane lining the thorax)", "p": 162}, {"t": "Cupula pleurae", "m": "Cupula (dome) of pleura — covers the apex of the lung at the superior thoracic aperture and forms the boundary between the neck and thorax", "e": "cupula (L. cupula: small tub or cask, diminutive of cupa = tub, vat) + pleurae (Gk. pleura: rib, side + -ae: genitive singular)", "p": 162}, {"t": "Pleura visceralis", "m": "Visceral (pulmonary) pleura — portion of the pleura that envelops the lung and passes into the interlobar spaces", "e": "pleura (Gk. pleura: rib, side) + visceralis (L. viscera: internal organs + -alis: adjective suffix)", "p": 162}, {"t": "Pleura pulmonalis", "m": "Pulmonary pleura — portion of the pleura that envelops the lung (alternate term for visceral pleura)", "e": "pleura (Gk. pleura: rib, side) + pulmonalis (L. pulmo: lung + -alis: adjective suffix)", "p": 162}, {"t": "Pleura parietalis", "m": "Parietal pleura — serous lining of the space in which the lungs lodge", "e": "pleura (Gk. pleura: rib, side) + parietalis (L. paries: wall + -alis: adjective suffix)", "p": 162}, {"t": "Pars mediastinalis", "m": "Mediastinal part of parietal pleura — portion of the parietal pleura lining the mediastinum", "e": "pars (L. pars: part, portion) + mediastinalis (L. mediastinum: middle partition, from medius = middle + -alis: adjective suffix)", "p": 162}, {"t": "Pars costalis", "m": "Costal part of parietal pleura — lines the ribs", "e": "pars (L. pars: part, portion) + costalis (L. costa: rib + -alis: adjective suffix)", "p": 162}, {"t": "Pars diaphragmatica", "m": "Diaphragmatic part of parietal pleura — covers the diaphragm", "e": "pars (L. pars: part, portion) + diaphragmatica (Gk. diaphragma: partition, midriff, from dia = through + phrassein = to fence + -ica: adjective suffix)", "p": 162}, {"t": "Recessus pleurales", "m": "Pleural recesses — fissure-shaped spaces formed by the parietal pleura for reception of the lungs during inspiration", "e": "recessus (L. recessus: recess, withdrawal, from recedere = to go back) + pleurales (Gk. pleura: rib, side + -ales: adjective suffix)", "p": 162}, {"t": "Recessus costodiaphragmaticus", "m": "Costodiaphragmatic recess — pleural recess between the descending sides of the diaphragm and the lateral wall of the thorax", "e": "recessus (L. recessus: recess, withdrawal) + costodiaphragmaticus (L. costa: rib + Gk. diaphragma: partition, midriff + -icus: adjective suffix)", "p": 162}, {"t": "Recessus costomediastinalis", "m": "Costomediastinal recess — anterior pleural space between the costal and mediastinal pleura; more extensive on the left than on the right", "e": "recessus (L. recessus: recess, withdrawal) + costomediastinalis (L. costa: rib + L. mediastinum: middle partition + -alis: adjective suffix)", "p": 162}, {"t": "Recessus phrenicomediastinalis", "m": "Phrenicomediastinal recess — pleural recess situated dorsally between the diaphragm and the mediastinum", "e": "recessus (L. recessus: recess, withdrawal) + phrenicomediastinalis (Gk. phren: diaphragm + L. mediastinum: middle partition + -alis: adjective suffix)", "p": 162}, {"t": "Lig. pulmonale", "m": "Pulmonary ligament — double fold extending from the right and left sides of the hilum, connecting the visceral and mediastinal pleura", "e": "lig. / ligamentum (L. ligamentum: ligament, bond, from ligare = to bind) + pulmonale (L. pulmo: lung + -ale: adjective suffix)", "p": 162}, {"t": "Mediastinum", "m": "Mediastinum — thoracic area between both pleural sacs, extending from the anterior surface of the vertebral column to the posterior surface of the sternum and from the upper thoracic aperture to the diaphragm", "e": "mediastinum (L. mediastinum: middle partition, from medius = middle + -astinum: suffix denoting region)", "p": 162}, {"t": "Mediastinum superius", "m": "Superior mediastinum — portion of the mediastinum above the heart, containing the arch of the aorta, brachiocephalic veins, superior vena cava, trachea, esophagus, vagus nerves, thoracic duct, thymus, etc.", "e": "mediastinum (L. medius: middle + -astinum: suffix) + superius (L. superus: upper, from super = above)", "p": 162}, {"t": "Mediastinum inferius", "m": "Inferior mediastinum — collective term for the following three divisions", "e": "mediastinum (L. medius: middle + -astinum: suffix) + inferius (L. inferus: lower, from infra = below)", "p": 162}, {"t": "Mediastinum anterius", "m": "Anterior mediastinum — area between the pericardium and sternum", "e": "mediastinum (L. medius: middle + -astinum: suffix) + anterius (L. anterior: more in front, from ante = before)", "p": 162}, {"t": "Mediastinum medium", "m": "Middle mediastinum — area occupied by the heart, pericardium and phrenic nerves with their accompanying vessels", "e": "mediastinum (L. medius: middle + -astinum: suffix) + medium (L. medius: middle, central)", "p": 162}, {"t": "Mediastinum posterius", "m": "Posterior mediastinum — area between the pericardium and the vertebral column, containing the esophagus, vagus nerves, descending aorta, thoracic duct and the azygos and hemiazygos veins", "e": "mediastinum (L. medius: middle + -astinum: suffix) + posterius (L. posterior: more behind, from post = after, behind)", "p": 162}, {"t": "Apparatus urogenitalis", "m": "Urogenital system", "e": "apparatus (L. apparātus: equipment, preparation, from apparāre = to prepare) + urogenitalis (L. uro- from Gk. ouron: urine + genitalis from L. genere: to beget, produce)", "p": 164}, {"t": "Systema urogenitale", "m": "Urogenital system (alternate term)", "e": "systema (Gk. systēma: organized whole, from syn- = together + histanai = to set) + urogenitale (L. uro- from Gk. ouron: urine + genitale from L. genere: to beget)", "p": 164}, {"t": "Organa urinaria", "m": "Urinary organs", "e": "organa (Gk. organon: instrument, organ) + urinaria (L. urinarius: of urine, from urina: urine)", "p": 164}, {"t": "Ren", "m": "Kidney", "e": "ren (L. rēn: kidney)", "p": 164}, {"t": "Nephros", "m": "Kidney (Greek term)", "e": "nephros (Gk. nephros: kidney)", "p": 164}, {"t": "Hilum renale", "m": "Renal hilum — site of entry and exit of renal blood vessels and ureter", "e": "hilum (L. hilum: small thing, trifle; anatomically: notch or depression where vessels enter) + renale (L. renālis: of the kidney, from rēn: kidney)", "p": 164}, {"t": "Sinus renalis", "m": "Renal sinus — very concave cavity at the medial border for the renal hilum", "e": "sinus (L. sinus: curve, hollow, bay, cavity) + renalis (L. renālis: of the kidney, from rēn: kidney)", "p": 164}, {"t": "Extremitas superior", "m": "Upper pole of kidney", "e": "extremitas (L. extremitās: end, tip, extremity, from extremus: outermost) + superior (L. superior: upper, higher, from superus: above)", "p": 164}, {"t": "Extremitas inferior", "m": "Lower pole of kidney", "e": "extremitas (L. extremitās: end, tip, extremity) + inferior (L. inferior: lower, from inferus: below)", "p": 164}, {"t": "Fascia renalis", "m": "Renal fascia — fibrous sheath that separates the adipose capsule from the perirenal fat", "e": "fascia (L. fascia: band, bandage, strip) + renalis (L. renālis: of the kidney, from rēn: kidney)", "p": 164}, {"t": "Corpus adiposum pararenale", "m": "Pararenal fatty body — fat pad between the posterior layer of the renal fascia and the transversalis fascia", "e": "corpus (L. corpus: body) + adiposum (L. adipōsus: fatty, from adeps: fat) + pararenale (Gk. para: beside, near + L. renāle: of the kidney)", "p": 164}, {"t": "Capsula adiposa", "m": "Fatty capsule — fatty capsule of the kidney, more prominent posteriorly and medially", "e": "capsula (L. capsula: small box, diminutive of capsa: box, case) + adiposa (L. adipōsa: fatty, from adeps: fat)", "p": 164}, {"t": "Capsula fibrosa", "m": "Fibrous capsule — tough organ capsule fused with the surface of the kidney, but removable", "e": "capsula (L. capsula: small box, case) + fibrosa (L. fibrōsa: fibrous, from fibra: fiber, filament)", "p": 164}, {"t": "Segmenta renalia", "m": "Renal segments — five segments of the kidney corresponding to the blood supply regions of the branches of the renal artery", "e": "segmenta (L. segmentum: piece cut off, segment, from secare: to cut) + renalia (L. renālia: of the kidneys, from rēn: kidney)", "p": 164}, {"t": "Segm. superius", "m": "Superior segment — upper segment extending up to the posterior surface", "e": "segmentum (L. segmentum: segment, piece cut off) + superius (L. superius: upper, from superus: above)", "p": 164}, {"t": "Segm. anterius superius", "m": "Upper anterior segment", "e": "segmentum (L. segmentum: segment) + anterius (L. anterius: in front, from ante: before) + superius (L. superius: upper, from superus: above)", "p": 164}, {"t": "Segm. anterius inferius", "m": "Lower anterior segment", "e": "segmentum (L. segmentum: segment) + anterius (L. anterius: in front) + inferius (L. inferius: lower, from inferus: below)", "p": 164}, {"t": "Segm. inferius", "m": "Inferior segment — reaches as far as the posterior and anterior surfaces", "e": "segmentum (L. segmentum: segment) + inferius (L. inferius: lower, from inferus: below)", "p": 164}, {"t": "Segm. posterius", "m": "Posterior segment", "e": "segmentum (L. segmentum: segment) + posterius (L. posterius: behind, from post: after, behind)", "p": 164}, {"t": "Tubulus renalis", "m": "Renal (uriniferous) tubule (nephron) — tubular system representing the structural unit of the kidney", "e": "tubulus (L. tubulus: small tube, diminutive of tubus: tube, pipe) + renalis (L. renālis: of the kidney, from rēn: kidney)", "p": 164}, {"t": "Tubuli renales contorti", "m": "Convoluted uriniferous tubules — tortuous parts of the renal tubules", "e": "tubuli (L. tubuli: small tubes, plural of tubulus) + renales (L. renāles: of the kidneys) + contorti (L. contortus: twisted, wound, from contorquēre: to twist together)", "p": 164}, {"t": "Tubuli renales recti", "m": "Straight segments of renal tubules", "e": "tubuli (L. tubuli: small tubes) + renales (L. renāles: of the kidneys) + recti (L. rectus: straight, upright, from regere: to keep straight)", "p": 164}, {"t": "Lobi renales", "m": "Renal lobes — still preserved in the newborn, corresponding to renal pyramids with cortical caps", "e": "lobi (L. lobus: lobe, from Gk. lobos: lobe, rounded projection) + renales (L. renāles: of the kidneys, from rēn: kidney)", "p": 164}, {"t": "Cortex renalis", "m": "Renal cortex — about 6 mm thick, consists of glomeruli and predominantly convoluted uriniferous tubules", "e": "cortex (L. cortex: bark, rind, outer layer) + renalis (L. renālis: of the kidney, from rēn: kidney)", "p": 164}, {"t": "Pars convoluta", "m": "Convoluted part (cortical labyrinth) — cortical region consisting of glomeruli and convoluted uriniferous tubules", "e": "pars (L. pars: part, portion) + convoluta (L. convolūta: rolled together, convoluted, from convolvere: to roll together)", "p": 164}, {"t": "Pars radiata", "m": "Radiating part (medullary rays) — collecting tubules coursing radially into the cortex from the medulla", "e": "pars (L. pars: part, portion) + radiata (L. radiāta: radiated, from radius: ray, spoke of a wheel)", "p": 164}, {"t": "Lobuli corticales", "m": "Cortical lobules — areas delimited by interlobular arteries", "e": "lobuli (L. lobuli: small lobes, diminutive of lobus: lobe) + corticales (L. corticāles: of the cortex, from cortex: bark, outer layer)", "p": 164}, {"t": "Radii medullares", "m": "Medullary rays — consisting of pale collecting tubules which project into the cortex", "e": "radii (L. radii: rays, spokes, plural of radius: ray) + medullares (L. medullāres: of the medulla, from medulla: marrow, inner part, from medius: middle)", "p": 164}, {"t": "Medulla renalis", "m": "Renal medulla — medullary tissue in the shape of renal pyramids consisting of straight portions of the uriniferous tubules and collecting ducts", "e": "medulla (L. medulla: marrow, inner substance, from medius: middle) + renalis (L. renālis: of the kidney, from rēn: kidney)", "p": 164}, {"t": "Pyramides renales", "m": "Renal pyramids — six to twenty pyramidal areas separated by renal columns forming the medullary substance", "e": "pyramides (Gk./L. pyramides: pyramids, plural of pyramis, from Gk. pyramis: pyramid) + renales (L. renāles: of the kidneys, from rēn: kidney)", "p": 164}, {"t": "Basis pyramidis", "m": "Base of pyramid — lies at the corticomedullary border", "e": "basis (Gk./L. basis: base, foundation, from Gk. bainein: to go, step) + pyramidis (L. pyramidis: of the pyramid, genitive of pyramis)", "p": 164}, {"t": "Papillae renales", "m": "Renal papillae — rounded apical portion of the renal pyramid projecting into the renal calyx", "e": "papillae (L. papilla: nipple, teat, diminutive of papula: pimple; plural papillae) + renales (L. renāles: of the kidneys, from rēn: kidney)", "p": 164}, {"t": "Area cribrosa", "m": "Area cribrosa — surface of renal papillae with sieve-like perforations created by the openings of the uriniferous tubules", "e": "area (L. area: open space, surface, area) + cribrosa (L. cribrōsa: sieve-like, perforated, from cribrum: sieve)", "p": 164}, {"t": "Foramina papillaria", "m": "Papillary foramina — holes in the area cribrosa produced by the openings of the uriniferous tubules", "e": "foramina (L. foramina: openings, holes, plural of foramen, from forāre: to bore, pierce) + papillaria (L. papillāria: of the papilla, from papilla: nipple, teat)", "p": 164}, {"t": "Columnae renales", "m": "Renal columns — cortical substance which extends toward the hilum between the renal pyramids", "e": "columnae (L. columnae: columns, pillars, plural of columna: column, pillar) + renales (L. renāles: of the kidneys, from rēn: kidney)", "p": 164}, {"t": "Corpusculum renale", "m": "Renal corpuscle — composed of a glomerulus and its capsule; lies in the convoluted part of the cortex", "e": "corpusculum (L. corpusculum: small body, diminutive of corpus: body) + renale (L. renāle: of the kidney, from rēn: kidney)", "p": 164}, {"t": "Glomerulus", "m": "Glomerulus — capillary tuft within a renal corpuscle", "e": "glomerulus (L. glomerulus: small ball of thread, diminutive of glomus: ball, clew of thread)", "p": 164}, {"t": "Capsula glomerularis", "m": "Glomerular (Bowman's) capsule — the capsule around a capillary tuft (glomerulus) of a renal corpuscle, continuous with a convoluted tubule", "e": "capsula (L. capsula: small box, case, diminutive of capsa: box) + glomerularis (L. glomerulāris: of the glomerulus, from glomerulus: small ball)", "p": 164}, {"t": "Arteriae renales", "m": "Renal arteries", "e": "arteriae (L. arteria: artery, from Gk. artēria: windpipe, artery) + renales (L. renalis: of the kidney, from renes = kidneys)", "p": 166}, {"t": "Arteriae interlobares", "m": "Interlobar arteries — arteries that run between the pyramids", "e": "arteriae (L. arteria: artery) + interlobares (L. inter: between + lobus: lobe, from Gk. lobos: lobe)", "p": 166}, {"t": "Arteriae arcuatae", "m": "Arcuate arteries — arising from the interlobar arteries, they take an arched course along the medullo-cortical border", "e": "arteriae (L. arteria: artery) + arcuatae (L. arcuatus: arched, bow-shaped, from arcus = bow, arch)", "p": 166}, {"t": "Arteriola glomerularis afferens", "m": "Afferent glomerular arteriole — arteriole arising from an interlobular artery and entering a renal corpuscle where it subdivides to form the capillary tuft", "e": "arteriola (L. arteriola: small artery, diminutive of arteria) + glomerularis (L. glomerularis: of a glomerulus, from glomus = ball of thread) + afferens (L. afferens: carrying toward, from ad = to + ferre = to carry)", "p": 166}, {"t": "Arteriola glomerularis efferens", "m": "Efferent glomerular arteriole — arteriole leaving the glomerulus and forming a capillary network between the convoluted tubules", "e": "arteriola (L. arteriola: small artery) + glomerularis (L. glomerularis: of a glomerulus, from glomus = ball) + efferens (L. efferens: carrying away, from ex = out + ferre = to carry)", "p": 166}, {"t": "Rami capsulares", "m": "Capsular branches — small arteries passing from the cortex to the capsule", "e": "rami (L. ramus: branch) + capsulares (L. capsularis: of a capsule, from capsula = small box, diminutive of capsa = box)", "p": 166}, {"t": "Arteriolae rectae", "m": "Straight arterioles — straight vessels coursing from the efferent glomerular arterioles to the capillary network of the tubules or coming from the arcuate arteries into the medulla", "e": "arteriolae (L. arteriola: small artery, diminutive of arteria) + rectae (L. rectus: straight, upright)", "p": 166}, {"t": "Venae renales", "m": "Renal veins", "e": "venae (L. vena: vein) + renales (L. renalis: of the kidney, from renes = kidneys)", "p": 166}, {"t": "Venae interlobares", "m": "Interlobar veins — veins coming from the periphery between the renal pyramids", "e": "venae (L. vena: vein) + interlobares (L. inter: between + lobus: lobe, from Gk. lobos)", "p": 166}, {"t": "Venae arcuatae", "m": "Arcuate veins — veins that run an arched course along the corticomedullary border", "e": "venae (L. vena: vein) + arcuatae (L. arcuatus: arched, from arcus = bow, arch)", "p": 166}, {"t": "Venulae rectae", "m": "Straight venules — fine veins in the medullary substance which open into the arcuate veins", "e": "venulae (L. venula: small vein, diminutive of vena) + rectae (L. rectus: straight)", "p": 166}, {"t": "Venulae stellatae", "m": "Stellate venules — veins forming a stellate network beneath the capsule and emptying into the interlobular veins", "e": "venulae (L. venula: small vein, diminutive of vena) + stellatae (L. stellatus: star-shaped, from stella = star)", "p": 166}, {"t": "Pelvis renalis", "m": "Renal pelvis — funnel-shaped beginning of the ureter occupying the renal hilum", "e": "pelvis (L. pelvis: basin, bowl) + renalis (L. renalis: of the kidney, from renes = kidneys)", "p": 166}, {"t": "Calices renales", "m": "Renal calices — more or less long tubular processes of the renal pelvis that drain the renal papillae", "e": "calices (L. calix: cup, chalice, from Gk. kalyx = cup, husk) + renales (L. renalis: of the kidney, from renes = kidneys)", "p": 166}, {"t": "Calices renales majores", "m": "Major calices of kidney — two to three primary tubular diverticula of the renal pelvis", "e": "calices (L. calix: cup) + renales (L. renalis: of the kidney) + majores (L. major: greater, larger, comparative of magnus = great)", "p": 166}, {"t": "Calices renales minores", "m": "Minor calices of kidney — seven to 13 calices formed by further division of the major calices, each receives a renal papilla", "e": "calices (L. calix: cup) + renales (L. renalis: of the kidney) + minores (L. minor: smaller, lesser, comparative of parvus = small)", "p": 166}, {"t": "Pars pelvica", "m": "Pelvic part of ureter — part of ureter that extends from the terminal line to the urinary bladder", "e": "pars (L. pars: part, portion) + pelvica (L. pelvicus: of the pelvis, from pelvis = basin)", "p": 166}, {"t": "Vesica urinaria", "m": "Urinary bladder — receptacle that holds about 350–500 ml or more of urine", "e": "vesica (L. vesica: bladder, blister) + urinaria (L. urinarius: of urine, from urina = urine, from Gk. ouron = urine)", "p": 166}, {"t": "Apex vesicae", "m": "Apex of urinary bladder — anterosuperiorly directed apical portion of urinary bladder", "e": "apex (L. apex: tip, summit, top) + vesicae (L. vesica: bladder, genitive form)", "p": 166}, {"t": "Corpus vesicae", "m": "Body of urinary bladder — portion of the urinary bladder situated between the fundus and apex", "e": "corpus (L. corpus: body) + vesicae (L. vesica: bladder, genitive form)", "p": 166}, {"t": "Fundus vesicae", "m": "Fundus of urinary bladder — posterior wall of the urinary bladder lying opposite to the apex, specifically in its lower segment between the ureters", "e": "fundus (L. fundus: bottom, base, foundation) + vesicae (L. vesica: bladder, genitive form)", "p": 166}, {"t": "Cervix vesicae", "m": "Cervix (neck) of urinary bladder — the urethra arises from it", "e": "cervix (L. cervix: neck) + vesicae (L. vesica: bladder, genitive form)", "p": 166}, {"t": "Lig. umbilicale medianum", "m": "Median umbilical ligament — fibrous cord derived from the urachus; it extends from the apex of the bladder to the umbilicus", "e": "ligamentum (L. ligamentum: band, tie, from ligare = to bind) + umbilicale (L. umbilicalis: of the navel, from umbilicus = navel) + medianum (L. medianus: middle, from medius = middle)", "p": 166}, {"t": "Basis pedunculi cerebri", "m": "Synonymous with anterior part of cerebral peduncle, the cerebral crus", "e": "basis (Gk. basis: base, foundation) + pedunculi (L. pedunculus: little foot, stalk, diminutive of pes = foot) + cerebri (L. cerebrum: brain, genitive = of the brain)", "p": 302}, {"t": "Fibrae corticospinales", "m": "Corticospinal fibers — fibers of the pyramidal tract leading into the spinal cord", "e": "fibrae (L. fibra: fiber, thread, plural) + corticospinales (L. cortex = bark/outer layer + spina = spine, thorn)", "p": 302}, {"t": "Fibrae corticonucleares", "m": "Corticonuclear (corticobulbar) fibers — pyramidal tract fibers for the cranial nerve nuclei", "e": "fibrae (L. fibra: fiber) + corticonucleares (L. cortex = bark/outer layer + nucleus = kernel, nut)", "p": 302}, {"t": "Fibrae corticopontinae", "m": "Corticopontine fibers — fibers of the cerebropontocerebellar tract", "e": "fibrae (L. fibra: fiber) + corticopontinae (L. cortex = bark/outer layer + pons/pontis = bridge)", "p": 302}, {"t": "Fibrae parietotemporopontinae", "m": "Parietotemporopontine fibers — fibers of the cerebropontine tract which originate from the parietal and temporal lobes", "e": "fibrae (L. fibra: fiber) + parietotemporopontinae (L. paries/parietis = wall + temporalis = of the temple + pons/pontis = bridge)", "p": 302}, {"t": "Fibrae frontopontinae", "m": "Frontopontine fibers — fibers of the cerebropontine tract which arise from the frontal lobes and occupy the medial sixth of the cerebral crus", "e": "fibrae (L. fibra: fiber) + frontopontinae (L. frons/frontis = forehead/front + pons/pontis = bridge)", "p": 302}, {"t": "Substantia nigra", "m": "Black nucleus lying on the cerebral crus, derived from its content of numerous pigmented ganglion cells", "e": "substantia (L. substantia: substance, essence, from sub = under + stare = to stand) + nigra (L. niger: black)", "p": 302}, {"t": "Pars compacta", "m": "Compact part — dense part of substantia nigra containing pigmented cells", "e": "pars (L. pars: part, portion) + compacta (L. compactus: dense, compressed, from compingere = to fasten together)", "p": 302}, {"t": "Pars reticularis", "m": "Reticular (fibrous) part of substantia nigra containing disaggregated pigmented fibers facing the cerebral crus", "e": "pars (L. pars: part) + reticularis (L. reticulum: little net, diminutive of rete = net)", "p": 302}, {"t": "Tegmentum mesencephalicum", "m": "Mesencephalic tegmentum — extends from the substantia nigra to an imaginary plane drawn through the cerebral aqueduct", "e": "tegmentum (L. tegmentum: covering, roof, from tegere = to cover) + mesencephalicum (Gk. mesos = middle + enkephalos = brain)", "p": 302}, {"t": "Substantia grisea centralis", "m": "Central gray matter — gray matter around the cerebral aqueduct", "e": "substantia (L. substantia: substance) + grisea (Medieval L. griseus: gray) + centralis (L. centralis: central, from centrum = center)", "p": 302}, {"t": "Tectum mesencephalicum", "m": "Mesencephalic tectum — part of the mesencephalon located dorsal to the previously mentioned transverse plane through the cerebral aqueduct", "e": "tectum (L. tectum: roof, ceiling, from tegere = to cover) + mesencephalicum (Gk. mesos = middle + enkephalos = brain)", "p": 302}, {"t": "Lamina tectalis", "m": "Tectal lamina (quadrigeminal plate)", "e": "lamina (L. lamina: thin plate, layer) + tectalis (L. tectum = roof + -alis = pertaining to)", "p": 302}, {"t": "Colliculus inferior", "m": "Inferior colliculus — inferior hillock of quadrigeminal plate connected to the auditory pathway", "e": "colliculus (L. colliculus: small hill, diminutive of collis = hill) + inferior (L. inferior: lower, comparative of inferus = below)", "p": 302}, {"t": "Colliculus superior", "m": "Superior colliculus — superior hillock of quadrigeminal plate connected to the visual pathway", "e": "colliculus (L. colliculus: small hill, diminutive of collis = hill) + superior (L. superior: higher, comparative of superus = above)", "p": 302}, {"t": "Brachium colliculi inferioris", "m": "Brachium of inferior colliculus — connecting arm between the inferior colliculus and the medial geniculate body", "e": "brachium (L. brachium: arm, from Gk. brachion) + colliculi (L. colliculus: small hill, genitive) + inferioris (L. inferior: lower, genitive)", "p": 302}, {"t": "Brachium colliculi superioris", "m": "Brachium of superior colliculus — connecting arm between the superior colliculus and the lateral geniculate body", "e": "brachium (L. brachium: arm, from Gk. brachion) + colliculi (L. colliculus: small hill, genitive) + superioris (L. superior: higher, genitive)", "p": 302}, {"t": "Trigonum lemnisci", "m": "Trigone of lemniscus — triangular field located laterally between the tectal lamina, superior cerebellar peduncle and cerebral crus", "e": "trigonum (Gk. trigonon: triangle, from tri = three + gonia = angle) + lemnisci (Gk. lemniskos: ribbon, band, genitive = of the lemniscus)", "p": 302}, {"t": "Pedunculus cerebellaris superior", "m": "Superior cerebellar peduncle — transmits fibers mainly from the dentate nucleus to the red nucleus and thalamus", "e": "pedunculus (L. pedunculus: little foot/stalk, diminutive of pes = foot) + cerebellaris (L. cerebellum: little brain, diminutive of cerebrum + -aris = pertaining to) + superior (L. superior: higher)", "p": 302}, {"t": "Aquaeductus mesencephali", "m": "Mesencephalic (cerebral) aqueduct — narrow canal in the midbrain between the 3rd and 4th ventricle", "e": "aquaeductus (L. aqua = water + ductus = leading, from ducere = to lead) + mesencephali (Gk. mesos = middle + enkephalos = brain, genitive)", "p": 302}, {"t": "Sectiones mesencephalici", "m": "Sections through the mesencephalon", "e": "sectiones (L. sectio: cutting, section, from secare = to cut, plural) + mesencephalici (Gk. mesos = middle + enkephalos = brain, genitive plural)", "p": 302}, {"t": "Formatio reticularis", "m": "Reticular formation (substance) — mesencephalic portion of reticular formation extending up from the spinal cord", "e": "formatio (L. formatio: formation, shaping, from formare = to form) + reticularis (L. reticulum: little net, diminutive of rete = net)", "p": 302}, {"t": "Fibrae corticoreticulares", "m": "Corticoreticular fibers — nerve fibers extending from the cerebral motor cortex to the ganglion cells of the reticular formation", "e": "fibrae (L. fibra: fiber, plural) + corticoreticulares (L. cortex = bark/outer layer + reticulum = little net)", "p": 302}, {"t": "Fasciculus longitudinalis medialis", "m": "Medial longitudinal fasciculus — fiber bundle with connections to the ocular muscles, neck muscles and vestibular nuclei for coordination of movements of the eyeball and head", "e": "fasciculus (L. fasciculus: small bundle, diminutive of fascis = bundle) + longitudinalis (L. longitudo: length, from longus = long) + medialis (L. medialis: medial, from medius = middle)", "p": 302}, {"t": "Fasciculus longitudinalis posterior", "m": "Posterior longitudinal fasciculus — descending and ascending fibers with projections to the hypothalamus and cranial nerve nuclei", "e": "fasciculus (L. fasciculus: small bundle, diminutive of fascis = bundle) + longitudinalis (L. longitudo: length, from longus = long) + posterior (L. posterior: behind, hinder, comparative of posterus = coming after)", "p": 302}, {"t": "Tractus mesencephalicus nervi trigeminalis", "m": "Mesencephalic tract of trigeminal nerve — trigeminal fibers to the nucleus of the tract of the trigeminal nerve located lateral to the cerebral aqueduct and the 4th ventricle", "e": "tractus (L. tractus: tract, course, from trahere = to draw) + mesencephalicus (Gk. mesos = middle + enkephalos = brain) + nervi (L. nervus: nerve, sinew, genitive) + trigeminalis (L. trigeminus: threefold, triple, from tri = three + geminus = twin)", "p": 302}, {"t": "Nucleus tractus mesencephalici nervi trigeminalis", "m": "Nucleus of mesencephalic tract of the trigeminal nerve — upper sensory trigeminal nucleus extending to below the tectal lamina", "e": "nucleus (L. nucleus: kernel, nut, from nux = nut) + tractus (L. tractus: tract, from trahere = to draw) + mesencephalici (Gk. mesos = middle + enkephalos = brain, genitive) + nervi (L. nervus: nerve, genitive) + trigeminalis (L. trigeminus: threefold, genitive)", "p": 302}, {"t": "Nucleus nervi oculomotorii", "m": "Nucleus of oculomotor nerve — found in front of the cerebral aqueduct", "e": "nucleus (L. nucleus: kernel) + nervi (L. nervus: nerve, genitive) + oculomotorii (L. oculus = eye + motor = mover, from movere = to move, genitive)", "p": 302}, {"t": "Nucleus oculomotorius accessorius", "m": "Accessory nucleus of oculomotor nerve — parasymathetic portion of oculomotor nucleus; 96% supplies the ciliary muscle, the rest supplies sphincter pupillae muscle", "e": "nucleus (L. nucleus: kernel) + oculomotorius (L. oculus = eye + motorius = of motion, from movere = to move) + accessorius (L. accessorius: additional, supplementary, from accedere = to approach)", "p": 302}, {"t": "Nucleus nervi trochlearis", "m": "Nucleus of trochlear nerve — located in the central gray matter caudal to the nucleus of the oculomotor nerve", "e": "nucleus (L. nucleus: kernel) + nervi (L. nervus: nerve, genitive) + trochlearis (L. trochlea: pulley, from Gk. trokhilia = pulley, system of wheels)", "p": 302}, {"t": "Nucleus interpeduncularis", "m": "Interpeduncular nucleus — located in the floor of the interpeduncular fossa and has projections to the olfactory tract", "e": "nucleus (L. nucleus: kernel) + interpeduncularis (L. inter = between + pedunculus = little foot/stalk, diminutive of pes = foot)", "p": 302}, {"t": "Nucleus interstitialis", "m": "Interstitial nucleus of Cajal — group of cells located lateral to the nucleus of the oculomotor nerve", "e": "nucleus (L. nucleus: kernel, core) + interstitialis (L. interstitiālis: situated between, from inter = between +stitium = standing place)", "p": 304}, {"t": "Nuclei tegmenti", "m": "Tegmental nuclei — nuclei in the reticular formation dorsal to the trochlear nucleus and ventral to the medial longitudinal fasciculus", "e": "nuclei (L. nucleus: kernel, plural) + tegmenti (L. tegmentum: covering, roof, from tegere = to cover)", "p": 304}, {"t": "Nucleus ruber", "m": "Red nucleus — iron-rich nucleus between the substantia nigra and central gray matter", "e": "nucleus (L. nucleus: kernel, core) + ruber (L. ruber: red)", "p": 304}, {"t": "Pars parvocellularis", "m": "Parvicellular part — group of small cells forming the larger part of the red nucleus", "e": "pars (L. pars: part) + parvocellularis (L. parvus = small + cellula = little cell + -aris = pertaining to)", "p": 304}, {"t": "Pars magnocellularis", "m": "Magnocellular part — group of large cells occupying the caudal part of the red nucleus", "e": "pars (L. pars: part) + magnocellularis (L. magnus = large + cellula = little cell + -aris = pertaining to)", "p": 304}, {"t": "Nucleus endopeduncularis", "m": "Endopeduncular nucleus — cell group located medially in the cerebral crus", "e": "nucleus (L. nucleus: kernel) + endopeduncularis (Gk. endon = within + L. pedunculus = little foot/stalk, from pes = foot)", "p": 304}, {"t": "Decussationes tegmenti", "m": "Decussations of tegmentum — crossing of the rubrospinal, rubroreticular and tectospinal tracts", "e": "decussationes (L. decussatio: crossing in X-shape, from decussis = figure X) + tegmenti (L. tegmentum: covering, from tegere = to cover)", "p": 304}, {"t": "Decussatio pedunculorum cerebellarium superiorum", "m": "Decussation of superior cerebellar peduncle — crossing of the superior cerebellar peduncle below the inferior colliculus", "e": "decussatio (L. decussatio: X-shaped crossing) + pedunculorum (L. pedunculus: little stalk, from pes = foot) + cerebellarium (L. cerebellum: little brain, from cerebrum = brain) + superiorum (L. superior: upper, higher)", "p": 304}, {"t": "Fibrae dentatorubrales", "m": "Dentatorubral fibers — component of the superior cerebellar peduncle which passes into the red nucleus", "e": "fibrae (L. fibra: fiber, thread) + dentatorubrales (L. dentatus = toothed, from dens = tooth + ruber = red + -ales = pertaining to)", "p": 304}, {"t": "Tractus rubrospinalis", "m": "Rubrospinal tract — extrapyramidal tract passing from the red nucleus to the anterior horn cells", "e": "tractus (L. tractus: tract, course, from trahere = to draw) + rubrospinalis (L. ruber = red + spina = spine + -alis = pertaining to)", "p": 304}, {"t": "Tractus tectobulbaris", "m": "Tectobulbar tract — extends from the posterior tegmental decussation to the opposite side, passing to the pontine nuclei", "e": "tractus (L. tractus: tract, course) + tectobulbaris (L. tectum = roof + Gk. bolbos = bulb + L. -aris = pertaining to)", "p": 304}, {"t": "Tractus tectospinalis", "m": "Tectospinal tract — initially courses similar to the tectobulbar tract, then descends in the anterior funiculus of the spinal cord", "e": "tractus (L. tractus: tract, course) + tectospinalis (L. tectum = roof + spina = spine + -alis = pertaining to)", "p": 304}, {"t": "Lemniscus lateralis", "m": "Lateral lemniscus — partly crossing portion of auditory tract passing to the inferior colliculus", "e": "lemniscus (L. lemniscus: ribbon, band, from Gk. lemniskos = ribbon) + lateralis (L. lateralis: of the side, from latus = side)", "p": 304}, {"t": "Lemniscus medialis", "m": "Medial lemniscus — decussating connection between nuclei of posterior funiculus and thalamus", "e": "lemniscus (L. lemniscus: ribbon, band, from Gk. lemniskos = ribbon) + medialis (L. medialis: of the middle, from medius = middle)", "p": 304}, {"t": "Lemniscus spinalis", "m": "Spinal lemniscus — segment of spinothalamic tract lodging in the midbrain adjacent to the medial lemniscus", "e": "lemniscus (L. lemniscus: ribbon, band) + spinalis (L. spinalis: of the spine, from spina = spine)", "p": 304}, {"t": "Lemniscus trigeminalis", "m": "Trigeminal lemniscus — crossing fiber tract between the sensory nuclei of the trigeminal and the thalamus", "e": "lemniscus (L. lemniscus: ribbon, band) + trigeminalis (L. trigeminus = threefold, from tri = three + geminus = twin + -alis = pertaining to)", "p": 304}, {"t": "Nucleus colliculi inferioris", "m": "Nucleus of inferior colliculus — nucleus connecting the auditory tract with the extrapyramidal system", "e": "nucleus (L. nucleus: kernel) + colliculi (L. colliculus: little hill, from collis = hill) + inferioris (L. inferior: lower, genitive form)", "p": 304}, {"t": "Commissura colliculorum inferiorum", "m": "Commissure of inferior colliculus — connection between the right and left inferior colliculi which also receives fibers from the lateral lemniscus", "e": "commissura (L. commissura: joining together, from committere = to join) + colliculorum (L. colliculus: little hill, genitive plural) + inferiorum (L. inferior: lower, genitive plural)", "p": 304}, {"t": "Strata grisea et alba colliculi superioris", "m": "Gray and white layers of superior colliculus — gray matter and white matter surrounding the superior colliculus", "e": "strata (L. stratum: layer, from sternere = to spread) + grisea (L. griseus: gray) + et (L. et: and) + alba (L. albus: white) + colliculi (L. colliculus: little hill) + superioris (L. superior: upper, genitive)", "p": 304}, {"t": "Commissura colliculorum superiorum", "m": "Commissure of superior colliculus — connection between the right and left superior colliculi", "e": "commissura (L. commissura: joining together) + colliculorum (L. colliculus: little hill, genitive plural) + superiorum (L. superior: upper, genitive plural)", "p": 304}, {"t": "Decussatio trochlearis", "m": "Decussation of trochlear nerve — fibers of trochlear nerve crossing in the white matter", "e": "decussatio (L. decussatio: X-shaped crossing, from decussis = figure X) + trochlearis (L. trochlea = pulley, from Gk. trokhilia = pulley + -aris = pertaining to)", "p": 304}, {"t": "Tractus tegmentalis centralis", "m": "Central tegmental tract — tract passing to the olive, thought to partially arise from the thalamus", "e": "tractus (L. tractus: tract, course) + tegmentalis (L. tegmentum = covering/roof + -alis = pertaining to) + centralis (L. centralis: of the center, from centrum = center)", "p": 304}, {"t": "Ventriculus tertius", "m": "Third ventricle — diencephalic portion of the cerebral ventricular system", "e": "ventriculus (L. ventriculus: little belly, diminutive of venter = belly) + tertius (L. tertius: third)", "p": 308}, {"t": "Sulcus hypothalamicus", "m": "Hypothalamic sulcus — furrow extending from the interventricular foramen to the entrance into the cerebral aqueduct", "e": "sulcus (L. sulcus: groove, furrow) + hypothalamicus (Gk. hypo = under + thalamos = inner chamber, bed)", "p": 308}, {"t": "Foramen interventriculare", "m": "Interventricular foramen — opening between the lateral ventricle and third ventricle behind the genu of the fornix", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + interventriculare (L. inter = between + ventriculus = little belly)", "p": 308}, {"t": "Recessus opticus", "m": "Optic recess — recess of third ventricle above the optic chiasm", "e": "recessus (L. recessus: recess, withdrawal, from recedere = to recede) + opticus (Gk. optikos: of sight, from optos = seen)", "p": 308}, {"t": "Recessus infundibuli", "m": "Recess of infundibulum — recess of third ventricle within the infundibulum", "e": "recessus (L. recessus: recess, withdrawal) + infundibuli (L. infundibulum: funnel, from infundere = to pour into)", "p": 308}, {"t": "Recessus pinealis", "m": "Pineal recess — recess of third ventricle extending partially into the epiphysis", "e": "recessus (L. recessus: recess, withdrawal) + pinealis (L. pinealis: of the pine, from pinea = pine cone)", "p": 308}, {"t": "Recessus supraspinalis", "m": "Supraspinal recess — recess between the roof of the third ventricle and the epiphysis", "e": "recessus (L. recessus: recess, withdrawal) + supraspinalis (L. supra = above + spina = spine, thorn)", "p": 308}, {"t": "Tela choroidea", "m": "Tela choroidea — forms the thin, narrow roof of third ventricle and its choroid plexus", "e": "tela (L. tela: web, tissue) + choroidea (Gk. choroeides: membrane-like, from chorion = membrane + eidos = form)", "p": 308}, {"t": "Taenia thalami", "m": "Tenia of thalamus — lateral attachment line of the upper wall of the third ventricle along the stria medullaris of the thalamus", "e": "taenia (L./Gk. taenia: ribbon, band, from Gk. tainia = ribbon) + thalami (Gk. thalamos: inner chamber, bed)", "p": 308}, {"t": "Plexus choroideus", "m": "Choroid plexus — paired, highly vascularized villous infolding which hangs down from the thin roof of the third ventricle", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + choroideus (Gk. choroeides: membrane-like, from chorion = membrane + eidos = form)", "p": 308}, {"t": "Sectiones thalamici et metathalamici", "m": "Sections of thalamus and metathalamus", "e": "sectiones (L. sectio: cutting, section, from secare = to cut) + thalamici (Gk. thalamos: inner chamber, bed) + et (L. et: and) + metathalamici (Gk. meta = beyond/after + thalamos = inner chamber)", "p": 308}, {"t": "Nucleus reticulatus thalami", "m": "Reticular nucleus of thalamus — thin layer lying mainly laterally along the thalamus between the posterior limb of the internal capsule and external medullary lamina", "e": "nucleus (L. nucleus: kernel, core, from nux = nut) + reticulatus (L. reticulatus: net-like, from reticulum = little net) + thalami (Gk. thalamos: inner chamber, bed)", "p": 308}, {"t": "Nuclei anteriores thalami", "m": "Anterior nuclei of thalamus — cell group in the apex of the thalamus receiving fibers from the mamillothalamic tract", "e": "nuclei (L. nucleus: kernel, core) + anteriores (L. anterior: before, in front, comparative of ante = before) + thalami (Gk. thalamos: inner chamber, bed)", "p": 308}, {"t": "Nucleus anterodorsalis", "m": "Anterodorsal nucleus — narrow cell plate anterosuperiorly", "e": "nucleus (L. nucleus: kernel, core) + anterodorsalis (L. anterior = before + dorsum = back)", "p": 308}, {"t": "Nucleus anteroventralis", "m": "Anteroventral nucleus — main nucleus of the anterior nuclei", "e": "nucleus (L. nucleus: kernel, core) + anteroventralis (L. anterior = before + ventralis = of the belly, from venter = belly)", "p": 308}, {"t": "Nucleus anteromedialis", "m": "Anteromedial nucleus — degenerating nuclear remains situated medial and inferior to the anteroventral nucleus", "e": "nucleus (L. nucleus: kernel, core) + anteromedialis (L. anterior = before + medialis = middle, from medius = middle)", "p": 308}, {"t": "Nuclei mediani thalami", "m": "Median nuclei of thalamus — collective term for the nuclei located medial and for the most part directly inferior to the ependyma", "e": "nuclei (L. nucleus: kernel, core) + mediani (L. medianus: middle, from medius = middle) + thalami (Gk. thalamos: inner chamber, bed)", "p": 308}, {"t": "Nuclei paraventriculares anteriores", "m": "Anterior paraventricular nuclei — cell groups in the wall of the third ventricle with neuronal function", "e": "nuclei (L. nucleus: kernel, core) + paraventriculares (L. para = beside + ventriculus = little belly) + anteriores (L. anterior: in front, before)", "p": 308}, {"t": "Nucleus rhomboidalis", "m": "Rhomboidal nucleus — often forms the interthalamic adhesion", "e": "nucleus (L. nucleus: kernel, core) + rhomboidalis (Gk. rhomboeides: rhombus-shaped, from rhombos = spinning top, rhombus + eidos = form)", "p": 308}, {"t": "Nucleus reuniens", "m": "Nucleus reuniens — nucleus extending from the anterior end of the anterior tubercle to the middle of the interthalamic adhesion", "e": "nucleus (L. nucleus: kernel, core) + reuniens (L. reuniens: reuniting, joining again, from re = again + unire = to unite)", "p": 308}, {"t": "Nucleus parataenialis thalami", "m": "Paratenial nucleus of thalamus — located between the stria medullaris, tenia, anterodorsal and paraventricular nuclei", "e": "nucleus (L. nucleus: kernel, core) + parataenialis (Gk. para = beside + tainia = ribbon, band) + thalami (Gk. thalamos: inner chamber)", "p": 308}, {"t": "Nuclei mediales thalami", "m": "Medial nuclei of thalamus — mass of nuclei medial to the internal medullary lamina with projections to other thalamic nuclei and the frontal lobe", "e": "nuclei (L. nucleus: kernel, core) + mediales (L. medialis: middle, from medius = middle) + thalami (Gk. thalamos: inner chamber, bed)", "p": 308}, {"t": "Nucleus medialis dorsalis", "m": "Dorsal medial nucleus — principal nucleus of the medial nuclei group", "e": "nucleus (L. nucleus: kernel, core) + medialis (L. medialis: middle) + dorsalis (L. dorsalis: of the back, from dorsum = back)", "p": 308}, {"t": "Lamina medullaris interna", "m": "Internal medullary lamina — layer of white matter located internally with Y-shaped sections dividing the thalamus", "e": "lamina (L. lamina: thin plate, layer) + medullaris (L. medullaris: of the marrow, from medulla = marrow) + interna (L. internus: internal, inner)", "p": 308}, {"t": "Lamina medullaris externa", "m": "External medullary lamina — layer of white matter on the external side of the thalamus", "e": "lamina (L. lamina: thin plate, layer) + medullaris (L. medullaris: of the marrow, from medulla = marrow) + externa (L. externus: external, outer)", "p": 308}, {"t": "Nuclei reticulares intralaminares thalami", "m": "Reticular (intralaminar) nuclei of thalamus — nuclei located in the medullary lamina corresponding functionally to the reticular formation", "e": "nuclei (L. nucleus: kernel, core) + reticulares (L. reticularis: net-like, from reticulum = little net) + intralaminares (L. intra = within + lamina = layer) + thalami (Gk. thalamos: inner chamber)", "p": 308}, {"t": "Nucleus centromedianus", "m": "Centromedian nucleus — largest nucleus of the intralaminar group with projections to the corpus striatum, hypothalamus, and other structures", "e": "nucleus (L. nucleus: kernel, core) + centromedianus (L. centrum = center + medianus = middle, from medius = middle)", "p": 308}, {"t": "Nucleus paracentralis", "m": "Paracentral nucleus — lies in the internal medullary lamina lateral to the centromedian nucleus", "e": "nucleus (L. nucleus: kernel, core) + paracentralis (Gk. para = beside + L. centralis = of the center, from centrum = center)", "p": 308}, {"t": "Nucleus parafascicularis", "m": "Parafascicular nucleus — lies medial to the occipital region of the centromedian nucleus", "e": "nucleus (L. nucleus: kernel, core) + parafascicularis (Gk. para = beside + L. fasciculus = little bundle, from fascis = bundle)", "p": 308}, {"t": "Nucleus centralis lateralis", "m": "Lateral central nucleus — lies dorsolateral and medial to the centromedian nucleus", "e": "nucleus (L. nucleus: kernel, core) + centralis (L. centralis: of the center, from centrum = center) + lateralis (L. lateralis: of the side, from latus = side)", "p": 308}, {"t": "Nucleus centralis medialis", "m": "Medial central nucleus — lies at the lower medial end of the internal medullary lamina", "e": "nucleus (L. nucleus: kernel, core) + centralis (L. centralis: of the center, from centrum = center) + medialis (L. medialis: middle, from medius = middle)", "p": 308}, {"t": "Nuclei ventrolaterales [thalami]", "m": "Ventrolateral nuclei, the group of nuclei lateral to the internal medullary lamina", "e": "nuclei (L. nucleus: kernel, from nux = nut) + ventro- (L. venter: belly, front) + laterales (L. lateralis: of the side, from latus = side) + thalami (Gk. thalamos: inner chamber, bedroom)", "p": 310}, {"t": "Nucleus lateralis posterior", "m": "Posterior lateral nucleus — portion of the lateral nucleus situated between the pulvinar and dorsal lateral nucleus with connections to the parietal lobe", "e": "nucleus (L. nucleus: kernel) + lateralis (L. lateralis: of the side) + posterior (L. posterior: behind, later, from post = after)", "p": 310}, {"t": "Nucleus lateralis dorsalis", "m": "Dorsal lateral nucleus — anterosuperior portion of the lateral nucleus with projections to the region of the posterior cingulum segment and the lower part of the parietal lobe", "e": "nucleus (L. nucleus: kernel) + lateralis (L. lateralis: of the side) + dorsalis (L. dorsalis: of the back, from dorsum = back)", "p": 310}, {"t": "Nucleus ventralis anterior", "m": "Anterior ventral nucleus — anterior portion of the ventral nucleus with projections to the interlaminar nuclei, globus pallidus and dentate nucleus", "e": "nucleus (L. nucleus: kernel) + ventralis (L. ventralis: of the belly/front, from venter = belly) + anterior (L. anterior: in front, from ante = before)", "p": 310}, {"t": "Nucleus ventralis intermedius", "m": "Intermediate ventral nucleus — portion of the ventral nucleus situated behind the anterior ventral nucleus; synaptic station connecting cerebellum, red nucleus and motor cortex", "e": "nucleus (L. nucleus: kernel) + ventralis (L. ventralis: of the front) + intermedius (L. intermedius: in between, from inter = between + medius = middle)", "p": 310}, {"t": "Nucleus ventralis medialis", "m": "Medial ventral nucleus — poorly demarcated nuclear region situated anterior to the posterior ventral nucleus", "e": "nucleus (L. nucleus: kernel) + ventralis (L. ventralis: of the front) + medialis (L. medialis: of the middle, from medius = middle)", "p": 310}, {"t": "Nuclei ventrales posteriores", "m": "Posterior ventral nuclei — collective term for the following two nuclei", "e": "nuclei (L. nucleus: kernel) + ventrales (L. ventralis: of the front) + posteriores (L. posterior: behind, from post = after)", "p": 310}, {"t": "Nucleus ventralis posterolateralis", "m": "Posterolateral ventral nucleus — the lateral part of the posterior ventral nucleus that receives the medial lemniscus and spinothalamic tract", "e": "nucleus (L. nucleus: kernel) + ventralis (L. ventralis: of the front) + postero- (L. posterior: behind) + lateralis (L. lateralis: of the side)", "p": 310}, {"t": "Nucleus ventralis posteromedialis", "m": "Posteromedial ventral nucleus — part located between the centromedian and posterolateral nuclei, receives the trigeminal lemniscus", "e": "nucleus (L. nucleus: kernel) + ventralis (L. ventralis: of the front) + postero- (L. posterior: behind) + medialis (L. medialis: of the middle)", "p": 310}, {"t": "Nuclei posteriores [thalami]", "m": "Posterior nuclei of thalamus — collective term for the following three parts of the thalamus", "e": "nuclei (L. nucleus: kernel) + posteriores (L. posterior: behind) + thalami (Gk. thalamos: inner chamber)", "p": 310}, {"t": "Nuclei pulvinares", "m": "Pulvinar nuclei — nuclei that occupy the posterior portion of the thalamus", "e": "nuclei (L. nucleus: kernel) + pulvinares (L. pulvinar: cushioned seat, from pulvinus = cushion)", "p": 310}, {"t": "Nucleus [corporis geniculati] lateralis [pars dorsalis]", "m": "Lateral geniculate nucleus [dorsal part] — part of the visual pathway", "e": "nucleus (L. nucleus: kernel) + corporis (L. corpus: body) + geniculati (L. geniculatus: having knee-like joints, from genu = knee) + lateralis (L. lateralis: of the side) + pars (L. pars: part) + dorsalis (L. dorsalis: of the back)", "p": 310}, {"t": "Nucleus [corporis geniculati] medialis [pars dorsalis]", "m": "Medial geniculate nucleus [dorsal part] — part of medial geniculate body containing small cells", "e": "nucleus (L. nucleus: kernel) + corporis (L. corpus: body) + geniculati (L. geniculatus: knee-jointed) + medialis (L. medialis: of the middle) + pars (L. pars: part) + dorsalis (L. dorsalis: of the back)", "p": 310}, {"t": "Sectiones thalami ventralis", "m": "Sections of ventral thalamus", "e": "sectiones (L. sectio: cutting, section, from secare = to cut) + thalami (Gk. thalamos: inner chamber) + ventralis (L. ventralis: of the front/belly)", "p": 310}, {"t": "Nucleus corporis geniculati lateralis [pars ventralis]", "m": "Lateral geniculate nucleus [ventral part] — small group of cells with fibers from the retina; part of a light reflex tract", "e": "nucleus (L. nucleus: kernel) + corporis (L. corpus: body) + geniculati (L. geniculatus: knee-jointed) + lateralis (L. lateralis: of the side) + pars (L. pars: part) + ventralis (L. ventralis: of the front)", "p": 310}, {"t": "Nucleus corporis geniculati medialis [pars ventralis]", "m": "Medial geniculate nucleus [ventral part] — possibly the true acoustic part of the geniculate nucleus", "e": "nucleus (L. nucleus: kernel) + corporis (L. corpus: body) + geniculati (L. geniculatus: knee-jointed) + medialis (L. medialis: of the middle) + pars (L. pars: part) + ventralis (L. ventralis: of the front)", "p": 310}, {"t": "Nucleus subthalamicus", "m": "Subthalamic nucleus [corpus Luysii] — lies between the lower end of the internal capsule and the zona incerta", "e": "nucleus (L. nucleus: kernel) + sub- (L. sub: under, below) + thalamicus (Gk. thalamos: inner chamber + L. -icus: adjectival suffix)", "p": 310}, {"t": "Corpus Luysii", "m": "Subthalamic nucleus (alternative name)", "e": "corpus (L. corpus: body) + Luysii (eponym from Jules Bernard Luys, French neurologist)", "p": 310}, {"t": "Nuclei reticulares [thalami]", "m": "Reticular nuclei of thalamus — disaggregated cell layer on the lateral surface of the thalamus between the external medullary lamina and internal capsule", "e": "nuclei (L. nucleus: kernel) + reticulares (L. reticularis: net-like, from reticulum = small net, from rete = net) + thalami (Gk. thalamos: inner chamber)", "p": 310}, {"t": "Zona incerta", "m": "Basal continuation of the reticular nucleus of the thalamus — lies in the path of the globus pallidus to the tegmentum of the diencephalon", "e": "zona (Gk. zone: belt, girdle) + incerta (L. incertus: uncertain, from in- = not + certus = sure)", "p": 310}, {"t": "Nuclei regionum H, H1 and H2", "m": "Nuclear regions H, H1 and H2 — dispersed neurons in the corresponding Forel's fields", "e": "nuclei (L. nucleus: kernel) + regionum (L. regio: region, area, from regere = to rule/direct) + H/H1/H2 (abbreviations for Haubenfelder, from German Haube = tegmentum)", "p": 310}, {"t": "Tractus et fasciculi thalamici", "m": "Thalamic tract and fasciculi", "e": "tractus (L. tractus: tract, course, from trahere = to draw/pull) + et (L. et: and) + fasciculi (L. fasciculus: small bundle, diminutive of fascis = bundle) + thalamici (Gk. thalamos: inner chamber + L. -ici: adjectival suffix)", "p": 310}, {"t": "Radiatio acustica", "m": "Acoustic radiation — portion of auditory pathway extending from the medial geniculate body to the transverse temporal gyrus", "e": "radiatio (L. radiatio: radiation, from radiare = to radiate, from radius = ray) + acustica (Gk. akoustikos: of hearing, from akouein = to hear)", "p": 310}, {"t": "Radiatio optica [Gratiolet]", "m": "Optic radiation — portion of the visual pathway emanating from the lateral geniculate body, passing through the occipital part of the posterior limb of the internal capsule", "e": "radiatio (L. radiatio: radiation, from radiare = to radiate) + optica (Gk. optikos: of sight, from ops/optos = eye/seen) + Gratiolet (eponym from Louis Pierre Gratiolet, French anatomist)", "p": 310}, {"t": "Raditiones thalamicae anteriores", "m": "Anterior thalamic radiations — fibers of the anterior nucleus passing to and from the cingulate gyrus and reciprocal connections between the lateral nucleus and frontal lobe", "e": "radiationes (L. radiatio: radiation, spreading out, from radiare = to radiate) + thalamicae (Gk. thalamos: inner chamber, bridal chamber) + anteriores (L. anterior: in front, former, from ante = before)", "p": 312}, {"t": "Radiationes thalamicae centrales", "m": "Central thalamic radiations — reciprocal fibers passing fan-like through the posterior limb of the internal capsule", "e": "radiationes (L. radiatio: radiation, spreading out) + thalamicae (Gk. thalamos: inner chamber) + centrales (L. centralis: central, from centrum = center)", "p": 312}, {"t": "Radiationes thalamicae posteriores", "m": "Posterior thalamic radiations — lying in the occipital region of the posterior limb of the internal capsule", "e": "radiationes (L. radiatio: radiation, spreading out) + thalamicae (Gk. thalamos: inner chamber) + posteriores (L. posterior: behind, later, from post = after)", "p": 312}, {"t": "Tractus dentatothalamicus", "m": "Dentatothalamic tract — arises from the cerebellum and radiates into the thalamic fasciculus and to the lateral ventral nucleus", "e": "tractus (L. tractus: tract, course, from trahere = to draw) + dentato- (L. dentatus: toothed, from dens = tooth) + thalamicus (Gk. thalamos: inner chamber)", "p": 312}, {"t": "Fasciculus thalamicus", "m": "Thalamic fasciculus — lies below the thalamus, next to and above the zona incerta in field H1", "e": "fasciculus (L. fasciculus: small bundle, diminutive of fascis = bundle) + thalamicus (Gk. thalamos: inner chamber)", "p": 312}, {"t": "Fasciculus subthalamicus", "m": "Subthalamic fasciculus — fiber bundle extending from the globus pallidus to the subthalamic nucleus", "e": "fasciculus (L. fasciculus: small bundle) + sub- (L. sub: under, below) + thalamicus (Gk. thalamos: inner chamber)", "p": 312}, {"t": "Fasciculus mamillothalamicus", "m": "Mamillothalamic fasciculus — fiber tract extending from the mamillary body to the anterior nucleus of the thalamus", "e": "fasciculus (L. fasciculus: small bundle) + mamillo- (L. mamilla: small breast, nipple, diminutive of mamma = breast) + thalamicus (Gk. thalamos: inner chamber)", "p": 312}, {"t": "Pedunculus thalamicus inferior", "m": "Inferior thalamic peduncle — fibers between the hypothalamus and thalamus", "e": "pedunculus (L. pedunculus: small foot, stalk, diminutive of pes = foot) + thalamicus (Gk. thalamos: inner chamber) + inferior (L. inferior: lower, from inferus = low)", "p": 312}, {"t": "Ansa lenticularis", "m": "Ansa lenticularis — fiber bundle from the lentiform nucleus to the ventral nuclei of the thalamus passing around the anterior margin of the internal capsule", "e": "ansa (L. ansa: handle, loop) + lenticularis (L. lenticularis: lens-shaped, from lens/lentis = lentil, lens)", "p": 312}, {"t": "Fasciculus lenticularis", "m": "Fasciculus lenticularis — fiber bundle from the lentiform nucleus to the ventral nuclei of the thalamus passing through the internal capsule", "e": "fasciculus (L. fasciculus: small bundle) + lenticularis (L. lenticularis: lens-shaped, from lens/lentis = lentil, lens)", "p": 312}, {"t": "Ansa et fasciculus lenticulares", "m": "Ansa and fasciculus lenticulares — two fiber bundles from the lentiform nucleus to the ventral nuclei of the thalamus, united in the thalamic fasciculus", "e": "ansa (L. ansa: handle, loop) + et (L. et: and) + fasciculus (L. fasciculus: small bundle) + lenticulares (L. lenticularis: lens-shaped)", "p": 312}, {"t": "Ansa peduncularis", "m": "Ansa peduncularis — fiber tract connecting the thalamus and claustrum, extending between the lentiform nucleus and the amygdaloid body", "e": "ansa (L. ansa: handle, loop) + peduncularis (L. peduncularis: of a stalk/peduncle, from pedunculus = small foot)", "p": 312}, {"t": "Fasciculus peduncularis", "m": "Fasciculus peduncularis — fiber tract connecting the thalamus and claustrum, extending between the lentiform nucleus and the amygdaloid body", "e": "fasciculus (L. fasciculus: small bundle) + peduncularis (L. peduncularis: of a stalk/peduncle)", "p": 312}, {"t": "Ansa et fasciculus pedunculares", "m": "Ansa peduncularis and fasciculus peduncularis — fiber tract connecting the thalamus and claustrum", "e": "ansa (L. ansa: handle, loop) + et (L. et: and) + fasciculus (L. fasciculus: small bundle) + pedunculares (L. peduncularis: of a stalk/peduncle)", "p": 312}, {"t": "Fibrae intrathalamicae", "m": "Intrathalamic fibers — connections of individual thalamic nuclei", "e": "fibrae (L. fibra: fiber, thread) + intra- (L. intra: within, inside) + thalamicae (Gk. thalamos: inner chamber)", "p": 312}, {"t": "Fibrae periventriculares", "m": "Periventricular fibers — fibers coursing beneath the ependyma of the third ventricle between the medial nucleus and the hypothalamic nucleus to enter the posterior longitudinal fasciculus", "e": "fibrae (L. fibra: fiber, thread) + peri- (Gk. peri: around, surrounding) + ventriculares (L. ventriculus: small belly, ventricle, diminutive of venter = belly)", "p": 312}, {"t": "Sectiones hypothalami", "m": "Sections of the hypothalamus", "e": "sectiones (L. sectio: cutting, section, from secare = to cut) + hypothalami (Gk. hypo: under + thalamos: inner chamber)", "p": 312}, {"t": "Regio hypothalamica dorsalis", "m": "Dorsal (posterior) hypothalamic region — area of the hypothalamus next to the apex", "e": "regio (L. regio: region, area, from regere = to rule, direct) + hypothalamica (Gk. hypo: under + thalamos: inner chamber) + dorsalis (L. dorsalis: of the back, from dorsum = back)", "p": 312}, {"t": "Nucleus ansae lenticularis", "m": "Nucleus of ansa lenticularis — groups of cells dispersed in the ansa lenticularis", "e": "nucleus (L. nucleus: kernel, core, from nux = nut) + ansae (L. ansa: handle, loop) + lenticularis (L. lenticularis: lens-shaped, from lens/lentis = lentil)", "p": 312}, {"t": "Regio hypothalamica anterior", "m": "Anterior (ventral) region of hypothalamus", "e": "regio (L. regio: region, area) + hypothalamica (Gk. hypo: under + thalamos: inner chamber) + anterior (L. anterior: in front, from ante = before)", "p": 312}, {"t": "Nucleus preopticus medialis", "m": "Medial preoptic nucleus — group of nuclei located beneath the anterior commissure and along the lamina terminalis with projections to the stria terminalis, medial telencephalic fasciculus and medial thalamic nuclei", "e": "nucleus (L. nucleus: kernel, core) + pre- (L. prae: before, in front of) + opticus (Gk. optikos: of sight, from ops = eye) + medialis (L. medialis: middle, from medius = middle)", "p": 312}, {"t": "Nucleus preopticus lateralis", "m": "Lateral preoptic nucleus — group of nuclei located beneath the anterior commissure and along the lamina terminalis", "e": "nucleus (L. nucleus: kernel, core) + pre- (L. prae: before, in front of) + opticus (Gk. optikos: of sight) + lateralis (L. lateralis: of the side, from latus = side)", "p": 312}, {"t": "Nucleus supraopticus", "m": "Supraoptic nucleus — nucleus lying above the optic chiasm with neurosecretory fibers (oxytocin and vasopressin) projecting to the posterior pituitary", "e": "nucleus (L. nucleus: kernel, core) + supra- (L. supra: above, over) + opticus (Gk. optikos: of sight, from ops = eye)", "p": 312}, {"t": "Nuclei paraventriculares", "m": "Paraventricular nuclei — group of autonomic nuclei with neurosecretory fibers (oxytocin and vasopressin) projecting to the posterior lobe of the hypophysis", "e": "nuclei (L. nucleus: kernel, core) + para- (Gk. para: beside, alongside) + ventriculares (L. ventriculus: small belly, ventricle)", "p": 312}, {"t": "Nucleus hypothalamicus anterior", "m": "Anterior hypothalamic nucleus — located behind the preoptic nucleus with projections to the hemispheres, stria terminalis and thalamus; influences heat regulation, glandular activity and circulation", "e": "nucleus (L. nucleus: kernel, core) + hypothalamicus (Gk. hypo: under + thalamos: inner chamber) + anterior (L. anterior: in front, from ante = before)", "p": 312}, {"t": "Regio hypothalamica intermedia", "m": "Intermediate hypothalamic region — area situated between the anterior and posterior hypothalamic regions", "e": "regio (L. regio: region, area) + hypothalamica (Gk. hypo: under + thalamos: inner chamber) + intermedia (L. intermedius: in between, from inter = between + medius = middle)", "p": 312}, {"t": "Nucleus arcuatus", "m": "Arcuate nucleus — mural nucleus situated in the entrance to the infundibulum; regulates the release of hormones from the anterior lobe", "e": "nucleus (L. nucleus: kernel, core) + arcuatus (L. arcuatus: arched, bow-shaped, from arcus = bow, arch)", "p": 312}, {"t": "Nuclei tuberales", "m": "Tuberal nuclei — groups of nuclei in the posterior wall of the infundibulum; function similar to the arcuate nucleus", "e": "nuclei (L. nucleus: kernel, core) + tuberales (L. tuber: swelling, lump, bump; tuberalis = of a swelling)", "p": 312}, {"t": "Regio hypothalamica lateralis", "m": "Lateral hypothalamic region — area separated from the medial hypothalamus by the fornix, mamillothalamic fasciculus and medial telencephalic fasciculus", "e": "regio (L. regio: region, area) + hypothalamica (Gk. hypo: under + thalamos: inner chamber) + lateralis (L. lateralis: of the side, from latus = side)", "p": 312}, {"t": "Radiatio thalami", "m": "Radiation of thalamus", "e": "radiatio (L. radiātio: radiation, from radiare = to radiate, from radius = ray) + thalami (Gk. thalamos: inner chamber, bedroom; genitive of thalamus)", "p": 313}, {"t": "Ansa et fasciculus peduncularis", "m": "Ansa et fasciculus peduncularis", "e": "ansa (L. ansa: handle, loop) + et (L. et: and) + fasciculus (L. fasciculus: small bundle, diminutive of fascis = bundle) + peduncularis (L. peduncularis: of the peduncle, from pedunculus = little foot, from pes/pedis = foot)", "p": 313}, {"t": "Nuclei hypothalami", "m": "Nuclei of hypothalamus", "e": "nuclei (L. nucleus: kernel, core, from nux/nucis = nut; plural) + hypothalami (Gk. hypo = under + thalamos = inner chamber; genitive of hypothalamus)", "p": 313}, {"t": "Nucleus hypothalamicus ventromedialis", "m": "Ventromedial hypothalamic nucleus", "e": "nucleus (L. nucleus: kernel, core) + hypothalamicus (Gk. hypo: under + thalamos: inner chamber) + ventromedialis (L. venter: belly + medius: middle + -alis: pertaining to)", "p": 314}, {"t": "Nucleus hypothalamicus dorsomedialis", "m": "Dorsomedial hypothalamic nucleus", "e": "nucleus (L. nucleus: kernel, core) + hypothalamicus (Gk. hypo: under + thalamos: inner chamber) + dorsomedialis (L. dorsum: back + medius: middle + -alis: pertaining to)", "p": 314}, {"t": "Nucleus hypothalamicus dorsalis", "m": "Dorsal hypothalamic nucleus", "e": "nucleus (L. nucleus: kernel, core) + hypothalamicus (Gk. hypo: under + thalamos: inner chamber) + dorsalis (L. dorsum: back + -alis: pertaining to)", "p": 314}, {"t": "Nucleus periventricularis posterior", "m": "Posterior periventricular nucleus", "e": "nucleus (L. nucleus: kernel, core) + periventricularis (L. peri: around + ventriculus: little belly, ventricle + -aris: pertaining to) + posterior (L. posterior: behind, later)", "p": 314}, {"t": "Nucleus infundibularis (arcuatus)", "m": "Infundibular (arcuate) nucleus", "e": "nucleus (L. nucleus: kernel, core) + infundibularis (L. infundibulum: funnel + -aris: pertaining to) + arcuatus (L. arcus: arch, bow + -atus: having the form of)", "p": 314}, {"t": "Regio hypothalamica posterior", "m": "Posterior hypothalamic area", "e": "regio (L. regio: region, area) + hypothalamica (Gk. hypo: under + thalamos: inner chamber + -ica: pertaining to) + posterior (L. posterior: behind, later)", "p": 314}, {"t": "Nuclei corporis mamillaris mediales/laterales", "m": "Medial and lateral nuclei of mamillary body", "e": "nuclei (L. nucleus: kernel, core, pl.) + corporis (L. corpus: body, gen.) + mamillaris (L. mamilla: nipple, little breast + -aris: pertaining to) + mediales (L. medius: middle + -alis: pertaining to, pl.) + laterales (L. latus: side + -alis: pertaining to, pl.)", "p": 314}, {"t": "Nucleus hypothalamicus posterior", "m": "Posterior hypothalamic nucleus", "e": "nucleus (L. nucleus: kernel, core) + hypothalamicus (Gk. hypo: under + thalamos: inner chamber) + posterior (L. posterior: behind, later)", "p": 314}, {"t": "Tractus et fasciculi hypothalamici", "m": "Hypothalamic tract and fasciculi", "e": "tractus (L. tractus: tract, drawing out) + et (L. et: and) + fasciculi (L. fasciculus: little bundle, pl.) + hypothalamici (Gk. hypo: under + thalamos: inner chamber + -ici: pertaining to, pl.)", "p": 314}, {"t": "Commissura supraoptica dorsalis", "m": "Dorsal supraoptic commissure", "e": "commissura (L. commissura: joining together, from committere: to connect) + supraoptica (L. supra: above + opticus: of the eye, from Gk. optikos: visual + -a: pertaining to) + dorsalis (L. dorsum: back + -alis: pertaining to)", "p": 314}, {"t": "Commissura supraoptica ventralis", "m": "Ventral supraoptic commissure", "e": "commissura (L. commissura: joining together, from committere: to connect) + supraoptica (L. supra: above + opticus: of the eye, from Gk. optikos: visual + -a: pertaining to) + ventralis (L. venter: belly + -alis: pertaining to)", "p": 314}, {"t": "Fasciculus longitudinalis dorsalis", "m": "Posterior (dorsal) longitudinal fasciculus", "e": "fasciculus (L. fasciculus: little bundle, diminutive of fascis: bundle) + longitudinalis (L. longitudo: length + -alis: pertaining to) + dorsalis (L. dorsum: back + -alis: pertaining to)", "p": 314}, {"t": "Fasciculus mamillotegmentalis", "m": "Mamillotegmental fasciculus", "e": "fasciculus (L. fasciculus: little bundle) + mamillo (L. mamilla: nipple, little breast) + tegmentalis (L. tegmentum: covering, roof + -alis: pertaining to)", "p": 314}, {"t": "Fornix", "m": "Fornix", "e": "fornix (L. fornix: arch, vault)", "p": 314}, {"t": "Fibrae striae terminalis", "m": "Fibers of stria terminalis", "e": "fibrae (L. fibra: fiber, pl.) + striae (L. stria: groove, stripe, gen.) + terminalis (L. terminus: end, boundary + -alis: pertaining to)", "p": 314}, {"t": "Fasciculus prosencephalicus medialis", "m": "Medial prosencephalic fasciculus", "e": "fasciculus (L. fasciculus: little bundle) + prosencephalicus (Gk. pros: forward + enkephalos: brain + -icus: pertaining to) + medialis (L. medius: middle + -alis: pertaining to)", "p": 314}, {"t": "Tractus hypothalamohypophysialis", "m": "Hypothalamohypophysial tract", "e": "tractus (L. tractus: tract, drawing out) + hypothalamo (Gk. hypo: under + thalamos: inner chamber) + hypophysialis (Gk. hypo: under + phyein: to grow + -alis: pertaining to)", "p": 314}, {"t": "Fibrae supraopticae", "m": "Supraoptic fibers", "e": "fibrae (L. fibra: fiber, pl.) + supraopticae (L. supra: above + opticus: of the eye, from Gk. optikos: visual + -ae: pertaining to, pl.)", "p": 314}, {"t": "Fibrae paraventriculares", "m": "Paraventricular fibers", "e": "fibrae (L. fibra: fiber, pl.) + paraventriculares (L. para: beside + ventriculus: little belly, ventricle + -aris: pertaining to, pl.)", "p": 314}, {"t": "Tractus supraopticohypophysialis", "m": "Supraopticohypophysial tract", "e": "tractus (L. tractus: tract, drawing out) + supraoptico (L. supra: above + opticus: of the eye, from Gk. optikos: visual) + hypophysialis (Gk. hypo: under + phyein: to grow + -alis: pertaining to)", "p": 314}, {"t": "Tractus paraventriculohypophysialis", "m": "Paraventriculohypophysial tract", "e": "tractus (L. tractus: tract, drawing out) + paraventriculo (L. para: beside + ventriculus: little belly, ventricle) + hypophysialis (Gk. hypo: under + phyein: to grow + -alis: pertaining to)", "p": 314}, {"t": "Telencephalon", "m": "The endbrain, which is formed by invagination of the prosencephalon (forebrain)", "e": "telos (Gk. τέλος: end, completion) + enkephalon (Gk. ἐγκέφαλος: brain, from en = in + kephalē = head)", "p": 316}, {"t": "Prosencephalon", "m": "Forebrain", "e": "pros (Gk. πρός: before, forward) + enkephalon (Gk. ἐγκέφαλος: brain, from en = in + kephalē = head)", "p": 316}, {"t": "Cortex cerebralis", "m": "Cerebral cortex (pallium)", "e": "cortex (L. cortex: bark, outer layer) + cerebralis (L. cerebrālis: of the brain, from cerebrum = brain)", "p": 316}, {"t": "Pallium", "m": "Cerebral cortex (alternate term)", "e": "pallium (L. pallium: cloak, mantle)", "p": 316}, {"t": "Gyri cerebrales", "m": "Cerebral gyri — convolutions of the cerebral hemispheres, about 1 cm wide", "e": "gyri (Gk. γῦρος: circle, ring; pl. gyri) + cerebrales (L. cerebrālis: of the brain, from cerebrum = brain)", "p": 316}, {"t": "Sulci cerebrales", "m": "Cerebral sulci — fissures between gyri", "e": "sulci (L. sulcus: furrow, groove; pl. sulci) + cerebrales (L. cerebrālis: of the brain, from cerebrum = brain)", "p": 316}, {"t": "Lobi cerebrales", "m": "Cerebral lobes — the four lobes of the cerebrum: frontal, parietal, temporal and occipital", "e": "lobi (Gk. λοβός: lobe; pl. lobi) + cerebrales (L. cerebrālis: of the brain, from cerebrum = brain)", "p": 316}, {"t": "Fissura longitudinalis cerebri", "m": "Longitudinal fissure of cerebrum — deep longitudinal groove between the right and left cerebral hemispheres", "e": "fissura (L. fissūra: cleft, crack, from findere = to split) + longitudinalis (L. longitudinālis: lengthwise, from longitudo = length) + cerebri (L. cerebrum: brain; genitive = of the brain)", "p": 316}, {"t": "Fissura transversa cerebri", "m": "Transverse fissure of cerebrum — fissure beneath the corpus callosum and fornix as well as above the thalamus and roof of the 3rd ventricle", "e": "fissura (L. fissūra: cleft, crack, from findere = to split) + transversa (L. transversus: lying across, from trans = across + vertere = to turn) + cerebri (L. cerebrum: brain; genitive = of the brain)", "p": 316}, {"t": "Fissura telodiencephalica", "m": "Transverse fissure of cerebrum (alternate term)", "e": "fissura (L. fissūra: cleft, crack) + telo (Gk. τέλος: end) + di (Gk. δί: two, through) + enkephalica (Gk. ἐγκέφαλος: brain)", "p": 316}, {"t": "Corpus callosum", "m": "Part of the endbrain structure", "e": "corpus (L. corpus: body) + callosum (L. callōsus: hard, tough, from callum = hardened skin)", "p": 316}, {"t": "Fossa lateralis cerebri", "m": "Lateral fossa of cerebrum — space deep within the lateral sulcus", "e": "fossa (L. fossa: ditch, pit, from fodere = to dig) + lateralis (L. laterālis: of the side, from latus = side) + cerebri (L. cerebrum: brain; genitive = of the brain)", "p": 316}, {"t": "Margo superior (superomedialis)", "m": "Superior (superomedial) margin — superior border of a hemisphere between the superolateral and medial surface", "e": "margo (L. margo: border, edge, margin) + superior (L. superior: upper, higher) + superomedialis (L. superus = upper + medialis = middle, from medius = middle)", "p": 316}, {"t": "Margo inferior (inferolateralis)", "m": "Inferior (inferolateral) margin — inferolateral border of a hemisphere between the superolateral and inferior surfaces", "e": "margo (L. margo: border, edge, margin) + inferior (L. inferior: lower) + inferolateralis (L. inferus = below + laterālis = of the side, from latus = side)", "p": 316}, {"t": "Margo medialis (inferomedialis)", "m": "Medial (inferomedial) margin — inferomedial border of either hemisphere between the inferior and medial surfaces", "e": "margo (L. margo: border, edge, margin) + medialis (L. mediālis: of the middle, from medius = middle) + inferomedialis (L. inferus = below + medialis = of the middle)", "p": 316}, {"t": "Fissura limitans", "m": "Fissure between the insula and opercula; the floor of this cleft, the sulcus limitans, receives the insula", "e": "fissura (L. fissūra: cleft, crack, from findere = to split) + limitans (L. limitāns: limiting, bounding, from limes = boundary)", "p": 316}, {"t": "Sulcus limitans", "m": "Floor of the fissura limitans, receives the insula", "e": "sulcus (L. sulcus: furrow, groove) + limitans (L. limitāns: limiting, bounding, from limes = boundary)", "p": 316}, {"t": "Hemispharium cerebrale", "m": "Cerebral hemisphere — half of the telencephalon", "e": "hemispharium (Gk. hēmi = half + sphaira = sphere/ball) + cerebrale (L. cerebrālis: of the brain, from cerebrum = brain)", "p": 316}, {"t": "Facies superolateralis hemispherii", "m": "Superolateral surface of hemisphere — upper and lateral surface of the hemisphere", "e": "facies (L. faciēs: face, surface, appearance) + superolateralis (L. superus = upper + laterālis = of the side) + hemispherii (Gk. hēmi = half + sphaira = sphere; genitive = of the hemisphere)", "p": 316}, {"t": "Sulcus centralis", "m": "Central sulcus — furrow located between the pre- and postcentral gyri and between the frontal and parietal lobes", "e": "sulcus (L. sulcus: furrow, groove) + centralis (L. centrālis: of the center, from centrum = center, from Gk. kentron = center point)", "p": 316}, {"t": "Sulcus lateralis", "m": "Lateral sulcus — deep cleft passing superiorly between the temporal and frontal lobes and inferiorly between the temporal and parietal lobes", "e": "sulcus (L. sulcus: furrow, groove) + lateralis (L. laterālis: of the side, from latus = side)", "p": 316}, {"t": "Ramus ascendens", "m": "Ascending ramus — short branch of the lateral sulcus ascending into the frontal lobe", "e": "ramus (L. rāmus: branch) + ascendens (L. ascendēns: ascending, rising, from ascendere = to climb up)", "p": 316}, {"t": "Sulci interlobares", "m": "Interlobar sulci — furrows which separate the cerebral lobes from one another", "e": "sulci (L. sulcus: furrow, groove; pl. sulci) + interlobares (L. inter = between + lobus = lobe, from Gk. lobos = lobe)", "p": 316}, {"t": "Lobus frontalis", "m": "Frontal lobe — lobe extending from the frontal pole to the central sulcus", "e": "lobus (Gk. λοβός: lobe) + frontalis (L. frontālis: of the forehead/front, from frons = forehead, front)", "p": 316}, {"t": "Polus frontalis", "m": "Frontal pole — anterior end of the frontal lobe", "e": "polus (Gk. πόλος: axis, pole) + frontalis (L. frontālis: of the forehead/front, from frons = forehead, front)", "p": 316}, {"t": "Sulcus precentralis", "m": "Precentral sulcus — furrow in front of the precentral gyrus", "e": "sulcus (L. sulcus: furrow, groove) + precentralis (L. prae = before + centrālis = of the center, from centrum = center)", "p": 316}, {"t": "Gyrus precentralis", "m": "Precentral gyrus — convolution of the frontal lobe lying in front of the central sulcus; motor area of the cerebral cortex", "e": "gyrus (Gk. γῦρος: circle, ring) + precentralis (L. prae = before + centrālis = of the center, from centrum = center)", "p": 316}, {"t": "Gyrus frontalis superior", "m": "Superior frontal gyrus (primary motor area)", "e": "gyrus (Gk. γῦρος: circle, ring) + frontalis (L. frontālis: of the forehead/front, from frons = forehead) + superior (L. superior: upper, higher)", "p": 316}, {"t": "Sulcus frontalis superior", "m": "Superior frontal sulcus — furrow below the superior frontal gyrus", "e": "sulcus (L. sulcus: furrow, groove) + frontalis (L. frontālis: of the forehead/front, from frons = forehead) + superior (L. superior: upper, higher)", "p": 316}, {"t": "Gyrus frontalis medius", "m": "Middle frontal gyrus", "e": "gyrus (Gk. γῦρος: circle, ring) + frontalis (L. frontālis: of the forehead/front, from frons = forehead) + medius (L. medius: middle)", "p": 316}, {"t": "Sulcus frontalis inferior", "m": "Inferior frontal sulcus — furrow lying between the middle and inferior frontal gyri", "e": "sulcus (L. sulcus: furrow, groove) + frontalis (L. frontālis: of the forehead/front, from frons = forehead) + inferior (L. inferior: lower)", "p": 316}, {"t": "Gyrus frontalis inferior", "m": "Inferior frontal gyrus", "e": "gyrus (Gk. γῦρος: circle, ring) + frontalis (L. frontālis: of the forehead/front, from frons = forehead) + inferior (L. inferior: lower)", "p": 316}, {"t": "Pars opercularis", "m": "Opercular part (frontal operculum) — part of inferior frontal gyrus lying behind the ascending ramus and covering the insula", "e": "pars (L. pars: part, portion) + opercularis (L. operculum: lid, cover, from operire = to cover; operculāris = of the lid/cover)", "p": 316}, {"t": "Operculum frontale", "m": "Frontal operculum (alternate term for opercular part)", "e": "operculum (L. operculum: lid, cover, from operire = to cover) + frontale (L. frontālis: of the forehead/front, from frons = forehead)", "p": 316}, {"t": "Pars triangularis", "m": "Triangular part — portion of the inferior frontal gyrus located between the anterior and descending rami of the lateral sulcus; region of the motor speech center of Broca", "e": "pars (L. pars: part, portion) + triangularis (L. triangulāris: triangular, from tri = three + angulus = angle)", "p": 316}, {"t": "Corpus striatum", "m": "Part of the endbrain (corpus striatum)", "e": "corpus (L. corpus: body) + striatum (L. striātus: striped, grooved, from stria = stripe, groove)", "p": 316}, {"t": "Insula", "m": "The insula (received by the sulcus limitans)", "e": "insula (L. insula: island)", "p": 316}, {"t": "Lobus parietalis", "m": "Parietal lobe — bounded anteriorly by the central sulcus, posteriorly by the parieto-occipital sulcus", "e": "lobus (Gk. lobos: lobe, rounded projection) + parietalis (L. parietalis: of the wall, from paries = wall, referring to the parietal bone)", "p": 318}, {"t": "Sulcus postcentralis", "m": "Postcentral sulcus — posterior boundary of the postcentral gyrus", "e": "sulcus (L. sulcus: furrow, groove) + post- (L. post: after, behind) + centralis (L. centralis: central, from centrum = center)", "p": 318}, {"t": "Gyrus postcentralis", "m": "Postcentral gyrus — predominantly sensory area of the parietal lobe between the central and postcentral sulci", "e": "gyrus (Gk. gyros: circle, ring, convolution) + post- (L. post: after, behind) + centralis (L. centralis: central, from centrum = center)", "p": 318}, {"t": "Lobulus parietalis superior", "m": "Superior parietal lobule — upper half of parietal lobe situated behind the postcentral gyrus and above the intraparietal sulcus", "e": "lobulus (L. lobulus: small lobe, diminutive of lobus) + parietalis (L. parietalis: of the wall, from paries = wall) + superior (L. superior: upper, higher)", "p": 318}, {"t": "Sulcus intraparietalis", "m": "Intraparietal sulcus — inconstant sagittal furrow between the superior and inferior parietal lobulus", "e": "sulcus (L. sulcus: furrow, groove) + intra- (L. intra: within, inside) + parietalis (L. parietalis: of the wall, from paries = wall)", "p": 318}, {"t": "Lobulus parietalis inferior", "m": "Inferior parietal lobule — lower half of parietal lobe situated behind the postcentral gyrus and below the intraparietal sulcus", "e": "lobulus (L. lobulus: small lobe, diminutive of lobus) + parietalis (L. parietalis: of the wall, from paries = wall) + inferior (L. inferior: lower)", "p": 318}, {"t": "Operculum frontoparietale", "m": "Frontoparietal operculum — part of the cerebral segment located above the posterior ramus of the lateral sulcus and covering the insula", "e": "operculum (L. operculum: lid, cover, from operire = to cover) + fronto- (L. frons/frontis: forehead, front) + parietale (L. parietalis: of the wall, from paries = wall)", "p": 318}, {"t": "Gyrus supramarginalis", "m": "Supramarginal gyrus — convolution curving around the posterior end of the posterior ramus of the lateral sulcus", "e": "gyrus (Gk. gyros: circle, ring, convolution) + supra- (L. supra: above, over) + marginalis (L. marginalis: of the margin/edge, from margo = edge, border)", "p": 318}, {"t": "Gyrus angularis", "m": "Angular gyrus — convolution curving around the posterior end of the superior temporal sulcus", "e": "gyrus (Gk. gyros: circle, ring, convolution) + angularis (L. angularis: angular, of a corner, from angulus = angle, corner)", "p": 318}, {"t": "Lobus occipitalis", "m": "Occipital lobe — incompletely bounded by the parietal and parieto-occipital sulci and the pre-occipital incisure", "e": "lobus (Gk. lobos: lobe, rounded projection) + occipitalis (L. occipitalis: of the occiput, from ob = against + caput = head)", "p": 318}, {"t": "Polus occipitalis", "m": "Occipital pole — posterior end of occipital lobe", "e": "polus (Gk./L. polus: pole, end) + occipitalis (L. occipitalis: of the occiput, from ob = against + caput = head)", "p": 318}, {"t": "Sulcus occipitalis transversus", "m": "Transverse occipital sulcus — continuation of the intraparietalis sulcus on the occipital lobe", "e": "sulcus (L. sulcus: furrow, groove) + occipitalis (L. occipitalis: of the occiput, from ob = against + caput = head) + transversus (L. transversus: lying across, from trans = across + vertere = to turn)", "p": 318}, {"t": "Sulcus lunatus", "m": "Lunate sulcus — sometimes conspicuous semilunar furrow that forms the anterior boundary of the visual cortex", "e": "sulcus (L. sulcus: furrow, groove) + lunatus (L. lunatus: crescent-shaped, from luna = moon)", "p": 318}, {"t": "Incisura preoccipitalis", "m": "Preoccipital incisure — notch near the inferolateral edge of the cerebral hemisphere marking the boundary between occipital and temporal lobes", "e": "incisura (L. incisura: notch, incision, from incidere = to cut into) + pre- (L. pre: before, in front of) + occipitalis (L. occipitalis: of the occiput, from ob = against + caput = head)", "p": 318}, {"t": "Lobus temporalis", "m": "Temporal lobe — bounded superiorly by the posterior ramus of the lateral sulcus", "e": "lobus (Gk. lobos: lobe, rounded projection) + temporalis (L. temporalis: of the temple/time, from tempora = the temples of the head)", "p": 318}, {"t": "Polus temporalis", "m": "Temporal pole — anterior end of temporal lobe", "e": "polus (Gk./L. polus: pole, end) + temporalis (L. temporalis: of the temple, from tempora = the temples of the head)", "p": 318}, {"t": "Sulci temporales transversi", "m": "Transverse temporal sulci — transverse furrows between the transverse temporal gyri in the floor of the posterior ramus of the lateral sulcus", "e": "sulci (L. sulcus: furrow, groove, plural) + temporales (L. temporalis: of the temple, from tempora = temples) + transversi (L. transversus: lying across, from trans = across + vertere = to turn, plural)", "p": 318}, {"t": "Gyri temporales transversi", "m": "Transverse temporal gyri — 2–4 transverse convolutions in the floor of the posterior ramus of the lateral sulcus; acoustic center", "e": "gyri (Gk. gyros: circle, ring, convolution, plural) + temporales (L. temporalis: of the temple, from tempora = temples, plural) + transversi (L. transversus: lying across, from trans = across + vertere = to turn, plural)", "p": 318}, {"t": "Gyrus temporalis superior", "m": "Superior temporal gyrus", "e": "gyrus (Gk. gyros: circle, ring, convolution) + temporalis (L. temporalis: of the temple, from tempora = temples) + superior (L. superior: upper, higher)", "p": 318}, {"t": "Operculum temporale", "m": "Temporal operculum — part of superior temporal gyrus which covers the insula", "e": "operculum (L. operculum: lid, cover, from operire = to cover) + temporale (L. temporalis: of the temple, from tempora = temples)", "p": 318}, {"t": "Sulcus temporalis superior", "m": "Superior temporal sulcus — cleft between the superior and middle temporal gyri", "e": "sulcus (L. sulcus: furrow, groove) + temporalis (L. temporalis: of the temple, from tempora = temples) + superior (L. superior: upper, higher)", "p": 318}, {"t": "Gyrus temporalis medius", "m": "Middle temporal gyrus", "e": "gyrus (Gk. gyros: circle, ring, convolution) + temporalis (L. temporalis: of the temple, from tempora = temples) + medius (L. medius: middle, intermediate)", "p": 318}, {"t": "Sulcus temporalis inferior", "m": "Inferior temporal sulcus — cleft between the middle and inferior temporal gyri", "e": "sulcus (L. sulcus: furrow, groove) + temporalis (L. temporalis: of the temple, from tempora = temples) + inferior (L. inferior: lower)", "p": 318}, {"t": "Gyrus temporalis inferior", "m": "Inferior temporal gyrus", "e": "gyrus (Gk. gyros: circle, ring, convolution) + temporalis (L. temporalis: of the temple, from tempora = temples) + inferior (L. inferior: lower)", "p": 318}, {"t": "Lobus insularis", "m": "Insula (insular lobe) — originally exposed cerebral cortex overlapped during ontogenesis, lying on the floor of the lateral cerebral fossa", "e": "lobus (Gk. lobos: lobe, rounded projection) + insularis (L. insularis: of an island, from insula = island)", "p": 318}, {"t": "Gyri insulae", "m": "Insular gyri — gyri on the surface of the insula", "e": "gyri (Gk. gyros: circle, ring, convolution, plural) + insulae (L. insula: island, genitive singular)", "p": 318}, {"t": "Gyri breves insulae", "m": "Short gyri of insula — short gyri located in the upper portion of the insula", "e": "gyri (Gk. gyros: circle, ring, convolution, plural) + breves (L. brevis: short, brief, plural) + insulae (L. insula: island, genitive singular)", "p": 318}, {"t": "Gyrus longus insulae", "m": "Long gyrus of insula — long horizontal convolution located below the short gyri", "e": "gyrus (Gk. gyros: circle, ring, convolution) + longus (L. longus: long) + insulae (L. insula: island, genitive singular)", "p": 318}, {"t": "Limen insulae", "m": "Limen insulae — terminal portion of the insular directed anteroinferiorly toward the anterior perforated substance, covered by the middle cerebral artery", "e": "limen (L. limen: threshold, entrance) + insulae (L. insula: island, genitive singular)", "p": 318}, {"t": "Sulcus centralis insulae", "m": "Central sulcus of insula — cleft between the long and short gyri of the insula", "e": "sulcus (L. sulcus: furrow, groove) + centralis (L. centralis: central, from centrum = center) + insulae (L. insula: island, genitive singular)", "p": 318}, {"t": "Sulcus circularis insulae", "m": "Circular sulcus of insula — limiting furrow of the insula, interrupted by the limen insulae", "e": "sulcus (L. sulcus: furrow, groove) + circularis (L. circularis: circular, from circulus = circle) + insulae (L. insula: island, genitive singular)", "p": 318}, {"t": "Facies medialis et inferior hemispherii cerebri", "m": "Medial and inferior surfaces of a cerebral hemisphere", "e": "facies (L. faciēs: face, surface) + medialis (L. mediālis: middle, from medius = middle) + et (L. et: and) + inferior (L. inferior: lower) + hemispherii (Gk. hēmisphairion: half-sphere, from hēmi = half + sphaira = sphere) + cerebri (L. cerebrum: brain)", "p": 320}, {"t": "Sulcus corporis callosi", "m": "Sulcus of corpus callosum — cleft between the corpus callosum and the cingulate gyrus", "e": "sulcus (L. sulcus: groove, furrow) + corporis (L. corpus: body, genitive corporis) + callosi (L. callosus: hard, tough, from callum = hardened skin)", "p": 320}, {"t": "Gyrus cinguli (cingulatum)", "m": "Cingulate gyrus — convolution between the cingulate sulcus and sulcus of the corpus callosum", "e": "gyrus (Gk. gyros: circle, ring) + cinguli (L. cingulum: girdle, belt, from cingere = to encircle) + cingulatum (L. cingulatus: girdled, belted)", "p": 320}, {"t": "Isthmus gyri cinguli (cingulatus)", "m": "Isthmus of cingulate gyrus — constricted area where the cingulate gyrus connects with the parahippocampal gyrus", "e": "isthmus (Gk. isthmos: narrow passage, neck of land) + gyri (Gk. gyros: circle, ring) + cinguli (L. cingulum: girdle, from cingere = to encircle) + cingulatus (L. cingulatus: girdled)", "p": 320}, {"t": "Sulcus cinguli (cingulatus)", "m": "Cingulate sulcus — furrow bounding the anterior portion of cingulate gyrus anteriorly and superiorly", "e": "sulcus (L. sulcus: groove, furrow) + cinguli (L. cingulum: girdle, from cingere = to encircle) + cingulatus (L. cingulatus: girdled)", "p": 320}, {"t": "Sulcus subparietalis", "m": "Subparietal sulcus — furrow bounding the posterior portion of the cingulate gyrus superiorly and posteriorly", "e": "sulcus (L. sulcus: groove, furrow) + subparietalis (L. sub = under/below + parietalis = of a wall, from paries = wall)", "p": 320}, {"t": "Gyrus frontalis medialis", "m": "Medial frontal gyrus — convolution superior to the medial surface of the frontal lobe", "e": "gyrus (Gk. gyros: circle, ring) + frontalis (L. frontalis: of the forehead/front, from frons = forehead) + medialis (L. mediālis: middle, from medius = middle)", "p": 320}, {"t": "Lobulus paracentralis", "m": "Paracentral lobule — hooklike connection between the pre- and postcentral gyri on the medial surface", "e": "lobulus (L. lobulus: small lobe, diminutive of lobus) + paracentralis (Gk. para = beside + L. centralis = of the center, from centrum = center)", "p": 320}, {"t": "Precuneus", "m": "Precuneus — area in front of the parieto-occipital sulcus", "e": "pre (L. prae: before, in front of) + cuneus (L. cuneus: wedge)", "p": 320}, {"t": "Sulcus parieto-occipitalis", "m": "Parieto-occipital sulcus — deep cleft in front of the cuneus separating the occipital and parietal lobes", "e": "sulcus (L. sulcus: groove, furrow) + parietalis (L. parietalis: of a wall, from paries = wall) + occipitalis (L. occipitalis: of the back of the head, from ob = against + caput = head)", "p": 320}, {"t": "Cuneus", "m": "Cuneus — portion of the brain located between the calcarine and parieto-occipital sulci", "e": "cuneus (L. cuneus: wedge)", "p": 320}, {"t": "Sulcus calcarinus", "m": "Calcarine sulcus — deep furrow below the cuneus near the primary visual area", "e": "sulcus (L. sulcus: groove, furrow) + calcarinus (L. calcarinus: spur-like, from calcar = spur, from calx = heel)", "p": 320}, {"t": "Gyrus dentatus", "m": "Dentate gyrus — curved convolution of gray matter with a serrated appearance", "e": "gyrus (Gk. gyros: circle, ring) + dentatus (L. dentatus: toothed, from dens/dentis = tooth)", "p": 320}, {"t": "Sulcus hippocampi (hippocampalis)", "m": "Hippocampal sulcus — furrow situated between the parahippocampal and dentate gyri", "e": "sulcus (L. sulcus: groove, furrow) + hippocampi (Gk. hippokampos: sea-horse, from hippos = horse + kampos = sea-monster) + hippocampalis (Gk./L. of the hippocampus)", "p": 320}, {"t": "Gyrus hippocampi (parahippocampalis)", "m": "Parahippocampal gyrus — thick convolution located below the hippocampal sulcus", "e": "gyrus (Gk. gyros: circle, ring) + hippocampi (Gk. hippokampos: sea-horse) + parahippocampalis (Gk. para = beside + hippokampos = sea-horse)", "p": 320}, {"t": "Uncus", "m": "Uncus — hooklike structure on the anterior end of the parahippocampal gyrus", "e": "uncus (L. uncus: hook)", "p": 320}, {"t": "Gyrus lingualis", "m": "Lingual gyrus — occipitally directed continuation of the parahippocampal gyrus", "e": "gyrus (Gk. gyros: circle, ring) + lingualis (L. lingualis: of the tongue, from lingua = tongue)", "p": 320}, {"t": "Sulcus collateralis", "m": "Collateral sulcus — furrow between the parahippocampal and medial occipitotemporal gyri extending into the occipital lobe", "e": "sulcus (L. sulcus: groove, furrow) + collateralis (L. collateralis: alongside, from com = together + latus/lateris = side)", "p": 320}, {"t": "Sulcus rhinalis", "m": "Rhinal sulcus — continuation of the collateral sulcus occasionally present lateral to the uncus", "e": "sulcus (L. sulcus: groove, furrow) + rhinalis (Gk. rhinalis: of the nose, from rhis/rhinos = nose)", "p": 320}, {"t": "Gyrus occipitotemporalis medialis", "m": "Medial occipitotemporal gyrus — basal convolution between the collateral and occipitotemporal sulci", "e": "gyrus (Gk. gyros: circle, ring) + occipitotemporalis (L. occiput = back of head + temporalis = of the temple, from tempus = temple) + medialis (L. mediālis: middle, from medius = middle)", "p": 320}, {"t": "Sulcus occipitotemporalis", "m": "Occipitotemporal sulcus — cleft between the medial and lateral occipitotemporal gyri on the inferior surface", "e": "sulcus (L. sulcus: groove, furrow) + occipitotemporalis (L. occiput = back of head + temporalis = of the temple, from tempus = temple)", "p": 320}, {"t": "Gyrus occipitotemporalis lateralis", "m": "Lateral occipitotemporal gyrus — convolution adjoining the occipitotemporal sulcus laterally", "e": "gyrus (Gk. gyros: circle, ring) + occipitotemporalis (L. occiput = back of head + temporalis = of the temple) + lateralis (L. lateralis: of the side, from latus = side)", "p": 320}, {"t": "Gyrus rectus", "m": "Gyrus rectus — elongated convolution located above the orbit at its medial margin", "e": "gyrus (Gk. gyros: circle, ring) + rectus (L. rectus: straight, upright, from regere = to direct)", "p": 320}, {"t": "Gyri orbitales", "m": "Orbital gyri — frontal convolutions located lateral to the gyrus rectus", "e": "gyri (Gk. gyros: circle, ring) + orbitales (L. orbitalis: of the orbit, from orbita = track, orbit, from orbis = circle)", "p": 320}, {"t": "Sulci orbitales", "m": "Orbital sulci — furrows between the orbital gyri", "e": "sulci (L. sulcus: groove, furrow) + orbitales (L. orbitalis: of the orbit, from orbita = track)", "p": 320}, {"t": "Rhinencephalon", "m": "Olfactory brain", "e": "rhinen (Gk. rhis/rhinos: nose) + encephalon (Gk. enkephalos: brain, from en = in + kephalē = head)", "p": 320}, {"t": "Bulbus olfactorius", "m": "Olfactory bulb — knob-like enlargement containing dendrite-rich mitral cells at the beginning of the olfactory tract", "e": "bulbus (L. bulbus: bulb, from Gk. bolbos = bulbous root) + olfactorius (L. olfactorius: of smell, from olfacere = to smell)", "p": 320}, {"t": "Tractus olfactorius", "m": "Olfactory tract — connection between the olfactory bulb and trigone on the inferior surface of the frontal lobe", "e": "tractus (L. tractus: tract, path, from trahere = to draw/pull) + olfactorius (L. olfactorius: of smell, from olfacere = to smell)", "p": 320}, {"t": "Trigonum olfactorium", "m": "Olfactory trigone — triangular widening at the end of the olfactory tract", "e": "trigonum (Gk. trigonon: triangle, from tri = three + gonia = angle) + olfactorium (L. olfactorius: of smell, from olfacere = to smell)", "p": 320}, {"t": "Striae olfactoriae medialis et lateralis", "m": "Medial and lateral olfactory striae — diverging fiber bundles of the olfactory tract radiating fanlike at the olfactory trigone", "e": "striae (L. stria: stripe, groove, furrow) + olfactoriae (L. olfactorius: of smell, from olfacere = to smell) + medialis (L. mediālis: middle, from medius = middle) + et (L. et: and) + lateralis (L. lateralis: of the side, from latus = side)", "p": 320}, {"t": "Gyri olfactorii medialis et lateralis", "m": "Medial and lateral olfactory gyri — cellular continuations of the corresponding olfactory striae", "e": "gyri (Gk. gyros: circle, ring) + olfactorii (L. olfactorius: of smell, from olfacere = to smell) + medialis (L. mediālis: middle, from medius = middle) + et (L. et: and) + lateralis (L. lateralis: of the side, from latus = side)", "p": 320}, {"t": "Substantia perforata anterior", "m": "Anterior perforated substance — area posterior to the olfactory trigone with perforations for the passage of cerebral vessels", "e": "substantia (L. substantia: substance, matter) + perforata (L. perforāta: perforated, pierced through, from per- = through + forare = to bore) + anterior (L. anterior: front, former, from ante = before)", "p": 322}, {"t": "Stria diagonalis", "m": "Diagonal stria (band) of Broca — bundle of myelinated fibers often coursing obliquely over the anterior perforated substance", "e": "stria (L. stria: groove, stripe, furrow) + diagonalis (Gk. diagonios: diagonal, from dia- = across + gonia = angle)", "p": 322}, {"t": "Area subcallosa", "m": "Subcallosal area — area on the medial surface of the frontal lobe situated below the genu and rostrum of the corpus callosum", "e": "area (L. area: open space, area) + subcallosa (L. sub- = under + callosus = hard, thick-skinned, from callus = hard skin)", "p": 322}, {"t": "Gyrus paraterminalis", "m": "Paraterminal gyrus — convolution on the medial surface below the rostrum and in front of the laminal terminalis", "e": "gyrus (Gk. gyros: circle, ring, convolution) + paraterminalis (L. para- = beside + terminalis = of a boundary, from terminus = boundary, end)", "p": 322}, {"t": "Splenium", "m": "Splenium — thick, free posterior end of the corpus callosum", "e": "splenium (Gk. splenion: bandage, compress, from splen = spleen; used anatomically for a bandage-like structure)", "p": 322}, {"t": "Truncus", "m": "Trunk — portion of corpus callosum between the splenium and genu", "e": "truncus (L. truncus: trunk, main stem, torso)", "p": 322}, {"t": "Genu", "m": "Genu — bend in the corpus callosum located anteriorly above the rostrum", "e": "genu (L. genu: knee, a knee-like bend)", "p": 322}, {"t": "Rostrum", "m": "Rostrum — anterior end of corpus callosum that tapers inferiorly to a point where it joins the lamina terminalis", "e": "rostrum (L. rostrum: beak, snout, prow of a ship, from rodere = to gnaw)", "p": 322}, {"t": "Radiatio corporis callosi", "m": "Radiation of corpus callosum — fibers radiating from the corpus callosum to the cerebral cortex", "e": "radiatio (L. radiatio: radiation, spreading out, from radiare = to radiate, from radius = ray) + corporis (L. corpus: body, gen. corporis) + callosi (L. callosus: hard, gen. callosi)", "p": 322}, {"t": "Forceps frontalis (minor)", "m": "Forceps minor — U-shaped fibers passing through the genu of the corpus callosum and connecting the frontal lobes", "e": "forceps (L. forceps: tongs, pincers, from formus = warm + capere = to take, or ferre = to hold) + frontalis (L. frontalis: of the forehead/frontal, from frons = forehead) + minor (L. minor: smaller, lesser)", "p": 322}, {"t": "Forceps occipitalis (major)", "m": "Forceps major — U-shaped fibers passing through the splenium of the corpus callosum and connecting the posterior parts of the occipital lobes", "e": "forceps (L. forceps: tongs, pincers) + occipitalis (L. occipitalis: of the back of the head, from ob- = against + caput = head) + major (L. major: greater, larger)", "p": 322}, {"t": "Tapetum", "m": "Tapetum — continuous layer of fibers arching laterally and inferiorly from the corpus callosum and forming the lateral wall of the inferior and posterior horns of the lateral ventricle as well as the roof of the posterior horn", "e": "tapetum (L. tapetum: carpet, tapestry, from Gk. tapes = carpet)", "p": 322}, {"t": "Indusium griseum", "m": "Indusium griseum — thin layer of gray matter on the superior surface of the corpus callosum", "e": "indusium (L. indusium: undergarment, tunic, from induere = to put on) + griseum (Medieval L. griseus: gray, from Frankish *grīs = gray)", "p": 322}, {"t": "Stria longitudinalis medialis", "m": "Medial longitudinal stria — a medial longitudinal band of white fibers in the indusium griseum; part of the olfactory brain", "e": "stria (L. stria: groove, stripe, furrow) + longitudinalis (L. longitudinalis: longitudinal, from longitudo = length, from longus = long) + medialis (L. medialis: medial, middle, from medius = middle)", "p": 322}, {"t": "Stria longitudinalis lateralis", "m": "Lateral longitudinal stria — paired longitudinal stripe embedded in the indusium griseum and covered laterally by the cingulate gyrus; part of the olfactory brain", "e": "stria (L. stria: groove, stripe, furrow) + longitudinalis (L. longitudinalis: longitudinal, from longitudo = length) + lateralis (L. lateralis: lateral, from latus = side)", "p": 322}, {"t": "Gyrus fasciolaris", "m": "Gyrus fasciolaris — convolution that passes around the splenium of the corpus callosum and forms a connection between the longitudinal striae, including the indusium griseum and dentate gyrus", "e": "gyrus (Gk. gyros: circle, ring, convolution) + fasciolaris (L. fasciola: small band or bandage, diminutive of fascia = band, + -aris = pertaining to)", "p": 322}, {"t": "Lamina terminalis", "m": "Lamina terminalis — thin walled, anterior border of the 3rd ventricle", "e": "lamina (L. lamina: thin plate, layer, sheet) + terminalis (L. terminalis: of a boundary or end, from terminus = boundary, end)", "p": 322}, {"t": "Commissura anterior", "m": "Anterior commissure — anterior, transverse connection between the right and left halves of the cerebrum, lying behind the lamina terminalis", "e": "commissura (L. commissura: a joining together, seam, from committere = to join, from com- = together + mittere = to send) + anterior (L. anterior: front, from ante = before)", "p": 322}, {"t": "Crus", "m": "Crus of fornix — the posterior limb of the fornix that arises from the hippocampus as the hippocampal fimbria, circles around the pulvinar and unites with the contralateral limb to form the body of the fornix", "e": "crus (L. crus: leg, shank, limb, branch)", "p": 322}, {"t": "Corpus", "m": "Body of fornix — unparied middle part of fornix situated below the corpus callosum and formed by the union of both crura", "e": "corpus (L. corpus: body, main part)", "p": 322}, {"t": "Taenia", "m": "Tenia — thin, lateral margin of the fornix that gives attachment to the choroid plexus of the lateral ventricle", "e": "taenia (L. taenia, from Gk. tainia: band, ribbon, strip)", "p": 322}, {"t": "Columna", "m": "Column — anterior part of the fornix located partly in the lateral wall of the 3rd ventricle; extends as far as the mamillary body", "e": "columna (L. columna: column, pillar)", "p": 322}, {"t": "Commissura", "m": "Commissure — triangular connecting plate situated between the crura of the fornix below the posterior part of the corpus callosum; contains fibers crossing from the hippocampal fimbriae of both sides", "e": "commissura (L. commissura: a joining together, seam, from committere = com- = together + mittere = to send/put)", "p": 322}, {"t": "Septum pellucidum (lucidum)", "m": "Septum pellucidum — bilayered, thin plate extending between the corpus callosum and fornix; separates the anterior horns of the lateral ventricles from one another", "e": "septum (L. septum: partition, wall, fence, from saepire = to enclose) + pellucidum (L. pellucidus: transparent, clear, from per- = through + lucidus = bright, from lux = light); lucidum (L. lucidus: bright, clear, from lux = light)", "p": 322}, {"t": "Cavum septi pellucidi", "m": "Cavity of septum pellucidum — enclosed cavity of variable size between the two laminae of the septum pellucidum", "e": "cavum (L. cavum: hollow, cavity, from cavus = hollow) + septi (L. septum: partition, gen. septi) + pellucidi (L. pellucidus: transparent, gen. pellucidi, from per- = through + lucidus = bright)", "p": 322}, {"t": "Lamina septi pellucidi", "m": "Lamina of septum pellucidum — paired sheet forming the septum pellucidum and the lateral wall of its cavity", "e": "lamina (L. lamina: thin plate, layer, sheet) + septi (L. septum: partition, gen. septi) + pellucidi (L. pellucidus: transparent, gen. pellucidi, from per- = through + lucidus = bright)", "p": 322}, {"t": "Septum precommissurale", "m": "Precommissural septum — area on the free medial surface of the frontal lobe in front of the lamina terminalis", "e": "septum (L. septum: partition, wall, from saepire = to enclose) + precommissurale (L. prae- = before + commissura = joining together, from committere = com- = together + mittere = to send; -ale = adjectival suffix)", "p": 322}, {"t": "Crura", "m": "Crura — the legs/pillars of the fornix", "e": "crura (L. crura: plural of crus = leg, pillar)", "p": 323}, {"t": "Septum pellucidum", "m": "Pellucid septum — the thin translucent partition separating the two lateral ventricles", "e": "septum (L. septum: partition, fence, from saepire = to enclose) + pellucidum (L. pellucidus: transparent, from per = through + lucere = to shine)", "p": 323}, {"t": "Forceps major", "m": "Major forceps — the posterior (occipital) radiation of the corpus callosum", "e": "forceps (L. forceps: tongs, pincers, from formus = warm + capere = to take) + major (L. major: larger, greater)", "p": 323}, {"t": "Forceps minor", "m": "Minor forceps — the anterior (frontal) radiation of the corpus callosum", "e": "forceps (L. forceps: tongs, pincers, from formus = warm + capere = to take) + minor (L. minor: smaller, lesser)", "p": 323}, {"t": "Ventriculus lateralis", "m": "Lateral ventricle — paired ventricle which communicates with the third ventricle via the interventricular foramen", "e": "ventriculus (L. ventriculus: little belly, diminutive of venter = belly) + lateralis (L. lateralis: of the side, from latus = side)", "p": 324}, {"t": "Pars centralis", "m": "Central part — middle portion of lateral ventricle located above the thalamus and below the corpus callosum", "e": "pars (L. pars: part, portion) + centralis (L. centralis: central, from centrum = center, from Gk. kentron = center point)", "p": 324}, {"t": "Cornu frontale (anterius)", "m": "Anterior horn — part of the lateral ventricle that extends forward from the interventricular foramen", "e": "cornu (L. cornu: horn) + frontale (L. frontalis: of the forehead/front, from frons = forehead, front) + anterius (L. anterius: more anterior/forward, from ante = before)", "p": 324}, {"t": "Cornu occipitale (posterius)", "m": "Posterior horn — part of the lateral ventricle that extends into the occipital lobe", "e": "cornu (L. cornu: horn) + occipitale (L. occipitalis: of the back of the head, from ob = against + caput = head) + posterius (L. posterius: more posterior/behind, from post = after, behind)", "p": 324}, {"t": "Cornu temporale (inferius)", "m": "Inferior horn — part of the lateral ventricle that accompanies the hippocampus laterally and contains a part of the choroid plexus", "e": "cornu (L. cornu: horn) + temporale (L. temporalis: of the temple/temporal region, from tempora = temples of the head) + inferius (L. inferius: lower, from inferus = below)", "p": 324}, {"t": "Stria terminalis", "m": "Stria terminalis — longitudinal band of myelinated fibers located in the angle between the thalamus and caudate nucleus above the thalamostriate vein", "e": "stria (L. stria: stripe, groove, furrow) + terminalis (L. terminalis: of the end/boundary, from terminus = end, boundary)", "p": 324}, {"t": "Lamina affixa", "m": "Lamina affixa — floor of lateral ventricle between the stria terminalis and tenia choroidea", "e": "lamina (L. lamina: thin plate, layer) + affixa (L. affixus: attached, fixed to, from ad = to + figere = to fix)", "p": 324}, {"t": "Fissura choroidea", "m": "Choroid fissure — cleft between the thalamus and fornix for passage of the choroid plexus into the lateral ventricle", "e": "fissura (L. fissura: cleft, crack, from findere = to split) + choroidea (Gk. khorioeidēs: membrane-like, from khorion = membrane + eidos = form/appearance)", "p": 324}, {"t": "Taenia choroidea", "m": "Tenia choroidea — line of attachment of the lateral choroid plexus to the thalamus", "e": "taenia (L. taenia from Gk. tainia: band, ribbon, strip) + choroidea (Gk. khorioeidēs: membrane-like, from khorion = membrane + eidos = form)", "p": 324}, {"t": "Plexus choroideus ventriculi lateralis", "m": "Choroid plexus of lateral ventricle — highly vascularized fringelike villous folds that protrude into the lateral ventricle through the choroid fissure", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + choroideus (Gk. khorioeidēs: membrane-like, from khorion = membrane + eidos = form) + ventriculi (L. ventriculus: little belly, diminutive of venter = belly) + lateralis (L. lateralis: of the side, from latus = side)", "p": 324}, {"t": "Bulbus cornus occipitalis (posterioris)", "m": "Bulb of posterior horn — enlargement on the medial side of the posterior horn caused by fibers of the splenium of the corpus callosum", "e": "bulbus (L. bulbus from Gk. bolbos: bulb, rounded swelling) + cornus (L. cornu: horn, genitive form) + occipitalis (L. occipitalis: of the back of the head, from ob = against + caput = head) + posterioris (L. posterior: more behind, genitive form, from post = after)", "p": 324}, {"t": "Calcar avis", "m": "Calcar avis — enlargement on the medial side of the posterior horn produced by the calcarine fissure", "e": "calcar (L. calcar: spur, from calx = heel) + avis (L. avis: bird)", "p": 324}, {"t": "Eminentia collateralis", "m": "Collateral eminence — elevation in the lateral floor of the inferior horn near the hippocampus caused by the collateral sulcus", "e": "eminentia (L. eminentia: prominence, projection, from eminere = to stand out) + collateralis (L. collateralis: alongside, from com = together + latus = side)", "p": 324}, {"t": "Trigonum collaterale", "m": "Collateral trigone — broadened triangular area near the beginning of the collateral eminence at the border between the inferior and posterior horns", "e": "trigonum (L. trigonum from Gk. trigonon: triangle, from tri = three + gonia = angle) + collaterale (L. collateralis: alongside, from com = together + latus = side)", "p": 324}, {"t": "Hippocampus", "m": "Hippocampus — elongated elevation in the inferior horn formed by the hippocampal sulcus; a specifically structured part of the rhinencephalon", "e": "hippocampus (Gk. hippokampos: sea horse, from hippos = horse + kampos = sea monster/curve)", "p": 324}, {"t": "Pes", "m": "Pes — foot-like elevation at the anterior end of the hippocampus", "e": "pes (L. pes: foot)", "p": 324}, {"t": "Alveus", "m": "Alveus — thin layer of white matter on the hippocampus", "e": "alveus (L. alveus: trough, hollow, channel, from alvus = belly, cavity)", "p": 324}, {"t": "Fimbria", "m": "Fimbria — bundle of white fibers emanating from the alveus and passing medially and upward on the hippocampus to continue into the fornix as its crus", "e": "fimbria (L. fimbria: fringe, border, fiber edge)", "p": 324}, {"t": "Sectiones telencephalici", "m": "Sections of the telencephalon", "e": "sectiones (L. sectio: cutting, section, from secare = to cut) + telencephalici (Gk. telos = end + enkephalos = brain, from en = in + kephalē = head)", "p": 324}, {"t": "Archaeocortex (archipallium)", "m": "Archicortex — phylogenetically older part of the cerebral cortex with three instead of six layers, formed by the hippocampus and dentate gyrus", "e": "archaeo/archi (Gk. archaios/archi: ancient, primitive, from archē = beginning) + cortex (L. cortex: bark, outer layer) + pallium (L. pallium: cloak, mantle — referring to the cerebral mantle)", "p": 324}, {"t": "Palaeocortex", "m": "Paleocortex — oldest part of cerebral cortex originally derived from the piriform lobe", "e": "palaeo (Gk. palaios: old, ancient) + cortex (L. cortex: bark, outer layer)", "p": 324}, {"t": "Neocortex", "m": "Neocortex — the largest part of the cerebral cortex comprised of six layers", "e": "neo (Gk. neos: new) + cortex (L. cortex: bark, outer layer)", "p": 324}, {"t": "Mesocortex", "m": "Mesocortex — incompletely differentiated zone in the region of the insular cortex with visceral functions", "e": "meso (Gk. mesos: middle) + cortex (L. cortex: bark, outer layer)", "p": 324}, {"t": "Ventriculi laterales", "m": "Right and left lateral ventricles (with left caudate nucleus)", "e": "ventriculi (L. ventriculus: little belly, diminutive of venter = belly) + laterales (L. lateralis: of the side, from latus = side)", "p": 325}, {"t": "Nucleus caudatus", "m": "Caudate nucleus (left caudate nucleus shown with lateral ventricles)", "e": "nucleus (L. nucleus: kernel, nut, from nux = nut) + caudatus (L. caudatus: having a tail, from cauda = tail)", "p": 325}, {"t": "Thalamus", "m": "Thalamus (shown with fornix)", "e": "thalamus (Gk. thalamos: inner chamber, bedroom)", "p": 325}, {"t": "Sectiones telencephali", "m": "Sections through telencephalon", "e": "sectiones (L. sectio: a cutting, from secare = to cut) + telencephali (Gk. telos = end + enkephalos = brain, within the head)", "p": 326}, {"t": "Cortex cerebralis (pallium)", "m": "Cerebral cortex — gray matter, 1.5–4.5 mm thick", "e": "cortex (L. cortex: bark, outer layer) + cerebralis (L. cerebralis: of the brain, from cerebrum = brain) + pallium (L. pallium: cloak, mantle)", "p": 326}, {"t": "Lamina molecularis (plexiformis)", "m": "Molecular (plexiform) layer — 1st layer of cerebral cortex", "e": "lamina (L. lamina: thin plate, layer) + molecularis (L. molecula: small mass, diminutive of moles = mass) + plexiformis (L. plexus = network + forma = shape)", "p": 326}, {"t": "Lamina granularis externa", "m": "External granular layer — 2nd layer, small cells in a fine fiber network", "e": "lamina (L. lamina: thin plate) + granularis (L. granularis: of granules, from granum = grain) + externa (L. externus: outer, external)", "p": 326}, {"t": "Lamina pyramidalis externa", "m": "External pyramidal cell layer — 3rd layer, medium-sized pyramidal cells", "e": "lamina (L. lamina: thin plate) + pyramidalis (Gk. pyramis: pyramid) + externa (L. externus: outer)", "p": 326}, {"t": "Lamina granularis interna", "m": "Internal granular layer — 4th layer, predominantly closely packed stellate cells", "e": "lamina (L. lamina: thin plate) + granularis (L. granularis: of granules) + interna (L. internus: inner, internal)", "p": 326}, {"t": "Lamina pyramidalis interna (ganglionaris)", "m": "Internal pyramidal (ganglionic) layer — 5th layer, larger pyramidal cells", "e": "lamina (L. lamina: thin plate) + pyramidalis (Gk. pyramis: pyramid) + interna (L. internus: inner) + ganglionaris (Gk. ganglion: knot, swelling)", "p": 326}, {"t": "Lamina multiformis", "m": "Multiform (fusiform) layer — 6th layer, poorly defined layer of fusiform cells", "e": "lamina (L. lamina: thin plate) + multiformis (L. multus = many + forma = shape, form)", "p": 326}, {"t": "Neurofibrae tangentiales", "m": "Tangential fibers — superficial fiber complex of four layers", "e": "neurofibrae (Gk. neuron = nerve + L. fibra = fiber) + tangentiales (L. tangens: touching, from tangere = to touch)", "p": 326}, {"t": "Stria laminae molecularis (plexiformis)", "m": "Stria of molecular layer — band of tangential fibers in the 1st layer of the cerebral cortex", "e": "stria (L. stria: groove, stripe, band) + laminae (L. lamina: thin plate) + molecularis (L. molecula: small mass) + plexiformis (L. plexus = network + forma = shape)", "p": 326}, {"t": "Stria laminae granularis externa", "m": "Stria of external granular layer — thinner band of tangential fibers in the 2nd layer", "e": "stria (L. stria: band, stripe) + laminae (L. lamina: thin plate) + granularis (L. granum: grain) + externa (L. externus: outer)", "p": 326}, {"t": "Stria laminae granularis interna", "m": "Stria of internal granular layer — band of tangential fibers in the 4th layer [outer stripe of Baillarger]", "e": "stria (L. stria: band, stripe) + laminae (L. lamina: thin plate) + granularis (L. granum: grain) + interna (L. internus: inner)", "p": 326}, {"t": "Stria laminae pyramidalis interna (ganglionaris)", "m": "Stria of internal pyramidal layer — band of tangential fibers in the 5th layer [inner stripe of Baillarger]", "e": "stria (L. stria: band, stripe) + laminae (L. lamina: thin plate) + pyramidalis (Gk. pyramis: pyramid) + interna (L. internus: inner) + ganglionaris (Gk. ganglion: knot)", "p": 326}, {"t": "Fibrae arcuatae cerebri", "m": "Arcuate fibers of cerebrum — arcuate fibers connecting adjacent cerebral gyri", "e": "fibrae (L. fibra: fiber) + arcuatae (L. arcuatus: arched, bow-shaped, from arcus = bow) + cerebri (L. cerebrum: brain)", "p": 326}, {"t": "Fasciculus longitudinalis superior", "m": "Superior longitudinal fasciculus — largest bundle of association fibers extending from frontal to temporal lobe via occipital lobe", "e": "fasciculus (L. fasciculus: small bundle, diminutive of fascis = bundle) + longitudinalis (L. longitudo: length, from longus = long) + superior (L. superior: upper, higher)", "p": 326}, {"t": "Fasciculus longitudinalis inferior", "m": "Inferior longitudinal fasciculus — bundle of association fibers connecting temporal and occipital lobes", "e": "fasciculus (L. fasciculus: small bundle) + longitudinalis (L. longitudo: length) + inferior (L. inferior: lower)", "p": 326}, {"t": "Fasciculus uncinatus", "m": "Uncinate fasciculus — association fibers connecting inferior surface of frontal lobe and anterior part of temporal lobe", "e": "fasciculus (L. fasciculus: small bundle) + uncinatus (L. uncinatus: hooked, from uncus = hook)", "p": 326}, {"t": "Nuclei basales", "m": "Basal nuclei — basal ganglion", "e": "nuclei (L. nucleus: kernel, core, from nux = nut) + basales (L. basalis: of the base, from basis = base, from Gk. basis = step, base)", "p": 326}, {"t": "Caput nuclei caudati", "m": "Head of caudate nucleus — anteriorly situated structure forming lateral wall of anterior horn of lateral ventricle", "e": "caput (L. caput: head) + nuclei (L. nucleus: kernel) + caudati (L. caudatus: tailed, from cauda = tail)", "p": 326}, {"t": "Corpus nuclei caudati", "m": "Body of caudate nucleus — middle part of caudate nucleus lying on the thalamus", "e": "corpus (L. corpus: body) + nuclei (L. nucleus: kernel) + caudati (L. caudatus: tailed, from cauda = tail)", "p": 326}, {"t": "Cauda nuclei caudati", "m": "Tail of caudate nucleus — accompanies inferior horn and forms tapering posterior and inferior segments of caudate nucleus", "e": "cauda (L. cauda: tail) + nuclei (L. nucleus: kernel) + caudati (L. caudatus: tailed, from cauda = tail)", "p": 326}, {"t": "Nucleus lentiformis (lenticularis)", "m": "Lentiform nucleus — part of corpus striatum arising from telencephalon and diencephalon", "e": "nucleus (L. nucleus: kernel) + lentiformis (L. lens/lentis = lentil + forma = shape) + lenticularis (L. lenticula: small lentil, diminutive of lens)", "p": 326}, {"t": "Putamen", "m": "Putamen — lateral, telencephalic portion of the lentiform nucleus", "e": "putamen (L. putamen: shell, husk, from putare = to prune, clean)", "p": 326}, {"t": "Lamina medullaris lateralis", "m": "Lateral medullary lamina — medullary layer of corpus striatum situated between globus pallidus and putamen", "e": "lamina (L. lamina: thin plate) + medullaris (L. medullaris: of the marrow/medulla, from medulla = marrow) + lateralis (L. lateralis: of the side, from latus = side)", "p": 326}, {"t": "Globus pallidus lateralis", "m": "Lateral globus pallidus — part of diencephalic globus pallidus located between lateral and medial medullary laminae", "e": "globus (L. globus: ball, sphere) + pallidus (L. pallidus: pale, pallid) + lateralis (L. lateralis: of the side)", "p": 326}, {"t": "Lamina medullaris medialis", "m": "Medial medullary lamina — medullary layer between medial and lateral parts of globus pallidus", "e": "lamina (L. lamina: thin plate) + medullaris (L. medullaris: of the marrow) + medialis (L. medialis: of the middle, from medius = middle)", "p": 326}, {"t": "Globus pallidus medialis", "m": "Medial globus pallidus — part of globus pallidus located medial to the medial medullary lamina", "e": "globus (L. globus: ball, sphere) + pallidus (L. pallidus: pale) + medialis (L. medialis: of the middle)", "p": 326}, {"t": "Claustrum", "m": "Claustrum — layer of gray matter between the lentiform nucleus and the insular cortex", "e": "claustrum (L. claustrum: barrier, bolt, enclosure, from claudere = to close, shut)", "p": 326}, {"t": "Cortex cerebri", "m": "Cerebral cortex", "e": "cortex (L. cortex: bark, outer layer, rind) + cerebri (L. cerebrum: brain, genitive form = of the brain)", "p": 327}, {"t": "Fibrae arcuatae", "m": "Arcuate fibers", "e": "fibrae (L. fibra: fiber, thread, genitive plural) + arcuatae (L. arcuatus: arched, bow-shaped, from arcus = bow, arch)", "p": 327}, {"t": "Corpus amygdaloideum", "m": "Amygdaloid body (amygdala) — ovoid group of nuclei in front of the inferior horn of the lateral ventricle", "e": "corpus (L. corpus: body) + amygdaloideum (Gk. amygdalē: almond + eidos: form, shape)", "p": 328}, {"t": "Area amygdaloidea anterior", "m": "Anterior amygdaloid area — anterior group of cells directed toward the anterior perforated substance", "e": "area (L. area: open space, region) + amygdaloidea (Gk. amygdalē: almond + eidos: form) + anterior (L. anterior: former, in front)", "p": 328}, {"t": "Pars basolateralis", "m": "Basolateral part — contains the largest group of nuclei of the amygdala complex", "e": "pars (L. pars: part) + basolateralis (L. basis: base + lateralis: of the side, from latus: side)", "p": 328}, {"t": "Pars corticomedialis [olfactoria]", "m": "Corticomedial part — smaller superomedially directed group of nuclei that receives fibers from the olfactory tract", "e": "pars (L. pars: part) + corticomedialis (L. cortex: bark, rind + medialis: middle, from medius: middle) + olfactoria (L. olfactorius: of smell, from olfacere: to smell)", "p": 328}, {"t": "Capsula extrema", "m": "Extreme capsule — white matter between the cortex of the insula and the claustrum", "e": "capsula (L. capsula: little box, from capsa: box) + extrema (L. extremus: outermost, utmost)", "p": 328}, {"t": "Capsula externa", "m": "External capsule — white matter between the claustrum and lentiform nucleus", "e": "capsula (L. capsula: little box) + externa (L. externus: outer, outside)", "p": 328}, {"t": "Capsula interna", "m": "Internal capsule — very important conduction band lying medial to the lentiform nucleus and lateral to the thalamus and caudate nucleus", "e": "capsula (L. capsula: little box) + interna (L. internus: inner, internal)", "p": 328}, {"t": "Crus anterius capsulae internae", "m": "Anterior limb of internal capsule — structure lying between the lentiform nucleus and the head of the caudate nucleus", "e": "crus (L. crus: leg, limb, shank) + anterius (L. anterior: in front) + capsulae (L. capsula: little box, genitive) + internae (L. internus: inner, genitive)", "p": 328}, {"t": "Radiationes thalamicae anteriores", "m": "Anterior thalamic radiations — contains fibers that connect the frontal lobe and the medial nucleus of the thalamus, as well as the anterior nucleus of the thalamus and the anterior region of the cingulate gyrus", "e": "radiationes (L. radiatio: radiation, from radiare: to radiate) + thalamicae (Gk. thalamos: inner chamber, thalamus) + anteriores (L. anterior: in front, plural)", "p": 328}, {"t": "Tractus frontopontinus", "m": "Frontopontine tract — fibers extending from the frontal lobe to the nuclei of the pons", "e": "tractus (L. tractus: tract, drawing out, from trahere: to draw) + frontopontinus (L. frons: forehead, front + pons: bridge)", "p": 328}, {"t": "Genu capsulae internae", "m": "Genu of internal capsule — lies between the anterior and posterior limbs of the internal capsule and forms part of the lateral wall of the ventricular system", "e": "genu (L. genu: knee, bend) + capsulae (L. capsula: little box, genitive) + internae (L. internus: inner, genitive)", "p": 328}, {"t": "Tractus corticonuclearis", "m": "Corticonuclear tract — part of the pyramidal tract passing into the motor nuclei of the cranial nerves", "e": "tractus (L. tractus: tract, from trahere: to draw) + corticonuclearis (L. cortex: bark, rind + nucleus: kernel, from nux: nut)", "p": 328}, {"t": "Crus posterius capsulae internae", "m": "Posterior limb of internal capsule — part of the internal capsule that separates the lentiform nucleus from the thalamus and body of caudate nucleus", "e": "crus (L. crus: leg, limb) + posterius (L. posterior: behind, coming after) + capsulae (L. capsula: little box, genitive) + internae (L. internus: inner, genitive)", "p": 328}, {"t": "Pars thalamolentiformis", "m": "Thalamolentiform part — portion of the posterior limb of the internal capsule that extends up to the posterior margin of the lentiform nucleus", "e": "pars (L. pars: part) + thalamolentiformis (Gk. thalamos: inner chamber + L. lens/lentis: lentil + forma: shape)", "p": 328}, {"t": "Fibrae corticorubrales", "m": "Corticorubral fibers — fibers extending from the frontal lobe to the red nucleus", "e": "fibrae (L. fibra: fiber, plural) + corticorubrales (L. cortex: bark, rind + ruber: red)", "p": 328}, {"t": "Fibrae corticothalamicae", "m": "Corticothalamic fibers — part of the thalamic radiation in the thalamus", "e": "fibrae (L. fibra: fiber, plural) + corticothalamicae (L. cortex: bark, rind + Gk. thalamos: inner chamber)", "p": 328}, {"t": "Fibrae thalamoparietales", "m": "Thalamoparietal fibers — nerve fibers that project from the cerebral cortex to the thalamus", "e": "fibrae (L. fibra: fiber, plural) + thalamoparietales (Gk. thalamos: inner chamber + L. parietalis: of a wall, from paries: wall)", "p": 328}, {"t": "Pars sublentiformis", "m": "Sublentiform part — portion of internal capsule lying below the posterior part of the lentiform nucleus", "e": "pars (L. pars: part) + sublentiformis (L. sub: under + lens/lentis: lentil + forma: shape)", "p": 328}, {"t": "Radiatio optica [[Gratioleti]]", "m": "Optic radiation — fiber tract that radiates from the lateral geniculate body to the area striata in the occipital lobe", "e": "radiatio (L. radiatio: radiation, from radiare: to radiate) + optica (Gk. optikos: of sight, from ops: eye)", "p": 328}, {"t": "Fibrae corticotectales", "m": "Corticotectal fibers — connecting fibers between the cerebral cortex and the tectum", "e": "fibrae (L. fibra: fiber, plural) + corticotectales (L. cortex: bark, rind + tectum: roof, from tegere: to cover)", "p": 328}, {"t": "Fibrae temporopontinae", "m": "Temporopontine fibers — fibers of the cerebropontocerebellar tract that arise from the temporal lobe", "e": "fibrae (L. fibra: fiber, plural) + temporopontinae (L. temporalis: of the temple, from tempus: temple + pons: bridge)", "p": 328}, {"t": "Pars retrolentiformis", "m": "Retrolentiform part — portion of internal capsule situated occipital to the lentiform nucleus", "e": "pars (L. pars: part) + retrolentiformis (L. retro: behind, backward + lens/lentis: lentil + forma: shape)", "p": 328}, {"t": "Fasciculus parieto-occipitopontinus", "m": "Parieto-occipitopontine fasciculus — portion of cerebropontocerebellar tract arising from the parietal and occipital lobes", "e": "fasciculus (L. fasciculus: small bundle, from fascis: bundle) + parietooccipitopontinus (L. parietalis: of a wall + occiput: back of head + pons: bridge)", "p": 328}, {"t": "Corona radiata", "m": "Corona radiata — fibers of the internal capsule radiating fanlike in all directions toward the cerebral cortex", "e": "corona (L. corona: crown, wreath) + radiata (L. radiatus: radiated, from radiare: to radiate)", "p": 328}, {"t": "Commisura anterior", "m": "Anterior commissure — lies in front of the column of the fornix and is readily visible in the anterior wall of the third ventricle", "e": "commisura (L. commissura: joining together, from committere: to join) + anterior (L. anterior: in front)", "p": 328}, {"t": "Neurofibrae associationes", "m": "Association neurofibers — association fibers connecting adjacent or distant parts of the same side of the cerebrum", "e": "neurofibrae (Gk. neuron: nerve + L. fibra: fiber) + associationes (L. associatio: association, from associare: to unite)", "p": 328}, {"t": "Neurofibrae commissurales", "m": "Commissural neurofibers — connect symmetrical structures of contralateral hemispheres", "e": "neurofibrae (Gk. neuron: nerve + L. fibra: fiber) + commissurales (L. commissura: joining together, from committere: to join)", "p": 328}, {"t": "Neurofibrae projectiones", "m": "Projecting neurofibers — form the longer tracts, e.g., pyramidal tract, optic and acoustic radiations, thalamic radiation", "e": "neurofibrae (Gk. neuron: nerve + L. fibra: fiber) + projectiones (L. projectio: projection, from proicere: to throw forward)", "p": 328}, {"t": "Cerebrum", "m": "Cerebrum — the large upper part of the brain", "e": "cerebrum (L. cerebrum: brain, from Gk. karā: head)", "p": 329}, {"t": "Commissura anterior cerebri", "m": "Anterior commissure of cerebrum — white matter commissure connecting the two hemispheres anteriorly", "e": "commissura (L. commissura: junction, joining together, from committere: to join) + anterior (L. anterior: front, forward) + cerebri (L. cerebrum: brain, genitive form)", "p": 329}, {"t": "Pars peripherica", "m": "Peripheral part (of the nervous system)", "e": "pars (L. pars: part, portion) + peripherica (Gk. peripherikós: outer, from peri = around + pherein = to carry)", "p": 330}, {"t": "Systema nervosum periphericum", "m": "Peripheral nervous system", "e": "systema (Gk. sýstēma: system, organized whole) + nervosum (L. nervōsus: of nerves, from nervus = nerve, sinew) + periphericum (Gk. peripherikón: peripheral, from peri = around + pherein = to carry)", "p": 330}, {"t": "Nervi craniales", "m": "Cranial nerves", "e": "nervi (L. nervus: nerve, sinew; pl. nervi) + craniales (Gk./L. craniāles: of the skull, from Gk. kranion = skull)", "p": 330}, {"t": "Encephalici", "m": "Brain-related (cranial nerves)", "e": "encephalici (Gk. enképhalos: brain, from en = in + kephalē = head)", "p": 330}, {"t": "Nn. olfactorii", "m": "Olfactory nerves", "e": "Nn. (L. nervi: nerves, abbreviation) + olfactorii (L. olfactōrius: of smell, from olfacere = to smell, from olere = to smell + facere = to make)", "p": 330}, {"t": "N. opticus", "m": "Optic nerve", "e": "N. (L. nervus: nerve) + opticus (Gk. optikós: of sight, from ops/optos = eye, sight)", "p": 330}, {"t": "N. oculomotorius", "m": "Oculomotor nerve", "e": "N. (L. nervus: nerve) + oculomotorius (L. oculus = eye + motor = mover, from movere = to move)", "p": 330}, {"t": "Ramus superior", "m": "Superior branch/division", "e": "ramus (L. rāmus: branch) + superior (L. superior: upper, higher, comparative of superus = above)", "p": 330}, {"t": "Ramus inferior", "m": "Inferior branch/division", "e": "ramus (L. rāmus: branch) + inferior (L. inferior: lower, comparative of inferus = below)", "p": 330}, {"t": "Ganglion ciliare", "m": "Ciliary ganglion", "e": "ganglion (Gk. gagglion: knot, swelling, nerve knot) + ciliare (L. ciliāre: of the eyelid/cilia, from cilium = eyelid, eyelash)", "p": 330}, {"t": "Radix parasympathetica", "m": "Parasympathetic (motor) root", "e": "radix (L. rādix: root) + parasympathetica (Gk. para = beside + sympathētikós: sympathetic, from syn = together + pathos = feeling)", "p": 330}, {"t": "Radix parasympathetica (oculomotoria)", "m": "Parasympathetic (motor) root of ciliary ganglion", "e": "radix (L. rādix: root) + parasympathetica (Gk. para = beside + sympathētikós: sympathetic) + oculomotoria (L. oculus = eye + motorius = moving, from movere = to move)", "p": 330}, {"t": "Nn. ciliares breves", "m": "Short ciliary nerves", "e": "Nn. (L. nervi: nerves) + ciliares (L. ciliāres: of the cilia/eyelid, from cilium = eyelid) + breves (L. brevis: short)", "p": 330}, {"t": "Radix sympathetica", "m": "Sympathetic root", "e": "radix (L. rādix: root) + sympathetica (Gk. sympathētikós: sympathetic, from syn = together + pathos = feeling)", "p": 330}, {"t": "Radix sensoria (nasociliaris)", "m": "Sensory root (of ciliary ganglion)", "e": "radix (L. rādix: root) + sensoria (L. sēnsōrius: of sensation, from sentire = to feel) + nasociliaris (L. nasus = nose + ciliaris = of the eyelid/cilia)", "p": 330}, {"t": "N. trochlearis", "m": "Trochlear nerve", "e": "N. (L. nervus: nerve) + trochlearis (Gk./L. trochlea: pulley, from Gk. trokhilia = system of pulleys)", "p": 330}, {"t": "Decussatio nervorum trochlearium", "m": "Decussation of trochlear nerve; crossing of trochlear nerve fibers", "e": "decussatio (L. decussātio: crossing in X-shape, from decussis = the numeral X) + nervorum (L. nervus: nerve; gen. pl. nervōrum) + trochlearium (L. trochleāris: of the pulley/trochlear, from trochlea = pulley)", "p": 330}, {"t": "N. trigeminus", "m": "Trigeminal nerve", "e": "N. (L. nervus: nerve) + trigeminus (L. trigeminus: triple, threefold, from tri = three + geminus = twin, born together)", "p": 330}, {"t": "Radix sensoria [portio major]", "m": "Sensory root of trigeminal nerve", "e": "radix (L. rādix: root) + sensoria (L. sēnsōrius: of sensation, from sentire = to feel) + portio (L. portio: portion, part) + major (L. maior: larger, greater)", "p": 330}, {"t": "Ganglion trigeminale [semilunare; Gasseri]", "m": "Trigeminal (semilunar, gasserian) ganglion", "e": "ganglion (Gk. gagglion: knot, nerve knot) + trigeminale (L. trigeminus: triple, threefold) + semilunare (L. semi = half + luna = moon, hence half-moon shaped)", "p": 330}, {"t": "Cavum trigeminale", "m": "Outpocketing of subarachnoid space above foramen lacerum", "e": "cavum (L. cavum: hollow, cavity, from cavus = hollow) + trigeminale (L. trigeminus: triple, threefold)", "p": 330}, {"t": "Radix motoria [portio minor]", "m": "Motor root of trigeminal nerve", "e": "radix (L. rādix: root) + motoria (L. mōtōrius: of motion, from movere = to move) + portio (L. portio: portion, part) + minor (L. minor: smaller, lesser)", "p": 330}, {"t": "N. ophthalmicus", "m": "Ophthalmic nerve; first division of trigeminal nerve", "e": "N. (L. nervus: nerve) + ophthalmicus (Gk. ophthalmikós: of the eye, from ophthalmos = eye)", "p": 330}, {"t": "Ramus tentorii (meningeus)", "m": "Tentorial (meningeal) branch", "e": "ramus (L. rāmus: branch) + tentorii (L. tentorium: tent, covering, from tendere = to stretch) + meningeus (Gk. mēninx: membrane, meninges)", "p": 330}, {"t": "N. lacrimalis", "m": "Lacrimal nerve", "e": "N. (L. nervus: nerve) + lacrimalis (L. lacrima: tear; lacrimālis = of tears)", "p": 330}, {"t": "Ramus communicans [cum. n. zygomatico]", "m": "Communicating ramus with zygomatic nerve", "e": "ramus (L. rāmus: branch) + communicans (L. commūnicāns: communicating, from commūnicāre = to share, connect) + cum (L. cum: with) + zygomatico (Gk. zygōma: yoke, cheekbone, from zygon = yoke)", "p": 330}, {"t": "N. frontalis", "m": "Frontal nerve", "e": "N. (L. nervus: nerve) + frontalis (L. frontālis: of the forehead/front, from frons = forehead, front)", "p": 330}, {"t": "N. supraorbitalis", "m": "Supraorbital nerve", "e": "N. (L. nervus: nerve) + supraorbitalis (L. supra = above + orbita = orbit/eye socket, from orbis = circle)", "p": 330}, {"t": "N. supratrochlearis", "m": "Supratrochlear nerve", "e": "N. (L. nervus: nerve) + supratrochlearis (L. supra = above + trochleāris = of the pulley/trochlea, from Gk. trokhilia = pulley)", "p": 330}, {"t": "N. nasociliaris", "m": "Nasociliary nerve — most medial branch of the ophthalmic nerve", "e": "N. (L. nervus: nerve, sinew) + naso (L. nasus: nose) + ciliaris (L. cilium: eyelid/eyelash, relating to the eye)", "p": 332}, {"t": "Ramus communicans cum ganglio ciliari", "m": "Communicating branch of nasociliary nerve with ciliary ganglion", "e": "ramus (L. ramus: branch) + communicans (L. communicare: to connect, share) + cum (L. cum: with) + ganglio (Gk. ganglion: knot, swelling) + ciliari (L. cilium: eyelid/eyelash)", "p": 332}, {"t": "Nn. ciliares longi", "m": "Long ciliary nerves — two long fine twigs with sympathetic fibers", "e": "Nn. (L. nervi: nerves, plural) + ciliares (L. cilium: eyelid/eyelash) + longi (L. longus: long)", "p": 332}, {"t": "N. ethmoidalis posterior", "m": "Posterior ethmoidal nerve — thin nerve at the posterior end of the orbit", "e": "N. (L. nervus: nerve) + ethmoidalis (Gk. ethmos: sieve + eidos: form, shape) + posterior (L. posterior: behind, later)", "p": 332}, {"t": "N. ethmoidalis anterior", "m": "Anterior ethmoidal nerve — nerve entering cranial cavity through anterior ethmoidal foramen", "e": "N. (L. nervus: nerve) + ethmoidalis (Gk. ethmos: sieve + eidos: form) + anterior (L. anterior: before, in front)", "p": 332}, {"t": "Rami nasales", "m": "Nasal branches of anterior ethmoidal nerve", "e": "rami (L. ramus: branch, plural rami) + nasales (L. nasus: nose, relating to the nose)", "p": 332}, {"t": "Rami nasales interni", "m": "Internal nasal branches — innervate nasal mucosa in front of conchae and anterior nasal septum", "e": "rami (L. ramus: branch) + nasales (L. nasus: nose) + interni (L. internus: internal, inner)", "p": 332}, {"t": "Rami nasales laterales", "m": "Lateral nasal branches — innervate anterior part of lateral nasal wall", "e": "rami (L. ramus: branch) + nasales (L. nasus: nose) + laterales (L. lateralis: of the side, from latus: side)", "p": 332}, {"t": "Rami nasales mediales", "m": "Medial nasal branches — innervate anterior part of nasal septum", "e": "rami (L. ramus: branch) + nasales (L. nasus: nose) + mediales (L. medialis: of the middle, from medius: middle)", "p": 332}, {"t": "Ramus nasalis externus", "m": "External nasal branch — innervates skin on tip of nose and nasal ala", "e": "ramus (L. ramus: branch) + nasalis (L. nasus: nose) + externus (L. externus: external, outer)", "p": 332}, {"t": "N. infratrochlearis", "m": "Infratrochlear nerve — passes below trochlea of superior oblique", "e": "N. (L. nervus: nerve) + infra (L. infra: below, beneath) + trochlearis (Gk. trochilia: pulley, from trechein: to run)", "p": 332}, {"t": "Rami palpebrales", "m": "Palpebral branches — rami for part of upper and lower eyelids", "e": "rami (L. ramus: branch) + palpebrales (L. palpebra: eyelid)", "p": 332}, {"t": "N. maxillaris", "m": "Maxillary nerve — second division of trigeminal nerve", "e": "N. (L. nervus: nerve) + maxillaris (L. maxilla: jaw, cheekbone, from root mala: cheek)", "p": 332}, {"t": "Ramus meningeus", "m": "Meningeal nerve — branch given off in front of foramen rotundum supplying dura", "e": "ramus (L. ramus: branch) + meningeus (Gk. meninx: membrane, referring to meninges)", "p": 332}, {"t": "Rami ganglionici", "m": "Ganglionic branches — usually two rami from pterygopalatine ganglion", "e": "rami (L. ramus: branch) + ganglionici (Gk. ganglion: knot, swelling, referring to nerve ganglion)", "p": 332}, {"t": "Ganglion pterygopalatinum", "m": "Pterygopalatine ganglion — parasympathetic ganglion in pterygopalatine fossa", "e": "ganglion (Gk. ganglion: knot, swelling) + pterygo (Gk. pteryx: wing) + palatinum (L. palatum: palate)", "p": 332}, {"t": "Radix sensoria", "m": "Sensory root — communicates with the maxillary nerve", "e": "radix (L. radix: root) + sensoria (L. sensorius: of sensation, from sentire: to feel, perceive)", "p": 332}, {"t": "Rami orbitales", "m": "Orbital branches — two to three fine rami passing into orbit through inferior orbital fissure", "e": "rami (L. ramus: branch) + orbitales (L. orbita: track, orbit of the eye, from orbis: circle)", "p": 332}, {"t": "Rami nasales posteriores superiores laterales", "m": "Lateral posterior superior nasal branches — up to 10 fine rami through sphenopalatine foramen", "e": "rami (L. ramus: branch) + nasales (L. nasus: nose) + posteriores (L. posterior: behind) + superiores (L. superior: upper, higher) + laterales (L. lateralis: of the side)", "p": 332}, {"t": "Rami nasales posteriores superiores mediales", "m": "Medial posterior superior nasal branches — two to three branches through sphenopalatine foramen to nasal septum", "e": "rami (L. ramus: branch) + nasales (L. nasus: nose) + posteriores (L. posterior: behind) + superiores (L. superior: upper) + mediales (L. medialis: of the middle)", "p": 332}, {"t": "N. nasopalatinus", "m": "Nasopalatine nerve — passes between periosteum and mucosa of nasal septum then through incisive canal", "e": "N. (L. nervus: nerve) + naso (L. nasus: nose) + palatinus (L. palatum: palate)", "p": 332}, {"t": "Nervus nasopalatinus longus", "m": "Long nasopalatine nerve", "e": "nervus (L. nervus: nerve, sinew) + naso (L. nasus: nose) + palatinus (L. palatum: palate) + longus (L. longus: long)", "p": 332}, {"t": "Rami septales nasales", "m": "Branches to nasal septum", "e": "rami (L. ramus: branch) + septales (L. saeptum/septum: partition, fence, from saepire: to enclose) + nasales (L. nasus: nose)", "p": 332}, {"t": "Nervi nasopalatini breves", "m": "Short nasopalatine nerves", "e": "nervi (L. nervus: nerve, plural) + naso (L. nasus: nose) + palatini (L. palatum: palate) + breves (L. brevis: short, brief)", "p": 332}, {"t": "Rami sinus maxillaris", "m": "Branches to maxillary sinus", "e": "rami (L. ramus: branch) + sinus (L. sinus: curve, hollow, cavity) + maxillaris (L. maxilla: jaw, cheekbone)", "p": 332}, {"t": "N. pharyngeus", "m": "Pharyngeal nerve — fine nerve for pharyngeal mucosa", "e": "N. (L. nervus: nerve) + pharyngeus (Gk. pharynx: throat, gullet)", "p": 332}, {"t": "N. palatinus major", "m": "Greater palatine nerve — passes through greater palatine canal, supplies mucosa of hard palate and glands", "e": "N. (L. nervus: nerve) + palatinus (L. palatum: palate) + major (L. major: greater, larger)", "p": 332}, {"t": "Rami nasales posteriores inferiores", "m": "Posterior inferior nasal branches — rami for middle and inferior nasal meatuses and inferior nasal concha", "e": "rami (L. ramus: branch) + nasales (L. nasus: nose) + posteriores (L. posterior: behind) + inferiores (L. inferior: lower)", "p": 332}, {"t": "Nn. palatini minores", "m": "Lesser palatine nerves — travel through slender canals, exit through lesser palatine foramina, supply soft palate", "e": "Nn. (L. nervi: nerves, plural) + palatini (L. palatum: palate) + minores (L. minor: smaller, lesser)", "p": 332}, {"t": "Rami tonsillares", "m": "Tonsillar branches — branches to the palatine tonsil", "e": "rami (L. ramus: branch) + tonsillares (L. tonsilla: tonsil, almond-shaped gland)", "p": 332}, {"t": "N. zygomaticus", "m": "Zygomatic nerve — branches into pterygopalatine fossa, passes through inferior orbital fissure", "e": "N. (L. nervus: nerve) + zygomaticus (Gk. zygon: yoke + -oma: structure; referring to the cheekbone)", "p": 332}, {"t": "Ramus zygomaticotemporalis", "m": "Zygomaticotemporal branch — passes through respective foramen to lateral wall of orbit", "e": "ramus (L. ramus: branch) + zygomatico (Gk. zygon: yoke, cheekbone) + temporalis (L. temporalis: of the temple, from tempus: temple of head, time)", "p": 332}, {"t": "Ramus zygomaticofacialis", "m": "Zygomaticofacial branch — passes through corresponding foramen to skin on zygomatic bone", "e": "ramus (L. ramus: branch) + zygomatico (Gk. zygon: yoke, cheekbone) + facialis (L. facies: face, appearance)", "p": 332}, {"t": "Nervus nasociliaris", "m": "Nasociliary nerve", "e": "nervus (L. nervus: nerve, sinew) + nasociliaris (L. nasus = nose + cilium = eyelid/eyelash, referring to nose and eye region)", "p": 333}, {"t": "Nervus maxillaris", "m": "Maxillary nerve", "e": "nervus (L. nervus: nerve, sinew) + maxillaris (L. maxilla: jaw, from mala = cheekbone/jaw)", "p": 333}, {"t": "Nervus ethmoidalis anterior", "m": "Anterior ethmoidal nerve", "e": "nervus (L. nervus: nerve) + ethmoidalis (Gk. ethmos = sieve + eidos = form/shape, referring to the sieve-like ethmoid bone) + anterior (L. anterior: before, in front)", "p": 333}, {"t": "Nervi septi nasi", "m": "Nerves of nasal septum", "e": "nervi (L. nervus: nerve) + septi (L. septum: partition, fence, from saepire = to enclose) + nasi (L. nasus: nose)", "p": 333}, {"t": "N. infraorbitalis", "m": "Infraorbital nerve — terminal branch of maxillary nerve passing through inferior orbital fissure to skin of upper eyelid, nose, upper lip and cheek", "e": "N. (L. nervus: nerve, sinew) + infra (L. infra: below, beneath) + orbitalis (L. orbitalis: of the orbit, from orbita = track, circuit)", "p": 334}, {"t": "Nn. alveolares superiores", "m": "Superior alveolar nerves — branches to the maxillary teeth", "e": "Nn. (L. nervi: nerves) + alveolares (L. alveolāres: of the alveoli, from alveolus = small cavity, diminutive of alveus = hollow) + superiores (L. superiōres: upper, higher, comparative of superus)", "p": 334}, {"t": "Rami alveolares superiores posteriores", "m": "Posterior superior alveolar branches — two to three branches passing through alveolar foramina supplying maxillary sinus and molars", "e": "Rami (L. rami: branches, from ramus = branch) + alveolares (L. alveolāres: of the alveoli) + superiores (L. superiōres: upper) + posteriores (L. posteriōres: posterior, behind, from posterus = coming after)", "p": 334}, {"t": "R. alveolaris superior medius", "m": "Middle superior alveolar branch — courses through infraorbital sulcus to maxilla along lateral wall of maxillary sinus", "e": "R. (L. ramus: branch) + alveolaris (L. alveolāris: of the alveolus) + superior (L. superior: upper) + medius (L. medius: middle)", "p": 334}, {"t": "Rami alveolares superiores anteriores", "m": "Anterior superior alveolar branches — run in their canals via superior dental plexus to incisors, canines, premolars and first molar", "e": "Rami (L. rami: branches) + alveolares (L. alveolāres: of the alveoli) + superiores (L. superiōres: upper) + anteriores (L. anteriōres: anterior, in front, from ante = before)", "p": 334}, {"t": "Plexus dentalis superior", "m": "Superior dental plexus — nerve plexus in the bone above the roots of the teeth formed by superior alveolar rami", "e": "Plexus (L. plexus: network, braid, from plectere = to braid) + dentalis (L. dentālis: of the teeth, from dens = tooth) + superior (L. superior: upper)", "p": 334}, {"t": "Rami dentales superiores", "m": "Superior dental branches — branches to the individual roots of the teeth", "e": "Rami (L. rami: branches) + dentales (L. dentāles: of the teeth) + superiores (L. superiōres: upper)", "p": 334}, {"t": "Rami gingivales superiores", "m": "Superior gingival branches — rami to the gingiva", "e": "Rami (L. rami: branches) + gingivales (L. gingivāles: of the gums, from gingiva = gum) + superiores (L. superiōres: upper)", "p": 334}, {"t": "Rami palpebrales inferiores", "m": "Inferior palpebral branches — rami given off to the lower eyelid outside of the infraorbital foramen", "e": "Rami (L. rami: branches) + palpebrales (L. palpebrāles: of the eyelid, from palpebra = eyelid) + inferiores (L. inferiōres: lower, from inferus = below)", "p": 334}, {"t": "Rami nasales externi", "m": "External nasal branches — branches to the outside of the nasal ala", "e": "Rami (L. rami: branches) + nasales (L. nasāles: of the nose, from nasus = nose) + externi (L. externi: external, outer, from externus = outside)", "p": 334}, {"t": "Rami labiales superiores", "m": "Superior labial branches — rami to the skin and mucosa of the upper lip", "e": "Rami (L. rami: branches) + labiales (L. labiāles: of the lips, from labium = lip) + superiores (L. superiōres: upper)", "p": 334}, {"t": "N. mandibularis", "m": "Mandibular nerve — third division of the trigeminal nerve passing through foramen ovale containing both sensory and motor fibers", "e": "N. (L. nervus: nerve) + mandibularis (L. mandibulāris: of the mandible, from mandibula = jaw, from mandere = to chew)", "p": 334}, {"t": "Ramus meningeus (n. spinosus)", "m": "Meningeal branch (nervus spinosus) — passes through foramen spinosum with middle meningeal artery supplying dura and parts of sphenoidal sinus and mastoid air cells", "e": "Ramus (L. ramus: branch) + meningeus (Gk. mēningeus: of the meninges, from mēninx = membrane) + n. (L. nervus: nerve) + spinosus (L. spinōsus: spiny, thorny, from spina = spine, thorn)", "p": 334}, {"t": "N. massetericus", "m": "Masseteric nerve — motor nerve for the masseter muscle passing above lateral pterygoid muscle through mandibular notch", "e": "N. (L. nervus: nerve) + massetericus (Gk. massētērikos: of the masseter, from massētēr = chewer, from massasthai = to chew)", "p": 334}, {"t": "Nn. temporales profundi", "m": "Deep temporal nerves — motor nerves passing to the temporalis muscle from below", "e": "Nn. (L. nervi: nerves) + temporales (L. temporāles: of the temples, from tempora = temples) + profundi (L. profundi: deep, from profundus = deep)", "p": 334}, {"t": "N. pterygoideus lateralis", "m": "Nerve to lateral pterygoid — motor nerve for the lateral pterygoid muscle, frequently arising with the buccal nerve", "e": "N. (L. nervus: nerve) + pterygoideus (Gk. pterygoeides: wing-shaped, from pteryx = wing + eidos = form) + lateralis (L. laterālis: lateral, of the side, from latus = side)", "p": 334}, {"t": "N. pterygoideus medialis", "m": "Nerve to medial pterygoid — motor nerve for medial pterygoid muscle, sending twigs to tensor veli palatini and tensor tympani", "e": "N. (L. nervus: nerve) + pterygoideus (Gk. pterygoeides: wing-shaped) + medialis (L. mediālis: medial, middle, from medius = middle)", "p": 334}, {"t": "Ganglion oticum", "m": "Otic ganglion — parasympathetic ganglion medial to mandibular nerve below foramen ovale receiving tributaries from glossopharyngeal nerve via lesser petrosal nerve", "e": "Ganglion (Gk. ganglion: swelling, knot, cystic tumor on a tendon) + oticum (Gk. ōtikon: of the ear, from ous/ōtos = ear)", "p": 334}, {"t": "Ramus communicans [cum nervo pterygoi­deo mediali]", "m": "Branch which communicates with the nerve to the medial pterygoid muscle", "e": "Ramus (L. ramus: branch) + communicans (L. communicans: communicating, connecting, from communicare = to share) + cum (L. cum: with) + nervo (L. nervus: nerve) + pterygoi­deo (Gk. pterygoeides: wing-shaped) + mediali (L. mediālis: medial)", "p": 334}, {"t": "N. musculi tensoris veli palatini", "m": "Nerve to tensor veli palatini muscle — sometimes arises from nerve to medial pterygoid muscle", "e": "N. (L. nervus: nerve) + musculi (L. musculi: of the muscle, from musculus = muscle, little mouse) + tensoris (L. tensor: that which stretches, from tendere = to stretch) + veli (L. velum: veil, sail, covering) + palatini (L. palatinus: of the palate, from palatum = palate)", "p": 334}, {"t": "N. musculi tensoris tympani", "m": "Nerve to tensor tympani muscle — sometimes arises from nerve to medial pterygoid muscle", "e": "N. (L. nervus: nerve) + musculi (L. musculi: of the muscle) + tensoris (L. tensor: stretcher, from tendere = to stretch) + tympani (L. tympanum: drum, from Gk. tympanon = drum)", "p": 334}, {"t": "N. buccalis", "m": "Buccal nerve — sensory nerve for skin of the cheek and buccal gingiva in region of first molar", "e": "N. (L. nervus: nerve) + buccalis (L. buccālis: of the cheek, from bucca = cheek, mouth cavity)", "p": 334}, {"t": "N. auriculotemporalis", "m": "Auriculotemporal nerve — encircles middle meningeal artery, sends branch to temporomandibular joint then passes between ear and superficial temporal artery to temporal skin", "e": "N. (L. nervus: nerve) + auriculotemporalis (L. auriculotemporālis: of the auricle and temple, from auricula = ear, diminutive of auris = ear + tempora = temples)", "p": 334}, {"t": "N. meatus acustici externi", "m": "Nerve to external acoustic meatus — usually two small branches for skin of the external acoustic meatus", "e": "N. (L. nervus: nerve) + meatus (L. meātus: passage, channel, from meare = to go, pass) + acustici (Gk. akoustikos: of hearing, from akouein = to hear) + externi (L. externi: external)", "p": 334}, {"t": "Rami membranae tympani", "m": "Fine branches to the tympanic membrane", "e": "Rami (L. rami: branches) + membranae (L. membrana: membrane, thin skin, from membrum = limb) + tympani (L. tympanum: drum, from Gk. tympanon = drum)", "p": 334}, {"t": "Rami parotidei", "m": "Parotid branches — small branches supplying the parotid gland", "e": "Rami (L. rami: branches) + parotidei (Gk. parōtideos: of the parotid, from para = beside + ous/ōtos = ear)", "p": 334}, {"t": "Rami communicantes [cum n. faciali]", "m": "Branches communicating with the facial nerve — carry parasympathetic fibers from otic ganglion to parotid gland via facial nerve", "e": "Rami (L. rami: branches) + communicantes (L. communicantes: communicating, from communicare = to share) + cum (L. cum: with) + n. (L. nervus: nerve) + faciali (L. faciālis: of the face, from facies = face)", "p": 334}, {"t": "Nn. auriculares anteriores", "m": "Anterior auricular nerves — supply the anterior surface of the pinna", "e": "Nn. (L. nervi: nerves) + auriculares (L. auriculāres: of the ear/auricle, from auricula = little ear) + anteriores (L. anteriōres: anterior, in front)", "p": 334}, {"t": "Rami temporales superficiales", "m": "Superficial temporal rami — branches supplying skin of temporal region in front of and above the ear", "e": "Rami (L. rami: branches) + temporales (L. temporāles: of the temples, from tempora = temples) + superficiales (L. superficiāles: superficial, on the surface, from superficies = surface, from super = above + facies = face)", "p": 334}, {"t": "N. lingualis", "m": "Lingual nerve — a branch of the mandibular nerve that arches anteriorly between the lateral and medial pterygoid muscles to the floor of the mouth", "e": "N. (L. nervus: nerve, sinew) + lingualis (L. linguālis: of the tongue, from lingua = tongue)", "p": 336}, {"t": "Rami isthmi faucium", "m": "Branches to isthmus of the fauces", "e": "rami (L. rāmus: branch) + isthmi (Gk. isthmos: narrow passage, neck) + faucium (L. fauces: throat, gullet, narrow passage)", "p": 336}, {"t": "rami fauciales", "m": "Faucial branches", "e": "rami (L. rāmus: branch) + fauciales (L. faucialis: of the fauces, from fauces = throat)", "p": 336}, {"t": "Rami communicantes cum n. hypoglosso", "m": "Communicating rami to the hypoglossal nerve", "e": "rami (L. rāmus: branch) + communicantes (L. communicans: communicating, from communicare = to share) + cum (L. cum: with) + n. (L. nervus: nerve) + hypoglosso (Gk. hypo: under + glōssa: tongue)", "p": 336}, {"t": "Ramus communicans cum chorda tympani", "m": "Communicating ramus to the chorda tympani nerve", "e": "ramus (L. rāmus: branch) + communicans (L. communicans: communicating) + cum (L. cum: with) + chorda (Gk. khordē: string, cord) + tympani (Gk. tympanon: drum)", "p": 336}, {"t": "N. sublingualis", "m": "Sublingual nerve — passes lateral to the sublingual gland into the mucosa of the floor of the mouth", "e": "N. (L. nervus: nerve) + sublingualis (L. sub: under + lingua: tongue)", "p": 336}, {"t": "Rami linguales", "m": "Lingual branches — numerous rami containing sensory and taste fibers from the anterior two-thirds of the lingual mucosa", "e": "rami (L. rāmus: branch) + linguales (L. linguālis: of the tongue, from lingua = tongue)", "p": 336}, {"t": "Rami ganglionares", "m": "Ganglionic branches — rami communicating with the submandibular ganglion", "e": "rami (L. rāmus: branch) + ganglionares (Gk. ganglion: knot, swelling beneath the skin)", "p": 336}, {"t": "Ganglion submandibulare", "m": "Submandibular ganglion — parasympathetic ganglion above or in front of the submandibular gland", "e": "ganglion (Gk. ganglion: knot, swelling) + sub (L. sub: under, below) + mandibulare (L. mandibula: jaw, from mandere = to chew)", "p": 336}, {"t": "N. alveolaris inferior", "m": "Inferior alveolar nerve — largest branch of mandibular nerve with sensory and motor components", "e": "N. (L. nervus: nerve) + alveolaris (L. alveolus: small cavity, socket, from alveus = hollow) + inferior (L. inferior: lower)", "p": 336}, {"t": "N. mylohyoideus", "m": "Mylohyoid nerve — motor nerve supplying the mylohyoid muscle and the anterior belly of the digastric", "e": "N. (L. nervus: nerve) + mylo (Gk. myle: mill, molar) + hyoideus (Gk. hyoeides: shaped like the letter upsilon, U-shaped, from hys = the letter Y/upsilon)", "p": 336}, {"t": "Plexus dentalis inferior", "m": "Inferior dental plexus — plexus of nerves within the mandibular canal", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + dentalis (L. dentālis: of the teeth, from dens = tooth) + inferior (L. inferior: lower)", "p": 336}, {"t": "Rami dentales inferiores", "m": "Inferior dental branches — rami for the mandibular teeth", "e": "rami (L. rāmus: branch) + dentales (L. dentālis: of the teeth, from dens = tooth) + inferiores (L. inferior: lower)", "p": 336}, {"t": "Rami gingivales inferiores", "m": "Inferior gingival branches — rami for the buccal gingiva of the mandibular teeth", "e": "rami (L. rāmus: branch) + gingivales (L. gingivālis: of the gums, from gingiva = gum) + inferiores (L. inferior: lower)", "p": 336}, {"t": "N. mentalis", "m": "Mental nerve — sensory nerve exiting from the mental foramen below the 2nd premolar tooth", "e": "N. (L. nervus: nerve) + mentalis (L. mentālis: of the chin, from mentum = chin)", "p": 336}, {"t": "Rami mentales", "m": "Mental branches — branches supplying the chin", "e": "rami (L. rāmus: branch) + mentales (L. mentālis: of the chin, from mentum = chin)", "p": 336}, {"t": "Rami labiales", "m": "Labial branches — branches supplying the lower lip", "e": "rami (L. rāmus: branch) + labiales (L. labiālis: of the lips, from labium = lip)", "p": 336}, {"t": "Rami gingivales", "m": "Gingival branches", "e": "rami (L. rāmus: branch) + gingivales (L. gingivālis: of the gums, from gingiva = gum)", "p": 336}, {"t": "N. abducens [VI]", "m": "Abducent nerve — sixth cranial nerve, exits the brain in the angle between the pons and pyramid, supplies the rectus lateralis muscle", "e": "N. (L. nervus: nerve) + abducens (L. abducens: leading away, from ab = away + ducere = to lead)", "p": 336}, {"t": "Nervus lingualis", "m": "Lingual nerve", "e": "nervus (L. nervus: nerve, sinew) + lingualis (L. linguālis: of the tongue, from lingua = tongue)", "p": 337}, {"t": "Nervus alveolaris inferior", "m": "Inferior alveolar nerve", "e": "nervus (L. nervus: nerve, sinew) + alveolaris (L. alveolāris: of the socket/alveolus, from alveus = hollow, cavity) + inferior (L. inferior: lower, comparative of inferus = below)", "p": 337}, {"t": "Nervus abducens", "m": "Abducent nerve", "e": "nervus (L. nervus: nerve, sinew) + abducens (L. abdūcēns: drawing away, from ab = away + ducere = to lead)", "p": 337}, {"t": "N. facialis", "m": "Facial nerve (VII)", "e": "N. (L. nervus: nerve, sinew) + facialis (L. faciālis: of the face, from facies = face)", "p": 338}, {"t": "n. intermediofacialis", "m": "Intermediofacial nerve", "e": "n. (L. nervus: nerve) + intermedio (L. intermedius: in between, from inter = between + medius = middle) + facialis (L. faciālis: of the face)", "p": 338}, {"t": "Geniculum facialis", "m": "Genu of facial nerve — bend in the facial nerve just below the anterior wall of the petrous temporal bone", "e": "geniculum (L. geniculum: little knee, bend, from genu = knee) + facialis (L. faciālis: of the face)", "p": 338}, {"t": "N. stapedius", "m": "Nerve to the stapedius", "e": "N. (L. nervus: nerve) + stapedius (L. stapes/stapedius: stirrup, referring to the stapes bone, from Medieval L. stapes = stirrup)", "p": 338}, {"t": "Ramus communicans cum plexus tympanico", "m": "Communicating branch of facial nerve with tympanic plexus", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating, from communicare = to share) + cum (L. cum: with) + plexus (L. plexus: network, from plectere = to weave) + tympanico (L. tympanicus: of the eardrum, from Gk. tympanon = drum)", "p": 338}, {"t": "Ramus communicans cum nervo vago", "m": "Communicating branch of facial nerve with vagus nerve", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating) + cum (L. cum: with) + nervo (L. nervus: nerve) + vago (L. vagus: wandering, straying)", "p": 338}, {"t": "N. auricularis posterior", "m": "Posterior auricular nerve", "e": "N. (L. nervus: nerve) + auricularis (L. auriculāris: of the ear, from auricula = little ear, from auris = ear) + posterior (L. posterior: behind, later, from post = after)", "p": 338}, {"t": "Ramus occipitalis", "m": "Occipital branch", "e": "ramus (L. ramus: branch) + occipitalis (L. occipitālis: of the occiput, from ob = against/behind + caput = head)", "p": 338}, {"t": "Ramus auricularis", "m": "Auricular branch", "e": "ramus (L. ramus: branch) + auricularis (L. auriculāris: of the ear, from auricula = little ear)", "p": 338}, {"t": "Ramus digastricus", "m": "Digastric branch — supplies the posterior belly of the digastric muscle", "e": "ramus (L. ramus: branch) + digastricus (L./Gk. digastricus: two-bellied, from Gk. di = two + gaster = belly)", "p": 338}, {"t": "Ramus stylohyoideus", "m": "Stylohyoid branch — supplies the stylohyoid muscle", "e": "ramus (L. ramus: branch) + stylohyoideus (L./Gk. stylohyoideus: of the styloid and hyoid, from Gk. stylos = pillar + hyoeides = U-shaped, from Gk. letter upsilon)", "p": 338}, {"t": "Ramus communicans cum n. glossopharyngeo", "m": "Communicating branch of facial nerve with glossopharyngeal nerve", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating) + cum (L. cum: with) + n. (L. nervus: nerve) + glossopharyngeo (Gk. glossa = tongue + pharynx = throat)", "p": 338}, {"t": "Plexus intraparotideus", "m": "Intraparotid plexus — facial nerve plexus in the space between the two parotid lobes", "e": "plexus (L. plexus: network) + intraparotideus (L. intra = within + parotid, from Gk. para = beside + ous/otos = ear)", "p": 338}, {"t": "Rami temporales", "m": "Temporal branches — ascending over the zygomatic arch to the muscles of facial expression", "e": "rami (L. rami: branches, pl. of ramus) + temporales (L. temporāles: of the temple, from tempora = temples of the head)", "p": 338}, {"t": "Rami zygomatici", "m": "Zygomatic branches — supplying the lateral part of the orbicularis oculi and muscles of facial expression", "e": "rami (L. rami: branches) + zygomatici (Gk./L. zygomaticus: of the cheekbone, from Gk. zygon = yoke)", "p": 338}, {"t": "Rami buccales", "m": "Buccal branches — supplying the buccinator muscle and muscles of facial expression", "e": "rami (L. rami: branches) + buccales (L. buccālis: of the cheek, from bucca = cheek)", "p": 338}, {"t": "Ramus lingualis", "m": "Lingual branch — inconstant ramus to the tongue", "e": "ramus (L. ramus: branch) + lingualis (L. linguālis: of the tongue, from lingua = tongue)", "p": 338}, {"t": "Ramus marginalis mandibularis", "m": "Marginal mandibular branch — passes to the chin and muscles of facial expression below the oral fissure", "e": "ramus (L. ramus: branch) + marginalis (L. marginālis: of the margin, from margo = edge, border) + mandibularis (L. mandibulāris: of the mandible, from mandibula = jaw, from mandere = to chew)", "p": 338}, {"t": "Ramus colli cervicalis", "m": "Cervical branch — motor branch for the platysma", "e": "ramus (L. ramus: branch) + colli (L. collum: neck, genitive colli) + cervicalis (L. cervicālis: of the neck, from cervix = neck)", "p": 338}, {"t": "N. intermedius", "m": "Sensory root of facial nerve — arises from the brainstem independently between the facial and vestibular nerves", "e": "N. (L. nervus: nerve) + intermedius (L. intermedius: in between, from inter = between + medius = middle)", "p": 338}, {"t": "Ganglion geniculi geniculatum", "m": "Geniculate (facial) ganglion — equivalent to a spinal ganglion with pseudo-unipolar ganglion cells, located in the petrous part of the temporal bone", "e": "ganglion (Gk. ganglion: knot, swelling, mass of nerve tissue) + geniculi (L. geniculum: little knee, bend, genitive) + geniculatum (L. geniculatus: bent like a knee, from genu = knee)", "p": 338}, {"t": "Chorda tympani", "m": "Chorda tympani — nerve bundle with parasympathetic fibers for the submandibular gland and sensory fibers from taste buds", "e": "chorda (Gk. chorde: string, cord) + tympani (L. tympanum: drum, from Gk. tympanon = drum, genitive tympani)", "p": 338}, {"t": "N. canalis pterygoidei Radix facialis", "m": "Nerve of pterygoid canal — located in the pterygoid canal at the root of the pterygoid process", "e": "N. (L. nervus: nerve) + canalis (L. canālis: canal, channel, from canna = reed, tube) + pterygoidei (Gk. pteryx = wing + eidos = form, shape, genitive) + radix (L. radix: root) + facialis (L. faciālis: of the face)", "p": 338}, {"t": "N. petrosus major", "m": "Greater petrosal nerve — branch of facial nerve emerging from the anterior wall of the petrous part of the temporal bone", "e": "N. (L. nervus: nerve) + petrosus (L. petrōsus: rocky, stony, from petra = rock, stone) + major (L. maior: greater, larger)", "p": 338}, {"t": "N. petrosus profundus", "m": "Deep petrosal nerve — nerve carrying sympathetic fibers from the internal carotid plexus", "e": "N. (L. nervus: nerve) + petrosus (L. petrōsus: rocky, stony, from petra = rock) + profundus (L. profundus: deep, from pro = forward + fundus = bottom)", "p": 338}, {"t": "Ramus sympatheticus ad ganglion submandibulare", "m": "Sympathetic branch to the submandibular ganglion — branch from the internal carotid plexus", "e": "ramus (L. ramus: branch) + sympatheticus (Gk. sympathetikos: feeling together, from syn = together + pathos = feeling) + ad (L. ad: to, toward) + ganglion (Gk. ganglion: knot) + submandibulare (L. sub = under + mandibula = jaw)", "p": 338}, {"t": "Rami glandulares", "m": "Glandular branches — small rami at the inferior margin of the submandibular ganglion supplying the submandibular gland", "e": "rami (L. rami: branches) + glandulares (L. glandulāres: of the gland, from glans/glandis = acorn, gland)", "p": 338}, {"t": "Ganglion sublinguale", "m": "Sublingual ganglion — small group of cells occasionally present on the glandular rami", "e": "ganglion (Gk. ganglion: knot, mass of nerve tissue) + sublinguale (L. sub = under + lingua = tongue, lingualis = of the tongue)", "p": 338}, {"t": "N. vestibulocochlearis [VIII]", "m": "Vestibulocochlear nerve (VIII) — eighth cranial nerve", "e": "N. (L. nervus: nerve) + vestibulo (L. vestibulum: entrance hall, vestibule) + cochlearis (L. cochlea: snail shell, from Gk. kokhliās: snail)", "p": 340}, {"t": "N. vestibularis", "m": "Vestibular nerve — superior, ventral, vestibular portion of vestibulocochlear nerve", "e": "N. (L. nervus: nerve) + vestibularis (L. vestibulum: entrance hall, vestibule)", "p": 340}, {"t": "Nervus cochlearis", "m": "Cochlear nerve — inferior, dorsal, cochlear part of vestibulocochlear nerve", "e": "nervus (L. nervus: nerve) + cochlearis (L. cochlea: snail shell, from Gk. kokhliās: snail)", "p": 340}, {"t": "Nervus vestibularis", "m": "Vestibular nerve — portion of VIII nerve passing from the vestibular nucleus to the maculae and ampullary crest", "e": "nervus (L. nervus: nerve) + vestibularis (L. vestibulum: entrance hall, vestibule)", "p": 340}, {"t": "Ganglion vestibulare", "m": "Vestibular ganglion — ganglion located in the floor of the internal acoustic meatus", "e": "ganglion (Gk. ganglion: knot, swelling) + vestibulare (L. vestibulum: entrance hall, vestibule)", "p": 340}, {"t": "Ramus communicans cochlearis", "m": "Communicating branch with cochlear nerve", "e": "ramus (L. ramus: branch) + communicans (L. communicare: to connect, share) + cochlearis (L. cochlea: snail shell)", "p": 340}, {"t": "Pars superior ganglii vestibularis", "m": "Upper part of vestibular ganglion — supplies anterior and lateral semicircular canals, utricle and anterior part of saccule", "e": "pars (L. pars: part) + superior (L. superior: upper, higher) + ganglii (Gk. ganglion: knot) + vestibularis (L. vestibulum: entrance hall)", "p": 340}, {"t": "N. utriculoampullaris", "m": "Utriculoampullar nerve — superior branch of vestibular nerve with fibers from macula and ampullary crest", "e": "N. (L. nervus: nerve) + utriculo (L. utriculus: little bag, dim. of uter) + ampullaris (L. ampulla: flask, jug)", "p": 340}, {"t": "N. utricularis", "m": "Utricular nerve — branch from the macula utriculi", "e": "N. (L. nervus: nerve) + utricularis (L. utriculus: little bag, dim. of uter)", "p": 340}, {"t": "N. ampullaris anterior", "m": "Anterior ampullar nerve — branch from the ampullary crest of the anterior semicircular canal", "e": "N. (L. nervus: nerve) + ampullaris (L. ampulla: flask) + anterior (L. anterior: before, in front)", "p": 340}, {"t": "N. ampullaris lateralis", "m": "Lateral ampullar nerve — branch from the ampullary crest of the lateral semicircular canal", "e": "N. (L. nervus: nerve) + ampullaris (L. ampulla: flask) + lateralis (L. lateralis: of the side, from latus: side)", "p": 340}, {"t": "Pars inferior ganglii vestibularis", "m": "Inferior part of vestibular ganglion — supplies posterior semicircular canal and part of sacculus", "e": "pars (L. pars: part) + inferior (L. inferior: lower) + ganglii (Gk. ganglion: knot) + vestibularis (L. vestibulum: entrance hall)", "p": 340}, {"t": "N. ampullaris posterior", "m": "Posterior ampullar nerve — branch from ampullary crest of posterior semicircular canal", "e": "N. (L. nervus: nerve) + ampullaris (L. ampulla: flask) + posterior (L. posterior: behind, after)", "p": 340}, {"t": "N. saccularis", "m": "Saccular nerve — branch from the macula sacculi", "e": "N. (L. nervus: nerve) + saccularis (L. sacculus: little sac, dim. of saccus: bag)", "p": 340}, {"t": "Ganglion cochleare (spirale)", "m": "Cochlear (spiral) ganglion — helical band of ganglion cells directed towards the axis of the cochlea", "e": "ganglion (Gk. ganglion: knot, swelling) + cochleare (L. cochlea: snail shell) + spirale (L. spiralis: coiled, from spira: coil)", "p": 340}, {"t": "N. glossopharyngeus [IX]", "m": "Glossopharyngeal nerve (IX) — ninth cranial nerve", "e": "N. (L. nervus: nerve) + glosso (Gk. glōssa: tongue) + pharyngeus (Gk. pharynx: throat)", "p": 340}, {"t": "Ganglion superius [intracraniale]", "m": "Superior (jugular) ganglion — smaller ganglion in the jugular foramen, contains cell bodies of afferent fibers", "e": "ganglion (Gk. ganglion: knot) + superius (L. superius: upper, higher) + intracraniale (L. intra: within + cranium: skull, from Gk. kranion)", "p": 340}, {"t": "Ganglion inferius [extracraniale]", "m": "Inferior (petrous) ganglion — larger ganglion below the jugular foramen, contains cell bodies of afferent fibers", "e": "ganglion (Gk. ganglion: knot) + inferius (L. inferius: lower) + extracraniale (L. extra: outside + cranium: skull, from Gk. kranion)", "p": 340}, {"t": "N. tympanicus", "m": "Tympanic nerve — first branch of the IX nerve, branches from the inferior ganglion", "e": "N. (L. nervus: nerve) + tympanicus (Gk. tympanon: drum, tympanum)", "p": 340}, {"t": "Tumescentia tympanica (ganglion tympanicum)", "m": "Tympanic enlargement (ganglion) — irregularly scattered ganglion cells forming a dilatation in the course of the tympanic nerve", "e": "tumescentia (L. tumescere: to swell up) + tympanica (Gk. tympanon: drum) + ganglion (Gk. ganglion: knot) + tympanicum (Gk. tympanon: drum)", "p": 340}, {"t": "Plexus tympanicus", "m": "Tympanic plexus — plexus in mucosa over promontory, formed by tympanic nerve, internal carotid plexus and communicating ramus of facial nerve", "e": "plexus (L. plexus: braid, network, from plectere: to braid) + tympanicus (Gk. tympanon: drum)", "p": 340}, {"t": "Ramus tubarius (tubalis)", "m": "Tubal branch of tympanic plexus — ramus for the auditory tube", "e": "ramus (L. ramus: branch) + tubarius (L. tuba: tube, trumpet) + tubalis (L. tuba: tube)", "p": 340}, {"t": "Nn. caroticotympanici", "m": "Caroticotympanic nerves — sympathetic fibers of tympanic plexus derived from internal carotid plexus", "e": "Nn. (L. nervi: nerves) + carotico (Gk. karotis: carotid, from karoun: to stupefy) + tympanici (Gk. tympanon: drum)", "p": 340}, {"t": "Ramus communicans [cum ramo auriculari nervi vagi]", "m": "Communicating branch of glossopharyngeal nerve with auricular branch of vagus nerve — fine branch from inferior ganglion to the auricular ramus of vagus", "e": "ramus (L. ramus: branch) + communicans (L. communicare: to connect) + auriculari (L. auricula: little ear, dim. of auris: ear) + nervi (L. nervus: nerve) + vagi (L. vagus: wandering)", "p": 340}, {"t": "Rami pharyngei (pharyngeales)", "m": "Pharyngeal branches of IX nerve — three to four rami passing into the pharyngeal plexus", "e": "rami (L. ramus: branch) + pharyngei (Gk. pharynx: throat) + pharyngeales (Gk. pharynx: throat)", "p": 340}, {"t": "Ramus m. stylopharyngei", "m": "Ramus to stylopharyngeus muscle", "e": "ramus (L. ramus: branch) + m. (L. musculus: muscle) + stylo (Gk. stylos: pillar, post) + pharyngei (Gk. pharynx: throat)", "p": 340}, {"t": "Ramus sinus carotici", "m": "Branch to carotid sinus — also passes to carotid body and communicates with sympathetic trunk and vagus nerve", "e": "ramus (L. ramus: branch) + sinus (L. sinus: curve, hollow, bay) + carotici (Gk. karotis: carotid artery)", "p": 340}, {"t": "N. petrosus minor", "m": "Lesser petrosal nerve — nerve containing parasympathetic fibers from the glossopharyngeal nerve", "e": "N. (L. nervus: nerve) + petrosus (L. petrosus: rocky, stony, from petra: rock) + minor (L. minor: smaller, lesser)", "p": 340}, {"t": "Ramus communicans [cum ramo meningeo]", "m": "Communicating branch with the meningeal branch", "e": "ramus (L. ramus: branch) + communicans (L. communicare: to connect) + meningeo (Gk. meninx/meningos: membrane)", "p": 340}, {"t": "Ramus communicans [cum n. auriculotemporali]", "m": "Communicating branch with auriculo-temporal nerve — includes postganglionic parasympathetic fibers that supply the parotid gland", "e": "ramus (L. ramus: branch) + communicans (L. communicare: to connect) + n. (L. nervus: nerve) + auriculo (L. auricula: little ear) + temporali (L. temporalis: of the temple, from tempus: temple of head)", "p": 340}, {"t": "Ramus communicans [cum chorda tympani]", "m": "Communicating branch with chorda tympani — contains sensory nerve fibers", "e": "ramus (L. ramus: branch) + communicans (L. communicare: to connect) + chorda (Gk. khordē: string, cord) + tympani (Gk. tympanon: drum)", "p": 340}, {"t": "N. vagus", "m": "Vagus nerve — Tenth cranial nerve", "e": "N. (L. nervus: nerve, sinew) + vagus (L. vagus: wandering, roaming)", "p": 342}, {"t": "Ganglion superius", "m": "Superior (jugular) ganglion — small superior sensory ganglion of vagus situated in the jugular foramen", "e": "ganglion (Gk. ganglion: knot, swelling) + superius (L. superius: upper, higher)", "p": 342}, {"t": "Ganglion inferius", "m": "Inferior (nodose) ganglion — large inferior, spindle-shaped ganglion of the vagus nerve", "e": "ganglion (Gk. ganglion: knot, swelling) + inferius (L. inferius: lower)", "p": 342}, {"t": "Ramus communicans cum. n. glossopharyngeo", "m": "Communicating branch with IX nerve — anastomotic branch from the auricular ramus to the glossopharyngeal nerve", "e": "ramus (L. ramus: branch) + communicans (L. communicans: connecting, sharing, from communicare = to share) + cum (L. cum: with) + n. (L. nervus: nerve) + glossopharyngeo (Gk. glossa: tongue + pharynx: throat)", "p": 342}, {"t": "Ramus pharyngealis", "m": "Pharyngeal branch — branch radiating into the pharyngeal plexus", "e": "ramus (L. ramus: branch) + pharyngealis (Gk. pharynx: throat)", "p": 342}, {"t": "Plexus pharyngealis", "m": "Pharyngeal plexus — nerve plexus below the middle pharyngeal constrictor formed by the glossopharyngeal and vagus nerves and the cervical sympathetic trunk", "e": "plexus (L. plexus: braid, network, from plectere = to braid) + pharyngealis (Gk. pharynx: throat)", "p": 342}, {"t": "Rami cardiaci cervicales superiores", "m": "Superior cervical cardiac branches — branches given off at variably high cervical levels traveling to the deep part of the cardiac plexus", "e": "rami (L. rami: branches, plural of ramus) + cardiaci (Gk. kardiakos: of the heart, from kardia = heart) + cervicales (L. cervicales: of the neck, from cervix = neck) + superiores (L. superiores: upper, plural of superior)", "p": 342}, {"t": "N. laryngealis superior", "m": "Superior laryngeal nerve — nerve that arises from the inferior ganglion and passes downward medial to the internal carotid artery to supply the larynx", "e": "N. (L. nervus: nerve) + laryngealis (Gk. larynx: larynx, upper windpipe) + superior (L. superior: upper, higher)", "p": 342}, {"t": "Ramus externus", "m": "External branch of superior laryngeal nerve — nerve that branches to the inferior pharyngeal constrictor and then passes to the cricothyroid muscle", "e": "ramus (L. ramus: branch) + externus (L. externus: outer, external)", "p": 342}, {"t": "Ramus internus", "m": "Internal branch (internal laryngeal nerve) — together with the superior laryngeal artery, it penetrates the thyrohyoid membrane", "e": "ramus (L. ramus: branch) + internus (L. internus: inner, internal)", "p": 342}, {"t": "Ramus communicans cum. n. laryngeali recurrenti", "m": "Branch communicating with the recurrent laryngeal nerve", "e": "ramus (L. ramus: branch) + communicans (L. communicans: connecting, from communicare = to share) + cum (L. cum: with) + n. (L. nervus: nerve) + laryngeali (Gk. larynx: larynx) + recurrenti (L. recurrenti: returning, from recurrere = to run back)", "p": 342}, {"t": "Rami cardiaci cervicales inferiores", "m": "Inferior cervical cardiac branches — on the right they pass to the deep part of the cardiac plexus; on the left they pass to the superficial part", "e": "rami (L. rami: branches) + cardiaci (Gk. kardiakos: of the heart) + cervicales (L. cervicales: of the neck) + inferiores (L. inferiores: lower, plural of inferior)", "p": 342}, {"t": "N. laryngealis recurrens", "m": "Recurrent laryngeal nerve — on the right loops around the subclavian artery; on the left curves around the arch of the aorta", "e": "N. (L. nervus: nerve) + laryngealis (Gk. larynx: larynx) + recurrens (L. recurrens: returning, from recurrere = to run back)", "p": 342}, {"t": "Rami tracheales", "m": "Tracheal branches", "e": "rami (L. rami: branches) + tracheales (Gk. tracheia: rough, windpipe, from trachys = rough)", "p": 342}, {"t": "Rami oesophageales", "m": "Esophageal branches", "e": "rami (L. rami: branches) + oesophageales (Gk. oisophagos: gullet, from oisein = to carry + phagein = to eat)", "p": 342}, {"t": "Rami pharyngeales", "m": "Pharyngeal branches to the inferior pharyngeal constrictor", "e": "rami (L. rami: branches) + pharyngeales (Gk. pharynx: throat)", "p": 342}, {"t": "N. laryngeus inferior", "m": "Inferior laryngeal nerve — term sometimes used to denote the terminal branch of the recurrent laryngeal nerve, which supplies the intrinsic muscles of the larynx except the cricothyroid", "e": "N. (L. nervus: nerve) + laryngeus (Gk. larynx: larynx) + inferior (L. inferior: lower)", "p": 342}, {"t": "R. communicans cum ramo laryngeo interno", "m": "Communicating branch of the inferior (recurrent) laryngeal nerve to the internal laryngeal nerve", "e": "R. (L. ramus: branch) + communicans (L. communicans: connecting) + cum (L. cum: with) + ramo (L. ramus: branch, ablative) + laryngeo (Gk. larynx: larynx) + interno (L. internus: inner, internal)", "p": 342}, {"t": "Rami cardiaci thoracici", "m": "Thoracic cardiac branches — rami to the thoracic inlet", "e": "rami (L. rami: branches) + cardiaci (Gk. kardiakos: of the heart) + thoracici (Gk. thorax: chest, breastplate)", "p": 342}, {"t": "Rami bronchiales", "m": "Bronchial branches — rami projected to the hilum of the lung below the recurrent laryngeal nerve", "e": "rami (L. rami: branches) + bronchiales (Gk. bronchos: windpipe, bronchial tube)", "p": 342}, {"t": "Plexus pulmonalis", "m": "Pulmonary plexus — nerve plexus located anterior and posterior to the hilum of the lung for innervation of bronchi, vessels and visceral pleura", "e": "plexus (L. plexus: network, braid) + pulmonalis (L. pulmonalis: of the lung, from pulmo = lung)", "p": 342}, {"t": "Plexus oesophagealis", "m": "Esophageal plexus — nerve plexus around the esophagus formed directly by the two vagus nerves and superiorly also by the left recurrent laryngeal nerve", "e": "plexus (L. plexus: network, braid) + oesophagealis (Gk. oisophagos: gullet, esophagus)", "p": 342}, {"t": "Truncus vagalis anterior", "m": "Anterior vagal trunk — weak anterior plexus emerging from the esophageal plexus and containing fibers from the both vagi", "e": "truncus (L. truncus: trunk, main stem) + vagalis (L. vagalis: of the vagus, from vagus = wandering) + anterior (L. anterior: front, forward)", "p": 342}, {"t": "Truncus vagalis posterior", "m": "Posterior vagal trunk — better developed posterior nerve plexus arising from the esophageal plexus and containing fibers from both vagi", "e": "truncus (L. truncus: trunk, main stem) + vagalis (L. vagalis: of the vagus) + posterior (L. posterior: behind, hinder)", "p": 342}, {"t": "Rami gastrici anteriores", "m": "Anterior gastric branches — rami extending from the anterior vagal trunk to the anterior surface of the stomach", "e": "rami (L. rami: branches) + gastrici (Gk. gastrikos: of the stomach, from gaster = stomach) + anteriores (L. anteriores: front, plural of anterior)", "p": 342}, {"t": "Rami gastrici posteriores", "m": "Posterior gastric branches — rami extending from the posterior vagal trunk to the posterior surface of the stomach", "e": "rami (L. rami: branches) + gastrici (Gk. gastrikos: of the stomach) + posteriores (L. posteriores: behind, plural of posterior)", "p": 342}, {"t": "Rami hepatici", "m": "Hepatic branches — rami to the hilum of the liver", "e": "rami (L. rami: branches) + hepatici (Gk. hepatikos: of the liver, from hepar = liver)", "p": 342}, {"t": "Rami coeliaci", "m": "Celiac branches — rami to the celiac plexus", "e": "rami (L. rami: branches) + coeliaci (Gk. koiliakos: of the abdomen/belly, from koilia = belly)", "p": 342}, {"t": "Rami renales", "m": "Renal branches — rami to the renal plexus", "e": "rami (L. rami: branches) + renales (L. renales: of the kidneys, from ren = kidney)", "p": 342}, {"t": "N. accessorius", "m": "Accessory nerve (XI) — eleventh cranial nerve, its two roots unite in the skull and pass through the jugular foramen together with the IX and X nerves", "e": "N. (L. nervus: nerve) + accessorius (L. accessorius: supplementary, additional, from accedere = to approach, add to)", "p": 342}, {"t": "Radices craniales", "m": "Cranial roots (vagal part)", "e": "radices (L. radix: root, pl. radices) + craniales (L. cranialis: of the cranium, from Gk. kranion: skull)", "p": 343}, {"t": "pars vagalis", "m": "vagal part", "e": "pars (L. pars: part, portion) + vagalis (L. vagalis: of the vagus, from vagus: wandering)", "p": 343}, {"t": "nucleus ambiguus", "m": "ambiguous nucleus (brainstem motor nucleus)", "e": "nucleus (L. nucleus: kernel, core, from nux: nut) + ambiguus (L. ambiguus: uncertain, doubtful, from ambigere: to wander about)", "p": 343}, {"t": "Radices spinales", "m": "Spinal roots (spinal part)", "e": "radices (L. radix: root, pl. radices) + spinales (L. spinalis: of the spine, from spina: thorn, spine)", "p": 343}, {"t": "pars spinalis", "m": "spinal part", "e": "pars (L. pars: part, portion) + spinalis (L. spinalis: of the spine, from spina: thorn, spine)", "p": 343}, {"t": "Truncus nervi accessorii", "m": "Accessory nerve trunk", "e": "truncus (L. truncus: trunk, main stem) + nervi (L. nervus: nerve, sinew, gen. nervi) + accessorii (L. accessorius: accessory, additional, from accedere: to approach, add to)", "p": 343}, {"t": "Rami musculares", "m": "Muscular branches", "e": "rami (L. ramus: branch, pl. rami) + musculares (L. muscularis: of the muscle, from musculus: muscle, little mouse)", "p": 343}, {"t": "N. hypoglossus", "m": "Hypoglossal nerve (XII) — twelfth cranial nerve formed by numerous roots emerging from the brain between the pyramid and olive", "e": "N. (L. nervus: nerve) + hypoglossus (Gk. hypo: under + glossa: tongue)", "p": 344}, {"t": "Nervi spinales", "m": "Spinal nerves — formed by two roots, exit through the intervertebral foramina", "e": "nervi (L. nervus: nerve, pl. nervi) + spinales (L. spinalis: of the spine, from spina: spine, thorn)", "p": 344}, {"t": "Fila radicularia", "m": "Root filaments — fine root fibers emerging from the spinal cord within the anterior and posterior roots", "e": "fila (L. filum: thread, pl. fila) + radicularia (L. radicularis: of the rootlet, from radicula: small root, diminutive of radix: root)", "p": 344}, {"t": "Radix anterior", "m": "Anterior (ventral) root — motor root", "e": "radix (L. radix: root) + anterior (L. anterior: front, former, comparative of ante: before)", "p": 344}, {"t": "Radix posterior", "m": "Posterior (dorsal) root — sensory root", "e": "radix (L. radix: root) + posterior (L. posterior: behind, later, comparative of post: after)", "p": 344}, {"t": "Ganglion spinale", "m": "Spinal (dorsal root) ganglion — ganglion situated in the intervertebral foramen, composed of pseudo-unipolar cells", "e": "ganglion (Gk. ganglion: knot, swelling) + spinale (L. spinalis: of the spine, from spina: spine)", "p": 344}, {"t": "Truncus nervi spinalis", "m": "Spinal nerve trunk — segment between the union of the two roots and the first branch of the spinal nerve", "e": "truncus (L. truncus: trunk, main stem) + nervi (L. nervus: nerve, genitive nervi) + spinalis (L. spinalis: of the spine, from spina: spine)", "p": 344}, {"t": "Rami communicantes", "m": "Communicating branches — branches connecting the spinal nerve and the sympathetic trunk", "e": "rami (L. ramus: branch, pl. rami) + communicantes (L. communicans: communicating, connecting, from communicare: to share, connect)", "p": 344}, {"t": "Ramus griseus", "m": "Gray communicating ramus — postganglionic part", "e": "ramus (L. ramus: branch) + griseus (Medieval L. griseus: gray)", "p": 344}, {"t": "Ramus albus", "m": "White communicating ramus — preganglionic part", "e": "ramus (L. ramus: branch) + albus (L. albus: white)", "p": 344}, {"t": "Cauda equina", "m": "Cauda equina — collection of all spinal nerve roots extending from L1–2 caudally in addition to the filum terminale", "e": "cauda (L. cauda: tail) + equina (L. equinus: of a horse, from equus: horse)", "p": 344}, {"t": "Nervi cervicales", "m": "Cervical nerves — eight spinal nerves emerging from the cervical spinal cord", "e": "nervi (L. nervus: nerve, pl. nervi) + cervicales (L. cervicalis: of the neck, from cervix: neck)", "p": 344}, {"t": "Rami posteriores", "m": "Posterior (dorsal) branches — posterior branches of the spinal nerve supplying the nuchal muscles and skin lateral to the nuchal region and near the occiput", "e": "rami (L. ramus: branch, pl. rami) + posteriores (L. posterior: behind, later, pl. posteriores)", "p": 344}, {"t": "N. suboccipitalis", "m": "Suboccipital nerve — posterior branch of the first cervical spinal nerve, exits between the vertebral artery and posterior arch of the atlas", "e": "N. (L. nervus: nerve) + suboccipitalis (L. sub: under, below + occiput: back of the head, from ob: against + caput: head)", "p": 344}, {"t": "N. occipitalis major", "m": "Greater occipital nerve — posterior branch of the second cervical spinal nerve, emerges between the axis and obliquus capitis inferior muscle", "e": "N. (L. nervus: nerve) + occipitalis (L. occipitalis: of the occiput, from occiput: back of head) + major (L. major: greater, larger, comparative of magnus: great)", "p": 344}, {"t": "N. occipitalis tertius", "m": "Third occipital nerve — posterior branch of the third cervical spinal nerve, supplies the skin of the nuchal region close to the midline", "e": "N. (L. nervus: nerve) + occipitalis (L. occipitalis: of the occiput) + tertius (L. tertius: third)", "p": 344}, {"t": "Rami anteriores", "m": "Anterior (ventral) branches — anterior rami of cervical spinal nerves forming the cervical and brachial plexuses", "e": "rami (L. ramus: branch, pl. rami) + anteriores (L. anterior: front, pl. anteriores)", "p": 344}, {"t": "Plexus cervicalis", "m": "Cervical plexus — nerve plexus formed by the anterior rami of spinal nerves C1–4, supplying the skin and muscles of the neck", "e": "plexus (L. plexus: network, braid, from plectere: to weave) + cervicalis (L. cervicalis: of the neck, from cervix: neck)", "p": 344}, {"t": "Ansa cervicalis", "m": "Nerve loop from C1–3 — a nerve loop in the neck (C1-C3) supplying the infrahyoid muscles", "e": "ansa (L. ansa: handle, loop) + cervicalis (L. cervicalis: of the neck, from cervix: neck)", "p": 344}, {"t": "Ramus thyrohyoideus", "m": "Thyrohyoid branch of the ansa cervicalis — branch supplying the thyrohyoid muscle", "e": "ramus (L. ramus: branch) + thyrohyoideus (Gk. thyreos: shield + hyoeides: Y-shaped, from Gk. letter upsilon; adjectival form thyrohyoideus)", "p": 344}, {"t": "N. occipitalis minor", "m": "Lesser occipital nerve — uppermost cutaneous branch of the cervical plexus, passes upward at the posterior margin of the sternocleidomastoid", "e": "N. (L. nervus: nerve) + occipitalis (L. occipitalis: of the occiput) + minor (L. minor: lesser, smaller, comparative of parvus: small)", "p": 344}, {"t": "N. auricularis magnus", "m": "Great auricular nerve — courses to the ear, crossing the sternocleidomastoid vertically somewhat above its middle", "e": "N. (L. nervus: nerve) + auricularis (L. auricularis: of the ear, from auricula: little ear, from auris: ear) + magnus (L. magnus: great, large)", "p": 344}, {"t": "N. transversus colli", "m": "Transverse cervical (colli) nerve", "e": "N. (L. nervus: nerve) + transversus (L. transversus: lying across, from trans = across + vertere = to turn) + colli (L. collum: neck, genitive = of the neck)", "p": 346}, {"t": "Rami superiores", "m": "Superior branches", "e": "rami (L. ramus: branch, pl. rami) + superiores (L. superior: upper, higher)", "p": 346}, {"t": "Rami inferiores", "m": "Inferior branches", "e": "rami (L. ramus: branch, pl. rami) + inferiores (L. inferior: lower)", "p": 346}, {"t": "Nn. supraclaviculares", "m": "Supraclavicular nerves", "e": "Nn. (L. nervi: nerves, pl. of nervus) + supra (L. supra: above) + claviculares (L. clavicula: little key, collarbone, from clavis = key)", "p": 346}, {"t": "Nn. supraclaviculares mediales", "m": "Medial supraclavicular nerves", "e": "Nn. (L. nervi: nerves) + supraclaviculares (L. supra = above + clavicula = collarbone) + mediales (L. medialis: middle, from medius = middle)", "p": 346}, {"t": "Nn. supraclaviculares intermedii", "m": "Intermediate supraclavicular nerves", "e": "Nn. (L. nervi: nerves) + supraclaviculares (L. supra = above + clavicula = collarbone) + intermedii (L. intermedius: intermediate, from inter = between + medius = middle)", "p": 346}, {"t": "Nn. supraclaviculares laterales", "m": "Lateral (posterior) supraclavicular nerves", "e": "Nn. (L. nervi: nerves) + supraclaviculares (L. supra = above + clavicula = collarbone) + laterales (L. lateralis: lateral, from latus = side)", "p": 346}, {"t": "N. phrenicus", "m": "Phrenic nerve", "e": "N. (L. nervus: nerve) + phrenicus (Gk. phrenikos: of the diaphragm, from phrēn = diaphragm/mind)", "p": 346}, {"t": "Ramus pericardiacus", "m": "Pericardial branch", "e": "ramus (L. ramus: branch) + pericardiacus (Gk. perikardios: around the heart, from peri = around + kardia = heart)", "p": 346}, {"t": "Rami phrenicoabdominales", "m": "Phrenicoabdominal branches", "e": "rami (L. ramus: branch, pl.) + phrenico (Gk. phrēn: diaphragm) + abdominales (L. abdomen: belly, abdomen)", "p": 346}, {"t": "Nn. phrenici accessorii", "m": "Accessory phrenic nerves", "e": "Nn. (L. nervi: nerves) + phrenici (Gk. phrēn: diaphragm) + accessorii (L. accessorius: supplementary, from accedere = to come to, add to)", "p": 346}, {"t": "Plexus brachialis", "m": "Brachial plexus", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + brachialis (L. brachialis: of the arm, from brachium = arm)", "p": 346}, {"t": "Radices", "m": "Nerve roots", "e": "radices (L. radix: root, pl. radices)", "p": 346}, {"t": "Trunci", "m": "Trunks", "e": "trunci (L. truncus: trunk, main stem, pl. trunci)", "p": 346}, {"t": "Truncus superior", "m": "Upper trunk", "e": "truncus (L. truncus: trunk, main stem) + superior (L. superior: upper, higher)", "p": 346}, {"t": "Truncus medius", "m": "Middle trunk", "e": "truncus (L. truncus: trunk) + medius (L. medius: middle)", "p": 346}, {"t": "Truncus inferior", "m": "Lower trunk", "e": "truncus (L. truncus: trunk) + inferior (L. inferior: lower)", "p": 346}, {"t": "Divisiones anteriores", "m": "Anterior divisions", "e": "divisiones (L. divisio: division, from dividere = to divide) + anteriores (L. anterior: front, from ante = before)", "p": 346}, {"t": "Divisiones posteriores", "m": "Posterior divisions", "e": "divisiones (L. divisio: division) + posteriores (L. posterior: behind, from post = after)", "p": 346}, {"t": "Fasciculi", "m": "Cords — three nerve bundles formed by the union of branches from the three trunks", "e": "fasciculi (L. fasciculus: small bundle, diminutive of fascis = bundle, pl. fasciculi)", "p": 346}, {"t": "Pars supraclavicularis", "m": "Supraclavicular part — part of brachial plexus extending up to the superior margin of the clavicle", "e": "pars (L. pars: part) + supra (L. supra: above) + clavicularis (L. clavicula: little key, collarbone)", "p": 346}, {"t": "N. dorsalis scapulae", "m": "Dorsal scapular nerve", "e": "N. (L. nervus: nerve) + dorsalis (L. dorsalis: of the back, from dorsum = back) + scapulae (L. scapula: shoulder blade, genitive = of the shoulder blade)", "p": 346}, {"t": "N. thoracicus longus", "m": "Long thoracic nerve", "e": "N. (L. nervus: nerve) + thoracicus (Gk. thorakikos: of the chest, from thorax = chest) + longus (L. longus: long)", "p": 346}, {"t": "N. subclavius", "m": "Nerve to subclavius", "e": "N. (L. nervus: nerve) + sub (L. sub: under, below) + clavius (L. clavis/clavicula: key, collarbone)", "p": 346}, {"t": "N. suprascapularis", "m": "Suprascapular nerve", "e": "N. (L. nervus: nerve) + supra (L. supra: above) + scapularis (L. scapula: shoulder blade)", "p": 346}, {"t": "Pars infraclavicularis", "m": "Infraclavicular part — portion of brachial plexus below the clavicle", "e": "pars (L. pars: part) + infra (L. infra: below) + clavicularis (L. clavicula: little key, collarbone)", "p": 346}, {"t": "Fasciculus lateralis", "m": "Lateral cord — located lateral to the axillary artery", "e": "fasciculus (L. fasciculus: small bundle, from fascis = bundle) + lateralis (L. lateralis: lateral, from latus = side)", "p": 346}, {"t": "Fasciculus medialis", "m": "Medial cord — located medial to the axillary artery", "e": "fasciculus (L. fasciculus: small bundle) + medialis (L. medialis: middle, from medius = middle)", "p": 346}, {"t": "Fasciculus posterior", "m": "Posterior cord — located posterior to the axillary artery", "e": "fasciculus (L. fasciculus: small bundle) + posterior (L. posterior: behind, from post = after)", "p": 346}, {"t": "N. pectoralis medialis", "m": "Medial pectoral nerve", "e": "N. (L. nervus: nerve) + pectoralis (L. pectoralis: of the chest, from pectus = chest, breast) + medialis (L. medialis: medial, from medius = middle)", "p": 346}, {"t": "N. pectoralis lateralis", "m": "Lateral pectoral nerve", "e": "N. (L. nervus: nerve) + pectoralis (L. pectoralis: of the chest, from pectus = chest) + lateralis (L. lateralis: lateral, from latus = side)", "p": 346}, {"t": "N. musculocutaneus", "m": "Musculocutaneous nerve — nerve that arises from the lateral cord (C5–7), penetrates the coracobrachialis and supplies it as well as the biceps and brachialis muscles", "e": "N. (L. nervus: nerve, sinew) + musculo (L. musculus: muscle, little mouse) + cutaneus (L. cutaneus: of the skin, from cutis = skin)", "p": 348}, {"t": "N. cutaneus antebrachii lateralis", "m": "Lateral antebrachial cutaneous nerve — terminal branch of musculocutaneous nerve supplying the skin of the lateral forearm", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + antebrachii (L. ante = before/in front + brachium = arm, thus forearm) + lateralis (L. lateralis: lateral, from latus = side)", "p": 348}, {"t": "N. cutaneus brachii medialis", "m": "Medial brachial cutaneous nerve — nerve that arises from the medial cord (C8, T1) and supplies the skin of the medial upper arm together with the intercostobrachial nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + brachii (L. brachium: arm, from Gk. brakhiōn = arm) + medialis (L. medialis: medial, from medius = middle)", "p": 348}, {"t": "N. cutaneus antebrachii medialis", "m": "Medial antebrachial cutaneous nerve — nerve that arises from the medial cord (C8, T1) and supplies the skin on the medial side of both the distal upper arm and the forearm", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + antebrachii (L. ante = before + brachium = arm) + medialis (L. medialis: medial, from medius = middle)", "p": 348}, {"t": "N. medianus", "m": "Median nerve — nerve formed by the union of medial and lateral roots from the medial and lateral cords (C6–T1)", "e": "N. (L. nervus: nerve) + medianus (L. medianus: middle, median, from medius = middle)", "p": 348}, {"t": "Radix medialis", "m": "Medial root — part of the median nerve coming from the medial cord with fibers from C8 and T1", "e": "radix (L. radix: root) + medialis (L. medialis: medial, from medius = middle)", "p": 348}, {"t": "Radix lateralis", "m": "Lateral root — part of the median nerve arising from the lateral cord with fibers from C6–7", "e": "radix (L. radix: root) + lateralis (L. lateralis: lateral, from latus = side)", "p": 348}, {"t": "N. interosseus (antebrachii) anterior", "m": "Anterior interosseous nerve of forearm — nerve that arises from the bend of the elbow from the posterior side of the median nerve and supplies the radiocarpal joint, intercarpal joints, flexor pollicis longus, flexor digitorum profundus (radial part) and pronator quadratus", "e": "N. (L. nervus: nerve) + interosseus (L. inter = between + os/ossis = bone) + antebrachii (L. ante = before + brachium = arm) + anterior (L. anterior: front, from ante = before)", "p": 348}, {"t": "Ramus palmaris n. mediani", "m": "Palmar branch of median nerve — nerve that arises in the distal third of the forearm and supplies the skin of the lateral palm", "e": "ramus (L. ramus: branch) + palmaris (L. palmaris: of the palm, from palma = palm) + n. (L. nervus: nerve) + mediani (L. medianus: middle/median)", "p": 348}, {"t": "Ramus communicans [cum nervo ulnari]", "m": "Communicating branch to the ulnar nerve", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating, from communicare = to share/connect) + cum (L. cum: with) + nervo (L. nervus: nerve) + ulnari (L. ulnaris: of the ulna, from ulna = forearm bone/elbow)", "p": 348}, {"t": "Nn. digitales communes", "m": "Common digital nerves — nerves that run in the spaces between the first four fingers and then divide", "e": "Nn. (L. nervi: nerves, pl. of nervus) + digitales (L. digitalis: of the fingers, from digitus = finger/toe) + communes (L. communes: common, shared, from communis = common)", "p": 348}, {"t": "Nn. digitales palmares proprii", "m": "Proper palmar digital nerves — terminal branches of common palmar digital nerves supplying the palmar aspect of the skin of the radial 3½ fingers and dorsal aspect of the skin of the radial 2½ distal phalanges", "e": "Nn. (L. nervi: nerves) + digitales (L. digitalis: of the fingers, from digitus = finger) + palmares (L. palmaris: of the palm, from palma = palm) + proprii (L. proprius: own, particular, proper)", "p": 348}, {"t": "N. ulnaris", "m": "Ulnar nerve — nerve that arises from the medial cord (C8, T1), initially lies in the medial bicipital groove, breaks through the medial intermuscular septum and penetrates the flexor carpi ulnaris", "e": "N. (L. nervus: nerve) + ulnaris (L. ulnaris: of the ulna, from ulna = the forearm bone, cogn. Gk. ōlenē = elbow)", "p": 348}, {"t": "Ramus dorsalis n. ulnaris", "m": "Dorsal branch of ulnar nerve — cutaneous branch passing between the distal and middle third of the forearm beneath the flexor carpi ulnaris to innervate the dorsum of the hand", "e": "ramus (L. ramus: branch) + dorsalis (L. dorsalis: of the back/dorsum, from dorsum = back) + n. (L. nervus: nerve) + ulnaris (L. ulnaris: of the ulna)", "p": 348}, {"t": "Nn. digitales dorsales", "m": "Dorsal digital nerves — individual branches to the little finger, ring finger and the ulnar side of the middle finger", "e": "Nn. (L. nervi: nerves, pl.) + digitales (L. digitalis: of the fingers, from digitus = finger) + dorsales (L. dorsalis: of the dorsum/back, from dorsum = back)", "p": 348}, {"t": "Ramus palmaris nervi ulnaris", "m": "Palmar branch of ulnar nerve — nerve that arises in the distal third of the forearm, penetrates the deep fascia and supplies the skin on the palmar surface of the hand", "e": "ramus (L. ramus: branch) + palmaris (L. palmaris: of the palm, from palma = palm) + nervi (L. nervus: nerve, gen. sing.) + ulnaris (L. ulnaris: of the ulna)", "p": 348}, {"t": "Ramus superficialis", "m": "Superficial branch — branch that courses beneath the palmar aponeurosis and divides to form the common palmar distal nerves and a fine branch to the palmaris brevis", "e": "ramus (L. ramus: branch) + superficialis (L. superficialis: superficial, from super = above + facies = surface)", "p": 348}, {"t": "Nn. digitales palmares communes", "m": "Common palmar digital nerves — usually only one branch which runs in the region between the ring and little fingers", "e": "Nn. (L. nervi: nerves, pl.) + digitales (L. digitalis: of the fingers, from digitus = finger) + palmares (L. palmaris: of the palm, from palma = palm) + communes (L. communes: common, from communis = common/shared)", "p": 348}, {"t": "Ramus profundus (of ulnar nerve)", "m": "Deep branch of ulnar nerve — branch that curves around the hamulus to supply the muscles of the hypothenar eminence, the interossei, the two ulnar lumbricals, the adductor pollicis and the deep head of the flexor pollicis brevis", "e": "ramus (L. ramus: branch) + profundus (L. profundus: deep, from pro = forward/down + fundus = bottom)", "p": 348}, {"t": "N. radialis", "m": "Radial nerve — nerve that originates from the posterior cord", "e": "N. (L. nervus: nerve, sinew) + radialis (L. radialis: of the radius/ray, from radius = spoke of a wheel, ray)", "p": 350}, {"t": "N. cutaneus brachii posterior", "m": "Posterior brachial cutaneous nerve — small cutaneous branch supplying the skin on the extensor side of the upper arm", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + brachii (L. brachium: arm, from Gk. brakhion = upper arm) + posterior (L. posterior: behind, coming after)", "p": 350}, {"t": "N. cutaneus brachii lateralis inferior", "m": "Lateral brachial cutaneous nerve — second cutaneous branch for the lateral and dorsal surfaces of the upper arm below the deltoid muscle", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + brachii (L. brachium: arm) + lateralis (L. lateralis: of the side, from latus = side) + inferior (L. inferior: lower, below)", "p": 350}, {"t": "N. cutaneus antebrachii posterior", "m": "Posterior antebrachial cutaneous nerve — cutaneous branch for the field between the lateral and medial antebrachial cutaneous nerves", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + antebrachii (L. ante = before/in front + brachium = arm, thus forearm) + posterior (L. posterior: behind, at the back)", "p": 350}, {"t": "Ramus profundus", "m": "Deep branch — branch that supplies the extensors of the forearm", "e": "ramus (L. ramus: branch) + profundus (L. profundus: deep, from pro = forward + fundus = bottom)", "p": 350}, {"t": "N. interosseus (antebrachii) posterior", "m": "Posterior interosseous nerve of forearm — terminal branch of the deep ramus that lies on the interosseous membrane in the distal third of the forearm", "e": "N. (L. nervus: nerve) + interosseus (L. inter = between + os/ossis = bone, thus between bones) + antebrachii (L. ante = before + brachium = arm) + posterior (L. posterior: behind, at the back)", "p": 350}, {"t": "Ramus communicans ulnaris", "m": "Communicating branch to the ulnar nerve — joins the dorsal ramus of the ulnar nerve on the dorsum and the hand", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating, from communicare = to share, connect) + ulnaris (L. ulnaris: of the ulna, from ulna = forearm bone, elbow)", "p": 350}, {"t": "Nervi subscapulares", "m": "Subscapular nerves — two to three branches from the brachial plexus supplying the subscapularis and teres major muscles", "e": "nervi (L. nervus: nerve, plural nervi) + subscapulares (L. sub = under + scapula = shoulder blade, thus under the scapula)", "p": 350}, {"t": "N. thoracodorsalis", "m": "Thoracodorsal nerve — longest subscapular nerve with fibers from C6–8, courses along the lateral margin of the scapula and supplies the latissimus dorsi", "e": "N. (L. nervus: nerve) + thoracodorsalis (L. thorax/thoracis = chest, from Gk. thorax = breastplate + dorsalis = of the back, from dorsum = back)", "p": 350}, {"t": "N. axillaris", "m": "Axillary nerve — nerve that arises from the posterior cord (C5–6) and passes together with the posterior circumflex humeral artery through the axilla to the teres minor and deltoid muscles", "e": "N. (L. nervus: nerve) + axillaris (L. axillaris: of the axilla/armpit, from axilla = armpit, diminutive of ala = wing)", "p": 350}, {"t": "N. cutaneus brachii lateralis superior", "m": "Superior lateral brachial cutaneous nerve — supplies the area of the skin located somewhat over the deltoid muscle", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + brachii (L. brachium: arm) + lateralis (L. lateralis: of the side, from latus = side) + superior (L. superior: upper, higher)", "p": 350}, {"t": "Nn. thoracici", "m": "Thoracic nerves — twelve thoracic spinal nerves emerging below thoracic vertebrae 1–12", "e": "Nn. (L. nervi: nerves, plural) + thoracici (L. thoracicus: of the thorax/chest, from Gk. thorax = breastplate, chest)", "p": 350}, {"t": "Ramus muscularis lateralis", "m": "Lateral muscular branch", "e": "ramus (L. ramus: branch) + muscularis (L. muscularis: of muscle, from musculus = muscle) + lateralis (L. lateralis: of the side, from latus = side)", "p": 350}, {"t": "Ramus muscularis medialis", "m": "Medial muscular branch", "e": "ramus (L. ramus: branch) + muscularis (L. muscularis: of muscle) + medialis (L. medialis: of the middle, from medius = middle)", "p": 350}, {"t": "Ramus cutaneus posterior", "m": "Posterior cutaneous branch", "e": "ramus (L. ramus: branch) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + posterior (L. posterior: behind, at the back)", "p": 350}, {"t": "Rami anteriores (nn. intercostales)", "m": "Anterior branches (intercostal nerves) — rami forming the intercostal nerves ventrally in the thoracic region", "e": "rami (L. ramus: branch, plural) + anteriores (L. anterior: in front, from ante = before) + nn. (L. nervi: nerves) + intercostales (L. inter = between + costa = rib, thus between the ribs)", "p": 350}, {"t": "Ramus cutaneus lateralis (pectoralis/abdominalis)", "m": "Lateral cutaneous branch (pectoral/abdominal) — nerve arising from the middle of the intercostal nerve, passes obliquely ventrad and appears between the slips of the serratus anterior muscle and the latissimus dorsi", "e": "ramus (L. ramus: branch) + cutaneus (L. cutaneus: of the skin) + lateralis (L. lateralis: of the side) + pectoralis (L. pectoralis: of the chest, from pectus = chest, breast) + abdominalis (L. abdominalis: of the abdomen, from abdomen = belly)", "p": 350}, {"t": "Rami mammarii laterales", "m": "Lateral mammary branches — rami of lateral cutaneous branches arising from T4–6 and passing anteriorly to the mammary region", "e": "rami (L. ramus: branch, plural) + mammarii (L. mammarius: of the breast, from mamma = breast, mother) + laterales (L. lateralis: of the side, plural)", "p": 350}, {"t": "Nn. intercostobrachiales", "m": "Intercostobrachial nerves — lateral cutaneous rami arising usually from T1, but also from T1–3 and passing to the upper arm", "e": "Nn. (L. nervi: nerves, plural) + intercostobrachiales (L. inter = between + costa = rib + brachium = arm, thus between ribs and arm)", "p": 350}, {"t": "Ramus cutaneus anterior (pectoralis/abdominalis)", "m": "Anterior cutaneous branch (pectoral/abdominal) — branch that emerges medially and anteriorly and divides to form medial and lateral branches", "e": "ramus (L. ramus: branch) + cutaneus (L. cutaneus: of the skin) + anterior (L. anterior: in front, from ante = before) + pectoralis (L. pectoralis: of the chest, from pectus = chest) + abdominalis (L. abdominalis: of the abdomen, from abdomen = belly)", "p": 350}, {"t": "Rami mammarii mediales", "m": "Medial mammary branches — medial branches from the anterior cutaneous rami of intercostal nerves 2–4", "e": "rami (L. ramus: branch, plural) + mammarii (L. mammarius: of the breast, from mamma = breast) + mediales (L. medialis: of the middle, plural, from medius = middle)", "p": 350}, {"t": "N. subcostalis", "m": "Subcostal nerve — anterior branch of the 12th thoracic nerve located below the 12th rib", "e": "N. (L. nervus: nerve) + subcostalis (L. sub = under/below + costa = rib, thus below the rib)", "p": 350}, {"t": "Nn. lumbales", "m": "Lumbar nerves — five lumbar spinal nerves each emerging below its respective lumbar vertebra", "e": "Nn. (L. nervi: nerves, plural abbreviation) + lumbales (L. lumbalis: of the loins, from lumbus = loin)", "p": 352}, {"t": "lumbares", "m": "Lumbar (alternative form used in lumbares)", "e": "lumbares (L. lumbaris: of the loins, from lumbus = loin)", "p": 352}, {"t": "Rami clunium superiores", "m": "Superior clunial (gluteal) branches — lateral rami of L1–3 supplying the skin up to the greater trochanter (buttock region)", "e": "rami (L. ramus: branch) + clunium (L. clunis: buttock) + superiores (L. superiores: upper, from superus = above)", "p": 352}, {"t": "Nn. sacrales et n. coccygeus", "m": "Sacral nerves and coccygeal nerve — five sacral and one coccygeal nerve", "e": "Nn. (L. nervi: nerves) + sacrales (L. sacralis: sacral, from sacrum = sacred bone) + et (L.: and) + n. (L. nervus: nerve) + coccygeus (L./Gk. coccygeus: of the coccyx, from kokkyx = cuckoo, coccyx)", "p": 352}, {"t": "Rami clunium mediales", "m": "Medial clunial (gluteal) nerves — sensory nerves from S1–3 that penetrate the gluteus maximus and supply the skin of the medial, upper gluteal region", "e": "rami (L. ramus: branch) + clunium (L. clunis: buttock) + mediales (L. medialis: medial, middle, from medius = middle)", "p": 352}, {"t": "Plexus lumbosacralis", "m": "Lumbosacral plexus — collective term for the combined lumbar and sacral plexuses joined together by fibers from L4 and mutually supplying the lower limb", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + lumbosacralis (L. lumbo- from lumbus = loin + sacralis from sacrum = sacred bone)", "p": 352}, {"t": "Plexus lumbalis", "m": "Lumbar plexus — nerve network formed by spinal nerves L1–4 which lie at the anterior side of the leg", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + lumbalis (L. lumbalis: of the loins, from lumbus = loin)", "p": 352}, {"t": "N. iliohypogastricus", "m": "Iliohypogastric nerve — nerve that contains sensory and motor fibers from T12 and L1 for the abdominal muscles", "e": "N. (L. nervus: nerve) + ilio- (L. ilium: flank, groin) + hypogastricus (Gk. hypo = under + gaster = belly, stomach)", "p": 352}, {"t": "Ramus cutaneus lateralis", "m": "Lateral cutaneous branch — it can reach as far as the lateral gluteal region", "e": "ramus (L. ramus: branch) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + lateralis (L. lateralis: lateral, of the side, from latus = side)", "p": 352}, {"t": "Ramus cutaneus anterior", "m": "Anterior cutaneous branch — it frequently penetrates the aponeurosis of the external oblique just above the superficial inguinal ring and supplies the skin in this area", "e": "ramus (L. ramus: branch) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + anterior (L. anterior: in front, from ante = before)", "p": 352}, {"t": "N. ilioinguinalis", "m": "Ilioinguinal nerve — nerve arising from L1, possibly also T12, appearing at the lateral margin of the psoas and coursing between the kidney and quadratus lumborum", "e": "N. (L. nervus: nerve) + ilio- (L. ilium: flank, groin) + inguinalis (L. inguinalis: of the groin, from inguen = groin)", "p": 352}, {"t": "Nn. scrotales anteriores", "m": "Anterior scrotal nerves — sensory branches to the anterior skin of the scrotum, mons pubis and adjacent skin of the thigh", "e": "Nn. (L. nervi: nerves) + scrotales (L. scrotalis: of the scrotum, from scrotum = pouch) + anteriores (L. anteriores: anterior, in front, from ante = before)", "p": 352}, {"t": "Nn. labiales anteriores", "m": "Anterior labial nerves — sensory rami to the labium majus, mons pubis and adjacent skin of the thigh", "e": "Nn. (L. nervi: nerves) + labiales (L. labialis: of the lips/labia, from labium = lip) + anteriores (L. anteriores: anterior, in front, from ante = before)", "p": 352}, {"t": "N. genitofemoralis", "m": "Genitofemoral nerve — nerve that arises from L1–2, penetrates the psoas major and courses on top of it", "e": "N. (L. nervus: nerve) + genito- (L. genitalis: of the genitals, from gignere = to beget) + femoralis (L. femoralis: of the thigh, from femur = thigh)", "p": 352}, {"t": "Ramus genitalis", "m": "Genital branch — branch that courses through the inguinal canal and supplies the cremaster muscle, skin of scrotum (labium majus) and adjacent skin of the thigh", "e": "ramus (L. ramus: branch) + genitalis (L. genitalis: of the genitals, from gignere = to beget)", "p": 352}, {"t": "Ramus femoralis", "m": "Femoral branch — branch that passes through the vascular lacuna (between femoral artery and iliopectineal arch), then through the saphenous hiatus to supply the skin located there", "e": "ramus (L. ramus: branch) + femoralis (L. femoralis: of the thigh, from femur = thigh)", "p": 352}, {"t": "N. cutaneus femoris lateralis", "m": "Lateral femoral cutaneous nerve — nerve that arises from L2–3, appears at the lateral margin of the psoas and courses beneath the iliac fascia and through the lateral part of the muscular lacuna into the thigh", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + femoris (L. femoris: of the thigh, genitive of femur = thigh) + lateralis (L. lateralis: lateral, of the side, from latus = side)", "p": 352}, {"t": "N. obturatorius", "m": "Obturator nerve — nerve that arises from L2–4, passes beneath the psoas, behind the internal iliac artery and lateral to the ureter, then through the obturator canal to the adductor group and to the medial skin of the thigh", "e": "N. (L. nervus: nerve) + obturatorius (L. obturatorius: of the obturator, from obturare = to stop up, close)", "p": 352}, {"t": "Ramus cutaneus", "m": "Cutaneous branch — variable terminal branch which appears between the adductor longus and gracilis muscles and supplies the distal 2/3 of the skin of the thigh", "e": "ramus (L. ramus: branch) + cutaneus (L. cutaneus: of the skin, from cutis = skin)", "p": 352}, {"t": "N. obturatorius accessorius", "m": "Accessory obturator nerve — it frequently arises as an additional obturator nerve from L3–4 to supply the pectineus and hip joint", "e": "N. (L. nervus: nerve) + obturatorius (L. obturatorius: of the obturator, from obturare = to stop up, close) + accessorius (L. accessorius: additional, accessory, from accedere = to come to, approach)", "p": 352}, {"t": "N. femoralis", "m": "Femoral nerve", "e": "N. (L. nervus: nerve, sinew) + femoralis (L. femoralis: of the femur/thigh, from femur = thigh)", "p": 354}, {"t": "Rami cutanei anteriores", "m": "Anterior cutaneous branches", "e": "rami (L. ramus: branch) + cutanei (L. cutaneus: of the skin, from cutis = skin) + anteriores (L. anterior: in front, forward)", "p": 354}, {"t": "N. saphenus", "m": "Saphenous nerve", "e": "N. (L. nervus: nerve) + saphenus (Gk. saphēnēs: manifest, visible, from saphainein = to show clearly)", "p": 354}, {"t": "Ramus infrapatellaris", "m": "Infrapatellar branch", "e": "ramus (L. ramus: branch) + infrapatellaris (L. infra: below + patella: small pan/kneecap, dim. of patera = shallow dish)", "p": 354}, {"t": "Rami cutanei cruris mediales", "m": "Medial cutaneous branches of the leg", "e": "rami (L. ramus: branch) + cutanei (L. cutaneus: of the skin) + cruris (L. crus, cruris: leg, shin) + mediales (L. medialis: middle, from medius = middle)", "p": 354}, {"t": "Truncus lumbosacralis", "m": "Lumbosacral trunk", "e": "truncus (L. truncus: trunk, main stem) + lumbosacralis (L. lumbus: loin + sacralis: of the sacrum, from sacer = sacred/holy)", "p": 354}, {"t": "Plexus sacralis", "m": "Sacral plexus", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + sacralis (L. sacralis: of the sacrum, from sacer = sacred)", "p": 354}, {"t": "N. musculi obturatorii interni", "m": "Nerve to obturator internus muscle", "e": "N. (L. nervus: nerve) + musculi (L. musculus: muscle) + obturatorii (L. obturator: one who stops up, from obturare = to stop up) + interni (L. internus: internal, within)", "p": 354}, {"t": "N. musculi piriformis", "m": "Nerve to piriformis muscle", "e": "N. (L. nervus: nerve) + musculi (L. musculus: muscle) + piriformis (L. pirum: pear + forma: shape; pear-shaped)", "p": 354}, {"t": "N. musculi quadrati femoris", "m": "Nerve to quadratus femoris muscle", "e": "N. (L. nervus: nerve) + musculi (L. musculus: muscle) + quadrati (L. quadratus: squared, from quattuor = four) + femoris (L. femur, femoris: thigh)", "p": 354}, {"t": "N. gluteus superior", "m": "Superior gluteal nerve", "e": "N. (L. nervus: nerve) + gluteus (Gk. gloutos: buttock) + superior (L. superior: upper, higher)", "p": 354}, {"t": "N. gluteus inferior", "m": "Inferior gluteal nerve", "e": "N. (L. nervus: nerve) + gluteus (Gk. gloutos: buttock) + inferior (L. inferior: lower)", "p": 354}, {"t": "N. cutaneus femoralis posterior", "m": "Posterior femoral cutaneous nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + femoralis (L. femoralis: of the thigh) + posterior (L. posterior: behind, coming after)", "p": 354}, {"t": "Rami clunium (gluteales) inferiores", "m": "Inferior clunial (gluteal) rami", "e": "rami (L. ramus: branch) + clunium (L. clunis: buttock) + gluteales (Gk. gloutos: buttock) + inferiores (L. inferior: lower)", "p": 354}, {"t": "Rami perineales", "m": "Perineal branches", "e": "rami (L. ramus: branch) + perineales (Gk. perinaion: perineum, from peri = around + inan = to evacuate)", "p": 354}, {"t": "N. cutaneus perforans", "m": "Perforating cutaneous nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + perforans (L. perforans: piercing through, from per = through + forare = to bore/pierce)", "p": 354}, {"t": "N. ischiadicus (sciaticus)", "m": "Sciatic nerve", "e": "N. (L. nervus: nerve) + ischiadicus (Gk. ischion: hip joint) + sciaticus (L./Gk. variant of ischiadicus: of the hip)", "p": 354}, {"t": "N. fibularis communis", "m": "Common peroneal (fibular) nerve", "e": "N. (L. nervus: nerve) + fibularis (L. fibula: clasp/brooch, the smaller leg bone) + communis (L. communis: common, shared)", "p": 354}, {"t": "N. cutaneus surae lateralis", "m": "Lateral sural cutaneous nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + surae (L. sura: calf of the leg) + lateralis (L. lateralis: of the side, from latus = side)", "p": 354}, {"t": "Ramus communicans fibularis", "m": "Communicating branch of common peroneal (fibular) nerve", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating, sharing, from communicare = to share) + fibularis (L. fibula: clasp, the smaller leg bone)", "p": 354}, {"t": "N. fibularis superficialis", "m": "Superficial peroneal (fibular) nerve", "e": "N. (L. nervus: nerve) + fibularis (L. fibula: clasp, smaller leg bone) + superficialis (L. superficialis: superficial, from super = above + facies = surface)", "p": 354}, {"t": "N. cutaneus dorsalis medialis", "m": "Medial dorsal cutaneous nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + dorsalis (L. dorsalis: of the back, from dorsum = back) + medialis (L. medialis: middle)", "p": 354}, {"t": "N. cutaneus dorsalis intermedius", "m": "Intermediate dorsal cutaneous nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin) + dorsalis (L. dorsalis: of the back) + intermedius (L. intermedius: intermediate, from inter = between + medius = middle)", "p": 354}, {"t": "Nn. digitales dorsales pedis", "m": "Dorsal digital nerves of foot", "e": "Nn. (L. nervi: nerves, pl.) + digitales (L. digitalis: of the digits/toes, from digitus = finger/toe) + dorsales (L. dorsalis: of the back/dorsum) + pedis (L. pes, pedis: foot)", "p": 354}, {"t": "N. fibularis profundus", "m": "Deep peroneal (fibular) nerve", "e": "N. (L. nervus: nerve) + fibularis (L. fibula: clasp, smaller leg bone) + profundus (L. profundus: deep, from pro = forward + fundus = bottom)", "p": 354}, {"t": "Nn. digitales dorsales hallucis lateralis et digiti secundi medialis", "m": "Dorsal digital nerves of lateral surface of great toe and of medial surface of second toe", "e": "Nn. (L. nervi: nerves) + digitales (L. digitalis: of the digits) + dorsales (L. dorsalis: of the dorsum) + hallucis (L. hallux, hallucis: great toe) + lateralis (L. lateralis: of the side) + et (L. et: and) + digiti (L. digitus: finger/toe) + secundi (L. secundus: second) + medialis (L. medialis: of the middle)", "p": 354}, {"t": "N. tibialis", "m": "Tibial nerve", "e": "N. (L. nervus: nerve, sinew) + tibialis (L. tibialis: of the tibia, from tibia = shin bone, flute)", "p": 356}, {"t": "N. interosseus cruris", "m": "Interosseous nerve of leg", "e": "N. (L. nervus: nerve) + interosseus (L. inter = between + osseus = bony, from os = bone) + cruris (L. crus/cruris: leg, shin)", "p": 356}, {"t": "N. cutaneus surae medialis", "m": "Medial sural cutaneous nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + surae (L. sura/surae: calf of the leg) + medialis (L. medialis: medial, from medius = middle)", "p": 356}, {"t": "N. suralis", "m": "Sural nerve", "e": "N. (L. nervus: nerve) + suralis (L. suralis: of the calf, from sura = calf of the leg)", "p": 356}, {"t": "N. cutaneus dorsalis lateralis", "m": "Lateral dorsal cutaneous nerve", "e": "N. (L. nervus: nerve) + cutaneus (L. cutaneus: of the skin, from cutis = skin) + dorsalis (L. dorsalis: of the back/dorsum, from dorsum = back) + lateralis (L. lateralis: lateral, from latus = side)", "p": 356}, {"t": "Rami calcanei laterales", "m": "Lateral calcaneal branches", "e": "rami (L. ramus: branch) + calcanei (L. calcaneus: of the heel bone, from calx/calcis = heel) + laterales (L. lateralis: lateral, from latus = side)", "p": 356}, {"t": "Rami calcanei mediales", "m": "Medial calcaneal branches", "e": "rami (L. ramus: branch) + calcanei (L. calcaneus: of the heel bone, from calx/calcis = heel) + mediales (L. medialis: medial, from medius = middle)", "p": 356}, {"t": "N. plantaris medialis", "m": "Medial plantar nerve", "e": "N. (L. nervus: nerve) + plantaris (L. plantaris: of the sole, from planta = sole of the foot) + medialis (L. medialis: medial, from medius = middle)", "p": 356}, {"t": "Nn. digitales plantares communes", "m": "Common plantar digital nerves", "e": "Nn. (L. nervi: nerves, plural of nervus) + digitales (L. digitalis: of the fingers/toes, from digitus = finger, toe) + plantares (L. plantaris: of the sole, from planta = sole of the foot) + communes (L. communis: common, shared)", "p": 356}, {"t": "Nn. digitales plantares proprii", "m": "Proper plantar digital nerves", "e": "Nn. (L. nervi: nerves) + digitales (L. digitalis: of the fingers/toes, from digitus = finger, toe) + plantares (L. plantaris: of the sole, from planta = sole) + proprii (L. proprius: one's own, proper)", "p": 356}, {"t": "N. plantaris lateralis", "m": "Lateral plantar nerve", "e": "N. (L. nervus: nerve) + plantaris (L. plantaris: of the sole, from planta = sole of the foot) + lateralis (L. lateralis: lateral, from latus = side)", "p": 356}, {"t": "N. pudendus", "m": "Pudendal nerve", "e": "N. (L. nervus: nerve) + pudendus (L. pudendus: of shame, from pudere = to be ashamed; referring to the pudendum/external genitalia)", "p": 356}, {"t": "Nn. rectales inferiores", "m": "Inferior rectal nerves", "e": "Nn. (L. nervi: nerves) + rectales (L. rectalis: of the rectum, from rectus = straight) + inferiores (L. inferior: lower, comparative of inferus = below)", "p": 356}, {"t": "Nn. perineales", "m": "Perineal nerves", "e": "Nn. (L. nervi: nerves) + perineales (L. perinealis: of the perineum, from Gk. perinaion = perineum, from peri = around + inaein = to evacuate)", "p": 356}, {"t": "Nn. scrotales/libiales posteriores", "m": "Posterior scrotal (labial) nerves", "e": "Nn. (L. nervi: nerves) + scrotales (L. scrotalis: of the scrotum, from scrotum = pouch) + labiales (L. labialis: of the lips/labia, from labium = lip) + posteriores (L. posterior: behind, from posterus = coming after)", "p": 356}, {"t": "N. dorsalis penis", "m": "Dorsal nerve of penis", "e": "N. (L. nervus: nerve) + dorsalis (L. dorsalis: of the back/dorsum, from dorsum = back) + penis (L. penis: tail, penis)", "p": 356}, {"t": "N. dorsalis clitoridis", "m": "Dorsal nerve of clitoris", "e": "N. (L. nervus: nerve) + dorsalis (L. dorsalis: of the dorsum, from dorsum = back) + clitoridis (Gk. kleitoris/L. clitoris: clitoris, from Gk. kleiein = to close or kleis = key)", "p": 356}, {"t": "N. coccygeus", "m": "Coccygeal nerve", "e": "N. (L. nervus: nerve) + coccygeus (L. coccygeus: of the coccyx, from Gk. kokkyx = cuckoo, coccyx — shaped like a cuckoo's beak)", "p": 356}, {"t": "Plexus coccygeus", "m": "Coccygeal plexus", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + coccygeus (L. coccygeus: of the coccyx, from Gk. kokkyx = cuckoo, coccyx)", "p": 356}, {"t": "Nn. anococcygei", "m": "Anococcygeal nerves", "e": "Nn. (L. nervi: nerves) + anococcygei (L. ano- from anus = ring, anus + coccygei from Gk. kokkyx = coccyx)", "p": 356}, {"t": "Nervi cruris", "m": "Nerves of leg and foot from behind", "e": "nervi (L. nervus: nerve, sinew) + cruris (L. crus/cruris: leg, shin)", "p": 357}, {"t": "Nervi cutanei cruris", "m": "Cutaneous nerves of leg from behind", "e": "nervi (L. nervus: nerve, sinew) + cutanei (L. cutaneus: of the skin, from cutis = skin) + cruris (L. crus/cruris: leg, shin)", "p": 357}, {"t": "Nervus pudendus", "m": "Pudendal nerve", "e": "nervus (L. nervus: nerve, sinew) + pudendus (L. pudendus: of shame, pertaining to the pudendum, from pudere = to be ashamed)", "p": 357}, {"t": "Systema nervorum autonomicum", "m": "Autonomic nervous system", "e": "systema (Gk. systēma: organized whole, from syn = together + histanai = to set) + nervorum (L. nervus: nerve, sinew; genitive plural) + autonomicum (Gk. autonomikos: self-governing, from autos = self + nomos = law)", "p": 358}, {"t": "Plexus autonomici viscerales", "m": "Autonomic (visceral) plexus — autonomic nerve plexuses mainly in front of the vertebral column at the branches of the aorta", "e": "plexus (L. plexus: braid, network, from plectere = to braid) + autonomici (Gk. autonomikos: self-governing) + viscerales (L. visceralis: of the viscera, from viscera = internal organs)", "p": 358}, {"t": "Ganglia plexuum autonomicorum visceralium", "m": "Ganglia of autonomic plexus — groups of ganglion cells scattered in the autonomic plexuses for synaptic connections between pre- and postganglionic fibers", "e": "ganglia (Gk. ganglion: knot, swelling under skin; plural) + plexuum (L. plexus: network; genitive plural) + autonomicorum (Gk. autonomikos: self-governing; genitive plural) + visceralium (L. visceralis: of the viscera; genitive plural)", "p": 358}, {"t": "Pars thoracica autonomica", "m": "Thoracic part of the autonomic nervous system", "e": "pars (L. pars: part) + thoracica (Gk. thōrakikos: of the chest, from thōrax = chest) + autonomica (Gk. autonomikos: self-governing)", "p": 358}, {"t": "Plexus aorticus thoracicus", "m": "Thoracic aortic plexus — autonomic nerve plexus around the aorta with fibers from the first five thoracic ganglia and the splanchnic nerve", "e": "plexus (L. plexus: network) + aorticus (Gk. aortē: aorta, from aeirein = to lift; adjective form) + thoracicus (Gk. thōrakikos: of the chest)", "p": 358}, {"t": "Plexus cardiacus", "m": "Cardiac plexus — autonomic nerve plexus from sympathetic and vagal fibers at the base of the heart", "e": "plexus (L. plexus: network) + cardiacus (Gk. kardiakos: of the heart, from kardia = heart)", "p": 358}, {"t": "Ganglia cardiaca", "m": "Cardiac ganglia — small macroscopic accumulations of ganglion cells especially to the right of the ligamentum arteriosum", "e": "ganglia (Gk. ganglion: knot, swelling; plural) + cardiaca (Gk. kardiakos: of the heart)", "p": 358}, {"t": "Rami pulmonales", "m": "Pulmonary branches — rami from the 3rd to 4th thoracic sympathetic ganglia, particularly to the posterior part of the pulmonary plexus", "e": "rami (L. ramus: branch; plural) + pulmonales (L. pulmonalis: of the lung, from pulmo = lung)", "p": 358}, {"t": "Pars abdominalis autonomica", "m": "Abdominal part of the autonomic nervous system", "e": "pars (L. pars: part) + abdominalis (L. abdominalis: of the abdomen, from abdomen = belly) + autonomica (Gk. autonomikos: self-governing)", "p": 358}, {"t": "Plexus aorticus abdominalis", "m": "Abdominal aortic plexus — nerve plexus in front of and on both sides of the aorta", "e": "plexus (L. plexus: network) + aorticus (Gk. aortē: aorta; adjective form) + abdominalis (L. abdominalis: of the abdomen)", "p": 358}, {"t": "Plexus coeliacus", "m": "Celiac plexus — nerve plexus around the celiac trunk", "e": "plexus (L. plexus: network) + coeliacus (Gk. koiliakos: of the belly/abdomen, from koilia = belly, cavity)", "p": 358}, {"t": "Ganglia coeliaca", "m": "Celiac ganglia — aggregations of ganglion cells communicating with the celiac plexus and lying to the right and left of the aorta by the celiac trunk", "e": "ganglia (Gk. ganglion: knot, swelling; plural) + coeliaca (Gk. koiliakos: of the belly)", "p": 358}, {"t": "Ganglia aorticorenalia", "m": "Aorticorenal ganglia — accumulations of ganglion cells at the exit of the renal artery", "e": "ganglia (Gk. ganglion: knot; plural) + aortico- (Gk. aortē: aorta) + renalia (L. renalis: of the kidney, from ren = kidney)", "p": 358}, {"t": "Ganglion mesentericum superius", "m": "Superior mesenteric ganglion — group of ganglion cells at the right and left of the aorta near the superior mesenteric artery", "e": "ganglion (Gk. ganglion: knot, swelling) + mesentericum (Gk. mesenterion: mesentery, from mesos = middle + enteron = intestine; adjective form) + superius (L. superius: upper, from super = above)", "p": 358}, {"t": "Plexus intermesentericus", "m": "Intermesenteric plexus — nerve plexus between the superior and inferior mesenteric plexuses", "e": "plexus (L. plexus: network) + inter- (L. inter: between) + mesentericus (Gk. mesenterion: mesentery; adjective form)", "p": 358}, {"t": "Ganglion mesentericum inferius", "m": "Inferior mesenteric ganglion — ganglion cells located entirely within the inferior mesenteric plexus", "e": "ganglion (Gk. ganglion: knot, swelling) + mesentericum (Gk. mesenterion: mesentery; adjective form) + inferius (L. inferius: lower, from inferus = below)", "p": 358}, {"t": "Ganglia phrenica", "m": "Phrenic ganglia — small accumulation of ganglion cells in the nerve plexus accompanying the inferior phrenic artery", "e": "ganglia (Gk. ganglion: knot; plural) + phrenica (Gk. phrenikos: of the diaphragm, from phrēn = diaphragm/mind)", "p": 358}, {"t": "Plexus hepaticus", "m": "Hepatic plexus — continuation of the celiac plexus at the liver with fibers from the vagus and phrenic nerves", "e": "plexus (L. plexus: network) + hepaticus (Gk. hēpatikos: of the liver, from hēpar = liver)", "p": 358}, {"t": "Plexus splenicus", "m": "Splenic (lienal) plexus — extensions of the celiac plexus along the splenic artery to the spleen", "e": "plexus (L. plexus: network) + splenicus (Gk. splēnikos: of the spleen, from splēn = spleen)", "p": 358}, {"t": "Plexus lienalis", "m": "Lienal (splenic) plexus — extensions of the celiac plexus along the splenic artery to the spleen", "e": "plexus (L. plexus: network) + lienalis (L. lienalis: of the spleen, from lien = spleen)", "p": 358}, {"t": "Plexus gastrici", "m": "Gastric plexus — autonomic nerve plexus for the stomach", "e": "plexus (L. plexus: network) + gastrici (Gk. gastrikos: of the stomach, from gastēr = stomach; genitive/plural form)", "p": 358}, {"t": "Plexus pancreaticus", "m": "Pancreatic plexus — continuation of the celiac plexus along the pancreatic vessels", "e": "plexus (L. plexus: network) + pancreaticus (Gk. pankreas: pancreas, from pan = all + kreas = flesh; adjective form)", "p": 358}, {"t": "Plexus suprarenalis", "m": "Suprarenal plexus — continuation of the celiac plexus along the suprarenal vessels with preganglionic fibers for the suprarenal medulla", "e": "plexus (L. plexus: network) + supra- (L. supra: above) + renalis (L. renalis: of the kidney, from ren = kidney)", "p": 358}, {"t": "Plexus renalis", "m": "Renal plexus — nerve plexus continued onto the renal artery; also contains vagal fibers", "e": "plexus (L. plexus: network) + renalis (L. renalis: of the kidney, from ren = kidney)", "p": 358}, {"t": "Ganglia renalia", "m": "Renal ganglia — microscopically small groups of ganglion cells dispersed within the renal plexus", "e": "ganglia (Gk. ganglion: knot; plural) + renalia (L. renalis: of the kidney, from ren = kidney; plural)", "p": 358}, {"t": "Plexus uretericus", "m": "Ureteric plexus — nerve plexus along the ureter with fibers from the renal and abdominal aortic plexuses and the aorticorenal ganglia", "e": "plexus (L. plexus: network) + uretericus (Gk. ourētēr: ureter, from ourein = to urinate; adjective form)", "p": 358}, {"t": "Plexus testicularis", "m": "Testicular plexus — nerve plexus along the testicular artery extending as far as the testis", "e": "plexus (L. plexus: network) + testicularis (L. testicularis: of the testis, from testiculus = small testis, diminutive of testis)", "p": 358}, {"t": "Plexus ovaricus", "m": "Ovarian plexus — autonomic nerve plexus along the ovarian artery with fibers from the abdominal aortic and renal plexuses", "e": "plexus (L. plexus: network) + ovaricus (L./Med.L. ovarium: ovary, from ovum = egg; adjective form)", "p": 358}, {"t": "Plexus mesentericus superior", "m": "Superior mesenteric plexus — nerve plexus accompanying the superior mesenteric artery and its branches", "e": "plexus (L. plexus: network) + mesentericus (Gk. mesenterion: mesentery, from mesos = middle + enteron = intestine; adjective form) + superior (L. superior: upper, from super = above)", "p": 358}, {"t": "Plexus mesentericus inferior", "m": "Inferior mesenteric plexus — continuation of the abdominal aortic plexus along the inferior mesenteric artery", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + mesentericus (Gk. mesenterikos: of the mesentery, from mesos = middle + enteron = intestine) + inferior (L. inferior: lower)", "p": 360}, {"t": "Plexus rectalis superior", "m": "Superior rectal plexus — continuation of the inferior mesenteric plexus on the superior rectal artery and rectum", "e": "plexus (L. plexus: network, braid) + rectalis (L. rectalis: of the rectum, from rectus = straight) + superior (L. superior: upper, higher)", "p": 360}, {"t": "Plexus entericus", "m": "Enteric plexus — collective term for the autonomic plexuses in the wall of the intestinal tract", "e": "plexus (L. plexus: network, braid) + entericus (Gk. enterikos: of the intestine, from enteron = intestine)", "p": 360}, {"t": "Plexus subserosus", "m": "Subserosal plexus — fine autonomic plexus located directly beneath the serosa", "e": "plexus (L. plexus: network, braid) + subserosus (L. sub = under + serosus: of the serous membrane, from serum = watery fluid)", "p": 360}, {"t": "Plexus myentericus", "m": "Myenteric (Auerbach's) plexus — prominent plexus situated between the longitudinal and circular muscle layers", "e": "plexus (L. plexus: network, braid) + myentericus (Gk. mys = muscle + enteron = intestine: of the muscular intestinal layer)", "p": 360}, {"t": "Plexus submucosus", "m": "Submucosal (Meissner's) plexus — prominent plexus occupying the submucosa", "e": "plexus (L. plexus: network, braid) + submucosus (L. sub = under + mucosus: of mucus, from mucus = slime)", "p": 360}, {"t": "Plexus iliaci", "m": "Iliac plexus — continuation of the abdominal aortic plexus onto both iliac arteries", "e": "plexus (L. plexus: network, braid) + iliaci (L. iliacus: of the ilium/flank, from ilia = flanks, groin)", "p": 360}, {"t": "Plexus femoralis", "m": "Femoral plexus — continuation of the iliac plexus onto the femoral artery", "e": "plexus (L. plexus: network, braid) + femoralis (L. femoralis: of the femur/thigh, from femur = thigh)", "p": 360}, {"t": "PARS PELVICA AUTONOMICA", "m": "Pelvic part of the autonomic nervous system", "e": "pars (L. pars: part, portion) + pelvica (L. pelvicus: of the pelvis, from pelvis = basin) + autonomica (Gk. autonomikos: self-governing, from autos = self + nomos = law)", "p": 360}, {"t": "Plexus hypogastricus superior", "m": "Superior hypogastric plexus (presacral nerve) — plexus-like connection between the abdominal aortic and inferior hypogastric plexuses", "e": "plexus (L. plexus: network, braid) + hypogastricus (Gk. hypogastrikos: below the stomach, from hypo = under + gaster = stomach/belly) + superior (L. superior: upper, higher)", "p": 360}, {"t": "n. praesacralis", "m": "Presacral nerve — alternative name for the superior hypogastric plexus", "e": "n. (abbreviation of nervus: L. nervus = nerve, sinew) + praesacralis (L. prae = before/in front of + sacralis: of the sacrum, from sacer = sacred, holy)", "p": 360}, {"t": "N. hypogastricus dexter/sinister", "m": "Right/left hypogastric nerve — right and left branches of the superior hypogastric plexus to the pelvic viscera", "e": "N. (abbreviation of nervus: L. nervus = nerve) + hypogastricus (Gk. hypo = under + gaster = belly) + dexter (L. dexter: right) + sinister (L. sinister: left)", "p": 360}, {"t": "Plexus hypogastricus inferior", "m": "Inferior hypogastric plexus (pelvic plexus) — network of sympathetic and parasympathetic fibers located to the right and left of the rectum", "e": "plexus (L. plexus: network, braid) + hypogastricus (Gk. hypo = under + gaster = belly) + inferior (L. inferior: lower)", "p": 360}, {"t": "plexus pelvicus", "m": "Pelvic plexus — alternative name for the inferior hypogastric plexus", "e": "plexus (L. plexus: network, braid) + pelvicus (L. pelvicus: of the pelvis, from pelvis = basin)", "p": 360}, {"t": "Plexus rectalis medius", "m": "Middle rectal plexus — continuation of the inferior hypogastric plexus onto the wall of the rectum", "e": "plexus (L. plexus: network, braid) + rectalis (L. rectalis: of the rectum, from rectus = straight) + medius (L. medius: middle)", "p": 360}, {"t": "Plexus rectalis inferior", "m": "Inferior rectal plexus — autonomic nerve plexus located around branches of the internal iliac artery passing to both sides of the rectum", "e": "plexus (L. plexus: network, braid) + rectalis (L. rectalis: of the rectum, from rectus = straight) + inferior (L. inferior: lower)", "p": 360}, {"t": "Plexus prostaticus", "m": "Prostatic plexus — nerve plexus mainly located at the posterior and inferior surfaces of the prostate", "e": "plexus (L. plexus: network, braid) + prostaticus (Gk. prostatikos: of the prostate, from prostates = one who stands before, from pro = before + histanai = to stand)", "p": 360}, {"t": "Plexus deferentialis", "m": "Deferential plexus — nerve plexus around the ductus deferens", "e": "plexus (L. plexus: network, braid) + deferentialis (L. deferentialis: of the ductus deferens, from deferens = carrying away, from de = down/away + ferre = to carry)", "p": 360}, {"t": "Plexus uterovaginalis", "m": "Uterovaginal plexus — nerve plexus occupying the parametrium and infiltrated with many ganglia", "e": "plexus (L. plexus: network, braid) + uterovaginalis (L. uterus = womb + vagina = sheath + -alis = pertaining to)", "p": 360}, {"t": "Nervi vaginales", "m": "Vaginal nerves — branches of the uterovaginal plexus passing to the vagina", "e": "nervi (L. nervus: nerve, plural nervi) + vaginales (L. vaginalis: of the vagina, from vagina = sheath)", "p": 360}, {"t": "Plexus vesicalis", "m": "Vesical plexus — plexus situated on both sides of the urinary bladder containing parasympathetic fibers", "e": "plexus (L. plexus: network, braid) + vesicalis (L. vesicalis: of the bladder, from vesica = bladder, blister)", "p": 360}, {"t": "Nn. cavernosi penis", "m": "Cavernous nerves of penis — rami from the prostatic plexus to the cavernous bodies of the penis", "e": "Nn. (abbreviation of nervi: L. nervus = nerve, plural) + cavernosi (L. cavernosus: full of caverns, from caverna = cave, hollow) + penis (L. penis: tail, penis)", "p": 360}, {"t": "Nn. cavernosi clitoridis", "m": "Cavernous nerves of clitoris — nerves corresponding to the cavernous nerves of the penis", "e": "Nn. (abbreviation of nervi: L. nervus = nerve, plural) + cavernosi (L. cavernosus: full of caverns, from caverna = cave) + clitoridis (Gk. kleitoris: genitive of clitoris, from kleiein = to close)", "p": 360}, {"t": "Pars sympathetica", "m": "Sympathetic part (system) — thoracolumbar part of the autonomic nervous system represented in the sympathetic trunk", "e": "pars (L. pars: part, portion) + sympathetica (Gk. sympathetikos: feeling together, from syn = together + pathos = feeling, suffering)", "p": 360}, {"t": "Truncus sympatheticus", "m": "Sympathetic trunk — chain of ganglia connected by nerve fibers lying to the right and left of the vertebral column", "e": "truncus (L. truncus: trunk, stem) + sympatheticus (Gk. sympathetikos: feeling together, from syn = together + pathos = feeling)", "p": 360}, {"t": "Ganglia trunci sympathetici", "m": "Ganglia of sympathetic trunk — groups of small, mostly multipolar ganglion cells producing macroscopic thickenings", "e": "ganglia (Gk. ganglion: knot, swelling, plural ganglia) + trunci (L. truncus: trunk, genitive trunci) + sympathetici (Gk. sympathetikos: feeling together, from syn = together + pathos = feeling)", "p": 360}, {"t": "Rami interganglionares", "m": "Interganglionic branches — bundles of white and gray fibers linking the sympathetic ganglia", "e": "rami (L. ramus: branch, plural rami) + interganglionares (L. inter = between + ganglion: Gk. knot/swelling, from ganglia + -ares = pertaining to)", "p": 360}, {"t": "Ganglia intermedia", "m": "Intermediate ganglia — additional accumulations of sympathetic ganglion cells mainly in the rami communicantes of the cervical and lumbar regions", "e": "ganglia (Gk. ganglion: knot, swelling, plural) + intermedia (L. intermedius: in between, from inter = between + medius = middle)", "p": 360}, {"t": "Ganglion cervicale superius", "m": "Superior cervical ganglion — uppermost sympathetic trunk ganglion, about 2.5 cm long and lying 2 cm below the base of the skull", "e": "ganglion (Gk. ganglion: knot, swelling) + cervicale (L. cervicalis: of the neck, from cervix = neck) + superius (L. superius: upper, higher, from super = above)", "p": 360}, {"t": "N. jugularis", "m": "Jugular nerve — branch to the inferior ganglion of the glossopharyngeal nerve and to the superior ganglion of the vagus", "e": "N. (abbreviation of nervus: L. nervus = nerve) + jugularis (L. jugularis: of the throat/jugular, from jugulum = throat, collarbone, from jugum = yoke)", "p": 360}, {"t": "N. caroticus internus", "m": "Internal carotid nerve — contains postganglionic fibers and forms the internal carotid plexus in the carotid canal", "e": "N. (abbreviation of nervus: L. nervus = nerve) + caroticus (Gk. karotikos: of the carotid, from karos = deep sleep, as pressure causes unconsciousness) + internus (L. internus: internal, from inter = within)", "p": 360}, {"t": "Plexus caroticus internus", "m": "Internal carotid plexus — nerve plexus in the carotid canal giving rise to the deep petrosal nerve and branches to the inner ear", "e": "plexus (L. plexus: network, braid) + caroticus (Gk. karotikos: of the carotid) + internus (L. internus: internal, from inter = within)", "p": 360}, {"t": "Nn. carotici externi", "m": "External carotid nerves — nerves for the external carotid plexus descending along the external carotid artery", "e": "Nn. (abbreviation of nervi: L. nervus = nerve, plural) + carotici (Gk. karotikos: of the carotid) + externi (L. externus: external, outside, from exter = outward)", "p": 360}, {"t": "ductus deferens", "m": "Ductus deferens — structure around which the deferential plexus is located", "e": "ductus (L. ductus: duct, channel, from ducere = to lead) + deferens (L. deferens: carrying away, from de = down/away + ferre = to carry)", "p": 360}, {"t": "Plexus caroticus externus", "m": "External carotid plexus — autonomic nerve plexus around the external carotid artery", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + caroticus (Gk. karōtikos: of the carotid, from karoun = to stupefy) + externus (L. externus: external, outer)", "p": 362}, {"t": "Plexus caroticus communis", "m": "Common carotid plexus — surrounds the common carotid artery", "e": "plexus (L. plexus: network, braid) + caroticus (Gk. karōtikos: of the carotid) + communis (L. communis: common, shared)", "p": 362}, {"t": "Rami laryngopharyngeales", "m": "Laryngopharyngeal branches — postganglionic fibers to the pharyngeal plexus", "e": "rami (L. ramus: branch) + laryngopharyngeales (Gk. larynx = larynx + pharynx = throat + L. -ales = pertaining to)", "p": 362}, {"t": "N. cardiacus cervicalis superior", "m": "Superior cervical cardiac nerve", "e": "N. = nervus (L. nervus: nerve, sinew) + cardiacus (Gk. kardiakos: of the heart, from kardia = heart) + cervicalis (L. cervicalis: of the neck, from cervix = neck) + superior (L. superior: upper, higher)", "p": 362}, {"t": "Ganglion cervicale medium", "m": "Middle cervical ganglion — often very small ganglion of the sympathetic trunk at the level of C6", "e": "ganglion (Gk. ganglion: knot, swelling) + cervicale (L. cervicalis: of the neck) + medium (L. medius: middle)", "p": 362}, {"t": "Ganglion vertebrale", "m": "Vertebral ganglion — small accessory ganglion usually on the vertebral artery in front of its entrance into the foramen transversarium", "e": "ganglion (Gk. ganglion: knot, swelling) + vertebrale (L. vertebralis: of the vertebra, from vertere = to turn)", "p": 362}, {"t": "N. cardiacus cervicalis medius", "m": "Middle cervical cardiac nerve — passes from the middle cervical ganglion to the deep part of the cardiac plexus", "e": "N. = nervus (L. nervus: nerve) + cardiacus (Gk. kardiakos: of the heart) + cervicalis (L. cervicalis: of the neck) + medius (L. medius: middle)", "p": 362}, {"t": "Ganglion cervicothoracicum (stellatum)", "m": "Cervicothoracic (stellate) ganglion — fusion of the inferior cervical ganglion with the 1st or 2nd thoracic ganglion", "e": "ganglion (Gk. ganglion: knot) + cervicothoracicum (L. cervix = neck + Gk. thorax = chest) + stellatum (L. stellatus: star-shaped, from stella = star)", "p": 362}, {"t": "Ansa subclavia", "m": "Ansa subclavia — cord of nerve fibers forming a loop around the subclavian artery", "e": "ansa (L. ansa: handle, loop) + subclavia (L. sub = under + clavicula = little key, collarbone)", "p": 362}, {"t": "N. cardiacus cervicalis inferior", "m": "Inferior cervical cardiac nerve — passes to the deep part of the cardiac plexus", "e": "N. = nervus (L. nervus: nerve) + cardiacus (Gk. kardiakos: of the heart) + cervicalis (L. cervicalis: of the neck) + inferior (L. inferior: lower)", "p": 362}, {"t": "Plexus subclavius", "m": "Subclavian plexus — autonomic nerve plexus around the subclavian artery", "e": "plexus (L. plexus: network, braid) + subclavius (L. sub = under + clavicula = collarbone)", "p": 362}, {"t": "N. vertebralis", "m": "Vertebral nerve — located behind the vertebral artery; forms the vertebral plexus", "e": "N. = nervus (L. nervus: nerve) + vertebralis (L. vertebralis: of the vertebra, from vertere = to turn)", "p": 362}, {"t": "Plexus vertebralis", "m": "Vertebral plexus — network of nerves around the vertebral artery", "e": "plexus (L. plexus: network, braid) + vertebralis (L. vertebralis: of the vertebra, from vertere = to turn)", "p": 362}, {"t": "Ganglia thoracica", "m": "Thoracic ganglia — 11–12 thickenings in the thoracic sympathetic trunk", "e": "ganglia (Gk. ganglion: knot, swelling, plural ganglia) + thoracica (Gk. thorax: chest, breastplate)", "p": 362}, {"t": "Rami pulmonales thoracici", "m": "Thoracic pulmonary branches — efferent fibers from T2–4 ganglia to the pulmonary plexus at the lung hilum", "e": "rami (L. ramus: branch) + pulmonales (L. pulmonalis: of the lung, from pulmo = lung) + thoracici (Gk. thorax: chest)", "p": 362}, {"t": "N. splanchnicus major", "m": "Greater splanchnic nerve — passes from sympathetic trunk ganglia 5–9(10) to the celiac ganglion", "e": "N. = nervus (L. nervus: nerve) + splanchnicus (Gk. splanchnikos: of the viscera, from splanchna = viscera) + major (L. major: greater, larger)", "p": 362}, {"t": "Ganglion thoracicum splanchnicum", "m": "Thoracic splanchnic ganglion — accessory ganglion at the level of T9 incorporated into the greater splanchnic nerve", "e": "ganglion (Gk. ganglion: knot) + thoracicum (Gk. thorax: chest) + splanchnicum (Gk. splanchnikos: of the viscera)", "p": 362}, {"t": "N. splanchnicus minor", "m": "Lesser splanchnic nerve — arises from sympathetic trunk ganglia 9–11", "e": "N. = nervus (L. nervus: nerve) + splanchnicus (Gk. splanchnikos: of the viscera) + minor (L. minor: lesser, smaller)", "p": 362}, {"t": "Ramus renalis", "m": "Renal branch — occasional branch from the lesser splanchnic nerve to the renal plexus", "e": "ramus (L. ramus: branch) + renalis (L. renalis: of the kidney, from ren = kidney)", "p": 362}, {"t": "N. splanchnicus imus", "m": "Lowest splanchnic nerve — often arises independently from the T12 ganglion and passes to the renal plexus", "e": "N. = nervus (L. nervus: nerve) + splanchnicus (Gk. splanchnikos: of the viscera) + imus (L. imus: lowest, deepest)", "p": 362}, {"t": "Ganglia lumbalia (lumbaria)", "m": "Lumbar ganglia — sympathetic ganglia of the lumbar vertebral column, usually four on either side", "e": "ganglia (Gk. ganglion: knot, swelling, plural) + lumbalia (L. lumbalis: of the loins, from lumbus = loin) + lumbaria (L. lumbaris: of the loins)", "p": 362}, {"t": "Nervi splanchnici lumbales (lumbares)", "m": "Lumber splanchnic nerves — usually four nerves from the lumbar sympathetic trunk forming a plexus on L5", "e": "nervi (L. nervus: nerve, plural nervi) + splanchnici (Gk. splanchnikos: of the viscera) + lumbales (L. lumbalis: of the loins) + lumbares (L. lumbaris: of the loins)", "p": 362}, {"t": "Ganglia sacralia", "m": "Sacral ganglia — four smaller ganglia lying medial to the pelvis sacral foramina", "e": "ganglia (Gk. ganglion: knot, swelling) + sacralia (L. sacralis: of the sacrum, from sacer = sacred)", "p": 362}, {"t": "Nervi splanchnici sacrales", "m": "Sacral splanchnic nerves — two to three fine nerves from sacral ganglia 2–4", "e": "nervi (L. nervus: nerve) + splanchnici (Gk. splanchnikos: of the viscera) + sacrales (L. sacralis: of the sacrum)", "p": 362}, {"t": "Ganglion impar", "m": "Ganglion impar — last unpaired sympathetic trunk ganglion lying in front of the coccyx", "e": "ganglion (Gk. ganglion: knot, swelling) + impar (L. impar: unequal, unpaired, from in = not + par = equal)", "p": 362}, {"t": "Pars parasympathetica", "m": "Parasympathetic part (system) — craniosacral component of the autonomic nervous system", "e": "pars (L. pars: part) + parasympathetica (Gk. para = beside + sympathetikos: sympathetic, from syn = together + pathos = feeling)", "p": 362}, {"t": "Pars cranialis", "m": "Cranial part", "e": "pars (L. pars: part) + cranialis (Gk. kranion: skull, cranium + L. -alis = pertaining to)", "p": 362}, {"t": "N. terminalis", "m": "Terminal nerve — slender, partly interwoven nerve of unknown function, but probably autonomic", "e": "N. = nervus (L. nervus: nerve) + terminalis (L. terminalis: of the boundary, end, from terminus = end, boundary)", "p": 362}, {"t": "Ganglion terminale", "m": "Terminal ganglion — comprises all of the ganglion cells dispersed in the terminal nerves", "e": "ganglion (Gk. ganglion: knot) + terminale (L. terminalis: of the end, from terminus = end)", "p": 362}, {"t": "Nn. pelvici splanchnici (nn. erigentes)", "m": "Pelvic splanchnic nerves — parasympathetic fibers from S2–4 spinal nerves to the pelvic ganglia for the pelvic and genital organs", "e": "Nn. = nervi (L. nervus: nerve, plural) + pelvici (L. pelvis: basin) + splanchnici (Gk. splanchnikos: of the viscera) + erigentes (L. erigens: erecting, from erigere = to erect, raise up)", "p": 362}, {"t": "Ganglia pelvica", "m": "Pelvic ganglia — groups of autonomic cells in the inferior hypogastric plexus giving rise to postganglionic axons", "e": "ganglia (Gk. ganglion: knot, plural) + pelvica (L. pelvis: basin)", "p": 362}, {"t": "Truncus sympathicus cervicalis", "m": "Cervical sympathetic trunk", "e": "truncus (L. truncus: trunk, main stem) + sympathicus (Gk. sympathētikos: feeling together, from syn = together + pathos = feeling) + cervicalis (L. cervicālis: of the neck, from cervix = neck)", "p": 363}, {"t": "Truncus sympathicus lumbosacralis", "m": "Lumbosacral sympathetic trunk", "e": "truncus (L. truncus: trunk, main stem) + sympathicus (Gk. sympathētikos: feeling together, from syn = together + pathos = feeling) + lumbosacralis (L. lumbosacrālis: of the lumbar and sacral regions, from lumbus = loin + sacer = sacred, holy — referring to the sacrum)", "p": 363}, {"t": "Nervi terminales", "m": "Terminal nerves", "e": "nervi (L. nervus: nerve, sinew) + terminales (L. terminālis: of the end, from terminus = boundary, end)", "p": 363}, {"t": "Ganglia autonomica capitis", "m": "Autonomic ganglia of the head", "e": "ganglia (Gk. ganglion: knot, swelling under the skin) + autonomica (Gk. autonomikos: self-governing, from autos = self + nomos = law) + capitis (L. caput/capitis: of the head)", "p": 363}, {"t": "Nervi splanchnici", "m": "Splanchnic nerves", "e": "nervi (L. nervus: nerve, sinew) + splanchnici (Gk. splanchnikos: of the viscera, from splanchna = entrails, viscera)", "p": 363}, {"t": "Organa sensoria", "m": "Sense organs", "e": "organa (L. organum, from Gk. organon: instrument, organ) + sensoria (L. sensorius: of sensation, from sentire = to feel/perceive)", "p": 364}, {"t": "sensuum", "m": "of the senses", "e": "sensuum (L. sensus, gen. pl.: of the senses, from sentire = to feel)", "p": 364}, {"t": "Organum visus", "m": "Organ of vision", "e": "organum (L. organum, from Gk. organon: instrument, organ) + visus (L. visus: sight, vision, from videre = to see)", "p": 364}, {"t": "Organum visuale", "m": "Visual organ", "e": "organum (L. organum, from Gk. organon: instrument, organ) + visuale (L. visualis: of sight, from visus = vision)", "p": 364}, {"t": "Oculus", "m": "Eye", "e": "oculus (L. oculus: eye, related to Gk. ops = eye)", "p": 364}, {"t": "Pars intracranialis", "m": "Intracranial part — segment of the optic nerve between the optic canal and the chiasm", "e": "pars (L. pars: part) + intracranialis (L. intra: within + cranialis: of the skull, from Gk. kranion = skull)", "p": 364}, {"t": "Pars intracanicularis", "m": "Intracanalicular part — segment of the optic nerve located in the optic canal", "e": "pars (L. pars: part) + intracanicularis (L. intra: within + canalicularis: of a small canal, from canalis = channel)", "p": 364}, {"t": "Pars intraocularis", "m": "Intraocular part — segment of optic nerve located in the wall of the eyeball", "e": "pars (L. pars: part) + intraocularis (L. intra: within + ocularis: of the eye, from oculus = eye)", "p": 364}, {"t": "Pars postlaminaris", "m": "Postlaminar part — intraocular segment located behind the lamina cribrosa", "e": "pars (L. pars: part) + postlaminaris (L. post: behind/after + laminaris: of a layer, from lamina = thin plate/layer)", "p": 364}, {"t": "Pars intralaminaris", "m": "Intralaminar part — intraocular segment lying within the lamina cribrosa", "e": "pars (L. pars: part) + intralaminaris (L. intra: within + laminaris: of a layer, from lamina = thin plate)", "p": 364}, {"t": "Pars preliminaris", "m": "Prelaminar part — intraocular segment extending between the lamina cribrosa and the nerve fiber layer of the retina", "e": "pars (L. pars: part) + preliminaris (L. pre: before + laminaris: of a layer, from lamina = thin plate)", "p": 364}, {"t": "Vagina externa", "m": "External sheath — dural covering of the optic nerve extending up to the eyeball", "e": "vagina (L. vagina: sheath, scabbard) + externa (L. externus: outer, external)", "p": 364}, {"t": "Vagina interna", "m": "Internal sheath — pia and arachnoid coverings accompanying the optic nerve to the eyeball", "e": "vagina (L. vagina: sheath, scabbard) + interna (L. internus: inner, internal)", "p": 364}, {"t": "Spatia intervaginalia", "m": "Intervaginal spaces — subarachnoid space accompanying the optic nerve and the capillary space between the arachnoid and dura", "e": "spatia (L. spatium, pl. spatia: space, interval) + intervaginalia (L. inter: between + vaginalia: of sheaths, from vagina = sheath)", "p": 364}, {"t": "Bulbus oculi", "m": "Eyeball — globe of the eye consisting of the cornea and sclera together with all the structures they enclose", "e": "bulbus (L. bulbus, from Gk. bolbos: bulb, rounded structure) + oculi (L. oculus, gen.: of the eye)", "p": 364}, {"t": "Polus anterior", "m": "Anterior pole — center of anterior curvature of the eyeball, determined by the corneal vertex", "e": "polus (L. polus, from Gk. polos: pole, axis end) + anterior (L. anterior: more in front, former, from ante = before)", "p": 364}, {"t": "Polus posterior", "m": "Posterior pole — center of posterior curvature of the eyeball, lies lateral to the exit of the optic nerve", "e": "polus (L. polus, from Gk. polos: pole, axis end) + posterior (L. posterior: more behind, later, from post = after/behind)", "p": 364}, {"t": "Aequator", "m": "Equator — greatest circumference of the eyeball located equidistant from the anterior and posterior poles", "e": "aequator (L. aequator: one who equalizes, from aequare = to make equal, from aequus = equal)", "p": 364}, {"t": "Meridiani", "m": "Meridians — semicircles oriented at right angles to the equator between the anterior and posterior poles", "e": "meridiani (L. meridianus, pl.: of midday/meridian, from medius = middle + dies = day; used for lines like meridians)", "p": 364}, {"t": "Axis bulbi externus", "m": "External axis of eyeball — line connecting anterior and posterior poles", "e": "axis (L. axis: axle, axis) + bulbi (L. bulbus, gen.: of the bulb/eyeball) + externus (L. externus: outer, external)", "p": 364}, {"t": "Axis bulbi internus", "m": "Internal axis of eyeball — distance from posterior surface of cornea to the inner surface of retina measured along an imaginary line through the anterior and posterior poles", "e": "axis (L. axis: axle, axis) + bulbi (L. bulbus, gen.: of the bulb/eyeball) + internus (L. internus: inner, internal)", "p": 364}, {"t": "Axis opticus", "m": "Optic axis — line passing through the midline of the cornea and lens and bisecting the retina between the fovea centralis and optic disc", "e": "axis (L. axis: axle, axis) + opticus (L. opticus, from Gk. optikos: of sight, from ops = eye)", "p": 364}, {"t": "Tunica fibrosa bulbi", "m": "Fibrous tunic of eyeball — external wall of eyeball comprising the cornea and sclera", "e": "tunica (L. tunica: tunic, coat, covering layer) + fibrosa (L. fibrosus: fibrous, from fibra = fiber) + bulbi (L. bulbus, gen.: of the bulb/eyeball)", "p": 364}, {"t": "Sclera", "m": "Sclera — the bluish-white outer coat of the eyeball consisting of irregularly arranged collagenous fibers visible through the conjunctiva", "e": "sclera (Gk. skleros: hard; L. sclera: hard outer coat of the eye)", "p": 364}, {"t": "Sulcus sclerae", "m": "Scleral sulcus — shallow groove between the cornea and sclera caused by the greater curvature of the cornea", "e": "sulcus (L. sulcus: groove, furrow) + sclerae (Gk./L. sclera, gen.: of the sclera/hard coat)", "p": 364}, {"t": "Limbus", "m": "Corneoscleral junction — the concave border of the sclera adjacent to the cornea", "e": "limbus (L. limbus: border, edge, hem)", "p": 364}, {"t": "Reticulum trabeculare", "m": "Trabecular meshwork (pectinate ligament) — connective tissue framework at the iridocorneal (filtration) angle", "e": "reticulum (L. reticulum: small net, from rete = net) + trabeculare (L. trabecularis: of small beams, from trabecula = small beam, from trabs = beam)", "p": 364}, {"t": "lig. pectinatum", "m": "Pectinate ligament — part of the trabecular meshwork", "e": "lig. = ligamentum (L. ligamentum: band, ligament, from ligare = to bind) + pectinatum (L. pectinatus: comb-like, from pecten = comb)", "p": 364}, {"t": "spongium iridocorneale", "m": "Spongium iridocorneale — connective tissue framework at the iridocorneal angle", "e": "spongium (L./Gk. spongium, from Gk. spongos: sponge) + iridocorneale (L. iridocornealis: of the iris and cornea, from Gk. iris = rainbow/iris + L. cornea = horn-like)", "p": 364}, {"t": "Pars corneoscleralis", "m": "Corneoscleral part — part of the meshwork attached to the sclera", "e": "pars (L. pars: part) + corneoscleralis (L. corneoscleralis: of the cornea and sclera, from cornea = horn-like + Gk. skleros = hard)", "p": 364}, {"t": "Pars uvealis", "m": "Uveal part — part of the trabecular meshwork attached to the iris", "e": "pars (L. pars: part) + uvealis (L. uvealis: of the uvea, from uva = grape; the uvea resembles a grape in appearance)", "p": 364}, {"t": "Sinus venosus sclerae", "m": "Canal of Schlemm — circular vessel occupying the interior aspect of the trabecular meshwork", "e": "sinus (L. sinus: bay, hollow, channel) + venosus (L. venosus: venous, full of veins, from vena = vein) + sclerae (Gk./L. sclera, gen.: of the sclera)", "p": 364}, {"t": "Lamina episcleralis", "m": "Episclera — delicate displaceable connective tissue between the outer surface of the sclera and Tenon's capsule", "e": "lamina (L. lamina: thin plate, layer) + episcleralis (Gk. epi: upon/over + L. sclera: hard coat; thus: upon the sclera)", "p": 364}, {"t": "Substantia propria sclerae", "m": "Corneal stroma — the proper substance, i.e., main part of the sclera consisting of irregularly arranged collagenous fibers with sparse elastic fibers", "e": "substantia (L. substantia: substance, matter, from sub = under + stare = to stand) + propria (L. proprius: own, proper, characteristic) + sclerae (Gk./L. sclera, gen.: of the sclera)", "p": 364}, {"t": "Lamina fusca sclerae", "m": "Lamina fusca sclerae — layer of loose connective tissue connecting the sclera and the choroid lying below it, appearing yellowish owing to pigment cells", "e": "lamina (L. lamina: thin plate, layer) + fusca (L. fuscus: dark, dusky, brownish) + sclerae (Gk./L. sclera, gen.: of the sclera)", "p": 364}, {"t": "Anulus conjunctivae", "m": "Conjunctival ring — junction between bulbar conjunctival epithelium and the anterior epithelium of the cornea", "e": "anulus (L. anulus: ring) + conjunctivae (L. conjunctiva: connecting, from conjungere = to join together)", "p": 366}, {"t": "Limbus corneae", "m": "Corneoscleral junction", "e": "limbus (L. limbus: border, edge) + corneae (L. cornea: horny, from cornu = horn)", "p": 366}, {"t": "Epithelium anterius", "m": "Anterior epithelium — stratified squamous epithelium covering the anterior surface of the cornea", "e": "epithelium (Gk. epi: upon + thele: nipple, surface layer) + anterius (L. anterius: anterior, neuter of anterior)", "p": 366}, {"t": "Lamina limitans anterior", "m": "Anterior limiting (Bowman's) membrane — basal membrane of the anterior epithelium", "e": "lamina (L. lamina: thin plate, layer) + limitans (L. limitans: limiting, from limitare = to limit) + anterior (L. anterior: in front)", "p": 366}, {"t": "Lamina limitans posterior", "m": "Posterior limiting (Descemet's) membrane — basal membrane of the corneal posterior endothelium", "e": "lamina (L. lamina: thin plate, layer) + limitans (L. limitans: limiting, from limitare = to limit) + posterior (L. posterior: behind)", "p": 366}, {"t": "Epithelium posterius", "m": "Posterior epithelium (endothelium) — simple squamous epithelium lining the posterior surface of the cornea", "e": "epithelium (Gk. epi: upon + thele: surface layer) + posterius (L. posterius: posterior, neuter of posterior)", "p": 366}, {"t": "Tunica vasculosa bulbi", "m": "Vascular tunic of eyeball (uveal tract) — middle layer of the wall of the eyeball consisting of the choroid, ciliary body and iris", "e": "tunica (L. tunica: coat, covering) + vasculosa (L. vasculosus: full of vessels, from vasculum = small vessel) + bulbi (L. bulbus: bulb, globe, from Gk. bolbos = bulb)", "p": 366}, {"t": "Tractus uvealis", "m": "Uveal tract — the middle layer of the wall of the eyeball", "e": "tractus (L. tractus: tract, from trahere = to draw) + uvealis (L. uvealis: of the uvea, from uva = grape, referring to the uvea's grape-like appearance)", "p": 366}, {"t": "Choroidea", "m": "Choroid — the vascular coat lying between the retina and sclera", "e": "choroidea (Gk. chorion: membrane + eidos: resembling, form)", "p": 366}, {"t": "Lamina suprachoroidea", "m": "Suprachoroid lamina (lamina fusca) — displaceable layer directly beneath the sclera", "e": "lamina (L. lamina: thin plate, layer) + supra (L. supra: above) + choroidea (Gk. chorion: membrane + eidos: form)", "p": 366}, {"t": "Spatium perichoroideale", "m": "Perichoroidal space — spatial system in the suprachoroid lamina housing lymph pathways, ciliary nerves and vessels", "e": "spatium (L. spatium: space) + peri (Gk. peri: around) + choroideale (Gk. chorion: membrane + eidos: form)", "p": 366}, {"t": "Lamina vasculosa", "m": "Vascular lamina — contains the branchings of the short posterior ciliary arteries", "e": "lamina (L. lamina: thin plate, layer) + vasculosa (L. vasculosus: full of vessels, from vasculum = small vessel)", "p": 366}, {"t": "Lamina choroidocapillaris", "m": "Choriocapillaris — pigment-free layer of connective tissue with a dense network of capillaries extending as far as the ora serrata", "e": "lamina (L. lamina: thin plate, layer) + choroido (Gk. chorion: membrane + eidos: form) + capillaris (L. capillaris: hair-like, from capillus = hair)", "p": 366}, {"t": "Complexus basalis", "m": "Basal lamina (Bruch's membrane) — homogeneous zone about 2–4 mm thick between the choriocapillaris and pigment epithelium of the retina", "e": "complexus (L. complexus: embrace, combination, from complecti = to encompass) + basalis (L. basalis: basal, from basis = base, from Gk. basis = step, base)", "p": 366}, {"t": "Corpus ciliare", "m": "Ciliary body — enlarged uveal segment situated between the ora serrata and root of the iris", "e": "corpus (L. corpus: body) + ciliare (L. ciliare: of the cilia/eyelashes, from cilium = eyelid, eyelash)", "p": 366}, {"t": "Corona ciliaris", "m": "Pars plicata — circular zone occupied by ciliary processes", "e": "corona (L. corona: crown, from Gk. korone = crown) + ciliaris (L. ciliaris: of the cilia, from cilium = eyelid)", "p": 366}, {"t": "Processus ciliares", "m": "Ciliary processes — 70–80 radially oriented, capillary-rich folds whose epithelium produces aqueous humor", "e": "processus (L. processus: projection, going forward, from procedere = to go forward) + ciliares (L. ciliares: of the cilia, from cilium = eyelid)", "p": 366}, {"t": "Plicate ciliares", "m": "Ciliary folds — low folds in the region of the corona ciliaris and between the ciliary processes", "e": "plicate (L. plicatae: folds, from plicare = to fold) + ciliares (L. ciliares: of the cilia, from cilium = eyelid)", "p": 366}, {"t": "Orbiculus ciliaris", "m": "Pars plana — circular zone lying between the corona and ora serrata, occupied by ciliary folds", "e": "orbiculus (L. orbiculus: small circle, from orbis = circle) + ciliaris (L. ciliaris: of the cilia, from cilium = eyelid)", "p": 366}, {"t": "M. ciliaris", "m": "Ciliary muscle — smooth muscle occupying the ciliary body that pulls the choroid forward and relaxes the zonule fibers", "e": "M. (L. musculus: muscle, from mus = mouse, referring to muscle's shape) + ciliaris (L. ciliaris: of the cilia, from cilium = eyelid)", "p": 366}, {"t": "Fibrae meridionales", "m": "Meridional (longitudinal) fibers — larger muscle fibers oriented meridionally, attached anteriorly to the posterior limiting lamina and inserting into the choroid posteriorly", "e": "fibrae (L. fibra: fiber, thread) + meridionales (L. meridionalis: meridional, from meridies = midday, south, referring to a meridian line)", "p": 366}, {"t": "Fibrae longitudinales", "m": "Longitudinal fibers — larger muscle fibers oriented longitudinally (meridionally)", "e": "fibrae (L. fibra: fiber, thread) + longitudinales (L. longitudinalis: longitudinal, from longitudo = length, from longus = long)", "p": 366}, {"t": "Fibrae circulares", "m": "Circular fibers — circular muscle lying internal to the meridional fibers", "e": "fibrae (L. fibra: fiber, thread) + circulares (L. circularis: circular, from circulus = circle)", "p": 366}, {"t": "Fibrae radiales", "m": "Radial fibers — muscle fibers crossing perpendicular to the two other muscle systems and coursing outwardly", "e": "fibrae (L. fibra: fiber, thread) + radiales (L. radialis: radial, from radius = ray, spoke)", "p": 366}, {"t": "Lamina basalis", "m": "Basal lamina — continuation of the basal membrane of the choroid, supports the epithelium", "e": "lamina (L. lamina: thin plate, layer) + basalis (L. basalis: basal, from basis = base, from Gk. basis = step, base)", "p": 366}, {"t": "Margo pupillaris", "m": "Pupillary margin — medial (internal) margin of the iris bordering the pupil", "e": "margo (L. margo: edge, border, margin) + pupillaris (L. pupillaris: of the pupil, from pupilla = pupil of the eye, diminutive of pupa = girl, doll)", "p": 368}, {"t": "Margo ciliaris", "m": "Ciliary margin — lateral (external) margin of iris attached to ciliary body at the iridocorneal angle", "e": "margo (L. margo: edge, border, margin) + ciliaris (L. ciliaris: of the eyelash/ciliary body, from cilium = eyelid, eyelash)", "p": 368}, {"t": "Anulus iridis major", "m": "Greater ring (circle) of iris — ciliary segment of the iris and outer circular zone on the anterior surface of the iris", "e": "anulus (L. anulus: ring, small ring, from anus = ring) + iridis (Gk. iris/iridis: rainbow, iris of the eye) + major (L. major: greater, larger, comparative of magnus = great)", "p": 368}, {"t": "Anulus iridis minor", "m": "Lesser ring (circle) of iris — pupillary segment of iris, narrow circular inner zone on the anterior surface of iris", "e": "anulus (L. anulus: ring, small ring) + iridis (Gk. iris/iridis: rainbow, iris of the eye) + minor (L. minor: lesser, smaller, comparative of parvus = small)", "p": 368}, {"t": "Plicae iridis", "m": "Iridial folds — folds passing around the pupillary margin on the anterior side of the iris", "e": "plicae (L. plica: fold, plait, from plicare = to fold) + iridis (Gk. iris/iridis: rainbow, iris of the eye)", "p": 368}, {"t": "Pupilla", "m": "Pupil — aperture in the iris surrounded by the pupillary margin of the iris", "e": "pupilla (L. pupilla: pupil of the eye, diminutive of pupa = girl, doll; named for the tiny reflection of oneself seen in another's eye)", "p": 368}, {"t": "M. sphincter pupillae", "m": "Sphincter pupillae muscle — network of spirally coursing muscle fibers the longitudinal axes of which run approximately parallel to the pupillary margin", "e": "musculus (L. musculus: muscle, little mouse) + sphincter (Gk. sphinktēr: that which binds tight, from sphingein = to bind tight) + pupillae (L. pupilla: pupil of the eye, genitive form)", "p": 368}, {"t": "M. dilator pupillae", "m": "Dilator pupillae muscle — thin layer of smooth muscle mainly comprised of radially oriented fibers innervated by sympathetic fibers from the carotid plexus", "e": "musculus (L. musculus: muscle) + dilator (L. dilator: one who dilates/widens, from dilatare = to spread out, widen) + pupillae (L. pupilla: pupil of the eye, genitive form)", "p": 368}, {"t": "Stroma iridis", "m": "Stroma iridis — vascular framework of the iris infiltrated by pigmented connective tissue cells", "e": "stroma (Gk. strōma: bed, mattress, layer, from strōnnynai = to spread out) + iridis (Gk. iris/iridis: rainbow, iris of the eye, genitive form)", "p": 368}, {"t": "Epithelium pigmentosum", "m": "Pigmented (posterior) epithelium — bilayered epithelium on the posterior surface of the iris", "e": "epithelium (Gk. epi = upon + thēlē = nipple; layer upon a surface) + pigmentosum (L. pigmentosus: full of pigment, from pigmentum = paint, pigment, from pingere = to paint)", "p": 368}, {"t": "Spatia anguli iridocornealis", "m": "Spaces of iridocorneal angle (spaces of Fontana) — interstices between the fibers of the trabecular meshwork", "e": "spatia (L. spatium: space, interval, plural form) + anguli (L. angulus: angle, corner, genitive form) + iridocornealis (Gk./L. hybrid: iris/iridis = iris + cornea = horn-like, from cornu = horn; relating to the iris and cornea)", "p": 368}, {"t": "Circulus arteriosus iridis major", "m": "Greater arterial circle of iris — ringlike vascular system with radiating branches formed by anastomoses between the long and short posterior ciliary arteries", "e": "circulus (L. circulus: circle, small ring, from circus = circle) + arteriosus (L. arteriosus: arterial, of an artery, from arteria = artery, from Gk. artēria = windpipe, artery) + iridis (Gk. iris/iridis: rainbow, iris, genitive form) + major (L. major: greater, larger)", "p": 368}, {"t": "Circulus arteriosus iridis minor", "m": "Lesser arterial circle of iris — ringlike vascular system in the vicinity of the pupillary margin formed by anastomoses between the radial branches of the greater arterial circle", "e": "circulus (L. circulus: circle, small ring) + arteriosus (L. arteriosus: arterial, of an artery) + iridis (Gk. iris/iridis: rainbow, iris, genitive form) + minor (L. minor: lesser, smaller)", "p": 368}, {"t": "Membrana pupillaris", "m": "Pupillary membrane — anterior part of embryonical vascular membrane around the lens situated behind the pupil", "e": "membrana (L. membrana: membrane, skin, from membrum = limb, body part) + pupillaris (L. pupillaris: of the pupil, from pupilla = pupil of the eye)", "p": 368}, {"t": "Tunica interna bulbi", "m": "Internal (sensory) tunic of eyeball — comprises the retina with its pigment epithelium", "e": "tunica (L. tunica: tunic, coat, covering layer) + interna (L. internus: internal, inner, from inter = within) + bulbi (L. bulbus: bulb, globe, from Gk. bolbos = bulbous plant; genitive form referring to the eyeball)", "p": 368}, {"t": "Retina", "m": "Retina — inner lining of eyeball developed from the two layers of the optic cup", "e": "retina (L. rete: net; retina named for its net-like appearance of blood vessels)", "p": 368}, {"t": "Pars optica retinae", "m": "Pars optica retinae — retinal segment capable of transforming light stimuli into nerve impulses, lining the posterior aspect of the eyeball extending as far anteriorly as the ora serrata", "e": "pars (L. pars: part, portion) + optica (Gk. optikos: of sight, visual, from ops = eye, sight) + retinae (L. rete: net; genitive form of retina)", "p": 368}, {"t": "Pars pigmentosa", "m": "Pigmented part — pigment epithelium arising from the external layer of the optic cup", "e": "pars (L. pars: part, portion) + pigmentosa (L. pigmentosus: full of pigment, from pigmentum = paint, pigment, from pingere = to paint)", "p": 368}, {"t": "Pars nervosa", "m": "Nervous part — retina proper consisting essentially of three nuclear layers lying internal to the pigment epithelium", "e": "pars (L. pars: part, portion) + nervosa (L. nervosus: nervous, sinewy, full of nerves, from nervus = nerve, sinew)", "p": 368}, {"t": "Stratum neuroepitheliale", "m": "Neuroepithelial (photosensitive) layer — outer layer of the cerebral stratum consisting of rods and cones", "e": "stratum (L. stratum: layer, covering, from sternere = to spread, lay down) + neuroepitheliale (Gk. neuron = nerve + epi = upon + thēlē = nipple; relating to nerve-surface layer)", "p": 368}, {"t": "Stratum ganglionare retinae", "m": "Internal nuclear layer — middle layer of cell nuclei mainly consisting of the cell bodies of bipolar and amacrine cells", "e": "stratum (L. stratum: layer, from sternere = to spread) + ganglionare (Gk. ganglion: knot, swelling under the skin; relating to a ganglion) + retinae (L. rete: net; genitive of retina)", "p": 368}, {"t": "Stratum ganglionare n. optici", "m": "Ganglion cell layer — internal layer of nuclei consisting of multipolar cell bodies of initially non-myelinated ganglion cells the axons of which form the optic nerve", "e": "stratum (L. stratum: layer) + ganglionare (Gk. ganglion: knot, neural cluster) + nervus (L. nervus: nerve, sinew) + optici (Gk. optikos: of sight, visual, genitive form)", "p": 368}, {"t": "Ora serrata", "m": "Ora serrata — serrated margin between the light-sensitive and light-insensitive parts of the neural retina", "e": "ora (L. ora: edge, border, margin, from os/oris = mouth, rim) + serrata (L. serratus: saw-toothed, serrated, from serra = saw)", "p": 368}, {"t": "Pars ciliaris retinae", "m": "Pars ciliaris retinae — light-insensitive retinal segment consisting of a bilayered cuboidal epithelium (ciliary epithelium) forming the posterior surface of the ciliary body", "e": "pars (L. pars: part, portion) + ciliaris (L. ciliaris: of the ciliary body/eyelash, from cilium = eyelid, eyelash) + retinae (L. rete: net; genitive of retina)", "p": 368}, {"t": "Pars iridica retinae", "m": "Pars iridica retinae — light-insensitive retinal segment on the posterior surface of the iris, forming the bilayered posterior epithelium of the iris", "e": "pars (L. pars: part, portion) + iridica (Gk. iris/iridis: rainbow, iris of the eye; adjectival form) + retinae (L. rete: net; genitive of retina)", "p": 368}, {"t": "Discus nervi optici", "m": "Optic disc (papilla) — beginning of the optic nerve as visualized in the fundus about 3–4 mm medial to the macula", "e": "discus (Gk. diskos: disc, flat round object) + nervi (L. nervus: nerve, sinew) + optici (Gk. optikos: of sight, from ops = eye)", "p": 370}, {"t": "papilla nervi optici", "m": "Optic disc (papilla) — alternate term", "e": "papilla (L. papilla: nipple, teat, small protrusion) + nervi (L. nervus: nerve) + optici (Gk. optikos: of sight)", "p": 370}, {"t": "Excavatio disci", "m": "Physiological cup — depression in the middle of the optic disc with the stems of the central retinal artery and vein", "e": "excavatio (L. excavatio: hollowing out, from ex- = out + cavare = to hollow) + disci (L. discus: disc)", "p": 370}, {"t": "Macula", "m": "Transversely oval, yellowish area, 2–4 mm in diameter, at the posterior pole of the retina", "e": "macula (L. macula: spot, stain, blemish)", "p": 370}, {"t": "Fovea centralis", "m": "Central fovea — small depression in the macula caused by thinning of the upper retinal layers", "e": "fovea (L. fovea: pit, small depression) + centralis (L. centralis: central, from centrum = center)", "p": 370}, {"t": "Foveola", "m": "Thinnest area of fovea centralis with a diameter of about 0.2–0.4 mm, comprised entirely of approx. 2500 closely packed cones", "e": "foveola (L. foveola: small pit, diminutive of fovea = pit)", "p": 370}, {"t": "Vasa sanguinae retinae", "m": "Retinal blood vessels — branches of the central retinal artery and vein located on the internal aspect of the retina", "e": "vasa (L. vas: vessel, container, plural vasa) + sanguinae (L. sanguis: blood, genitive sanguinis) + retinae (L. rete: net, retina, genitive retinae)", "p": 370}, {"t": "Circulus vasculosus nervi optici", "m": "Circle of arteries around the optic nerve — small vascular ring penetrating the sclera around the optic nerve", "e": "circulus (L. circulus: small circle, ring) + vasculosus (L. vasculosus: full of vessels, from vasculum = small vessel) + nervi (L. nervus: nerve) + optici (Gk. optikos: of sight)", "p": 370}, {"t": "Arteriola temporalis retinae superior", "m": "Superior temporal arteriole/venule of retina — lateral upper branch of the central retinal artery and vein", "e": "arteriola (L. arteriola: small artery, diminutive of arteria) + temporalis (L. temporalis: of the temple, from tempora = temples) + retinae (L. rete: net, retina) + superior (L. superior: upper, higher)", "p": 370}, {"t": "Arteriola temporalis retinae inferior", "m": "Inferior temporal arteriole/venule of retina — lateral lower branch of the central retinal artery and vein", "e": "arteriola (L. arteriola: small artery) + temporalis (L. temporalis: of the temple) + retinae (L. rete: net, retina) + inferior (L. inferior: lower)", "p": 370}, {"t": "Arteriola nasalis retinae superior", "m": "Superior nasal arteriole/venule of retina — upper medial branch of the central retinal artery and vein", "e": "arteriola (L. arteriola: small artery) + nasalis (L. nasalis: of the nose, from nasus = nose) + retinae (L. rete: net, retina) + superior (L. superior: upper, higher)", "p": 370}, {"t": "Arteriola nasalis retinae inferior", "m": "Inferior nasal arteriole/venule of retina — lower medial branch of the central retinal artery and vein", "e": "arteriola (L. arteriola: small artery) + nasalis (L. nasalis: of the nose) + retinae (L. rete: net, retina) + inferior (L. inferior: lower)", "p": 370}, {"t": "Arteriola macularis superior", "m": "Superior macular arteriole/venule — supply and drain the upper part of the macula", "e": "arteriola (L. arteriola: small artery) + macularis (L. macularis: of the macula/spot, from macula = spot) + superior (L. superior: upper, higher)", "p": 370}, {"t": "Arteriola macularis inferior", "m": "Inferior macular arteriole/venule — supply and drain the lower part of the macula", "e": "arteriola (L. arteriola: small artery) + macularis (L. macularis: of the macula/spot) + inferior (L. inferior: lower)", "p": 370}, {"t": "Arteriola medialis retinae", "m": "Medial arteriole/venule of retina — small branches that supply and drain the medial part of retina proximal to the optic disc", "e": "arteriola (L. arteriola: small artery) + medialis (L. medialis: medial, middle, from medius = middle) + retinae (L. rete: net, retina)", "p": 370}, {"t": "Camerae bulbi", "m": "Chambers of the eye", "e": "camerae (L. camera: chamber, vaulted room, plural camerae) + bulbi (L. bulbus: bulb, globe of the eye, from Gk. bolbos = bulb)", "p": 370}, {"t": "Camera anterior", "m": "Anterior chamber — space that extends from the anterior surface of the iris to the posterior surface of the cornea, communicates with the posterior chamber via the pupil", "e": "camera (L. camera: chamber, vaulted room) + anterior (L. anterior: front, former, from ante = before)", "p": 370}, {"t": "Angulus iridocornealis", "m": "Iridocorneal angle — angle between the iris and cornea, houses the trabecular meshwork whose interstices drain aqueous humor into the sinus venosus sclerae", "e": "angulus (L. angulus: angle, corner) + iridocornealis (Gk. iris/iridos: rainbow, iris of eye + L. cornea: horn-like, transparent front of eye, from cornu = horn)", "p": 370}, {"t": "Humor aquosus", "m": "Aqueous humor — fluid produced by the epithelium of the ciliary processes, total quantity 0.2–0.3 cm³, consisting of 98% water, 1.4% NaCl and traces of protein and sugar, refractive index of 1.336", "e": "humor (L. humor: fluid, moisture, body fluid) + aquosus (L. aquosus: watery, full of water, from aqua = water)", "p": 370}, {"t": "venula temporalis retinae superior", "m": "Superior temporal arteriole/venule of retina — lateral upper branch of the central retinal artery and vein", "e": "venula (L. venula: small vein, diminutive of vena = vein) + temporalis (L. temporalis: of the temple) + retinae (L. rete: net, retina) + superior (L. superior: upper, higher)", "p": 370}, {"t": "venula temporalis retinae inferior", "m": "Inferior temporal arteriole/venule of retina — lateral lower branch of the central retinal artery and vein", "e": "venula (L. venula: small vein) + temporalis (L. temporalis: of the temple) + retinae (L. rete: net, retina) + inferior (L. inferior: lower)", "p": 370}, {"t": "venula nasalis retinae superior", "m": "Superior nasal arteriole/venule of retina — upper medial branch of the central retinal artery and vein", "e": "venula (L. venula: small vein) + nasalis (L. nasalis: of the nose) + retinae (L. rete: net, retina) + superior (L. superior: upper)", "p": 370}, {"t": "venula nasalis retinae inferior", "m": "Inferior nasal arteriole/venule of retina — lower medial branch of the central retinal artery and vein", "e": "venula (L. venula: small vein) + nasalis (L. nasalis: of the nose) + retinae (L. rete: net, retina) + inferior (L. inferior: lower)", "p": 370}, {"t": "venula macularis superior", "m": "Superior macular arteriole/venule — supply and drain the upper part of the macula", "e": "venula (L. venula: small vein) + macularis (L. macularis: of the macula/spot) + superior (L. superior: upper, higher)", "p": 370}, {"t": "venula macularis inferior", "m": "Inferior macular arteriole/venule — supply and drain the lower part of the macula", "e": "venula (L. venula: small vein) + macularis (L. macularis: of the macula/spot) + inferior (L. inferior: lower)", "p": 370}, {"t": "venula medialis retinae", "m": "Medial arteriole/venule of retina — small branches that supply and drain the medial part of retina proximal to the optic disc", "e": "venula (L. venula: small vein) + medialis (L. medialis: medial, from medius = middle) + retinae (L. rete: net, retina)", "p": 370}, {"t": "Fundus", "m": "Fundus — the interior posterior surface/back of the eye as seen through an ophthalmoscope", "e": "fundus (L. fundus: bottom, base, foundation)", "p": 371}, {"t": "Camera posterior", "m": "Posterior chamber", "e": "camera (L. camera: chamber, vault) + posterior (L. posterior: behind, coming after, from post = after)", "p": 372}, {"t": "Camera vitrea", "m": "Vitreous chamber", "e": "camera (L. camera: chamber, vault) + vitrea (L. vitreus: glassy, of glass, from vitrum = glass)", "p": 372}, {"t": "Corpus vitreum", "m": "Vitreous body", "e": "corpus (L. corpus: body) + vitreum (L. vitreus: glassy, from vitrum = glass)", "p": 372}, {"t": "A. hyaloidea", "m": "Hyaloid artery — branch of the ophthalmic artery supplying the vascular membrane of the lens", "e": "arteria (L. arteria: artery, from Gk. artēria) + hyaloidea (Gk. hyaloeidēs: glassy, from hyalos = glass + eidos = form)", "p": 372}, {"t": "Canalis hyaloideus", "m": "Hyaloid canal — canal within the vitreous body formerly occupied by the embryonic hyaloid artery", "e": "canalis (L. canalis: channel, canal, from canna = reed) + hyaloideus (Gk. hyaloeidēs: glassy, from hyalos = glass + eidos = form)", "p": 372}, {"t": "Fossa hyaloidea", "m": "Hyaloid (lenticular, patellar) fossa — fossa on the anterior surface of the vitreous body adjacent to the lens", "e": "fossa (L. fossa: pit, ditch, from fodere = to dig) + hyaloidea (Gk. hyaloeidēs: glassy, from hyalos = glass + eidos = form)", "p": 372}, {"t": "Membrana vitrea", "m": "Vitreous (hyaloid) membrane — condensation of fibers on the surface of the vitreous body", "e": "membrana (L. membrana: membrane, thin skin) + vitrea (L. vitreus: glassy, from vitrum = glass)", "p": 372}, {"t": "Stroma vitreum", "m": "Stroma of vitreous body — fine network of fibers in the vitreous body", "e": "stroma (Gk. strōma: bed, layer, from strōnnynai = to spread) + vitreum (L. vitreus: glassy, from vitrum = glass)", "p": 372}, {"t": "Humor vitreus", "m": "Vitreous humor — fluid part of vitreous body", "e": "humor (L. humor: fluid, moisture) + vitreus (L. vitreus: glassy, from vitrum = glass)", "p": 372}, {"t": "Substantia lentis", "m": "Lens substance — situated beneath the lens epithelium and comprising the lens nucleus and lens cortex", "e": "substantia (L. substantia: substance, essence, from sub = under + stare = to stand) + lentis (L. lens/lentis: lentil, lens)", "p": 372}, {"t": "Cortex lentis", "m": "Lens cortex — external zone of the lens", "e": "cortex (L. cortex: bark, outer layer) + lentis (L. lens/lentis: lentil, lens)", "p": 372}, {"t": "Nucleus lentis", "m": "Nucleus of lens — harder core of the lens with a low water content", "e": "nucleus (L. nucleus: kernel, core, from nux = nut) + lentis (L. lens/lentis: lentil, lens)", "p": 372}, {"t": "Fibrae lentis", "m": "Lens fibers — fibers corresponding to the lens epithelium from which they develop", "e": "fibrae (L. fibra: fiber, filament) + lentis (L. lens/lentis: lentil, lens)", "p": 372}, {"t": "Epithelium lentis", "m": "Epithelium of lens — part of the lens confined to the anterior surface and extending as far as the equator", "e": "epithelium (Gk. epi = upon + thēlē = nipple, hence surface layer) + lentis (L. lens/lentis: lentil, lens)", "p": 372}, {"t": "Capsula lentis", "m": "Lens capsule — transparent membrane, up to 15 μm thick, covering the lens including its epithelium", "e": "capsula (L. capsula: small box, diminutive of capsa = box) + lentis (L. lens/lentis: lentil, lens)", "p": 372}, {"t": "Zonula ciliaris", "m": "Ciliary zonule — suspensory apparatus together with its interstices, encircling the lens equator", "e": "zonula (L. zonula: small zone or belt, diminutive of zona = belt, from Gk. zōnē) + ciliaris (L. ciliaris: of the eyelashes/ciliary body, from cilium = eyelid, eyelash)", "p": 372}, {"t": "Fibrae zonulares", "m": "Zonular fibers (suspensory ligaments) — suspensory fibers attached to the equator and the adjacent anterior and posterior surfaces of the lens", "e": "fibrae (L. fibra: fiber, filament) + zonulares (L. zonularis: of the zonule, from zonula = small belt)", "p": 372}, {"t": "Spatia zonularia", "m": "Zonular spaces — spaces between the zonule fibers filled with percolating aqueous humor", "e": "spatia (L. spatium: space, interval) + zonularia (L. zonularis: of the zonule, from zonula = small belt, from zona = belt)", "p": 372}, {"t": "Organa oculi accessoria", "m": "Accessory organs of eye", "e": "organa (L. organum, from Gk. organon: instrument, organ) + oculi (L. oculus: eye) + accessoria (L. accessorius: supplementary, from accedere = to approach, add to)", "p": 374}, {"t": "Musculi bulbi", "m": "Muscles of eye / Extrinsic ocular muscles", "e": "musculi (L. musculus: muscle, little mouse) + bulbi (L. bulbus, from Gk. bolbos: bulb, referring to the eyeball)", "p": 374}, {"t": "M. orbitalis", "m": "Orbital muscle — thin layer of smooth muscle which bridges the inferior orbital fissure", "e": "musculus (L. musculus: muscle) + orbitalis (L. orbitalis: of the orbit, from orbita = track, circuit, from orbis = circle)", "p": 374}, {"t": "M. rectus superior", "m": "Superior rectus", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight) + superior (L. superior: upper, higher)", "p": 374}, {"t": "Anulus tendineus communis", "m": "Common tendinous ring (common annular tendon) — tendinous ring for attachment of the recti ocular muscles", "e": "anulus (L. anulus: ring, diminutive of anus = ring) + tendineus (L. tendineus: of a tendon, from tendere = to stretch) + communis (L. communis: common, shared)", "p": 374}, {"t": "M. rectus inferior", "m": "Inferior rectus", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight) + inferior (L. inferior: lower)", "p": 374}, {"t": "M. rectus medialis", "m": "Medial rectus", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight) + medialis (L. medialis: of the middle, from medius = middle)", "p": 374}, {"t": "M. rectus lateralis", "m": "Lateral rectus", "e": "musculus (L. musculus: muscle) + rectus (L. rectus: straight) + lateralis (L. lateralis: of the side, from latus = side)", "p": 374}, {"t": "Lacertus musculi recti lateralis", "m": "Tendon of lateral rectus at greater wing", "e": "lacertus (L. lacertus: muscular part of the arm, band, strap) + musculi (L. musculus: muscle) + recti (L. rectus: straight) + lateralis (L. lateralis: of the side, from latus = side)", "p": 374}, {"t": "M. obliquus superior", "m": "Superior oblique", "e": "musculus (L. musculus: muscle) + obliquus (L. obliquus: slanting, oblique) + superior (L. superior: upper, higher)", "p": 374}, {"t": "Trochlea", "m": "Cartilaginous sling attached to the medial wall of the orbit serving as a pulley for the tendon of the superior oblique muscle", "e": "trochlea (L. trochlea, from Gk. trokhilia: pulley, system of pulleys, from trokhos = wheel)", "p": 374}, {"t": "Bursa synovialis trochlearis", "m": "Synovial bursa of trochlea — synovial sheath (bursa) for the tendon of the superior oblique muscle separating the tendon from the trochlea", "e": "bursa (L./Gk. bursa: pouch, purse, from Gk. byrsa = hide, wineskin) + synovialis (Gk./NL. synovialis: of synovial fluid, from syn = together + L. ovum = egg, coined by Paracelsus) + trochlearis (L. trochlearis: of the trochlea, from Gk. trokhilia = pulley)", "p": 374}, {"t": "M. obliquus inferior", "m": "Inferior oblique", "e": "musculus (L. musculus: muscle) + obliquus (L. obliquus: slanting, oblique) + inferior (L. inferior: lower)", "p": 374}, {"t": "M. levator palpebrae superioris", "m": "Levator palpebrae superioris — muscle whose tendon broadens anteriorly and splits to form an upper and lower layer", "e": "musculus (L. musculus: muscle) + levator (L. levator: lifter, from levare = to lift) + palpebrae (L. palpebra: eyelid, from palpare = to touch gently) + superioris (L. superior: upper, higher)", "p": 374}, {"t": "Lamina superficialis", "m": "Superficial lamina of levator tendon — passes between the tarsus and orbicularis oculi to insert into the subcutaneous connective tissue of the upper eyelid", "e": "lamina (L. lamina: thin plate, layer, leaf) + superficialis (L. superficialis: of the surface, from superficies = surface, from super = above + facies = face)", "p": 374}, {"t": "Lamina profunda", "m": "Deep lamina of levator tendon — inserts into the upper margin and the anterior surface of the tarsus", "e": "lamina (L. lamina: thin plate, layer, leaf) + profunda (L. profundus: deep, from pro = forward + fundus = bottom)", "p": 374}, {"t": "Fasciae orbitales", "m": "Orbital fasciae", "e": "fasciae (L. fascia: band, bandage, bundle) + orbitales (L. orbitalis: of the orbit, from orbita = track, circuit)", "p": 374}, {"t": "Periorbita", "m": "Periosteum of orbit — delicate and fused solidly to the bone at the inlet and outlet of the orbit", "e": "peri- (Gk. peri: around, surrounding) + orbita (L. orbita: track, circuit, orbit, from orbis = circle)", "p": 374}, {"t": "Septum orbitale", "m": "Orbital septum — connective tissue septum partly reinforced by tendon, passes from the orbital margin below the orbicularis oculi to the external margins of the tarsi", "e": "septum (L. septum: partition, wall, from saepire = to enclose) + orbitale (L. orbitalis: of the orbit, from orbita = track, circuit)", "p": 374}, {"t": "Fasciae musculares", "m": "Muscular fasciae — sheaths of Tenon's capsule enveloping the tendons and muscular bellies of the 6 extrinsic ocular muscles", "e": "fasciae (L. fascia: band, bandage, bundle) + musculares (L. muscularis: of muscle, from musculus = muscle)", "p": 374}, {"t": "Vagina bulbi", "m": "Tenon's capsule (fascia bulbi) — connective tissue gliding membrane between the eyeball and orbital fat", "e": "vagina (L. vagina: sheath, scabbard) + bulbi (L. bulbus, from Gk. bolbos: bulb, referring to the eyeball)", "p": 374}, {"t": "Spatium episclerale", "m": "Episcleral space — gliding space between the eyeball and Tenon's capsule, traversed by long delicate connective tissue fibers", "e": "spatium (L. spatium: space, room, interval) + epi- (Gk. epi: upon, over) + sclerale (Gk. skleros: hard, referring to the sclera of the eye)", "p": 374}, {"t": "Corpus adiposum orbitae", "m": "Orbital fat body — adipose tissue filling the spaces around the ocular muscles, the eyeball and the optic nerve, bordered anteriorly by the orbital septum", "e": "corpus (L. corpus: body) + adiposum (L. adiposus: fatty, from adeps/adipis = fat) + orbitae (L. orbita: track, circuit, orbit, from orbis = circle)", "p": 374}, {"t": "Supercilium", "m": "Eyebrow — the transverse elevation above the eyes, covered by thick, bristle-like hairs", "e": "super (L. super: above) + cilium (L. cilium: eyelid, eyelash)", "p": 376}, {"t": "Palpebrae", "m": "Eyelids", "e": "palpebrae (L. palpebra: eyelid, from palpare: to touch, feel)", "p": 376}, {"t": "Palpebra superior", "m": "Upper eyelid", "e": "palpebra (L. palpebra: eyelid) + superior (L. superior: upper, higher)", "p": 376}, {"t": "Palpebra inferior", "m": "Lower eyelid", "e": "palpebra (L. palpebra: eyelid) + inferior (L. inferior: lower)", "p": 376}, {"t": "Facies anterior palpebralis", "m": "Anterior palpebral surface — the anterior external (skin-covered) surface of the eyelid", "e": "facies (L. facies: face, surface) + anterior (L. anterior: front, from ante: before) + palpebralis (L. palpebralis: of the eyelid, from palpebra: eyelid)", "p": 376}, {"t": "Plica palpebronasalis", "m": "Epicanthus (mongolian fold) — vertical fold covering the medial angle of the eye", "e": "plica (L. plica: fold, from plicare: to fold) + palpebro- (L. palpebra: eyelid) + nasalis (L. nasalis: of the nose, from nasus: nose)", "p": 376}, {"t": "Facies posterior palpebralis", "m": "Posterior palpebral surface — surface lined by conjunctival epithelium and containing dispersed goblet cells", "e": "facies (L. facies: surface) + posterior (L. posterior: behind, from post: after) + palpebralis (L. palpebralis: of the eyelid)", "p": 376}, {"t": "Rima palpebrarum", "m": "Palpebral fissure — space between the margins of the upper and lower eyelids", "e": "rima (L. rima: cleft, slit, fissure) + palpebrarum (L. palpebra gen. pl.: of the eyelids)", "p": 376}, {"t": "Commissura palpebralis lateralis", "m": "Lateral palpebral commissure — lateral junction of the upper and lower eyelids", "e": "commissura (L. commissura: junction, from committere: to join) + palpebralis (L. palpebralis: of the eyelid) + lateralis (L. lateralis: of the side, from latus: side)", "p": 376}, {"t": "Commissura palpebralis medialis", "m": "Medial palpebral commissure — medial junction of the upper and lower eyelids", "e": "commissura (L. commissura: junction) + palpebralis (L. palpebralis: of the eyelid) + medialis (L. medialis: middle, from medius: middle)", "p": 376}, {"t": "Angulus oculi lateralis", "m": "Lateral angle (canthus) of eye — acute lateral angle of the eye; lateral end of the palpebral fissure", "e": "angulus (L. angulus: angle, corner) + oculi (L. oculus gen. sing.: of the eye) + lateralis (L. lateralis: lateral, from latus: side)", "p": 376}, {"t": "Angulus oculi medialis", "m": "Medial angle (canthus) of eye — more rounded medial end of the palpebral fissure which delimits a triangular space, the lacrimal lake", "e": "angulus (L. angulus: angle, corner) + oculi (L. oculus gen. sing.: of the eye) + medialis (L. medialis: medial, from medius: middle)", "p": 376}, {"t": "Limbi palpebrales anteriores", "m": "Anterior edges of the free margins of the eyelids adjacent to the external skin", "e": "limbi (L. limbus gen./pl.: border, edge) + palpebrales (L. palpebralis pl.: of the eyelids) + anteriores (L. anterior pl.: front, anterior)", "p": 376}, {"t": "Limbi palpebrales posteriores", "m": "Posterior edges of the free margins of the eyelids adjacent to the conjunctiva", "e": "limbi (L. limbus: border, edge) + palpebrales (L. palpebralis pl.: of the eyelids) + posteriores (L. posterior pl.: behind, posterior)", "p": 376}, {"t": "Cilia", "m": "Eyelashes — the 3–4 rows of hair growing near the anterior edge of the free margin of the eyelids", "e": "cilia (L. cilia pl. of cilium: eyelash, eyelid)", "p": 376}, {"t": "Tarsus superior", "m": "Superior tarsal plate — curved plate about 10 mm high occupying the upper eyelid and consisting of compact, interwoven collagenous connective tissue with tarsal glands", "e": "tarsus (Gk. tarsos: flat of the foot, broad flat surface; used for the eyelid cartilage) + superior (L. superior: upper, higher)", "p": 376}, {"t": "Tarsus inferior", "m": "Inferior tarsal plate — plate about 5 mm high within the lower eyelid, consisting of firm interwoven collagenous connective tissue with tarsal glands", "e": "tarsus (Gk. tarsos: flat surface; used for eyelid plate) + inferior (L. inferior: lower)", "p": 376}, {"t": "Lig. palpebrale mediale", "m": "Medial palpebral ligament — band of connective tissue between the medial palpebral commissure and the medial wall of the orbit, lying in front of the lacrimal sac", "e": "lig. (L. ligamentum: ligament, band, from ligare: to bind) + palpebrale (L. palpebralis: of the eyelid) + mediale (L. medialis: medial, middle)", "p": 376}, {"t": "Raphe palpebralis lateralis", "m": "Lateral palpebral raphe — delicate band on the lateral palpebral ligament, reinforced by the orbicularis oculi muscle", "e": "raphe (Gk. rhaphe: seam, suture) + palpebralis (L. palpebralis: of the eyelid) + lateralis (L. lateralis: lateral, from latus: side)", "p": 376}, {"t": "Lig. palpebrale laterale", "m": "Lateral palpebral ligament — fibrous band that attaches the lateral palpebral commissure to the lateral wall of the orbit in front of the orbital septum", "e": "lig. (L. ligamentum: ligament, from ligare: to bind) + palpebrale (L. palpebralis: of the eyelid) + laterale (L. lateralis: lateral, from latus: side)", "p": 376}, {"t": "Glandulae tarsales", "m": "Tarsal (Meibomian) glands — elongated holocrine glands located in the superior and inferior tarsal plates with openings near the posterior edge of the free margin of the eyelids", "e": "glandulae (L. glandula pl.: small glands, from glans: acorn) + tarsales (L. tarsalis pl.: of the tarsus/tarsal plate, from Gk. tarsos)", "p": 376}, {"t": "M. tarsalis superior", "m": "Superior tarsal muscle — smooth muscle fibers between the muscle-tendon border of the levator palpebrae muscle and the superior tarsal plate", "e": "M. (L. musculus: muscle, lit. little mouse) + tarsalis (L. tarsalis: of the tarsus/tarsal plate) + superior (L. superior: upper, higher)", "p": 376}, {"t": "M. tarsalis inferior", "m": "Inferior tarsal muscle — smooth muscle fibers between the inferior fornix of the conjunctiva and the inferior tarsal plate", "e": "M. (L. musculus: muscle) + tarsalis (L. tarsalis: of the tarsal plate) + inferior (L. inferior: lower)", "p": 376}, {"t": "Tunica conjunctiva", "m": "The lining of the inner surface of the eyelids, consisting of two or more layers of columnar epithelium with goblet cells and a loose, cell-rich lamina propria containing multiple blood vessels", "e": "tunica (L. tunica: covering, coat, layer) + conjunctiva (L. conjunctiva: connecting, from conjungere: to join together)", "p": 376}, {"t": "Plica semilunaris conjunctivae", "m": "Semilunar fold of conjunctive — lies in the medial angle of the eye between the fornix of the upper and lower eyelid", "e": "plica (L. plica: fold, from plicare: to fold) + semilunaris (L. semi: half + lunaris: of the moon, from luna: moon) + conjunctivae (L. conjunctiva gen. sing.: of the conjunctiva)", "p": 376}, {"t": "Caruncula lacrimalis", "m": "Lacrimal caruncle — mucosal mass in the medial angle of the eye covered by stratified squamous or columnar epithelium", "e": "caruncula (L. caruncula: small fleshy mass, diminutive of caro: flesh) + lacrimalis (L. lacrimalis: of tears, from lacrima: tear)", "p": 376}, {"t": "Epicanthus", "m": "Epicanthus (epicanthic fold) — a skin fold covering the inner canthus", "e": "epi- (Gk. epí: upon, over) + kanthos (Gk. kanthos: corner of the eye)", "p": 377}, {"t": "Lamina tarsalis superior", "m": "Superior tarsal plate — the upper fibrous plate of the upper eyelid", "e": "lamina (L. lāmina: plate, layer) + tarsalis (Gk. tarsos: flat of the foot, frame; here applied to eyelid plate) + superior (L. superior: upper, higher)", "p": 377}, {"t": "Lamina tarsalis inferior", "m": "Inferior tarsal plate — the lower fibrous plate of the lower eyelid", "e": "lamina (L. lāmina: plate, layer) + tarsalis (Gk. tarsos: flat surface; applied to eyelid plate) + inferior (L. inferior: lower)", "p": 377}, {"t": "Ligamentum palpebrale mediale", "m": "Medial palpebral ligament — ligament anchoring the tarsal plates medially", "e": "ligamentum (L. ligāmentum: band, tie, from ligāre = to bind) + palpebrale (L. palpebra: eyelid) + mediale (L. mediālis: middle, from medius = middle)", "p": 377}, {"t": "Ligamentum palpebrale laterale", "m": "Lateral palpebral ligament — ligament anchoring the tarsal plates laterally", "e": "ligamentum (L. ligāmentum: band, tie, from ligāre = to bind) + palpebrale (L. palpebra: eyelid) + laterale (L. laterālis: of the side, from latus = side)", "p": 377}, {"t": "Musculus orbicularis oculi", "m": "Orbicular muscle of eye — the sphincter-like muscle surrounding the eye", "e": "musculus (L. musculus: muscle, little mouse) + orbicularis (L. orbiculāris: circular, from orbis = circle, disk) + oculi (L. oculus: eye, genitive = of the eye)", "p": 377}, {"t": "Glandulae ciliares", "m": "Ciliary glands (glands of Moll) — modified sweat glands at the eyelid margin", "e": "glandulae (L. glandula: small gland, diminutive of glans = acorn) + ciliares (L. cilium: eyelash, eyelid)", "p": 377}, {"t": "Glandulae sebaceae", "m": "Sebaceous glands — oil-secreting glands of the eyelid", "e": "glandulae (L. glandula: small gland) + sebaceae (L. sebum: tallow, grease, suet)", "p": 377}, {"t": "Conjunctiva", "m": "Conjunctiva — the mucous membrane lining the eyelids and covering the eyeball", "e": "conjunctiva (L. conjunctīva: connective membrane, from conjungere = to join together, con- = together + jungere = to join)", "p": 377}, {"t": "Tunica conjunctiva palpebrarum", "m": "Palpebral conjunctiva — the part of the conjunctiva lining the inner surface of the eyelids", "e": "tunica (L. tunica: coat, covering layer) + conjunctiva (L. conjunctīva: connective, from conjungere = to join) + palpebrarum (L. palpebra: eyelid, genitive plural = of the eyelids)", "p": 377}, {"t": "Fornix conjunctivae", "m": "Conjunctival fornix — the reflection of the conjunctiva from the eyelid to the eyeball", "e": "fornix (L. fornix: arch, vault) + conjunctivae (L. conjunctīva: connective membrane, from conjungere = to join)", "p": 377}, {"t": "Tunica conjunctiva bulbaris", "m": "Bulbar conjunctiva — part of conjunctiva covering the eyeball", "e": "tunica (L. tunica: covering, coat, membrane) + conjunctiva (L. conjunctivus: connecting, joining, from conjungere = to join together) + bulbaris (L. bulbaris: of the bulb, from bulbus = bulb, eyeball)", "p": 378}, {"t": "Tunica conjunctiva palpebralis", "m": "Palpebral conjunctiva — portion of conjunctiva covering posterior surface of eyelid", "e": "tunica (L. tunica: covering, coat, membrane) + conjunctiva (L. conjunctivus: connecting, from conjungere = to join together) + palpebralis (L. palpebralis: of the eyelid, from palpebra = eyelid)", "p": 378}, {"t": "Fornix conjunctivae superior", "m": "Superior fornix of conjunctiva — reflected fold of conjunctiva extending from eyeball to upper eyelid", "e": "fornix (L. fornix: arch, vault) + conjunctivae (L. conjunctivus: connecting, from conjungere = to join together) + superior (L. superior: upper, higher)", "p": 378}, {"t": "Fornix conjunctivae inferior", "m": "Inferior fornix of conjunctiva — reflected fold of conjunctiva from eyeball to lower eyelid", "e": "fornix (L. fornix: arch, vault) + conjunctivae (L. conjunctivus: connecting, from conjungere = to join together) + inferior (L. inferior: lower)", "p": 378}, {"t": "Saccus conjunctivalis", "m": "Conjunctival sac — space between palpebral and bulbar conjunctivae", "e": "saccus (L. saccus: sac, bag, from Gk. sakkos = bag) + conjunctivalis (L. conjunctivalis: of the conjunctiva, from conjungere = to join together)", "p": 378}, {"t": "Glanduale conjunctivales", "m": "Conjunctival glands — follicular aggregations of lymphocytes at medial angle of eye", "e": "glanduale (L. glandulae: glands, from glandula, diminutive of glans = acorn) + conjunctivales (L. conjunctivalis: of the conjunctiva, from conjungere = to join together)", "p": 378}, {"t": "Apparatus lacrimalis", "m": "Lacrimal apparatus — system of structures that lubricate the cornea and conjunctiva", "e": "apparatus (L. apparatus: equipment, system, from apparare = to prepare) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Glandula lacrimalis", "m": "Lacrimal gland — gland located above lateral angle of eyelids", "e": "glandula (L. glandula: small gland, diminutive of glans = acorn) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Ductuli exretorii", "m": "Excretory ducts of lacrimal gland — 6–14 ducts opening into superior fornix of conjunctiva", "e": "ductuli (L. ductuli: small ducts, plural of ductulus, diminutive of ductus = leading, from ducere = to lead) + exretorii (L. excretorius: of excretion, from excernere = to separate out)", "p": 378}, {"t": "Glandulae lacrimales accessoriae", "m": "Accessory lacrimal glands — additional smaller lacrimal glands found especially in vicinity of superior conjunctival fornix", "e": "glandulae (L. glandulae: glands, from glandula, diminutive of glans = acorn) + lacrimales (L. lacrimalis: of tears, from lacrima = tear) + accessoriae (L. accessorius: additional, supplementary, from accedere = to come to, approach)", "p": 378}, {"t": "Rivus lacrimalis", "m": "Lacrimal rivus — pathway that conducts tears from excretory ducts to lacrimal lake", "e": "rivus (L. rivus: stream, brook, channel) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Lacus lacrimalis", "m": "Lacrimal lake — space in medial angle of eye around lacrimal caruncle", "e": "lacus (L. lacus: lake, pool, basin) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Papilla lacrimalis", "m": "Lacrimal papilla — small cone-shaped elevation medial to inner edge of both upper and lower eyelids", "e": "papilla (L. papilla: nipple, small projection, diminutive of papula = pimple) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Punctum lacrimale", "m": "Lacrimal punctum — small opening marking beginning of lacrimal fluid drainage system", "e": "punctum (L. punctum: point, small opening, from pungere = to prick, pierce) + lacrimale (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Canaliculus lacrimalis", "m": "Lacrimal canaliculus — small canal up to 1 cm long from each lacrimal punctum to lacrimal sac", "e": "canaliculus (L. canaliculus: small channel, diminutive of canalis = channel, from canna = reed, pipe) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Ampulla canaliculi lacrimalis", "m": "Ampulla of lacrimal canaliculus — slight enlargement at bend of lacrimal canaliculus", "e": "ampulla (L. ampulla: flask, a rounded enlargement, from amphora = two-handled vessel) + canaliculi (L. canaliculus: small channel, diminutive of canalis = channel) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Saccus lacrimalis", "m": "Lacrimal sac — located in lacrimal fossa, about 1.5 cm long and 0.5 cm wide, descends into nasolacrimal duct", "e": "saccus (L. saccus: sac, bag, from Gk. sakkos = bag) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Fornix sacci lacrimalis", "m": "Fornix of lacrimal sac — dome-shaped upper margin of lacrimal sac", "e": "fornix (L. fornix: arch, vault) + sacci (L. saccus: sac, bag, from Gk. sakkos = bag) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Ductus nasolacrimalis", "m": "Nasolacrimal duct — duct directly continuous with lacrimal sac, 1.2–2.4 cm long, passes through nasolacrimal canal into inferior nasal meatus", "e": "ductus (L. ductus: duct, leading, from ducere = to lead) + naso (L. nasus: nose) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Plica lacrimalis", "m": "Lacrimal fold — mucosal fold at opening of nasolacrimal duct in inferior nasal meatus about 3–3.5 cm posterior to external naris", "e": "plica (L. plica: fold, from plicare = to fold) + lacrimalis (L. lacrimalis: of tears, from lacrima = tear)", "p": 378}, {"t": "Organum vestibulocochlear", "m": "Vestibulocochlear organ — sensory apparatus housed in the temporal bone for the perception of sound, equilibrium and positional changes", "e": "organum (L. organum, from Gk. organon: instrument, organ) + vestibulocochlear (L. vestibulum: entrance hall, antechamber + L. cochlea, from Gk. kokhlias: snail, spiral)", "p": 380}, {"t": "Auris interna", "m": "Internal ear — part of the vestibulocochlear organ residing in the petrous temporal bone", "e": "auris (L. auris: ear) + interna (L. internus: inner, internal)", "p": 380}, {"t": "Labyrinthus membranaceus", "m": "Membranous labyrinth — complicated system of ducts and dilatations within the bony labyrinth", "e": "labyrinthus (L./Gk. labyrinthos: labyrinth, maze) + membranaceus (L. membranaceus: membranous, from membrana: membrane, from membrum: limb)", "p": 380}, {"t": "Labyrinthus vestibularis", "m": "Vestibular labyrinth — portion of membranous labyrinth constituting the organ of equilibrium, includes the semicircular ducts", "e": "labyrinthus (L./Gk. labyrinthos: labyrinth, maze) + vestibularis (L. vestibularis: of the vestibule, from vestibulum: entrance hall)", "p": 380}, {"t": "Ductus endolymphaticus", "m": "Endolymphatic duct — slender duct arising from the utriculosaccular duct and passing through the osseous aqueduct of the vestibule to terminate as the endolymphatic sac", "e": "ductus (L. ductus: duct, channel, from ducere: to lead) + endo (Gk. endon: within) + lymphaticus (L. lymphaticus: of lymph, from lympha: clear water)", "p": 380}, {"t": "Saccus endolymphaticus", "m": "Endolymphatic sac — blind sac of endolymphatic duct located between two dural layers at the posterior wall of the petrous temporal", "e": "saccus (L. saccus, from Gk. sakkos: bag, sack) + endo (Gk. endon: within) + lymphaticus (L. lymphaticus: of lymph, from lympha: clear water)", "p": 380}, {"t": "Ductus utriculosaccularis", "m": "Utriculosaccular duct — slender duct between the saccule and utricle, gives rise to the endolymphatic duct", "e": "ductus (L. ductus: duct, from ducere: to lead) + utriculosaccularis (L. utriculus: small bag/wineskin, diminutive of uter: bag + sacculus: small sac, diminutive of saccus: bag)", "p": 380}, {"t": "Utriculus", "m": "Utricle — sac 2.5–3.5 mm in diameter, serving as the base for the three semicircular ducts", "e": "utriculus (L. utriculus: small bag, small wineskin, diminutive of uter: bag, wineskin)", "p": 380}, {"t": "Ductus semicirculares", "m": "Semicircular duct — three membranous ducts that resemble two-thirds of a circular arch, each occupying its own osseous semicircular canal oriented perpendicular to the others", "e": "ductus (L. ductus: duct, channel, from ducere: to lead) + semi (L. semi: half) + circulares (L. circularis: circular, from circulus: circle, from circus: ring)", "p": 380}, {"t": "Ductus semicircularis anterior", "m": "Anterior (superior) semicircular duct — oriented vertically and somewhat perpendicular to the petrous part of the temporal bone", "e": "ductus (L. ductus: duct, from ducere: to lead) + semi (L. semi: half) + circularis (L. circularis: circular, from circulus: circle) + anterior (L. anterior: in front, former, from ante: before)", "p": 380}, {"t": "Ductus semicircularis posterior", "m": "Posterior semicircular duct — oriented somewhat vertically in a plane parallel to the longitudinal axis of the petrous part of the temporal bone", "e": "ductus (L. ductus: duct, from ducere: to lead) + semi (L. semi: half) + circularis (L. circularis: circular, from circulus: circle) + posterior (L. posterior: behind, later, from post: after)", "p": 380}, {"t": "Ductus semicircularis lateralis", "m": "Lateral semicircular duct — the most lateral, horizontally oriented semicircular duct, may create a bulge in the medial wall of the tympanic cavity", "e": "ductus (L. ductus: duct, from ducere: to lead) + semi (L. semi: half) + circularis (L. circularis: circular, from circulus: circle) + lateralis (L. lateralis: lateral, of the side, from latus: side)", "p": 380}, {"t": "Membrana propria ductus semicircularis", "m": "Proper membrane of semicircular duct — layer below the basal membrane consisting primarily of densely packed fibers extending into the looser network of the perilymphatic space", "e": "membrana (L. membrana: membrane, from membrum: limb) + propria (L. proprius: one's own, proper) + ductus (L. ductus: duct, from ducere: to lead) + semi (L. semi: half) + circularis (L. circularis: circular, from circulus: circle)", "p": 380}, {"t": "Membrana basalis ductus semicircularis", "m": "Basal membrane of semicircular duct — appears upon light microscopy as a homogeneous basal membrane situated directly below the epithelium", "e": "membrana (L. membrana: membrane, from membrum: limb) + basalis (L. basalis: basal, of the base, from basis, from Gk. basis: base, step) + ductus (L. ductus: duct, from ducere: to lead) + semi (L. semi: half) + circularis (L. circularis: circular, from circulus: circle)", "p": 380}, {"t": "Epithelium ductus semicircularis", "m": "Epithelium of semicircular duct — simple epithelium lining the inner aspect of the membranous semicircular duct; cells are flat and become cuboidal on their concave side", "e": "epithelium (Gk. epi: upon + thele: nipple, hence upon/over the surface) + ductus (L. ductus: duct, from ducere: to lead) + semi (L. semi: half) + circularis (L. circularis: circular, from circulus: circle)", "p": 380}, {"t": "Ampullae membranaceae", "m": "Membranous ampullae — dilatations of the semicircular ducts in the vicinity of the utricle", "e": "ampullae (L. ampulla: flask, jug, bulbous container; plural ampullae) + membranaceae (L. membranaceus: membranous, from membrana: membrane)", "p": 380}, {"t": "Ampulla membranacea anterior", "m": "Anterior membranous ampulla — dilatation at the end of the anterior (superior) semicircular duct located near the lateral membranous ampulla", "e": "ampulla (L. ampulla: flask, jug, bulbous container) + membranacea (L. membranaceus: membranous, from membrana: membrane) + anterior (L. anterior: in front, from ante: before)", "p": 380}, {"t": "Ampulla membranacea posterior", "m": "Posterior membranous ampulla — dilatation at the end of the posterior semicircular duct located distal to the other two membranous ampullae", "e": "ampulla (L. ampulla: flask, jug, bulbous container) + membranacea (L. membranaceus: membranous, from membrana: membrane) + posterior (L. posterior: behind, later, from post: after)", "p": 380}, {"t": "Ampulla membranacea lateralis", "m": "Lateral membranous ampulla — ampulla of the lateral semicircular duct located proximal to the anterior membranous ampulla", "e": "ampulla (L. ampulla: flask, jug, bulbous container) + membranacea (L. membranaceus: membranous, from membrana: membrane) + lateralis (L. lateralis: of the side, from latus: side)", "p": 380}, {"t": "Crista ampullaris", "m": "Ampullary crest — crescent-shaped ridge projecting into the ampullary space, covered by sensory epithelium with a base of nerve fibers and connective tissue", "e": "crista (L. crista: crest, ridge, plume) + ampullaris (L. ampullaris: of the ampulla, from ampulla: flask, jug)", "p": 380}, {"t": "Cupula", "m": "Cupula — gelatinous body suspended above the ampullary crest as far as the roof of the ampulla, penetrated by hairs of the sensory cells", "e": "cupula (L. cupula: small tub, small cask, diminutive of cupa: tub, barrel)", "p": 380}, {"t": "Crura membranacea", "m": "Membranous crura — limbs of semicircular ducts opening into the utricle", "e": "crura (L. crura: plural of crus: leg, limb, shank) + membranacea (L. membranaceus: membranous, from membrana: membrane)", "p": 380}, {"t": "Crus membranaceum simplex", "m": "Simple membranous crus — posterior limb of lateral semicircular duct opening independently into the utricle", "e": "crus (L. crus: leg, limb, shank) + membranaceum (L. membranaceus: membranous, from membrana: membrane) + simplex (L. simplex: simple, single, from semel: once + plicare: to fold)", "p": 380}, {"t": "Crura membranacea ampullaria", "m": "Ampullary membranous crura — semicircular duct segments situated between the ampullae and the utricle", "e": "crura (L. crura: plural of crus: leg, limb) + membranacea (L. membranaceus: membranous, from membrana: membrane) + ampullaria (L. ampullaris: of the ampulla, from ampulla: flask, jug)", "p": 380}, {"t": "Crus membranaceum commune", "m": "Common membranous crus — common limb formed by the anterior and posterior semicircular ducts and opening into the utricle", "e": "crus (L. crus: leg, limb, shank) + membranaceum (L. membranaceus: membranous, from membrana: membrane) + commune (L. communis: common, shared, general)", "p": 380}, {"t": "Sulcus ampullaris", "m": "Sulcus ampullaris — indentation below the ampullary crest bearing branches from the ampullar nerve for innervation of the ampullary crest", "e": "sulcus (L. sulcus: groove, furrow, trench) + ampullaris (L. ampullaris: of the ampulla, from ampulla: flask, jug)", "p": 380}, {"t": "Sacculus", "m": "Saccule — round vesicle, 2–3 mm in size, equipped with a sensory field", "e": "sacculus (L. sacculus: small sack, diminutive of saccus = bag)", "p": 382}, {"t": "Macula staticae", "m": "Maculae — sensory fields for the perception of the position of the head in space", "e": "macula (L. macula: spot, patch) + staticae (L. staticus: of standing/balance, from Gk. statikos = causing to stand)", "p": 382}, {"t": "Macula utriculi", "m": "Utricular macula — horizontally oriented sensory field, 2.3–3 mm in size, occupying the floor of the utricle", "e": "macula (L. macula: spot, patch) + utriculi (L. utriculus: small bag/pouch, genitive of utriculus, diminutive of uter = bag)", "p": 382}, {"t": "Macula sacculi", "m": "Saccular macula — vertically oriented, arched sensory field, about 1.5 mm wide; in the medial wall of the saccule", "e": "macula (L. macula: spot, patch) + sacculi (L. sacculus: small sack, genitive of sacculus)", "p": 382}, {"t": "Membrana statoconiorum", "m": "Statoconial membrane — membrane covering the maculae and consisting of a gelatinous ground substance with statoconia on its surface", "e": "membrana (L. membrana: membrane, thin skin) + statoconiorum (Gk. statos: standing + konios: dust/grain, genitive plural)", "p": 382}, {"t": "Labyrinthus cochlearis", "m": "Cochlear labyrinth — complex contents of the osseous cochlea", "e": "labyrinthus (Gk. labyrinthos: labyrinth, maze) + cochlearis (L. cochlearis: of the cochlea, from cochlea = snail shell)", "p": 382}, {"t": "Spatium perilymphaticum", "m": "Perilymphatic space — space occupied by perilymph and partially permeated by connective tissue fibers", "e": "spatium (L. spatium: space) + perilymphaticum (Gk. peri: around + L. lympha: water/lymph + -aticum: pertaining to)", "p": 382}, {"t": "Scala vestibuli", "m": "Scala vestibuli — perilymphatic canal located above the osseous spiral lamina and cochlear duct", "e": "scala (L. scala: staircase, ladder) + vestibuli (L. vestibulum: entrance hall, genitive of vestibulum)", "p": 382}, {"t": "Scala tympani", "m": "Scala tympani — perilymphatic canal below the osseous spiral lamina and basilar membrane", "e": "scala (L. scala: staircase, ladder) + tympani (Gk. tympanon: drum, genitive of tympanum)", "p": 382}, {"t": "Aquaeductus cochleae", "m": "Cochlear aqueduct (perilymphatic duct) — pathway connecting the perilymphatic space with the subarachnoid space", "e": "aquaeductus (L. aqua: water + ductus: leading, from ducere = to lead) + cochleae (L. cochlea: snail shell, genitive of cochlea)", "p": 382}, {"t": "Apertura externa aquaeductus cochleae", "m": "External aperture of perilymphatic duct — opening for the tympanic nerve in the vicinity of the canaliculus", "e": "apertura (L. apertura: opening, from aperire = to open) + externa (L. externus: outer, external) + aquaeductus (L. aqua: water + ductus: leading) + cochleae (L. cochlea: snail shell, genitive)", "p": 382}, {"t": "Ductus cochlearis", "m": "Cochlear duct — spiral endolymphatic tube taking 2½–2¾ turns around a bony axis before ending blindly at the apex of the cochlea", "e": "ductus (L. ductus: duct, leading, from ducere = to lead) + cochlearis (L. cochlearis: of the cochlea, from cochlea = snail shell)", "p": 382}, {"t": "Caecum cupulare", "m": "Cupular cecum — blind end of cochlear duct located at the apex of the cochlea", "e": "caecum (L. caecum: blind, blind end) + cupulare (L. cupula: small tub/dome, diminutive of cupa = tub)", "p": 382}, {"t": "Caecum vestibulare", "m": "Vestibular cecum — blind end of the cochlear duct facing the vestibule", "e": "caecum (L. caecum: blind, blind end) + vestibulare (L. vestibulum: entrance hall, from vestibulum)", "p": 382}, {"t": "Paries tympanicus ductus cochlearis", "m": "Tympanic wall of cochlear duct (spiral membrane) — inferior wall of cochlear duct situated above the scala tympani", "e": "paries (L. paries: wall) + tympanicus (Gk. tympanon: drum + L. -icus: pertaining to) + ductus (L. ductus: duct) + cochlearis (L. cochlearis: of the cochlea)", "p": 382}, {"t": "Membrana spiralis", "m": "Spiral membrane — another name for the tympanic wall of the cochlear duct", "e": "membrana (L. membrana: membrane, thin skin) + spiralis (L. spiralis: spiral, from spira = coil, from Gk. speira)", "p": 382}, {"t": "Organum spirale", "m": "Spiral organ (of Corti) — sensory field on the basilar membrane that transforms sound waves into nerve impulses", "e": "organum (L. organum: organ, instrument, from Gk. organon) + spirale (L. spiralis: spiral, from spira = coil)", "p": 382}, {"t": "Lamina basilaris", "m": "Basilar membrane — plate of connective tissue between the cochlear duct and scala tympani", "e": "lamina (L. lamina: plate, thin layer) + basilaris (L. basilaris: basal, from basis = base, from Gk. basis)", "p": 382}, {"t": "Crista spiralis", "m": "Spiral crest (ligament) — spirally arranged system of fibers arising from the periosteum of the cochlear canal and radiating into the basilar lamina", "e": "crista (L. crista: crest, ridge) + spiralis (L. spiralis: spiral, from spira = coil)", "p": 382}, {"t": "Ligamentum spirale", "m": "Spiral ligament — part of the spiral crest", "e": "ligamentum (L. ligamentum: ligament, band, from ligare = to bind) + spirale (L. spiralis: spiral, from spira = coil)", "p": 382}, {"t": "Foramina nervosa", "m": "Nerve foramina — holes in the basilar lamina for transmission of cochlear nerve fibers from the hair cells to the spiral ganglion", "e": "foramina (L. foramen: hole, opening, plural foramina, from forare = to bore) + nervosa (L. nervosus: of nerves, from nervus = nerve)", "p": 382}, {"t": "Limbus laminae spiralis osseae", "m": "Limbus of osseous spiral lamina — thickening and transformation of the endosteum on the upper layer of the osseous spiral lamina", "e": "limbus (L. limbus: border, edge) + laminae (L. lamina: plate, genitive) + spiralis (L. spiralis: spiral) + osseae (L. osseus: bony, from os = bone, genitive)", "p": 382}, {"t": "Labium limbi vestibulare", "m": "Vestibular lip of limb of osseous spiral lamina — upper, shorter process of the limbus; site of attachment of the tectorial membrane", "e": "labium (L. labium: lip, edge) + limbi (L. limbus: border, genitive) + vestibulare (L. vestibulum: entrance hall, from vestibulum)", "p": 382}, {"t": "Labium limbi tympanicum", "m": "Tympanic lip of limb of osseous spiral lamina — lower, longer process of the limbus lying on the basilar membrane", "e": "labium (L. labium: lip, edge) + limbi (L. limbus: border, genitive) + tympanicum (Gk. tympanon: drum + L. -icum: pertaining to)", "p": 382}, {"t": "Dentes acustici", "m": "Auditory teeth — ridge-like rows of cells on the surface of the vestibular lip; tectorial membrane attaches near here", "e": "dentes (L. dens: tooth, plural dentes) + acustici (Gk. akoustikos: of hearing, from akouein = to hear)", "p": 382}, {"t": "Sulcus spiralis internus", "m": "Internal spiral sulcus — groove between the vestibular and tympanic lips", "e": "sulcus (L. sulcus: groove, furrow) + spiralis (L. spiralis: spiral, from spira = coil) + internus (L. internus: inner, internal)", "p": 382}, {"t": "Sulcus spiralis externus", "m": "External spiral sulcus — groove on the outer wall of the cochlear duct between the spiral prominence and the spiral organ", "e": "sulcus (L. sulcus: groove, furrow) + spiralis (L. spiralis: spiral, from spira = coil) + externus (L. externus: outer, external)", "p": 382}, {"t": "Ductus reuniens", "m": "Fine tube connecting the saccule with the cochlear duct", "e": "ductus (L. ductus: duct, from ducere = to lead) + reuniens (L. reuniens: reuniting, joining together, from re- = again + unire = to unite)", "p": 382}, {"t": "Statoconia", "m": "Calcium concretions, up to 15 µm in size, embedded in a gelatinous substance together with the sensory hairs", "e": "statoconia (Gk. statos: standing, stationary + konos/konia: dust, grain — ear stones for balance)", "p": 382}, {"t": "Neuroepithelium", "m": "Pseudostratified, prismatic, sensory epithelium of the macula consisting of supporting and sensory cells", "e": "neuro- (Gk. neuron: nerve) + epithelium (Gk. epi: upon + thele: nipple — tissue covering surfaces)", "p": 382}, {"t": "Modiolus", "m": "Bony axis around which the cochlear duct turns", "e": "modiolus (L. modiolus: hub of a wheel, small measure, diminutive of modus = measure)", "p": 382}, {"t": "Helicotrema", "m": "Apex of the cochlea where the scala vestibuli ends", "e": "helicotrema (Gk. helix: spiral, coil + trema: hole, opening)", "p": 382}, {"t": "Membrana reticularis", "m": "Reticular membrane — membrane covering the organ of Corti, formed by the heads of pillar/Deiters' cells", "e": "membrana (L. membrāna: membrane, skin) + reticularis (L. reticulāris: net-like, from reticulum = small net, from rete = net)", "p": 384}, {"t": "Vas spirale", "m": "Spiral vessel — small blood vessel below the tunnel, in the tympanic layer of the basilar membrane", "e": "vas (L. vās: vessel, duct) + spirale (L. spīrālis: spiral, coiled, from spira = coil, from Gk. speira = coil)", "p": 384}, {"t": "Paries vestibularis ductus cochlearis", "m": "Vestibular wall of cochlear duct (vestibular/Reissner's membrane) — upper wall of the cochlear duct", "e": "paries (L. pariēs: wall) + vestibularis (L. vestibulāris: of the vestibule, from vestibulum = entrance hall) + ductus (L. ductus: duct, canal, from ducere = to lead) + cochlearis (L. cochleāris: of the cochlea, from cochlea = snail shell, from Gk. kokhlias = snail)", "p": 384}, {"t": "Membrana vestibularis", "m": "Vestibular membrane — upper wall of the cochlear duct (Reissner's membrane)", "e": "membrana (L. membrāna: membrane, skin) + vestibularis (L. vestibulāris: of the vestibule, from vestibulum = entrance hall)", "p": 384}, {"t": "Paries externus ductus cochlearis", "m": "External wall of cochlear duct — lateral wall", "e": "paries (L. pariēs: wall) + externus (L. externus: outer, external, from exter = outside) + ductus (L. ductus: duct, canal, from ducere = to lead) + cochlearis (L. cochleāris: of the cochlea, from cochlea = snail shell, from Gk. kokhlias = snail)", "p": 384}, {"t": "Crista basilaris", "m": "Basilar crest — pointed edge of the spiral crest that joins the basilar membrane", "e": "crista (L. crista: crest, ridge) + basilaris (L. basilāris: basilar, of the base, from basis = base, from Gk. basis = step, base)", "p": 384}, {"t": "Prominentia spiralis", "m": "Spiral prominence — marginal ridge projecting above the external spiral sulcus", "e": "prominentia (L. prōminentia: prominence, projection, from prominēre = to jut out) + spiralis (L. spīrālis: spiral, coiled, from spira = coil)", "p": 384}, {"t": "Stria vascularis", "m": "Stria vascularis — broad, specialized band of highly vascularized stratified squamous epithelium above the spiral prominence", "e": "stria (L. stria: stripe, groove, furrow) + vascularis (L. vasculāris: of vessels, from vasculum = small vessel, from vas = vessel)", "p": 384}, {"t": "Ganglion spirale cochleae", "m": "Spiral ganglion of cochlea — accumulation of bipolar ganglion cells in the spiral canal of the modiolus", "e": "ganglion (Gk. ganglion: knot, swelling, nerve cluster) + spirale (L. spīrālis: spiral, from spira = coil) + cochleae (L. cochlea: snail shell, from Gk. kokhlias = snail, genitive form)", "p": 384}, {"t": "Vasa auris internae", "m": "Vessels of inner ear", "e": "vasa (L. vāsa: vessels, plural of vas = vessel) + auris (L. auris: ear) + internae (L. internus: internal, inner, genitive form)", "p": 384}, {"t": "A. labyrinthina", "m": "Labyrinthine artery — arises from the basilar artery, passes through the internal acoustic meatus and enters the petrous part of the temporal bone", "e": "arteria (L. artēria: artery, from Gk. artēria = windpipe, artery) + labyrinthina (L./Gk. labyrinthinus: of the labyrinth, from Gk. labyrinthos = labyrinth, maze)", "p": 384}, {"t": "Rami vestibulares", "m": "Vestibular branches — branches supplying the ampullae, maculae, semicircular ducts and the lower third of the basal turn of the cochlea", "e": "rami (L. rāmus: branch, plural rāmi) + vestibulares (L. vestibulāris: of the vestibule, from vestibulum = entrance hall)", "p": 384}, {"t": "Ramus cochlearis", "m": "Cochlear branch — passes into the modiolus where it supplies the spiral ganglion and the cochlear duct except for the lower third of the basal turn", "e": "ramus (L. rāmus: branch) + cochlearis (L. cochleāris: of the cochlea, from cochlea = snail shell, from Gk. kokhlias = snail)", "p": 384}, {"t": "Glomeruli arteriosi cochleae", "m": "Arterial glomeruli of cochlea — spirally oriented arterial network accompanying the spiral vein", "e": "glomeruli (L. glomerulus: small ball of thread, from glomus = ball of thread, plural glomeruli) + arteriosi (L. arteriōsus: arterial, of the artery, from arteria = artery) + cochleae (L. cochlea: snail shell, genitive form)", "p": 384}, {"t": "Vv. labyrinthinae", "m": "Labyrinthine veins — companion veins of the labyrinthine artery, pass through the internal acoustic meatus", "e": "venae (L. vēna: vein, abbreviated Vv.) + labyrinthinae (L./Gk. labyrinthinus: of the labyrinth, from Gk. labyrinthos = labyrinth, maze)", "p": 384}, {"t": "V. spiralis modioli", "m": "Spiral vein of modiolus — takes a spiral course in the modiolus and empties into the labyrinthine vein", "e": "vena (L. vēna: vein, abbreviated V.) + spiralis (L. spīrālis: spiral, from spira = coil) + modioli (L. modiolus: hub of a wheel, nave, genitive form; from modius = a measure, a peck)", "p": 384}, {"t": "Vv. vestibulares", "m": "Vestibular veins — arise from the semicircular ducts in the region of the utricle and saccule", "e": "venae (L. vēna: vein, abbreviated Vv.) + vestibulares (L. vestibulāris: of the vestibule, from vestibulum = entrance hall)", "p": 384}, {"t": "V. aqueductus vestibuli", "m": "Vein of vestibular aqueduct — companion vein of endolymphatic duct, opens into the inferior petrosal sinus", "e": "vena (L. vēna: vein, abbreviated V.) + aqueductus (L. aquaeductus: aqueduct, from aqua = water + ducere = to lead) + vestibuli (L. vestibulum: entrance hall, genitive form)", "p": 384}, {"t": "V. aqueductus cochleae", "m": "Vein of cochlear aqueduct — companion vein of perilymphatic duct, carries blood from the basal turn of the cochlea through the cochlear canaliculus", "e": "vena (L. vēna: vein, abbreviated V.) + aqueductus (L. aquaeductus: aqueduct, from aqua = water + ducere = to lead) + cochleae (L. cochlea: snail shell, from Gk. kokhlias = snail, genitive form)", "p": 384}, {"t": "Labyrinthus osseus", "m": "Osseous labyrinth — bony capsule enclosing the membranous labyrinth", "e": "labyrinthus (L./Gk. labyrinthos: labyrinth, maze) + osseus (L. osseus: bony, of bone, from os = bone)", "p": 384}, {"t": "Vestibulum", "m": "Vestibule — part of osseous labyrinth enclosing the utricle and saccule", "e": "vestibulum (L. vestibulum: entrance court, forecourt, antechamber)", "p": 384}, {"t": "Recessus sphericus", "m": "Spherical recess of vestibule — rounded recess in the medial wall of the vestibule, occupied by the saccule", "e": "recessus (L. recessus: recess, retreat, from recedere = to recede, withdraw) + sphericus (L./Gk. sphaericus: spherical, round, from Gk. sphaira = ball, sphere)", "p": 384}, {"t": "Recessus ellipticus", "m": "Elliptical recess of vestibule — oval depression in the medial wall of the vestibule, occupied by the utricle", "e": "recessus (L. recessus: recess, retreat, from recedere = to recede) + ellipticus (L./Gk. ellipticus: elliptical, from Gk. elleipsis = falling short, ellipse)", "p": 384}, {"t": "Crista vestibuli", "m": "Crest of vestibule — ridge between the spherical and elliptical recesses", "e": "crista (L. crista: crest, ridge) + vestibuli (L. vestibulum: entrance hall, genitive form)", "p": 384}, {"t": "Pyramis vestibuli", "m": "Pyramid of vestibule — upper broadened part of the crest of the vestibule", "e": "pyramis (L./Gk. pyramis: pyramid, from Gk. pyramis = pyramid) + vestibuli (L. vestibulum: entrance hall, genitive form)", "p": 384}, {"t": "Recessus cochlearis", "m": "Cochlear recess — depression lying below and in front of the spherical recess, occupied by the lower end of the cochlear duct", "e": "recessus (L. recessus: recess, retreat, from recedere = to withdraw) + cochlearis (L. cochlearis: of the cochlea, from cochlea = snail shell, from Gk. kokhliās = spiral shell)", "p": 386}, {"t": "Maculae cribrosae", "m": "Perforated bony areas transmitting fibers of the vestibulocochlear nerve", "e": "maculae (L. macula: spot, patch; pl. maculae) + cribrosae (L. cribrōsus: sieve-like, perforated, from cribrum = sieve)", "p": 386}, {"t": "Macula cribrosa superior", "m": "Perforated bony area transmitting fibers of the utriculoampullar nerve", "e": "macula (L. macula: spot, patch) + cribrosa (L. cribrōsa: sieve-like, perforated, from cribrum = sieve) + superior (L. superior: upper, higher)", "p": 386}, {"t": "Macula cribrosa media", "m": "Perforated bony area near the base of the cochlea for passage of fibers of the saccular nerve", "e": "macula (L. macula: spot, patch) + cribrosa (L. cribrōsa: sieve-like, perforated, from cribrum = sieve) + media (L. medius: middle)", "p": 386}, {"t": "Macula cribrosa inferior", "m": "Perforated bony area in the wall of the posterior osseous ampulla for passage of fibers of the posterior ampullar nerve", "e": "macula (L. macula: spot, patch) + cribrosa (L. cribrōsa: sieve-like, perforated, from cribrum = sieve) + inferior (L. inferior: lower)", "p": 386}, {"t": "Canales semicirculares ossei", "m": "Osseous semicircular canals — bony canals containing perilymph and enclosing the membranous semicircular ducts", "e": "canales (L. canalis: channel, canal; pl. canales) + semicirculares (L. semi = half + circularis = circular, from circulus = circle) + ossei (L. osseus: bony, of bone, from os = bone)", "p": 386}, {"t": "Canalis semicircularis anterior", "m": "Anterior (superior) semicircular canal — canal sharing a common crus with the posterior semicircular canal, oriented vertically", "e": "canalis (L. canalis: channel, canal) + semicircularis (L. semi = half + circularis = circular, from circulus = circle) + anterior (L. anterior: front, former, from ante = before)", "p": 386}, {"t": "Canalis semicircularis posterior", "m": "Posterior semicircular canal — posterior and most inferior semicircular canal, lying somewhat parallel to the axis of the petrous part of the temporal bone", "e": "canalis (L. canalis: channel, canal) + semicircularis (L. semi = half + circularis = circular, from circulus = circle) + posterior (L. posterior: behind, later, from post = after)", "p": 386}, {"t": "Canalis semicircularis lateralis", "m": "Lateral semicircular canal — horizontally oriented canal that sometimes creates a bulge in the medial wall of the tympanic cavity", "e": "canalis (L. canalis: channel, canal) + semicircularis (L. semi = half + circularis = circular, from circulus = circle) + lateralis (L. lateralis: of the side, from latus = side)", "p": 386}, {"t": "Ampullae osseae", "m": "Osseous ampullae — dilatations close to the base of the semicircular crura that lodge the membranous ampullae", "e": "ampullae (L. ampulla: flask, jug; pl. ampullae) + osseae (L. osseus: bony, of bone, from os = bone)", "p": 386}, {"t": "Ampulla ossea anterior", "m": "Anterior osseous ampulla — ampulla of the anterior semicircular canal located proximal to the ampulla of the lateral semicircular canal", "e": "ampulla (L. ampulla: flask, jug) + ossea (L. ossea: bony, of bone, from os = bone) + anterior (L. anterior: front, from ante = before)", "p": 386}, {"t": "Ampulla ossea posterior", "m": "Posterior osseous ampulla — ampulla of the posterior semicircular canal lying below the plane of the lateral semicircular canal", "e": "ampulla (L. ampulla: flask, jug) + ossea (L. ossea: bony, of bone, from os = bone) + posterior (L. posterior: behind, from post = after)", "p": 386}, {"t": "Ampulla ossea lateralis", "m": "Lateral osseous ampulla — ampulla of lateral semicircular canal, lying near the anterior semicircular ampulla", "e": "ampulla (L. ampulla: flask, jug) + ossea (L. ossea: bony, of bone, from os = bone) + lateralis (L. lateralis: of the side, from latus = side)", "p": 386}, {"t": "Crura ossea", "m": "Osseous crura of the semicircular canals", "e": "crura (L. crus: leg, limb, shank; pl. crura) + ossea (L. osseus: bony, of bone, from os = bone)", "p": 386}, {"t": "Crus osseum commune", "m": "Common osseous crus — posteriorly situated common limb formed by the union of the crura of the superior and posterior semicircular canals", "e": "crus (L. crus: leg, limb, shank) + osseum (L. osseus: bony, of bone, from os = bone) + commune (L. communis: common, shared)", "p": 386}, {"t": "Crus osseum simplex", "m": "Simple osseous crus — posteriorly situated crus of the lateral semicircular canal opening independently into the wall of the vestibule", "e": "crus (L. crus: leg, limb, shank) + osseum (L. osseus: bony, of bone, from os = bone) + simplex (L. simplex: simple, single, from semel = once + plicare = to fold)", "p": 386}, {"t": "Crura ossea ampullaria", "m": "Ampullary osseous crura — crura of the semicircular canals dilated for accommodation of the ampullae of the membranous labyrinth", "e": "crura (L. crus: leg, limb, shank; pl. crura) + ossea (L. osseus: bony, of bone, from os = bone) + ampullaria (L. ampullarius: of or pertaining to an ampulla, from ampulla = flask)", "p": 386}, {"t": "Cochlea", "m": "Cochlea — makes 2½–2¾ turns, measures 8–9 mm at its base and is altogether 4–5 mm high", "e": "cochlea (L. cochlea: snail shell, screw, from Gk. kokhliās = spiral shell, snail)", "p": 386}, {"t": "Cupula cochlea", "m": "Apex of cochlea — anteroinferiorly and laterally directed structure within the cranium", "e": "cupula (L. cupula: small tub, dome, diminutive of cupa = tub, cask) + cochlea (L. cochlea: snail shell, from Gk. kokhliās = spiral shell)", "p": 386}, {"t": "Basis cochlea", "m": "Base of cochlea — structure with a surface pointing approximately in the direction of the internal acoustic meatus", "e": "basis (Gk./L. basis: base, foundation, from Gk. basis = step, pedestal) + cochlea (L. cochlea: snail shell, from Gk. kokhliās = spiral shell)", "p": 386}, {"t": "Canalis spiralis cochleae", "m": "Spiral canal of cochlea — partitioned into three canals by the osseous spiral lamina and the basilar membrane on one side and the vestibular wall of the cochlear duct on the other", "e": "canalis (L. canalis: channel, canal) + spiralis (L. spiralis: spiral, coiling, from spira = coil, from Gk. speira = coil) + cochleae (L. cochlea: snail shell, from Gk. kokhliās = spiral shell; gen. cochleae)", "p": 386}, {"t": "Basis modioli", "m": "Base of modiolus — beginning of the cochlear axis", "e": "basis (Gk./L. basis: base, foundation, from Gk. basis = step, pedestal) + modioli (L. modiolus: hub of a wheel; gen. modioli)", "p": 386}, {"t": "Lamina modioli", "m": "Lamina of modiolus — bony plate extending upward as a continuation of the bony spiral lamina", "e": "lamina (L. lamina: thin plate, layer, blade) + modioli (L. modiolus: hub of a wheel; gen. modioli)", "p": 386}, {"t": "Canalis spiralis modioli", "m": "Spiral canal of modiolus — fine channel in the axial wall near the base of the bony spiral lamina, containing the spiral ganglion", "e": "canalis (L. canalis: channel, canal) + spiralis (L. spiralis: spiral, from spira = coil, from Gk. speira = coil) + modioli (L. modiolus: hub of a wheel; gen. modioli)", "p": 386}, {"t": "Canales longitudinales modioli", "m": "Longitudinal canals of modiolus — centrally located bony channels containing fibers of the cochlear nerve leaving the spiral ganglion", "e": "canales (L. canalis: channel, canal; pl. canales) + longitudinales (L. longitudinalis: lengthwise, from longitudo = length, from longus = long) + modioli (L. modiolus: hub of a wheel; gen. modioli)", "p": 386}, {"t": "Lamina spiralis ossea", "m": "Bony spiral lamina — bilayered bony plate projecting from the modiolus into the spiral canal of the cochlea", "e": "lamina (L. lamina: thin plate, layer) + spiralis (L. spiralis: spiral, from spira = coil) + ossea (L. osseus: bony, of bone, from os = bone)", "p": 388}, {"t": "Hamulus laminae spiralis", "m": "Hook of spiral lamina — free hook-shaped upper end of the osseous spiral lamina at the apex of the cochlea", "e": "hamulus (L. hamulus: small hook, diminutive of hamus = hook) + laminae (L. lamina: thin plate) + spiralis (L. spiralis: spiral, from spira = coil)", "p": 388}, {"t": "Lamina spiralis secundaria", "m": "Secondary spiral lamina — bony ridge situated in the lower half of the basal turn projecting from the outer wall of the spiral canal", "e": "lamina (L. lamina: thin plate) + spiralis (L. spiralis: spiral, from spira = coil) + secundaria (L. secundarius: secondary, from secundus = following, second)", "p": 388}, {"t": "Porus acusticus", "m": "Outer opening of internal acoustic meatus into the posterior wall of the petrous part of the temporal bone", "e": "porus (Gk. poros: passage, pore) + acusticus (Gk. akoustikos: of hearing, from akouein = to hear)", "p": 388}, {"t": "Fundus meatus acustici interni", "m": "Fundus of internal auditory meatus — floor of meatus, subdivided into several fields", "e": "fundus (L. fundus: bottom, floor, base) + meatus (L. meatus: passage, channel) + acustici (Gk. akoustikos: of hearing) + interni (L. internus: internal)", "p": 388}, {"t": "Crista transversa", "m": "Transverse crest — transversely oriented ridge dividing the fundus of the internal acoustic meatus into an upper and lower part", "e": "crista (L. crista: crest, ridge) + transversa (L. transversus: transverse, lying across, from trans = across + vertere = to turn)", "p": 388}, {"t": "Area nervi facialis", "m": "Facial nerve area — region containing the beginning of the facial nerve canal", "e": "area (L. area: open space, region) + nervi (L. nervus: nerve, sinew) + facialis (L. facialis: of the face, from facies = face)", "p": 388}, {"t": "Area cochleae", "m": "Cochlear area — large region below the transverse crest containing the foraminous spiral tract", "e": "area (L. area: open space, region) + cochleae (L. cochlea: snail shell, spiral, from Gk. kokhlias = snail with spiral shell)", "p": 388}, {"t": "Tractus spiralis foraminosus", "m": "Foraminous spiral tract — area perforated by fibers of the spiral ganglion forming the cochlear part of the vestibulocochlear nerve", "e": "tractus (L. tractus: tract, path, from trahere = to draw) + spiralis (L. spiralis: spiral) + foraminosus (L. foraminosus: full of holes, from foramen = opening, hole)", "p": 388}, {"t": "Area vestibularis superior", "m": "Superior vestibular area — region lateral to the facial canal perforated by fibers of the utriculo-ampullar nerve", "e": "area (L. area: open space, region) + vestibularis (L. vestibularis: of the vestibule, from vestibulum = entrance hall) + superior (L. superior: upper, higher)", "p": 388}, {"t": "Area vestibularis inferior", "m": "Inferior vestibular area — region located lateral to foraminous spiral tract perforated by fibers of the sacular nerve", "e": "area (L. area: open space, region) + vestibularis (L. vestibularis: of the vestibule, from vestibulum = entrance hall) + inferior (L. inferior: lower)", "p": 388}, {"t": "Foramen singulare", "m": "Small opening for the posterior ampullar nerve — lies behind the inferior vestibular area", "e": "foramen (L. foramen: opening, hole, from forare = to bore) + singulare (L. singularis: single, alone, from singulus = one at a time)", "p": 388}, {"t": "Auris media", "m": "Middle ear — part of the ear comprising the tympanic cavity, auditory tube and mastoid cells", "e": "auris (L. auris: ear) + media (L. medius: middle)", "p": 388}, {"t": "Cavum tympani", "m": "Tympanic cavity (alternative term)", "e": "cavum (L. cavum: hollow, cavity, from cavus = hollow) + tympani (Gk. tympanon: drum, from typtein = to strike)", "p": 388}, {"t": "Paries tegmentalis", "m": "Tegmental wall — thin roof of the tympanic cavity lying lateral to the arcuate eminence of the petrous part of the temporal bone", "e": "paries (L. paries: wall) + tegmentalis (L. tegmentalis: of a covering, from tegmentum = covering, from tegere = to cover)", "p": 388}, {"t": "Recessus epitympanicus", "m": "Epitympanic recess (attic) — dome of tympanic cavity located above the upper margin of the tympanic membrane", "e": "recessus (L. recessus: recess, withdrawal, from recedere = to recede) + epitympanicus (Gk. epi = upon, above + tympanon = drum)", "p": 388}, {"t": "Pars cupularis", "m": "Cupular part — upper portion of epitympanic recess", "e": "pars (L. pars: part) + cupularis (L. cupula: small tub/dome, diminutive of cupa = tub, cask)", "p": 388}, {"t": "Paries jugularis", "m": "Jugular wall — floor of the tympanic cavity facing the jugular fossa", "e": "paries (L. paries: wall) + jugularis (L. jugularis: of the jugular, from jugulum = throat, collarbone, from jugum = yoke)", "p": 388}, {"t": "Prominentia styloidea", "m": "Styloid prominence — elevation on the floor of the tympanic cavity produced by the styloid process", "e": "prominentia (L. prominentia: prominence, projection, from prominere = to project) + styloidea (Gk. stylos: pillar, stake + eidos = form, shape)", "p": 388}, {"t": "Paries labyrinthicus", "m": "Labyrinthine wall — medial wall of tympanic cavity", "e": "paries (L. paries: wall) + labyrinthicus (Gk. labyrinthos: labyrinth, maze)", "p": 388}, {"t": "Fenestra vestibuli", "m": "Oval window — closed by the base of the stapes", "e": "fenestra (L. fenestra: window, opening) + vestibuli (L. vestibulum: entrance hall, vestibule)", "p": 388}, {"t": "Fossula fenestrae vestibuli", "m": "Small depression in medial wall of tympanic cavity between the malleus and incus", "e": "fossula (L. fossula: small pit/depression, diminutive of fossa = ditch, pit) + fenestrae (L. fenestra: window) + vestibuli (L. vestibulum: entrance hall, vestibule)", "p": 388}, {"t": "Promontorium", "m": "Promontory — prominence caused by the basal turn of the cochlea", "e": "promontorium (L. promontorium: promontory, headland, from pro = forward + mons/montis = mountain)", "p": 388}, {"t": "Sulcus promontorii", "m": "Groove on the promontory produced by the tympanic nerve from the tympanic plexus", "e": "sulcus (L. sulcus: groove, furrow) + promontorii (L. promontorium: promontory, from pro = forward + mons = mountain)", "p": 388}, {"t": "Subiculum promontorii", "m": "Small bony ridge behind the promontory and round window", "e": "subiculum (L. subiculum: small support/underlayer, from subicere = to place under, from sub = under + iacere = to throw) + promontorii (L. promontorium: promontory)", "p": 388}, {"t": "Sinus tympani", "m": "Tympanic sinus — deep fossa behind the promontory and round window", "e": "sinus (L. sinus: hollow, cavity, bay) + tympani (L. tympanum: drum, from Gk. tympanon: drum)", "p": 390}, {"t": "Fenestra cochleae", "m": "Round window (fenestra of cochlea) — round opening at the end of the scala tympani", "e": "fenestra (L. fenestra: window, opening) + cochleae (L. cochlea: snail shell, from Gk. kokhlias: snail)", "p": 390}, {"t": "Fossula fenestrae cochleae", "m": "Fossula of round window — small fossa leading into the round window", "e": "fossula (L. fossula: small pit, diminutive of fossa: ditch) + fenestrae (L. fenestra: window) + cochleae (L. cochlea: snail shell, from Gk. kokhlias: snail)", "p": 390}, {"t": "Crista fenestrae cochleae", "m": "Crest of round window — bony ridge along the edge of the round window for attachment of the secondary tympanic membrane", "e": "crista (L. crista: crest, ridge) + fenestrae (L. fenestra: window) + cochleae (L. cochlea: snail shell, from Gk. kokhlias: snail)", "p": 390}, {"t": "Processus cochleariformis", "m": "Cochleariform process — spoon-shaped bony process found above the promontory at the end of the semicanal for the tensor tympani muscle", "e": "processus (L. processus: projection, going forward) + cochleariformis (L. cochlear: spoon + forma: shape, thus spoon-shaped)", "p": 390}, {"t": "Membrana tympani secundaria", "m": "Secondary tympanic membrane — sheath across the round window forming a membranous partition between the scala tympani and the tympanic cavity", "e": "membrana (L. membrana: membrane, skin) + tympani (L. tympanum: drum, from Gk. tympanon) + secundaria (L. secundarius: secondary, from secundus: second)", "p": 390}, {"t": "Paries mastoideus", "m": "Mastoid wall — components connected with the mastoid process", "e": "paries (L. paries: wall) + mastoideus (Gk. mastos: breast + eidos: form, shape; thus breast-shaped)", "p": 390}, {"t": "Adnexa mastoidea", "m": "Mastoid wall [adnexa mastoidea] — components connected with the mastoid process", "e": "adnexa (L. adnexa: appendages, attached parts, from ad: to + nectere: to bind) + mastoidea (Gk. mastos: breast + eidos: form)", "p": 390}, {"t": "Antrum mastoideum", "m": "Mastoid antrum — closed space, the posterosuperior part continuous with the tympanic cavity", "e": "antrum (L. antrum: cave, cavity, from Gk. antron: cave) + mastoideum (Gk. mastos: breast + eidos: form)", "p": 390}, {"t": "Aditus ad antrum", "m": "Aditus ad antrum — entrance to the mastoid antrum from the tympanic cavity", "e": "aditus (L. aditus: entrance, access, from adire: to go to) + ad (L. ad: to, toward) + antrum (L. antrum: cave, cavity, from Gk. antron)", "p": 390}, {"t": "Prominentia canalis semicircularis lateralis", "m": "Prominentia canalis semicircularis lateralis — prominence on the wall of lateral semicircular canal situated above the prominence of the facial canal", "e": "prominentia (L. prominentia: prominence, projection, from prominere: to jut out) + canalis (L. canalis: canal, channel) + semicircularis (L. semi: half + circularis: circular, from circulus: circle) + lateralis (L. lateralis: lateral, from latus: side)", "p": 390}, {"t": "Prominentia canalis facialis", "m": "Prominence of facial nerve canal — bulge lying between the oval window and prominence of the lateral semicircular canal", "e": "prominentia (L. prominentia: projection, from prominere: to jut out) + canalis (L. canalis: canal) + facialis (L. facialis: of the face, from facies: face)", "p": 390}, {"t": "Eminentia pyramidalis", "m": "Pyramidal eminence (pyramid) — small bony pyramidal projection at the level of the oval window containing the stapedius muscle", "e": "eminentia (L. eminentia: eminence, prominence, from eminere: to stand out) + pyramidalis (L. pyramidalis: pyramid-shaped, from Gk. pyramis: pyramid)", "p": 390}, {"t": "Fossa incudis", "m": "Incudal fossa — small depression in the aditus ad antrum for the posterior ligament of the incus", "e": "fossa (L. fossa: pit, ditch, from fodere: to dig) + incudis (L. incus, incudis: anvil)", "p": 390}, {"t": "Sinus posterior", "m": "Sinus posterior — small groove between the incudal fossa and pyramid", "e": "sinus (L. sinus: hollow, cavity, bay) + posterior (L. posterior: behind, back, from post: after, behind)", "p": 390}, {"t": "Apertura tympanica canaliculi chordae tympani", "m": "Tympanic aperture of canaliculus of chorda tympani — opening of chorda tympani canal into tympanic cavity at the posterior margin of the tympanic membrane at the level of the pyramid", "e": "apertura (L. apertura: opening, from aperire: to open) + tympanica (L. tympanicus: of the drum, from Gk. tympanon: drum) + canaliculi (L. canaliculus: small canal, diminutive of canalis: canal) + chordae (Gk. khorde: string, cord) + tympani (L. tympanum: drum, from Gk. tympanon)", "p": 390}, {"t": "Cellulae mastoideae", "m": "Mastoid air cells — like the tympanic cavity, lined by squamous and/or cuboidal epithelium", "e": "cellulae (L. cellula: small cell, diminutive of cella: room) + mastoideae (Gk. mastos: breast + eidos: form)", "p": 390}, {"t": "Cellulae tympanicae", "m": "Tympanic cells — small cell-like depressions in the floor of the tympanic cavity", "e": "cellulae (L. cellula: small cell, diminutive of cella: room) + tympanicae (L. tympanicus: of the drum, from Gk. tympanon: drum)", "p": 390}, {"t": "Paries caroticus", "m": "Carotid wall — anterior wall formed partly by the carotid canal, partly by the opening of the auditory tube", "e": "paries (L. paries: wall) + caroticus (Gk. karotikos: of the carotid, from karoun: to stupefy, referring to carotid arteries)", "p": 390}, {"t": "Membrana tympanica", "m": "Tympanic membrane (eardrum) — obliquely oriented membrane at the end of the external acoustic meatus, diameter 9–11 mm", "e": "membrana (L. membrana: membrane, skin) + tympanica (L. tympanicus: of the drum, from Gk. tympanon: drum)", "p": 390}, {"t": "Pars flaccida", "m": "Pars flaccida [Shrapnell's membrane] — smaller, more flaccid part of tympanic membrane located above the anterior and posterior mallear folds", "e": "pars (L. pars: part, portion) + flaccida (L. flaccidus: flaccid, soft, from flaccus: flabby)", "p": 390}, {"t": "Pars tensa", "m": "Pars tensa — by far the largest part of the tympanic membrane, situated within the tympanic ring", "e": "pars (L. pars: part, portion) + tensa (L. tensus: stretched, taut, from tendere: to stretch)", "p": 390}, {"t": "Plica mallearis anterior", "m": "Anterior malleolar fold — fold on the inner surface of the tympanic membrane with a concave lower edge extending anteriorly from the base of the manubrium of the malleus", "e": "plica (L. plica: fold, from plicare: to fold) + mallearis (L. mallearis: of the malleus, from malleus: hammer) + anterior (L. anterior: in front, from ante: before)", "p": 390}, {"t": "Plica mallearis posterior", "m": "Posterior malleolar fold — fold on the inner surface of the tympanic membrane with a concave lower edge extending posteriorly from the root of the manubrium of the malleus", "e": "plica (L. plica: fold, from plicare: to fold) + mallearis (L. mallearis: of the malleus, from malleus: hammer) + posterior (L. posterior: behind, from post: after)", "p": 390}, {"t": "Prominentia mallearis", "m": "Mallear prominence — small elevation on the outside of the tympanic membrane caused by the lateral process of the maleus", "e": "prominentia (L. prominentia: projection, from prominere: to jut out) + mallearis (L. mallearis: of the malleus, from malleus: hammer)", "p": 390}, {"t": "Stria mallearis", "m": "Stria mallearis — bright band on the outer surface of the tympanic membrane due to the underlying manubrium of the malleus fused with the tympanic membrane", "e": "stria (L. stria: groove, stripe, furrow) + mallearis (L. mallearis: of the malleus, from malleus: hammer)", "p": 390}, {"t": "Umbo membranae tympani", "m": "Umbo of tympanic membrane — structure at the tip of the manubrium of the malleus where the tympanic membrane is drawn inward", "e": "umbo (L. umbo: boss of a shield, central projection) + membranae (L. membrana: membrane, skin) + tympani (L. tympanum: drum, from Gk. tympanon)", "p": 390}, {"t": "Stratum cutaneum", "m": "Cutaneous layer — layer of stratified squamous epithelium on the external surface of the tympanic membrane", "e": "stratum (L. stratum: layer, from sternere: to spread) + cutaneum (L. cutaneus: of the skin, from cutis: skin)", "p": 390}, {"t": "Anulus fibrocartilagineus", "m": "Fibrocartilaginous ring — attaches the tympanic membrane in the tympanic sulcus", "e": "anulus (L. anulus: ring, from anus: ring) + fibrocartilagineus (L. fibra: fiber + cartilago: cartilage + -eus: pertaining to)", "p": 390}, {"t": "Stratum radiatum", "m": "Radiate layer — outer group of radially oriented fibers of the tympanic membrane", "e": "stratum (L. stratum: layer, from sternere: to spread) + radiatum (L. radiatus: radiate, from radius: ray, spoke)", "p": 390}, {"t": "Stratum mucosum", "m": "Mucosal layer — layer of simple squamous epithelium covering the inner surface of the tympanic membrane", "e": "stratum (L. stratum: layer, from sternere: to spread) + mucosum (L. mucosus: mucous, slimy, from mucus: slime, mucus)", "p": 390}, {"t": "Ossicula auditoria", "m": "Auditory ossicles", "e": "ossicula (L. ossiculum: small bone, diminutive of os = bone) + auditoria (L. auditorius: of hearing, from audire = to hear)", "p": 392}, {"t": "Stapes", "m": "Stirrup — a stirrup-shaped auditory ossicle", "e": "stapes (L. stapes: stirrup, possibly from sta- = stand + pes = foot)", "p": 392}, {"t": "Caput stapedis", "m": "Head of stapes", "e": "caput (L. caput: head) + stapedis (L. stapes, gen. stapedis: of the stirrup)", "p": 392}, {"t": "Crus anterius", "m": "Anterior crus (limb) — the virtually straight anterior limb of the stapes", "e": "crus (L. crus: leg, limb) + anterius (L. anterior: front, from ante = before)", "p": 392}, {"t": "Crus posterius", "m": "Posterior crus (limb) — the more curved posterior limb of the stapes", "e": "crus (L. crus: leg, limb) + posterius (L. posterior: behind, from post = after)", "p": 392}, {"t": "Basis stapedis", "m": "Base (footplate) of stapes — the plate of bone that inserts into the fenestra vestibuli", "e": "basis (Gk./L. basis: base, foundation) + stapedis (L. stapes, gen. stapedis: of the stirrup)", "p": 392}, {"t": "Corpus incudis", "m": "Body of incus", "e": "corpus (L. corpus: body) + incudis (L. incus, gen. incudis: anvil, from incudere = to forge)", "p": 392}, {"t": "Crus longum", "m": "Long crus (limb) — long process which projects almost vertically downward", "e": "crus (L. crus: leg, limb) + longum (L. longus: long)", "p": 392}, {"t": "Processus lenticularis", "m": "Lenticular process — small bony projection on the tip of the long crus", "e": "processus (L. processus: projection, going forward) + lenticularis (L. lenticularis: lens-shaped, from lens/lentis = lentil)", "p": 392}, {"t": "Crus breve", "m": "Short crus (limb) — small posteriorly directed process attached to the incudal fossa by a ligament", "e": "crus (L. crus: leg, limb) + breve (L. brevis: short, brief)", "p": 392}, {"t": "Malleus", "m": "Malleus (hammer) — lies between the tympanic membrane and the incus", "e": "malleus (L. malleus: hammer, mallet)", "p": 392}, {"t": "Manubrium mallei", "m": "Handle (manubrium) of malleus — outer surface is fused to the tympanic membrane", "e": "manubrium (L. manubrium: handle, from manus = hand) + mallei (L. malleus, gen. mallei: of the hammer)", "p": 392}, {"t": "Caput mallei", "m": "Head of malleus — has a convex articular surface for accommodation of the body of the incus", "e": "caput (L. caput: head) + mallei (L. malleus, gen. mallei: of the hammer)", "p": 392}, {"t": "Collum mallei", "m": "Neck of malleus — structure connecting the head and manubrium of the malleus", "e": "collum (L. collum: neck) + mallei (L. malleus, gen. mallei: of the hammer)", "p": 392}, {"t": "Processus anterior", "m": "Anterior process of malleus — long, very thin process extending into the petrotympanic fissure", "e": "processus (L. processus: projection, going forward) + anterior (L. anterior: front, from ante = before)", "p": 392}, {"t": "Articulationes ossiculorum auditoriorum", "m": "Articulations of auditory ossicles — they are not true joints but syndesmoses", "e": "articulationes (L. articulatio: joint, from articulus = small joint) + ossiculorum (L. ossiculum, gen. pl. ossiculorum: of the small bones) + auditoriorum (L. auditorius, gen. pl.: of hearing, from audire = to hear)", "p": 392}, {"t": "Articulatio incudomallearis", "m": "Incudomallear joint — joint between the incus and malleus", "e": "articulatio (L. articulatio: joint, from articulus = small joint) + incudomallearis (L. compound: incudo- from incus = anvil + mallearis from malleus = hammer)", "p": 392}, {"t": "Articulatio incudostapedialis", "m": "Incudostapedial articulation — union between the lenticular process of the long crus of the incus and the stapes", "e": "articulatio (L. articulatio: joint) + incudostapedialis (L. compound: incudo- from incus = anvil + stapedialis from stapes = stirrup)", "p": 392}, {"t": "Syndesmosis tympanostapedialis", "m": "Tympanostapedial syndesmosis — connective tissue attaching the base of the stapes to the oval window", "e": "syndesmosis (Gk. syndesmosis: ligamentous union, from syn = together + desmos = band/ligament) + tympanostapedialis (L./Gk. compound: tympano- from Gk. tympanon = drum + stapedialis from L. stapes = stirrup)", "p": 392}, {"t": "Ligg. ossiculorum auditoriorum", "m": "Ligaments of auditory ossicles", "e": "ligg. (L. ligamenta, abbreviation: ligaments, from ligare = to bind) + ossiculorum (L. ossiculum, gen. pl.: of the small bones) + auditoriorum (L. auditorius, gen. pl.: of hearing, from audire = to hear)", "p": 392}, {"t": "Lig. mallei anterius", "m": "Anterior ligament of malleus — arises from the anterior process of the malleus, lies in the anterior mallear fold", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + mallei (L. malleus, gen. mallei: of the hammer) + anterius (L. anterior: front, from ante = before)", "p": 392}, {"t": "Lig. mallei superius", "m": "Superior ligament of malleus — passes from the head of the malleus to the roof of the epitympanic recess", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + mallei (L. malleus, gen. mallei: of the hammer) + superius (L. superior: upper, from super = above)", "p": 392}, {"t": "Lig. mallei laterale", "m": "Lateral ligament of malleus — unites the neck of the malleus with the upper margin of the tympanic notch", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + mallei (L. malleus, gen. mallei: of the hammer) + laterale (L. lateralis: of the side, from latus = side)", "p": 392}, {"t": "Lig. incudis superius", "m": "Superior ligament of incus — courses approximately parallel to the superior ligament of the malleus and connects the body of the incus with the roof of the epitympanic recess", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + incudis (L. incus, gen. incudis: of the anvil) + superius (L. superior: upper, from super = above)", "p": 392}, {"t": "Lig. incudis posterius", "m": "Posterior ligament of incus — passes from the short limb of the incus to the lateral wall of the tympanic cavity", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + incudis (L. incus, gen. incudis: of the anvil) + posterius (L. posterior: behind, from post = after)", "p": 392}, {"t": "Membrana stapedialis", "m": "Stapedial membrane — thin membrane between the limbs and base of the stapes", "e": "membrana (L. membrana: membrane, thin skin, from membrum = limb) + stapedialis (L. stapedialis: of the stirrup, from stapes = stirrup)", "p": 392}, {"t": "Lig. anulare stapediale", "m": "Anular ligament of stapes — situated between the base of the stapes and the margin of the oval window", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + anulare (L. anularis: ring-shaped, from anulus = ring) + stapediale (L. stapedialis: of the stirrup, from stapes = stirrup)", "p": 392}, {"t": "Incus", "m": "Incus (anvil) — the central ossicle situated between the head of the malleus and the head of the stapes", "e": "incus (L. incus: anvil, from incudere = to forge upon)", "p": 392}, {"t": "Petrotympanica fissura", "m": "Petrotympanic fissure — fissure into which the anterior process of the malleus extends", "e": "petro- (Gk. petra: rock/stone, referring to the petrous part of temporal bone) + tympanica (Gk./L. tympanicus: of the drum, from Gk. tympanon = drum) + fissura (L. fissura: cleft, fissure, from findere = to split)", "p": 392}, {"t": "Musculi ossiculorum auditoriorum", "m": "Muscles of auditory ossicles", "e": "musculi (L. musculus: muscle, lit. little mouse) + ossiculorum (L. ossiculum: little bone, dim. of os = bone) + auditoriorum (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "M. tensor tympani", "m": "Muscle located in the semicanal for the tensor tympani muscle above the auditory tube", "e": "musculus (L. musculus: muscle) + tensor (L. tensor: one who stretches, from tendere = to stretch) + tympani (L. tympanum: drum, from Gk. tympanon = drum)", "p": 394}, {"t": "M. stapedius", "m": "Muscle that originates in a bony canal on the posterior wall of the tympanic cavity", "e": "musculus (L. musculus: muscle) + stapedius (L. stapes: stirrup, from Medieval L. stapes = stirrup)", "p": 394}, {"t": "Tunica mucosa cavitatis tympanicae", "m": "Mucous membrane of tympanic cavity", "e": "tunica (L. tunica: covering, coat) + mucosa (L. mucosus: slimy, from mucus = slime) + cavitatis (L. cavitas: hollow, cavity, from cavus = hollow) + tympanicae (L. tympanicus: of the drum, from Gk. tympanon = drum)", "p": 394}, {"t": "Plica chordae tympani", "m": "Fold of chorda tympani", "e": "plica (L. plica: fold, from plicare = to fold) + chordae (L. chorda: string, cord, from Gk. khorde = gut-string) + tympani (L. tympanum: drum, from Gk. tympanon = drum)", "p": 394}, {"t": "Recessus membranae tympanicae", "m": "Recess of tympanic membrane — mucosal pouch in the tympanic cavity", "e": "recessus (L. recessus: recess, withdrawal, from recedere = to recede) + membranae (L. membrana: membrane, from membrum = limb) + tympanicae (L. tympanicus: of the drum, from Gk. tympanon = drum)", "p": 394}, {"t": "Recessus membranae tympani anterior", "m": "Anterior recess of tympanic membrane", "e": "recessus (L. recessus: recess, from recedere = to recede) + membranae (L. membrana: membrane) + tympani (L. tympanum: drum, from Gk. tympanon = drum) + anterior (L. anterior: before, in front)", "p": 394}, {"t": "Recessus membranae tympani superior", "m": "Superior recess of tympanic membrane (Prussak's pouch)", "e": "recessus (L. recessus: recess, from recedere = to recede) + membranae (L. membrana: membrane) + tympani (L. tympanum: drum, from Gk. tympanon = drum) + superior (L. superior: upper, higher)", "p": 394}, {"t": "Recessus membranae tympani posterior", "m": "Posterior recess of tympanic membrane", "e": "recessus (L. recessus: recess, from recedere = to recede) + membranae (L. membrana: membrane) + tympani (L. tympanum: drum, from Gk. tympanon = drum) + posterior (L. posterior: behind, later)", "p": 394}, {"t": "Plica incudialis", "m": "Incudal fold — mucosal fold extending from the roof of the epitympanic recess", "e": "plica (L. plica: fold, from plicare = to fold) + incudialis (L. incus: anvil, from incudere = to forge; incudialis = of the incus/anvil)", "p": 394}, {"t": "Plica stpedialis", "m": "Stapedial fold — mucosal fold extending from the posterior wall of the tympanic cavity to the stapes", "e": "plica (L. plica: fold, from plicare = to fold) + stapedialis (L. stapes: stirrup; stapedialis = of the stapes)", "p": 394}, {"t": "Tuba auditoria", "m": "Auditory (pharyngotympanic, Eustachian) tube — narrow 4 cm long, partly cartilaginous, partly bony tube", "e": "tuba (L. tuba: tube, trumpet) + auditoria (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "Ostium tympanicum tubae auditoriae", "m": "Tympanic ostium of auditory tube — opening of the auditory tube on the anterior wall of the tympanic cavity", "e": "ostium (L. ostium: opening, door, from os = mouth) + tympanicum (L. tympanicus: of the drum, from Gk. tympanon = drum) + tubae (L. tuba: tube, trumpet) + auditoriae (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "Pars ossea tubae auditoriae", "m": "Osseous part of auditory tube — laterally and posterosuperiorly situated portion that involves about 1/3 of the tube's length", "e": "pars (L. pars: part, portion) + ossea (L. osseus: bony, of bone, from os = bone) + tubae (L. tuba: tube, trumpet) + auditoriae (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "Isthmus tubae auditoriae", "m": "Isthmus — narrow portion of the tube between the cartilaginous and bony parts", "e": "isthmus (Gk. isthmos: narrow neck, passage) + tubae (L. tuba: tube, trumpet) + auditoriae (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "Cellulae pneumaticae", "m": "Air cells — small fossae in the wall of the osseous part of the auditory tube", "e": "cellulae (L. cellula: small room, cell, dim. of cella = room) + pneumaticae (Gk. pneumatikos: of air, from pneuma = air, breath)", "p": 394}, {"t": "Pars cartilaginea tubae auditoriae", "m": "Cartilaginous part of auditory tube — located anteromedially, length of about 2.5 cm", "e": "pars (L. pars: part, portion) + cartilaginea (L. cartilagineus: of cartilage, from cartilago = cartilage) + tubae (L. tuba: tube, trumpet) + auditoriae (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "Cartilago tubae auditoriae", "m": "Cartilage of auditory tube — hook-shaped in cross section", "e": "cartilago (L. cartilago: cartilage, gristle) + tubae (L. tuba: tube, trumpet) + auditoriae (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "Lamina cartilaginis medialis", "m": "Medial cartilaginous lamina — broad plate of cartilage", "e": "lamina (L. lamina: thin plate, layer) + cartilaginis (L. cartilago: cartilage) + medialis (L. medialis: middle, from medius = middle)", "p": 394}, {"t": "Lamina cartilaginis lateralis", "m": "Lateral cartilaginous lamina — narrow anterolaterally directed plate of cartilage", "e": "lamina (L. lamina: thin plate, layer) + cartilaginis (L. cartilago: cartilage) + lateralis (L. lateralis: of the side, from latus = side)", "p": 394}, {"t": "Lamina membranacea", "m": "Membranous lamina — membranous portion of the wall of the cartilaginous part of the auditory tube", "e": "lamina (L. lamina: thin plate, layer) + membranacea (L. membranaceus: membranous, from membrana = membrane)", "p": 394}, {"t": "Glandulae tubariae", "m": "Glands of auditory tube — mucous glands especially in the cartilaginous part of the tube", "e": "glandulae (L. glandula: small gland, dim. of glans = acorn) + tubariae (L. tubarius: of the tube, from tuba = tube)", "p": 394}, {"t": "Ostium pharyngeum tubae auditoriae", "m": "Pharyngeal opening of auditory tube — funnel-shaped to slit-like opening above the levator eminence", "e": "ostium (L. ostium: opening, door, from os = mouth) + pharyngeum (Gk. pharynx: throat, pharynx) + tubae (L. tuba: tube, trumpet) + auditoriae (L. auditorius: of hearing, from audire = to hear)", "p": 394}, {"t": "Auris externa", "m": "External ear — the part of the ear consisting of the auricle (pinna) and external acoustic meatus", "e": "auris (L. auris: ear) + externa (L. externus: outer, external)", "p": 396}, {"t": "Meatus acusticus externus cartilagineus", "m": "Cartilaginous part of external acoustic meatus — lateral, cartilaginous third of the external acoustic meatus", "e": "meatus (L. meātus: passage, channel) + acusticus (Gk. akoustikos: of hearing) + externus (L. externus: outer) + cartilagineus (L. cartilago: cartilage, gristle)", "p": 396}, {"t": "Cartilago meatus acustici", "m": "Cartilage of external acoustic meatus — together with the cartilage of the pinna, it forms a groove that opens superiorly and posteriorly", "e": "cartilago (L. cartilago: cartilage, gristle) + meatus (L. meātus: passage, channel) + acustici (Gk. akoustikos: of hearing, genitive form)", "p": 396}, {"t": "Incisurae cartilaginis meatus acustici", "m": "Two fissures in the cartilage of the external acoustic meatus, bridged by connective tissue and usually directed anteriorly", "e": "incisurae (L. incisura: notch, cut, plural) + cartilaginis (L. cartilago: cartilage, genitive form) + meatus (L. meātus: passage, channel) + acustici (Gk. akoustikos: of hearing, genitive form)", "p": 396}, {"t": "Lamina tragi", "m": "Lateral part of the meatal cartilage, lying in front of the external opening of the acoustic meatus", "e": "lamina (L. lamina: thin plate, layer) + tragi (L./Gk. tragus: goat, referring to the tuft of hair; genitive form)", "p": 396}, {"t": "Auricula", "m": "Auricle (Pinna)", "e": "auricula (L. auricula: little ear, diminutive of auris = ear)", "p": 396}, {"t": "Lobulus auricularis", "m": "Ear lobe — lower end of the pinna devoid of cartilage", "e": "lobulus (L. lobulus: small lobe, diminutive of lobus) + auricularis (L. auricularis: of the ear, from auricula = little ear)", "p": 396}, {"t": "Cartilago auricularis", "m": "Auricular cartilage — structural framework of the pinna consisting of elastic cartilage", "e": "cartilago (L. cartilago: cartilage, gristle) + auricularis (L. auricularis: of the ear, from auricula = little ear)", "p": 396}, {"t": "Crus helicis", "m": "Crus of helix — site of origin of the helix in the cavity (concha) of the auricle", "e": "crus (L. crus: leg, limb, root) + helicis (Gk. helix: spiral, coil; genitive form)", "p": 396}, {"t": "Spina helicis", "m": "Spine of helix — small, forward-projecting cartilaginous prominence on the crus helices", "e": "spina (L. spina: spine, thorn) + helicis (Gk. helix: spiral, coil; genitive form)", "p": 396}, {"t": "Cauda helicis", "m": "Tail of helix — posterior, inferior end of the helix separated from the antitragus by an indentation", "e": "cauda (L. cauda: tail) + helicis (Gk. helix: spiral, coil; genitive form)", "p": 396}, {"t": "Fossa triangularis", "m": "Triangular fossa — anterosuperiorly located fossa enclosed by the two crura of the anthelix", "e": "fossa (L. fossa: ditch, pit, from fodere = to dig) + triangularis (L. triangularis: triangular, from tri = three + angulus = angle)", "p": 396}, {"t": "Crura anthelicis", "m": "Crura of anthelix (antihelix) — formed by the bifurcation of the anthelix superiorly, the two crura form the boundary of the triangular fossa", "e": "crura (L. crura: legs, limbs, plural of crus) + anthelicis (Gk. anti = against/opposite + helix = spiral; genitive form)", "p": 396}, {"t": "Scapha", "m": "Scaphoid fossa — narrow fossa situated posteriorly between the helix and anthelix", "e": "scapha (Gk. skaphe: boat, skiff, trough)", "p": 396}, {"t": "Concha auricularis", "m": "Concha (cavity) of auricle — embraced by the anthelix, antitragus and tragus", "e": "concha (Gk. konche: shell, conch) + auricularis (L. auricularis: of the ear, from auricula = little ear)", "p": 396}, {"t": "Cavitas (cavum) conchalis", "m": "Cavity of concha — main part of the concha located below the crus of the helix and behind the tragus", "e": "cavitas (L. cavitas: hollowness, cavity, from cavus = hollow) + cavum (L. cavum: hollow, cavity) + conchalis (Gk. konche: shell, conch; adjectival form)", "p": 396}, {"t": "Incisura anterior (auris)", "m": "Anterior notch — lies between the tragus (supratragic tubercle) and the crus of the helix", "e": "incisura (L. incisura: notch, cut, from incidere = to cut into) + anterior (L. anterior: in front, former, from ante = before) + auris (L. auris: ear)", "p": 396}, {"t": "Incisura intertragica", "m": "Intertragic incisure — notch between tragus and antitragus", "e": "incisura (L. incisura: notch, cut) + intertragica (L. inter = between + Gk. tragus = goat; adjectival form)", "p": 396}, {"t": "Tuberculum auriculare", "m": "Auricular (Darwin's) tubercle — occasionally present on the anterior margin of the helix from which it extends posteroinferiorly", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = swelling) + auriculare (L. auricularis: of the ear, from auricula = little ear)", "p": 396}, {"t": "Apex auricularis", "m": "Apex of auricle — outer margin of the auricular cartilage (helix) which, when present, projects backward, upward and outward", "e": "apex (L. apex: tip, summit, point) + auricularis (L. auricularis: of the ear, from auricula = little ear)", "p": 396}, {"t": "Sulcus auricularis posterior", "m": "Posterior auricular sulcus — shallow indentation between the antitragus and anthelix", "e": "sulcus (L. sulcus: furrow, groove) + auricularis (L. auricularis: of the ear, from auricula = little ear) + posterior (L. posterior: behind, later, from post = after)", "p": 396}, {"t": "Tuberculum supratragicum", "m": "Supratragic tubercle — small tubercle occasionally present at the upper end of the tragus", "e": "tuberculum (L. tuberculum: small swelling, diminutive of tuber = swelling) + supratragicum (L. supra = above + Gk. tragus = goat; adjectival form)", "p": 396}, {"t": "Isthmus cartilaginis auricularis", "m": "Narrow bridge of cartilage connecting the cartilage of the external acoustic meatus and tragic lamina with the auricular cartilage", "e": "isthmus (Gk. isthmos: narrow neck/passage) + cartilaginis (L. cartilago: cartilage, gristle) + auricularis (L. auricularis: of the ear, from auricula = little ear, from auris = ear)", "p": 398}, {"t": "Incisura terminalis auricularis", "m": "Deep notch separating the lamina tragi from the auricular cartilage", "e": "incisura (L. incisura: notch, from incidere = to cut into) + terminalis (L. terminalis: terminal, of the end, from terminus = end) + auricularis (L. auricularis: of the ear, from auricula = little ear)", "p": 398}, {"t": "Fissura antitragohelicina", "m": "Deep fissure separating the antitragus and helix inferiorly as well as the anthelix and helix further superiorly", "e": "fissura (L. fissura: cleft, fissure, from findere = to split) + anti (Gk. anti: against, opposite) + tragus (Gk. tragos: goat, used for the ear projection) + helicina (Gk. helix: spiral, coil)", "p": 398}, {"t": "Sulcus anthelicis transversus", "m": "Posteromedial depression visible between the eminences of the triangular fossa and concha", "e": "sulcus (L. sulcus: furrow, groove) + anthelicis (Gk. anti: against/opposite + helix: spiral coil) + transversus (L. transversus: transverse, lying across, from trans = across + vertere = to turn)", "p": 398}, {"t": "Sulcus cruris helicis", "m": "Shallow furrow on the posterior surface of the auricular cartilage corresponding to the crus of the helix on the anterior surface", "e": "sulcus (L. sulcus: furrow, groove) + cruris (L. crus: leg, limb, crus) + helicis (Gk. helix: spiral, coil)", "p": 398}, {"t": "Fossa anthelicis", "m": "Furrow on posterior surface of auricular cartilage corresponding to the anthelix on the anterior surface", "e": "fossa (L. fossa: pit, depression, ditch, from fodere = to dig) + anthelicis (Gk. anti: opposite + helix: spiral coil)", "p": 398}, {"t": "Eminentia conchae", "m": "Elevation on the posterior surface of the auricular cartilage corresponding to the cavity of the concha", "e": "eminentia (L. eminentia: projection, prominence, from eminere = to stand out) + conchae (Gk. konche: shell, concha)", "p": 398}, {"t": "Eminentia scaphae", "m": "Curved elevation on the posterior surface of the auricular cartilage corresponding to the scaphoid fossa on the anterior surface", "e": "eminentia (L. eminentia: projection, prominence) + scaphae (Gk. skaphe: boat, hollow vessel)", "p": 398}, {"t": "Eminentia fossae triangularis", "m": "Elevation on the posterior surface of the auricular cartilage corresponding to the triangular fossa", "e": "eminentia (L. eminentia: projection, prominence) + fossae (L. fossa: pit, depression) + triangularis (L. triangularis: triangular, from tri = three + angulus = angle)", "p": 398}, {"t": "Ligg. auricularia", "m": "Ligaments of the pinna; they attach the auricular cartilage to the temporal bone", "e": "ligg. (L. ligamenta pl.: ligaments, from ligare = to bind) + auricularia (L. auricularis: of the ear, from auricula = little ear)", "p": 398}, {"t": "Lig. auriculare anterius", "m": "Anterior auricular ligament; extends from the root of the zygomatic arch to the spine of the helix", "e": "lig. (L. ligamentum: ligament, from ligare = to bind) + auriculare (L. auricularis: of the ear) + anterius (L. anterior: in front, from ante = before)", "p": 398}, {"t": "Lig. auriculare superius", "m": "Superior auricular ligament; passes from the upper margin of the osseous external auditory meatus to the spine of the helix", "e": "lig. (L. ligamentum: ligament) + auriculare (L. auricularis: of the ear) + superius (L. superior: upper, higher, from super = above)", "p": 398}, {"t": "Lig. auriculare posterius", "m": "Posterior auricular ligament; extends from the eminence of the concha to the mastoid process", "e": "lig. (L. ligamentum: ligament) + auriculare (L. auricularis: of the ear) + posterius (L. posterior: behind, from post = after, behind)", "p": 398}, {"t": "Mm. auriculares", "m": "Muscles of the pinna", "e": "mm. (L. musculi pl.: muscles, from musculus = little mouse, muscle) + auriculares (L. auricularis: of the ear, from auricula = little ear)", "p": 398}, {"t": "M. helicis major", "m": "Passes upward from the spine of the helix to the helix", "e": "m. (L. musculus: muscle) + helicis (Gk. helix: spiral, coil) + major (L. major: greater, larger, comparative of magnus = great)", "p": 398}, {"t": "M. helicis minor", "m": "Lies on the crus of the helix", "e": "m. (L. musculus: muscle) + helicis (Gk. helix: spiral, coil) + minor (L. minor: smaller, lesser, comparative of parvus = small)", "p": 398}, {"t": "M. tragicus", "m": "Lies vertically on the lamina tragi", "e": "m. (L. musculus: muscle) + tragicus (Gk. tragos: goat, used for the ear projection; tragicus = of the tragus)", "p": 398}, {"t": "M. pyramidalis auricularis", "m": "Muscle fibers that occasionally split off from the tragicus muscle and pass to the spine of the helix", "e": "m. (L. musculus: muscle) + pyramidalis (Gk. pyramis: pyramid, pyramidal) + auricularis (L. auricularis: of the ear, from auricula = little ear)", "p": 398}, {"t": "M. antitragicus", "m": "Muscle fibers on the antitragus; extend partly to the tail of the helix", "e": "m. (L. musculus: muscle) + anti (Gk. anti: against, opposite) + tragicus (Gk. tragos: goat, the ear projection)", "p": 398}, {"t": "M. transversus auricularis", "m": "Muscle located on the posterior surface of the auricular cartilage; extends between the eminences of the scaphoid fossa and concha", "e": "m. (L. musculus: muscle) + transversus (L. transversus: transverse, from trans = across + vertere = to turn) + auricularis (L. auricularis: of the ear)", "p": 398}, {"t": "M. obliquus auricularis", "m": "Lies between the eminences of the concha and triangular fossa", "e": "m. (L. musculus: muscle) + obliquus (L. obliquus: oblique, slanting) + auricularis (L. auricularis: of the ear)", "p": 398}, {"t": "M. incisurae helicis", "m": "Muscle fibers occasionally present in the caudal continuation of transversus auricularis muscle", "e": "m. (L. musculus: muscle) + incisurae (L. incisura: notch, from incidere = to cut into) + helicis (Gk. helix: spiral, coil)", "p": 398}, {"t": "Organum olfactorium", "m": "Organ of smell", "e": "organum (Gk. organon: organ, instrument, tool) + olfactorium (L. olfactorius: of smell, from olfacere = to smell, from olere = to have a smell + facere = to make)", "p": 398}, {"t": "Regio olfactoria tunicae mucosae nasi", "m": "Nasal mucosa of the olfactory region; covered by olfactory epithelium, about the size of a nickel occupying the lateral and medial walls and roof of the nasal cavity", "e": "regio (L. regio: region, area, from regere = to rule, direct) + olfactoria (L. olfactorius: of smell) + tunicae (L. tunica: coat, layer, covering) + mucosae (L. mucosus: mucous, from mucus = slime) + nasi (L. nasus: nose)", "p": 398}, {"t": "Glandulae olfactoriae", "m": "Olfactory glands (of Bowman); serous glands found below the olfactory epithelium whose secretions can enhance or wash away odorous substances", "e": "glandulae (L. glandula: small gland, from glans = acorn) + olfactoriae (L. olfactorius: of smell, from olfacere = to smell)", "p": 398}, {"t": "Organum gustatorium", "m": "Organ of taste, comprised of all the taste buds", "e": "organum (Gk. organon: organ, instrument) + gustatorium (L. gustatorius: of taste, from gustare = to taste)", "p": 398}, {"t": "Caliculus gustatorius", "m": "Taste bud; occupies the full thickness of the epithelium, consists of supporting cells and taste cells with microvilli serving as chemoreceptors", "e": "caliculus (L. caliculus: small cup, diminutive of calix = cup) + gustatorius (L. gustatorius: of taste, from gustare = to taste)", "p": 398}, {"t": "gemma gustatoria", "m": "Taste bud (alternative term)", "e": "gemma (L. gemma: bud, gem, jewel) + gustatoria (L. gustatorius: of taste, from gustare = to taste)", "p": 398}, {"t": "Porus gustatorius", "m": "Taste pore; space left by the epithelium above the apex of the taste bud into which microvilli project", "e": "porus (Gk. poros: pore, passage, channel) + gustatorius (L. gustatorius: of taste, from gustare = to taste)", "p": 398}, {"t": "Integumentum commune", "m": "Common integument (skin) — the outer covering of the body consisting of three layers", "e": "integumentum (L. integumentum: covering, from integere = to cover) + commune (L. communis: common, shared)", "p": 400}, {"t": "Cutis", "m": "Collective term for epidermis and dermis", "e": "cutis (L. cutis: skin, hide)", "p": 400}, {"t": "Sulci cutis", "m": "Sulci of skin — variably sized depressions or furrows on the surface of the skin", "e": "sulci (L. sulcus, pl. sulci: furrow, groove) + cutis (L. cutis: skin)", "p": 400}, {"t": "Cristae cutis", "m": "Dermal ridges — ridges produced by the underlying papillae of the corium on the thick skin of the palms of the hands and soles of the feet", "e": "cristae (L. crista, pl. cristae: crest, ridge) + cutis (L. cutis: skin)", "p": 400}, {"t": "Retinacula cutis", "m": "Bands of connective tissue which attach the skin to the underlying tissue", "e": "retinacula (L. retinaculum, pl. retinacula: band, tether, from retinere = to hold back) + cutis (L. cutis: skin)", "p": 400}, {"t": "Toruli tactiles", "m": "Tactile elevations — skin regions with more abundant fat deposits, near the phalanges, thenar and hypothenar eminences", "e": "toruli (L. torulus, pl. toruli: small elevation, diminutive of torus = protuberance) + tactiles (L. tactilis: of touch, from tangere = to touch)", "p": 400}, {"t": "Foveola coccygea", "m": "Coccygeal foveola — pit above the coccyx caused by the caudal retinaculum", "e": "foveola (L. foveola: small pit, diminutive of fovea = pit) + coccygea (Gk. kokkyx: cuckoo, coccyx; L. coccygeus: of the coccyx)", "p": 400}, {"t": "Retinaculum caudale", "m": "Caudal retinaculum — connective tissue remains of the embryonic notochord lying between the coccygeal foveola and the coccyx", "e": "retinaculum (L. retinaculum: band, tether, from retinere = to hold back) + caudale (L. caudalis: of the tail, from cauda = tail)", "p": 400}, {"t": "Epidermis", "m": "Stratified, keratinized squamous epithelium covering the body, thickness varies from 30 μm to 4 mm or more", "e": "epi- (Gk. epi: upon, over) + dermis (Gk. derma: skin)", "p": 400}, {"t": "Stratum corneum", "m": "Most superficial, cornified (keratinized) layer of the epidermis which undergoes continual desquamation", "e": "stratum (L. stratum: layer, from sternere = to spread) + corneum (L. corneus: horny, from cornu = horn)", "p": 400}, {"t": "Stratum lucidum", "m": "Located between the stratum granulosum and stratum corneum; a homogeneous, strongly refractile layer rich in eleidin fibers", "e": "stratum (L. stratum: layer) + lucidum (L. lucidus: clear, bright, from lux = light)", "p": 400}, {"t": "Stratum granulosum", "m": "Consists of 1–5 cell layers with degenerative nuclear changes, contains stongly refractory keratohyaline granules", "e": "stratum (L. stratum: layer) + granulosum (L. granulosus: full of granules, from granulum = small grain)", "p": 400}, {"t": "Stratum spinosum", "m": "Prickle cell layer — consists of polygonal cells with spinous processes which project from their surfaces and contact each other by means of a desmosome", "e": "stratum (L. stratum: layer) + spinosum (L. spinosus: spiny, thorny, from spina = thorn, spine)", "p": 400}, {"t": "Stratum basale", "m": "Deepest, cylindrical cell layer of the epidermis; cell proliferation occurs here and in the stratum spinosum", "e": "stratum (L. stratum: layer) + basale (L. basalis: of the base, from Gk. basis = base, foundation)", "p": 400}, {"t": "Stratum basale cylindricum", "m": "Deepest, cylindrical cell layer of the epidermis", "e": "stratum (L. stratum: layer) + basale (L. basalis: of the base) + cylindricum (Gk. kylindros: cylinder, roller)", "p": 400}, {"t": "Dermis", "m": "The layer of skin consisting of an intimate network of collagenous and elastic fibers rich in nerves and blood vessels and devoid of fat", "e": "dermis (Gk. derma: skin, hide)", "p": 400}, {"t": "Corium", "m": "Part of the dermis (used interchangeably); layer of skin deep to epidermis", "e": "corium (L. corium: hide, skin, leather)", "p": 400}, {"t": "Stratum papillare", "m": "Papillary layer — the delicate upper layer of the dermis with numerous connective tissue papillae connecting it to the epidermis", "e": "stratum (L. stratum: layer) + papillare (L. papillaris: of a papilla, from papilla = nipple, teat, diminutive of papula = pimple)", "p": 400}, {"t": "Stratum reticulare", "m": "Reticular layer — part of dermis adjoining the papillary layer; consists of more compact, densely interwoven connective tissue", "e": "stratum (L. stratum: layer) + reticulare (L. reticularis: net-like, from reticulum = small net, diminutive of rete = net)", "p": 400}, {"t": "Tela subcutanea", "m": "Subcutaneous tissue — layer of subcutaneous fatty tissue compartmentalized by fibrous tracts and firmly connected with the corium with mobile connections to the fascia", "e": "tela (L. tela: web, tissue, from texere = to weave) + subcutanea (L. sub = under + cutaneus = of the skin, from cutis = skin)", "p": 400}, {"t": "Panniculus adiposus", "m": "The thicker layer of fat in the subcutaneous tissue", "e": "panniculus (L. panniculus: small piece of cloth, thin layer, diminutive of pannus = cloth) + adiposus (L. adiposus: fatty, from adeps = fat)", "p": 400}, {"t": "Corpuscula nervosa terminalia", "m": "Terminal nerve corpuscles — collective term for encapsulated nerve endings", "e": "corpuscula (L. corpusculum, pl. corpuscula: small body, diminutive of corpus = body) + nervosa (L. nervosus: of nerves, from nervus = nerve, sinew) + terminalia (L. terminalis: terminal, from terminus = end, boundary)", "p": 400}, {"t": "Corpuscula bulboidea", "m": "End bulbs of Krause (bulboid corpuscles) — oval convolutions of nerve fibers found especially in the lamina propria of the mucosa; considered cold receptors", "e": "corpuscula (L. corpusculum, pl. corpuscula: small body) + bulboidea (L./Gk. bulbus = bulb, from Gk. bolbos = onion + Gk. -oeides = resembling)", "p": 400}, {"t": "Corpuscula lamellosa", "m": "Lamellated (Vater-Pacini, pacinian) corpuscles — oval bodies 2–3 mm long with concentric layers of connective tissue surrounding an inner core; pressure receptors found in subcutaneous fat, muscles and viscera", "e": "corpuscula (L. corpusculum, pl. corpuscula: small body) + lamellosa (L. lamellosa: composed of lamellae, from lamella = thin plate, diminutive of lamina = layer)", "p": 400}, {"t": "Corpuscula tactus", "m": "Tactile (Meissner's) corpuscles — encapsulated sensory organs in the connective papilla of the dermis, about 0.1 mm in length, consisting of transversely oriented tactile cells within a ramified nerve network", "e": "corpuscula (L. corpusculum, pl. corpuscula: small body) + tactus (L. tactus: touch, from tangere = to touch)", "p": 400}, {"t": "Corpuscula genitalia", "m": "Genital corpuscles — elliptical, encapsulated nerve endings similar to the end bulbs of Krause, found abundantly in the clitoris, glans and nipple", "e": "corpuscula (L. corpusculum, pl. corpuscula: small body) + genitalia (L. genitalis: of generation/reproduction, from gignere = to beget)", "p": 400}, {"t": "Menisci tractus", "m": "Tactile menisci (Merkel's discs or corpuscles) — flat group of light cells with intracellular neurofibrils occupying the epithelium", "e": "menisci (Gk. meniskos, pl. meniskoi: crescent, small moon, diminutive of mene = moon) + tractus (L. tractus: tract, drawn-out structure, from trahere = to draw)", "p": 400}, {"t": "Corpuscula articularia", "m": "Articular corpuscles — modified pacinian corpuscles within joint capsules", "e": "corpuscula (L. corpusculum, pl. corpuscula: small body) + articularia (L. articularis: of a joint, from articulus = joint, diminutive of artus = joint)", "p": 400}, {"t": "Papillae", "m": "Conical extensions of connective tissue projecting into the epidermis; may form rows (dermal ridges) or branches and vary markedly in form and organization", "e": "papillae (L. papilla, pl. papillae: nipple, teat, small protuberance, diminutive of papula = pimple)", "p": 400}, {"t": "Pili", "m": "Collective term for any type of hair", "e": "pili (L. pilus: hair)", "p": 402}, {"t": "Capilli", "m": "Scalp hairs", "e": "capilli (L. capillus: hair of the head, from caput = head)", "p": 402}, {"t": "Supercilia", "m": "Hairs of eyebrow", "e": "supercilia (L. supercilium: eyebrow, from super = above + cilium = eyelid/edge)", "p": 402}, {"t": "Barba", "m": "Hairs of beard", "e": "barba (L. barba: beard)", "p": 402}, {"t": "Tragi", "m": "Hairs of external acoustic meatus", "e": "tragi (L. tragus, from Gk. tragos: goat, also the projection of the ear)", "p": 402}, {"t": "Vibrissae", "m": "Hairs of the nasal vestibule", "e": "vibrissae (L. vibrissae: hairs in the nostrils, from vibrare = to vibrate)", "p": 402}, {"t": "Hirci", "m": "Axillary hairs", "e": "hirci (L. hircus: goat, also armpit hair, referring to goat-like smell)", "p": 402}, {"t": "Pubes", "m": "Pubic hairs", "e": "pubes (L. pubes: pubic hair, groin, sign of maturity)", "p": 402}, {"t": "Folliculus pili", "m": "Hair follicle — connective tissue epithelium covering of the hair root", "e": "folliculus (L. folliculus: small bag/sac, diminutive of follis = bellows/bag) + pili (L. pilus: hair)", "p": 402}, {"t": "Papilla pili", "m": "Hair papilla — connective tissue papilla which projects into the bulb-like, distended lowermost part of the hair root", "e": "papilla (L. papilla: nipple, small projection) + pili (L. pilus: hair)", "p": 402}, {"t": "Scapus pili", "m": "Hair shaft — part of the hair that projects out from the skin", "e": "scapus (L. scapus: shaft, stalk, from Gk. skapos) + pili (L. pilus: hair)", "p": 402}, {"t": "Radix pili", "m": "Hair root", "e": "radix (L. radix: root) + pili (L. pilus: hair)", "p": 402}, {"t": "Bulbus pili", "m": "Bulb of hair — bulb-like enlargement at the lower end of the hair root", "e": "bulbus (L. bulbus: bulb, from Gk. bolbos = onion/bulb) + pili (L. pilus: hair)", "p": 402}, {"t": "Mm. arrectores pilorum", "m": "Bundles of smooth muscle passing from the middle of the hair follicle to the papillary layer of the dermis", "e": "musculi (L. musculus: muscle, diminutive of mus = mouse) + arrectores (L. arrector: one who raises, from arrigere = to raise up, from ad + regere) + pilorum (L. pilus: hair, genitive plural)", "p": 402}, {"t": "Flumina pilorum", "m": "Hair streams — orientational patterns of hair", "e": "flumina (L. flumen: river, stream, from fluere = to flow) + pilorum (L. pilus: hair, genitive plural)", "p": 402}, {"t": "Vortices pilorum", "m": "Whorled pattern of hair growth", "e": "vortices (L. vortex/vertex: whirl, spiral, from vertere = to turn) + pilorum (L. pilus: hair, genitive plural)", "p": 402}, {"t": "Cruces pilorum", "m": "Cruciate pattern of hair growth — found at sites where hair patterns meet from two directions and continue two new directions perpendicular to each other", "e": "cruces (L. crux: cross, plural cruces) + pilorum (L. pilus: hair, genitive plural)", "p": 402}, {"t": "Unguis", "m": "Nails — fingernails and toenails", "e": "unguis (L. unguis: nail, claw, hoof)", "p": 402}, {"t": "Matrix unguis", "m": "Nail matrix (bed) — tissue (epidermis) upon which the nail rests; nail substance is formed in the region of the lunula", "e": "matrix (L. matrix: womb, origin, from mater = mother) + unguis (L. unguis: nail)", "p": 402}, {"t": "Cristae matricis unguis", "m": "Crests of nail matrix — longitudinal ridges in nail bed", "e": "cristae (L. crista: crest, ridge) + matricis (L. matrix: womb/origin, genitive singular) + unguis (L. unguis: nail)", "p": 402}, {"t": "Sulcus matricis unguis", "m": "Nail groove (fold) — cutaneous slit into which the lateral nasal margins are embedded", "e": "sulcus (L. sulcus: groove, furrow) + matricis (L. matrix: womb/origin, genitive singular) + unguis (L. unguis: nail)", "p": 402}, {"t": "Sinus unguis", "m": "Nail sinus — deep furrow into which the root of the nail is inserted", "e": "sinus (L. sinus: cavity, hollow, curve) + unguis (L. unguis: nail)", "p": 402}, {"t": "Vallum unguis", "m": "Wall of nail — cutaneous fold overlapping the sides and proximal end of the nail", "e": "vallum (L. vallum: wall, rampart, from vallus = stake) + unguis (L. unguis: nail)", "p": 402}, {"t": "Corpus unguis", "m": "Body of nail", "e": "corpus (L. corpus: body) + unguis (L. unguis: nail)", "p": 402}, {"t": "Radix unguis", "m": "Root of nail — part of nail situated in the nail sinus", "e": "radix (L. radix: root) + unguis (L. unguis: nail)", "p": 402}, {"t": "Lunula", "m": "Crescentic, whitish area at the base of the nail; its anterior margin corresponds to the anterior border of the nail-forming tissue", "e": "lunula (L. lunula: small moon, diminutive of luna = moon, referring to crescent shape)", "p": 402}, {"t": "Margo occultus", "m": "Proximal, posterior margin of a nail located deep within the nail sinus", "e": "margo (L. margo: margin, border, edge) + occultus (L. occultus: hidden, concealed, from occulere = to cover over)", "p": 402}, {"t": "Margo liber", "m": "Free margin — anterior, free margin of nail corresponding to the abrasive or cutting edge", "e": "margo (L. margo: edge, border, margin) + liber (L. liber: free)", "p": 404}, {"t": "Margo lateralis (axillaris)", "m": "Lateral (axillary) process; axillary tail — glandular process extending toward the axilla", "e": "margo (L. margo: edge, border) + lateralis (L. lateralis: of the side) + axillaris (L. axillaris: of the armpit, from axilla = armpit)", "p": 404}, {"t": "Processus lateralis (axillaris)", "m": "Lateral (axillary) process; axillary tail — glandular process extending toward the axilla", "e": "processus (L. processus: projection, going forward) + lateralis (L. lateralis: of the side) + axillaris (L. axillaris: of the armpit, from axilla = armpit)", "p": 404}, {"t": "Lobi glandulae mammariae", "m": "Lobes of mammary gland — 15–20 conical lobes", "e": "lobi (L. lobus: lobe, from Gk. lobos = lobe) + glandulae (L. glandula: small gland, from glans = acorn) + mammariae (L. mammarius: of the breast, from mamma = breast)", "p": 404}, {"t": "Lobuli glandulae mammariae", "m": "Lobules of mammary gland — subdivisions of each lobe produced by connective tissue septa", "e": "lobuli (L. lobulus: small lobe, diminutive of lobus) + glandulae (L. glandula: small gland) + mammariae (L. mammarius: of the breast, from mamma = breast)", "p": 404}, {"t": "Ductus lactiferi", "m": "Lactiferous ducts — excretory ducts, 15–20, one from each lobe, diameter of 1.7–2.3 mm opening on nipple", "e": "ductus (L. ductus: duct, leading, from ducere = to lead) + lactiferi (L. lactifer: milk-bearing, from lac/lactis = milk + ferre = to carry)", "p": 404}, {"t": "Sinus lactiferi", "m": "Lactiferous sinus — spindle-shaped dilatation of the lactiferous duct with diameter of 5–8 mm shortly before opening at apex of nipple", "e": "sinus (L. sinus: cavity, hollow, bay) + lactiferi (L. lactifer: milk-bearing, from lac/lactis = milk + ferre = to carry)", "p": 404}, {"t": "Areola mammae", "m": "Areola mammae — round, pigmented area around the nipple with a ring of small, rounded papillae produced by the areolar glands", "e": "areola (L. areola: small area, diminutive of area = open space) + mammae (L. mamma: breast)", "p": 404}, {"t": "Glandulae areolares", "m": "Areolar glands (of Montgomery) — 10–15 apocrine glands in the region of the areola", "e": "glandulae (L. glandula: small gland, from glans = acorn) + areolares (L. areolaris: of the areola, from areola = small area)", "p": 404}, {"t": "Mamma masculina", "m": "Male mammary gland — rudimentary mammary gland of the male", "e": "mamma (L. mamma: breast) + masculina (L. masculinus: male, masculine, from masculus = male)", "p": 404}, {"t": "Mammae accessoriae", "m": "Accessory mammary glands — the accessory mammary glands lying along the embryonic milk ridge", "e": "mammae (L. mamma: breast) + accessoriae (L. accessorius: supplementary, from accedere = to approach, add to)", "p": 404}, {"t": "Ligg. suspensoria mammaria", "m": "Suspensory ligaments of breast — tracts of connective tissue from the skin of the breast to the pectoral fascia united by a thin layer of loose displaceable tissue", "e": "ligg. (L. ligamentum: ligament, band, from ligare = to bind) + suspensoria (L. suspensorius: suspending, from suspendere = to hang up) + mammaria (L. mammarius: of the breast, from mamma = breast)", "p": 404}, {"t": "Glandula mammaria", "m": "Mammary gland — glandular tissue of female breast", "e": "glandula (L. glandula: small gland, from glans = acorn) + mammaria (L. mammarius: of the breast, from mamma = breast)", "p": 404}, {"t": "Stratum corneum unguis", "m": "Already cornified part of nail", "e": "stratum (L. stratum: layer, from sternere = to spread out) + corneum (L. corneus: horny, from cornu = horn) + unguis (L. unguis: nail, claw)", "p": 404}, {"t": "Stratum germinativum unguis", "m": "Layer of nail bed epithelium still undergoing cell proliferation", "e": "stratum (L. stratum: layer, from sternere = to spread out) + germinativum (L. germinativus: germinating, from germinare = to sprout, from germen = bud) + unguis (L. unguis: nail, claw)", "p": 404}, {"t": "Glandulae cutis", "m": "Cutaneous glands — glands arising from the epidermis and standing in close relationship to the skin", "e": "glandulae (L. glandula: small gland, from glans = acorn) + cutis (L. cutis: skin)", "p": 404}, {"t": "Gll. glomiformes", "m": "Sweat glands — collective term for small eccrine sweat glands and large apocrine sweat or odoriferous glands", "e": "gll. (L. glandulae: glands) + glomiformes (L. glomiformis: ball-shaped, from glomus = ball of thread + forma = shape)", "p": 404}, {"t": "Gll. sudorifer merocrina (eccrina)", "m": "Eccrine (merocrine) sweat (sudiferous) glands — eccrine sweat glands as opposed to apocrine sweat glands of anal, genital and axillary regions", "e": "gll. (L. glandulae: glands) + sudorifer (L. sudorifer: sweat-bearing, from sudor = sweat + ferre = to carry) + merocrina (Gk. meros = part + krinein = to separate) + eccrina (Gk. ekkrinein: to secrete, from ek = out + krinein = to separate)", "p": 404}, {"t": "Portio terminalis", "m": "Terminal secretory part — coiled, secretory body of a sweat gland lying in subcutaneous tissue or in the deep portion of the dermis", "e": "portio (L. portio: portion, part) + terminalis (L. terminalis: terminal, of the end, from terminus = end, boundary)", "p": 404}, {"t": "Ductus sudorifer", "m": "Sweat gland duct — excretory duct passing to the surface, shaped like a corkscrew within the highly cornified squamous epithelium of palms and soles, opens on the dermal ridges", "e": "ductus (L. ductus: duct, from ducere = to lead) + sudorifer (L. sudorifer: sweat-bearing, from sudor = sweat + ferre = to carry)", "p": 404}, {"t": "Porus sudorifer", "m": "Pore of sweat gland — opening of the excretory duct of a sweat gland on the skin", "e": "porus (L. porus: pore, from Gk. poros = passage, pore) + sudorifer (L. sudorifer: sweat-bearing, from sudor = sweat + ferre = to carry)", "p": 404}, {"t": "Gll. circumanales", "m": "Circumanal glands — large apocrine sweat glands grouped around the anus", "e": "gll. (L. glandulae: glands) + circumanales (L. circumanalis: around the anus, from circum = around + anus = anus, ring)", "p": 404}, {"t": "Gll. ceruminosae", "m": "Ceruminous glands — apocrine glands that secrete a proteinaceous material called cerumen (ear wax)", "e": "gll. (L. glandulae: glands) + ceruminosae (L. ceruminosus: full of cerumen, from cera = wax + L. suffix -umen)", "p": 404}, {"t": "Gll. sebaceae", "m": "Sebaceous glands — holocrine glands opening into the hair follicles", "e": "gll. (L. glandulae: glands) + sebaceae (L. sebaceus: of tallow/sebum, from sebum = tallow, grease)", "p": 404}, {"t": "Mamma", "m": "Breast — consists of glandular tissue, connective tissue tracts and fat", "e": "mamma (L. mamma: breast, teat)", "p": 404}, {"t": "Papilla mammae", "m": "Nipple — contains openings of the lactiferous ducts and smooth muscle tissue", "e": "papilla (L. papilla: nipple, teat, small protuberance) + mammae (L. mamma: breast)", "p": 404}, {"t": "Corpus mammae", "m": "Body of mammary gland — glandular body surrounded by adipose tissue", "e": "corpus (L. corpus: body) + mammae (L. mamma: breast)", "p": 404}, {"t": "Termini generales", "m": "General terminology", "e": "termini (L. terminus: boundary, end, term) + generales (L. generalis: general, from genus = kind, type)", "p": 406}, {"t": "Verticalis", "m": "Vertical (perpendicular)", "e": "verticalis (L. verticalis: vertical, from vertex = highest point, from vertere = to turn)", "p": 406}, {"t": "Horizontalis", "m": "Horizontal", "e": "horizontalis (L./Gk. horizontalis: of the horizon, from Gk. horizein = to bound, limit)", "p": 406}, {"t": "Medianus", "m": "Median — lying in the midline (mid-sagittal plane)", "e": "medianus (L. medianus: of the middle, from medius = middle)", "p": 406}, {"t": "Coronalis", "m": "Coronal — lying in the plane of the coronal suture", "e": "coronalis (L. coronalis: of a crown, from corona = crown, Gk. korone = crown)", "p": 406}, {"t": "Sagittalis", "m": "Sagittal — lying in the plane of the sagittal suture", "e": "sagittalis (L. sagittalis: arrow-like, from sagitta = arrow)", "p": 406}, {"t": "Dexter", "m": "Right", "e": "dexter (L. dexter: right, on the right side)", "p": 406}, {"t": "Sinister", "m": "Left", "e": "sinister (L. sinister: left, on the left side)", "p": 406}, {"t": "Transversalis", "m": "Transverse — situated at right angles to the long axis of a part", "e": "transversalis (L. transversalis: crosswise, from trans = across + vertere = to turn)", "p": 406}, {"t": "Medialis", "m": "Medial — lying close to the median plane", "e": "medialis (L. medialis: of the middle, from medius = middle)", "p": 406}, {"t": "Lateralis", "m": "Lateral — situated toward the side", "e": "lateralis (L. lateralis: of the side, from latus = side)", "p": 406}, {"t": "Ventralis", "m": "Ventral (anterior) — toward the belly", "e": "ventralis (L. ventralis: of the belly, from venter = belly)", "p": 406}, {"t": "Dorsalis", "m": "Dorsal (posterior) — toward the back", "e": "dorsalis (L. dorsalis: of the back, from dorsum = back)", "p": 406}, {"t": "Frontalis", "m": "Frontal — pertaining to the forehead; plane separating body into front and back parts", "e": "frontalis (L. frontalis: of the forehead/front, from frons = forehead, front)", "p": 406}, {"t": "Occipitalis", "m": "Occipital — pertaining to the occiput", "e": "occipitalis (L. occipitalis: of the occiput, from ob = against/behind + caput = head)", "p": 406}, {"t": "Superior", "m": "Upper", "e": "superior (L. superior: higher, upper, comparative of superus = above, from super = above)", "p": 406}, {"t": "Inferior", "m": "Lower", "e": "inferior (L. inferior: lower, comparative of inferus = below, from infra = below)", "p": 406}, {"t": "Cranialis", "m": "Cranial — pertaining to the head; toward the head", "e": "cranialis (L./Gk. cranialis: of the skull, from Gk. kranion = skull)", "p": 406}, {"t": "Caudalis", "m": "Caudal — situated toward the tail", "e": "caudalis (L. caudalis: of the tail, from cauda = tail)", "p": 406}, {"t": "Rostralis", "m": "Rostral — located toward the rostrum of the corpus callosum", "e": "rostralis (L. rostralis: of the beak/rostrum, from rostrum = beak, snout)", "p": 406}, {"t": "Apicalis", "m": "Apical — pertaining to or located at the apex", "e": "apicalis (L. apicalis: of the apex/tip, from apex = tip, summit)", "p": 406}, {"t": "Basalis", "m": "Basal — pertaining to or located at the base", "e": "basalis (L./Gk. basalis: of the base, from Gk. basis = base, step)", "p": 406}, {"t": "Basilaris", "m": "Basilar — pertaining to the base of the skull", "e": "basilaris (L. basilaris: of the base, from Gk. basis = base, step)", "p": 406}, {"t": "Medius", "m": "Middle", "e": "medius (L. medius: middle, in the middle)", "p": 406}, {"t": "Transversus", "m": "Transverse", "e": "transversus (L. transversus: crosswise, from trans = across + vertere = to turn)", "p": 406}, {"t": "Longitudinalis", "m": "Longitudinal — running longitudinally", "e": "longitudinalis (L. longitudinalis: lengthwise, from longitudo = length, from longus = long)", "p": 406}, {"t": "Axialis", "m": "Axial — pertaining to or located at the axis, e.g., the 2nd cervical vertebra", "e": "axialis (L. axialis: of the axis, from axis = axle, pivot, from Gk. axon = axle)", "p": 406}, {"t": "Externus", "m": "External (outer)", "e": "externus (L. externus: external, outer, from exter = outside)", "p": 406}, {"t": "Internus", "m": "Internal (inner)", "e": "internus (L. internus: internal, inner, from inter = within, between)", "p": 406}, {"t": "Superficialis", "m": "Superficial — lying near the surface", "e": "superficialis (L. superficialis: of the surface, from super = above + facies = face, surface)", "p": 406}, {"t": "Profundus", "m": "Deep", "e": "profundus (L. profundus: deep, from pro = forward/down + fundus = bottom)", "p": 406}, {"t": "Proximalis", "m": "Proximal — lying near the trunk", "e": "proximalis (L. proximalis: nearest, from proximus = nearest, next, from prope = near)", "p": 406}, {"t": "Distalis", "m": "Distal — lying further away from the trunk", "e": "distalis (L. distalis: distant, from distare = to stand apart, from dis = apart + stare = to stand)", "p": 406}, {"t": "Centralis", "m": "Central — lying in the midpoint", "e": "centralis (L. centralis: of the center, from centrum = center, from Gk. kentron = center point)", "p": 406}, {"t": "Peripheralis", "m": "Peripheral — not pertaining to the center", "e": "peripheralis (L./Gk. peripheralis: of the periphery, from Gk. periphereia = circumference, from peri = around + pherein = to carry)", "p": 406}, {"t": "Periphericus", "m": "Periphery", "e": "periphericus (L./Gk. periphericus: peripheral, from Gk. periphereia = circumference, from peri = around + pherein = to carry)", "p": 406}, {"t": "Radialis", "m": "Radial — pertaining to or located at the radius", "e": "radialis (L. radialis: of the radius/ray, from radius = spoke, ray, radius bone)", "p": 406}, {"t": "Ulnaris", "m": "Ulnar — pertaining to or located at the ulna", "e": "ulnaris (L. ulnaris: of the ulna, from ulna = elbow, forearm bone, from Gk. olene = elbow)", "p": 406}, {"t": "Fibularis", "m": "Fibular — pertaining to the fibula or located on the fibular part of the leg", "e": "fibularis (L. fibularis: of the fibula, from fibula = clasp, pin, fibula bone, from figere = to fasten)", "p": 406}, {"t": "Tibialis", "m": "Tibial — pertaining to the tibia or located on the tibial part of the leg", "e": "tibialis (L. tibialis: of the tibia, from tibia = shin bone, flute)", "p": 406}, {"t": "Palmaris", "m": "Palmar — pertaining to or located on the palm", "e": "palmaris (L. palmaris: of the palm, from palma = palm of the hand)", "p": 406}, {"t": "Volaris", "m": "Volar — same as palmar", "e": "volaris (L. volaris: of the palm/sole, from vola = hollow of the hand or foot)", "p": 406}, {"t": "Plantaris", "m": "Plantar — pertaining to or located on the sole of the foot", "e": "plantaris (L. plantaris: of the sole, from planta = sole of the foot)", "p": 406}, {"t": "Regiones et partes corporis", "m": "Regions and parts of the body", "e": "regiones (L. regiones: regions, plural of regio = region, district, from regere = to rule/direct) + et (L. et: and) + partes (L. partes: parts, plural of pars = part) + corporis (L. corporis: of the body, genitive of corpus = body)", "p": 406}, {"t": "Linea mediana anterior", "m": "Anterior median line — vertical plane through the middle of the trunk", "e": "linea (L. linea: line, from linum = thread, flax) + mediana (L. mediana: of the middle, from medius = middle) + anterior (L. anterior: in front, comparative of ante = before)", "p": 406}, {"t": "Linea sternalis", "m": "Sternal line — line corresponding to the lateral margin of the sternum", "e": "linea (L. linea: line, from linum = thread) + sternalis (L./Gk. sternalis: of the sternum, from Gk. sternon = chest, breastbone)", "p": 406}, {"t": "Linea parasternalis", "m": "Parasternal line — vertical line midway between the sternal and midclavicular lines", "e": "linea (L. linea: line) + parasternalis (L./Gk. parasternalis: beside the sternum, from Gk. para = beside + sternon = breastbone)", "p": 406}, {"t": "Linea medioclavicularis", "m": "Midclavicular (mammary) line — vertical line passing through the halfway point of the clavicle", "e": "linea (L. linea: line) + medioclavicularis (L. medioclavicularis: of the middle of the clavicle, from medius = middle + clavicula = little key, clavicle, diminutive of clavis = key)", "p": 406}, {"t": "Linea mamillaris", "m": "Mammary line — same as midclavicular line", "e": "linea (L. linea: line) + mamillaris (L. mamillaris: of the nipple/breast, from mamilla = nipple, diminutive of mamma = breast)", "p": 406}, {"t": "Linea axillaris anterior", "m": "Anterior axillary line — lies at the anterior fold of the axilla", "e": "linea (L. linea: line) + axillaris (L. axillaris: of the armpit, from axilla = armpit) + anterior (L. anterior: in front, from ante = before)", "p": 406}, {"t": "Linea axillaris media", "m": "Axillary (midaxillary) line — lies in the middle between the anterior and posterior axillary lines", "e": "linea (L. linea: line) + axillaris (L. axillaris: of the armpit, from axilla = armpit) + media (L. media: middle, from medius = middle)", "p": 406}, {"t": "Linea axillaris posterior", "m": "Posterior axillary line — lies at the posterior fold of the axilla", "e": "linea (L. linea: line) + axillaris (L. axillaris: of the armpit, from axilla = armpit) + posterior (L. posterior: behind, comparative of posterus = coming after, from post = after)", "p": 406}, {"t": "Linea scapularis", "m": "Scapular line — a vertical line through the inferior angle of the scapula", "e": "linea (L. linea: line) + scapularis (L. scapularis: of the scapula, from scapula = shoulder blade, from Gk. skaphe = a digging tool)", "p": 406}, {"t": "Linea paravertebralis", "m": "Paravertebral line — vertical line through the ends of the transverse processes visible only in radiograms", "e": "linea (L. linea: line) + paravertebralis (L. paravertebralis: beside the vertebrae, from Gk. para = beside + vertebra = joint of the spine, from vertere = to turn)", "p": 406}, {"t": "Linea mediana posterior", "m": "Posterior median line — vertical line through the median plane of the posterior trunk", "e": "linea (L. līnea: line) + mediana (L. mediāna: middle, from medius = middle) + posterior (L. posterior: behind, hinder)", "p": 408}, {"t": "Planum subcostale", "m": "Subcostal plane — transverse plane through the lower edge of the 10th costal cartilage", "e": "planum (L. plānum: flat surface, plane) + subcostale (L. sub = under + costa = rib)", "p": 408}, {"t": "Planum transpyloricum", "m": "Transpyloric plane — horizontal plane transecting the trunk halfway between the upper margin of the pubic symphysis and the upper margin of the manubrium sterni", "e": "planum (L. plānum: flat surface) + transpyloricum (L. trans = across + Gk. pylōros = gatekeeper, pylorus)", "p": 408}, {"t": "Planum supracristale", "m": "Supracristal plane — horizontal plane through the highest point of the iliac crest", "e": "planum (L. plānum: flat surface) + supracristale (L. supra = above + crista = crest, ridge)", "p": 408}, {"t": "Planum intertuberculare", "m": "Intertubercular plane — transverse plane through the iliac tubercle", "e": "planum (L. plānum: flat surface) + intertuberculare (L. inter = between + tuberculum = small swelling, from tuber = swelling)", "p": 408}, {"t": "Planum interspinale", "m": "Interspinal plane — transverse plane through the anterior superior iliac spine", "e": "planum (L. plānum: flat surface) + interspinale (L. inter = between + spina = spine, thorn)", "p": 408}, {"t": "Linea praeaxillaris", "m": "Preaxillary line", "e": "linea (L. līnea: line) + praeaxillaris (L. prae = before, in front of + axilla = armpit)", "p": 408}, {"t": "Linea postaxillaris", "m": "Postaxillary line", "e": "linea (L. līnea: line) + postaxillaris (L. post = after, behind + axilla = armpit)", "p": 408}, {"t": "Regiones capitis", "m": "Head regions — the various anatomic regions of the head", "e": "regiones (L. regiōnēs: regions, plural of regio = region, from regere = to rule, direct) + capitis (L. caput, capitis: head)", "p": 408}, {"t": "Regio frontalis", "m": "Frontal region", "e": "regio (L. regiō: region) + frontalis (L. frontālis: of the forehead, from frons = forehead, front)", "p": 408}, {"t": "Regio parietalis", "m": "Parietal region — the region above the parietal bone", "e": "regio (L. regiō: region) + parietalis (L. parietālis: of a wall, from paries = wall)", "p": 408}, {"t": "Regio occipitalis", "m": "Occipital region — the region above the occipital bone", "e": "regio (L. regiō: region) + occipitalis (L. occipitālis: of the back of the head, from ob = against + caput = head)", "p": 408}, {"t": "Regio temporalis", "m": "Temporal region — the region above the temporal bone", "e": "regio (L. regiō: region) + temporalis (L. temporālis: of the temple, from tempora = the temples of the head)", "p": 408}, {"t": "Regiones faciales", "m": "Facial regions — the various anatomic regions of the face", "e": "regiones (L. regiōnēs: regions) + faciales (L. faciāles: of the face, from facies = face, appearance)", "p": 408}, {"t": "Regio orbitalis", "m": "Orbital region — area involving the orbit", "e": "regio (L. regiō: region) + orbitalis (L. orbitālis: of the orbit, from orbita = track, orbit, from orbis = circle)", "p": 408}, {"t": "Regio nasalis", "m": "Nasal region — region involving the nose", "e": "regio (L. regiō: region) + nasalis (L. nāsālis: of the nose, from nasus = nose)", "p": 408}, {"t": "Regio oralis", "m": "Oral region — area around the mouth", "e": "regio (L. regiō: region) + oralis (L. ōrālis: of the mouth, from os, oris = mouth)", "p": 408}, {"t": "Regio mentalis", "m": "Mental region — chin area", "e": "regio (L. regiō: region) + mentalis (L. mentālis: of the chin, from mentum = chin)", "p": 408}, {"t": "Regio infraorbitalis", "m": "Infraorbital region — region below the orbit", "e": "regio (L. regiō: region) + infraorbitalis (L. infra = below + orbita = orbit)", "p": 408}, {"t": "Regio buccalis", "m": "Buccal region — cheek area", "e": "regio (L. regiō: region) + buccalis (L. buccālis: of the cheek, from bucca = cheek)", "p": 408}, {"t": "Regio zygomatica", "m": "Zygomatic region", "e": "regio (L. regiō: region) + zygomatica (Gk. zygōma: yoke, cheekbone, from zygon = yoke)", "p": 408}, {"t": "Regiones cervicales", "m": "Cervical regions — the various anatomic regions of the neck", "e": "regiones (L. regiōnēs: regions) + cervicales (L. cervicāles: of the neck, from cervix = neck)", "p": 408}, {"t": "Regio cervicalis anterior", "m": "Anterior triangle of neck — region between the midline and the sternocleidomastoid muscle", "e": "regio (L. regiō: region) + cervicalis (L. cervicālis: of the neck) + anterior (L. anterior: front, former, from ante = before)", "p": 408}, {"t": "Trigonum cervicale anterius", "m": "Anterior triangle of neck", "e": "trigonum (L. trigonum from Gk. trigōnon: triangle, from tri = three + gōnia = angle) + cervicale (L. cervicāle: of the neck) + anterius (L. anterius: front)", "p": 408}, {"t": "Trigonum submandibulare", "m": "Submandibular (digastric) triangle — region bounded by the inferior border of the mandible and the two bellies of the digastric muscle", "e": "trigonum (L./Gk. trigōnon: triangle) + submandibulare (L. sub = under + mandibula = jaw, from mandere = to chew)", "p": 408}, {"t": "Trigonum caroticum", "m": "Carotid triangle — triangular region bounded by the sternocleidomastoid muscle, posterior belly of the digastric muscle and superior belly of the omohyoid muscle", "e": "trigonum (L./Gk. trigōnon: triangle) + caroticum (Gk. karōtikos: of the carotid, from karoun = to stupefy, as pressure causes unconsciousness)", "p": 408}, {"t": "Trigonum musculare", "m": "Muscular (inferior carotid) triangle — triangular region between the anterior median line of the neck, the anterior margin of the sternocleidomastoid muscle and the superior belly of the omohyoid muscle", "e": "trigonum (L./Gk. trigōnon: triangle) + musculare (L. musculāre: of muscle, from musculus = muscle, little mouse)", "p": 408}, {"t": "Trigonum omotracheale", "m": "Muscular (inferior carotid) triangle (alternate name)", "e": "trigonum (L./Gk. trigōnon: triangle) + omotracheale (Gk. ōmos = shoulder + L. trachea from Gk. trakheia = rough, windpipe)", "p": 408}, {"t": "Trigonum submentale", "m": "Submental (suprahyoid) triangle — triangle below the chin between the hyoid bone and the anterior belly of the digastric muscle on each side", "e": "trigonum (L./Gk. trigōnon: triangle) + submentale (L. sub = under + mentum = chin)", "p": 408}, {"t": "Regio sternocleidomastoidea", "m": "Sternocleidomastoid region — region overlying the sternocleidomastoid muscle", "e": "regio (L. regiō: region) + sternocleidomastoidea (Gk. sternon = chest + kleis = key, clavicle + mastos = breast + eidos = form, shape)", "p": 408}, {"t": "Fossa supraclavicularis minor", "m": "Lesser supraclavicular fossa — triangular depression between the sternal and clavicular origins of the sternocleidomastoid muscle", "e": "fossa (L. fossa: ditch, pit, from fodere = to dig) + supraclavicularis (L. supra = above + clavicula = little key, clavicle) + minor (L. minor: smaller, lesser)", "p": 408}, {"t": "Regio cervicalis lateralis", "m": "Posterior triangle of neck — triangle between the clavicle, anterior margin of the trapezius and posterior border of the sternocleidomastoid muscle", "e": "regio (L. regiō: region) + cervicalis (L. cervicālis: of the neck) + lateralis (L. laterālis: of the side, from latus = side)", "p": 408}, {"t": "Trigonum cervicale posterius", "m": "Posterior triangle of neck", "e": "trigonum (L./Gk. trigōnon: triangle) + cervicale (L. cervicāle: of the neck) + posterius (L. posterius: behind, from post = after)", "p": 408}, {"t": "Trigonum omoclaviculare", "m": "Supraclavicular (omoclavicular, subclavian) triangle — greater supraclavicular fossa; triangle between the sternocleidomastoid and omohyoid muscles and the clavicle", "e": "trigonum (L./Gk. trigōnon: triangle) + omoclaviculare (Gk. ōmos = shoulder + L. clavicula = little key, clavicle)", "p": 408}, {"t": "Fossa supraclavicularis major", "m": "Greater supraclavicular fossa (alternate name for supraclavicular triangle)", "e": "fossa (L. fossa: pit, ditch) + supraclavicularis (L. supra = above + clavicula = little key, clavicle) + major (L. maior: greater, larger)", "p": 408}, {"t": "Regio cervicalis posterior", "m": "Posterior region of the neck (nuchal region)", "e": "regio (L. regiō: region) + cervicalis (L. cervicālis: of the neck) + posterior (L. posterior: behind)", "p": 408}, {"t": "Regio nuchalis", "m": "Nuchal region — posterior region of the neck", "e": "regio (L. regiō: region) + nuchalis (Medieval L. nucha: nape of neck, from Arabic nukha = spinal marrow)", "p": 408}, {"t": "Regiones pectorales", "m": "Pectoral regions — collective term for the various regions of the chest", "e": "regiones (L. regiōnēs: regions) + pectorales (L. pectorāles: of the chest, from pectus = chest, breast)", "p": 408}, {"t": "Regio presternalis", "m": "Presternal region — area in front of the sternum", "e": "regio (L. regiō: region) + presternalis (L. prae = before, in front + Gk. sternon = chest, breastbone)", "p": 408}, {"t": "Fossa infraclavicularis", "m": "Infraclavicular fossa — depression produced by the clavipectoral triangle", "e": "fossa (L. fossa: pit, ditch) + infraclavicularis (L. infra = below + clavicula = little key, clavicle)", "p": 408}, {"t": "Trigonum clavipectorale", "m": "Clavipectoral triangle — triangle between the deltoid, pectoralis major and clavicle", "e": "trigonum (L./Gk. trigōnon: triangle) + clavipectorale (L. clavicula = little key, clavicle + pectus = chest, breast)", "p": 408}, {"t": "Regio pectoralis", "m": "Pectoral region — area on the pectoralis major muscle", "e": "regio (L. regiō: region) + pectoralis (L. pectorālis: of the chest, from pectus = chest)", "p": 408}, {"t": "Regio mammaria", "m": "Mammary region — region pertaining to the mammary gland", "e": "regio (L. regiō: region) + mammaria (L. mammāria: of the breast, from mamma = breast)", "p": 408}, {"t": "Regio inframammaria", "m": "Inframammary region — region below the mammary region", "e": "regio (L. regiō: region) + inframammaria (L. infra = below + mamma = breast)", "p": 408}, {"t": "Regio axillaris", "m": "Axillary region", "e": "regio (L. regiō: region) + axillaris (L. axillāris: of the armpit, from axilla = armpit)", "p": 408}, {"t": "Fossa axillaris", "m": "Axillary fossa", "e": "fossa (L. fossa: pit, ditch) + axillaris (L. axillāris: of the armpit, from axilla = armpit)", "p": 408}, {"t": "Myologia", "m": "Study of the muscles", "e": "myo (Gk. mys/myos: muscle) + logia (Gk. logos: study of)", "p": 415}, {"t": "Musculus", "m": "Muscle", "e": "musculus (L. musculus: muscle, little mouse, from mus: mouse)", "p": 415}, {"t": "Caput", "m": "Head", "e": "caput (L. caput: head)", "p": 415}, {"t": "Venter", "m": "Belly", "e": "venter (L. venter: belly, stomach)", "p": 415}, {"t": "Musculus fusiformis", "m": "Fusiform muscle — spindle-shaped muscle", "e": "musculus (L. musculus: muscle) + fusiformis (L. fusus: spindle + forma: shape)", "p": 415}, {"t": "M. quadratus", "m": "Quadrate muscle — square-shaped muscle", "e": "M. (abbrev. musculus: muscle) + quadratus (L. quadratus: squared, from quattuor: four)", "p": 415}, {"t": "M. triangularis", "m": "Triangular muscle", "e": "M. (abbrev. musculus: muscle) + triangularis (L. triangularis: triangular, from tri: three + angulus: angle)", "p": 415}, {"t": "M. unipennatus", "m": "Unipennate muscle — muscle with fibers approaching the tendon from one side", "e": "M. (abbrev. musculus: muscle) + uni (L. unus: one) + pennatus (L. penna: feather, wing)", "p": 415}, {"t": "M. bipennatus", "m": "Bipennate muscle — muscle with fibers approaching the tendon from two sides", "e": "M. (abbrev. musculus: muscle) + bi (L. bis: two) + pennatus (L. penna: feather, wing)", "p": 415}, {"t": "M. multipennatus", "m": "Multipennate muscle — muscle with fibers approaching the tendon from many sides", "e": "M. (abbrev. musculus: muscle) + multi (L. multus: many) + pennatus (L. penna: feather, wing)", "p": 415}, {"t": "M. sphincter", "m": "Sphincter muscle", "e": "M. (abbrev. musculus: muscle) + sphincter (Gk. sphinkter: binder, from sphingein: to bind tight)", "p": 415}, {"t": "M. dilator", "m": "Dilator muscle", "e": "M. (abbrev. musculus: muscle) + dilator (L. dilator: one who widens, from dilatare: to spread out)", "p": 415}, {"t": "M. orbicularis", "m": "Orbicular muscle — circular muscle", "e": "M. (abbrev. musculus: muscle) + orbicularis (L. orbicularis: circular, from orbis: circle, disk)", "p": 415}, {"t": "M. cruciatus", "m": "Cruciate muscle — muscle with crossing fibers", "e": "M. (abbrev. musculus: muscle) + cruciatus (L. cruciatus: crossed, from crux/crucis: cross)", "p": 415}, {"t": "M. articularis", "m": "Articular muscle — muscle which attaches to a joint capsule", "e": "M. (abbrev. musculus: muscle) + articularis (L. articularis: of a joint, from articulus: joint)", "p": 415}, {"t": "M. skeleti", "m": "Skeletal muscle — muscle with attachment to the skeleton in contrast to a cutaneous muscle", "e": "M. (abbrev. musculus: muscle) + skeleti (Gk. skeletos: dried up, from skellein: to dry)", "p": 415}, {"t": "M. cutaneus", "m": "Cutaneous muscle", "e": "M. (abbrev. musculus: muscle) + cutaneus (L. cutaneus: of the skin, from cutis: skin)", "p": 415}, {"t": "Tendo", "m": "Tendon", "e": "tendo (L. tendo: tendon, from tendere: to stretch)", "p": 415}, {"t": "Vagina tendinis", "m": "Tendon (synovial) sheath — lubricated sheath for easy gliding of a tendon", "e": "vagina (L. vagina: sheath, scabbard) + tendinis (L. tendo/tendinis: tendon, from tendere: to stretch)", "p": 415}, {"t": "Stratum fibrosum", "m": "Fibrous layer — outer, connective tissue portion of a tendon sheath", "e": "stratum (L. stratum: layer, from sternere: to spread) + fibrosum (L. fibrosus: fibrous, from fibra: fiber)", "p": 415}, {"t": "Stratum synoviale", "m": "Synovial layer — inner, smooth layer of a tendon sheath that secretes synovial fluid", "e": "stratum (L. stratum: layer) + synoviale (Gk./NL. synovialis: of synovial fluid, from syn: together + L. ovum: egg)", "p": 415}, {"t": "Vagina synovialis tendinis", "m": "Synovial sheath of tendon — the inner gliding capsule of the fibrous sheath of a tendon", "e": "vagina (L. vagina: sheath) + synovialis (Gk./NL. synovialis: of synovial fluid) + tendinis (L. tendo/tendinis: tendon)", "p": 415}, {"t": "Mesotendineum", "m": "Mesotendineum — mesentery-like sheath connecting a tendon to its fibrous sheath, carries blood vessels to the tendon", "e": "meso (Gk. mesos: middle) + tendineum (L. tendo/tendinis: tendon)", "p": 415}, {"t": "Peritendineum", "m": "Peritendineum — connective tissue on the surface of a tendon", "e": "peri (Gk. peri: around) + tendineum (L. tendo/tendinis: tendon)", "p": 415}, {"t": "Aponeurosis", "m": "Aponeurosis — flat tendinous expansion", "e": "apo (Gk. apo: away from) + neurosis (Gk. neuron: nerve, sinew, tendon)", "p": 415}, {"t": "Epimysium", "m": "Epimysium — fibrous sheath enveloping an entire muscle", "e": "epi (Gk. epi: upon, over) + mysium (Gk. mys/myos: muscle)", "p": 415}, {"t": "Perimysium", "m": "Perimysium — fibrous sheath enclosing a bundle of muscle fibers", "e": "peri (Gk. peri: around) + mysium (Gk. mys/myos: muscle)", "p": 415}, {"t": "Endomysium", "m": "Endomysium — fibrous sheath surrounding a single muscle fiber enclosed by sarcolemma", "e": "endo (Gk. endon: within) + mysium (Gk. mys/myos: muscle)", "p": 415}, {"t": "Fascia", "m": "Fascia — external sheath investing one or more muscles", "e": "fascia (L. fascia: band, bandage, bundle)", "p": 415}, {"t": "Fascia superficialis", "m": "Superficial fascia", "e": "fascia (L. fascia: band, bandage) + superficialis (L. superficialis: superficial, from super: above + facies: surface)", "p": 415}, {"t": "Fascia profunda", "m": "Deep fascia", "e": "fascia (L. fascia: band, bandage) + profunda (L. profundus: deep, from pro: forward + fundus: bottom)", "p": 415}, {"t": "Intersectio tendinea", "m": "Tendinous intersections", "e": "intersectio (L. intersectio: intersection, from inter: between + secare: to cut) + tendinea (L. tendineus: of a tendon, from tendo: tendon)", "p": 415}, {"t": "Tendo intermedius", "m": "Intermediate tendon", "e": "tendo (L. tendo: tendon, from tendere: to stretch) + intermedius (L. intermedius: intermediate, from inter: between + medius: middle)", "p": 415}, {"t": "Arcus tendineus", "m": "Tendinous arch — serves as the origin of muscle fibers", "e": "arcus (L. arcus: arch, bow) + tendineus (L. tendineus: of a tendon, from tendo: tendon)", "p": 415}, {"t": "Trochlea muscularis", "m": "Muscular trochlea — structure that changes the direction of pull of a tendon", "e": "trochlea (L. trochlea: pulley, from Gk. trokhilia: pulley) + muscularis (L. muscularis: muscular, from musculus: muscle)", "p": 415}, {"t": "Bursae synoviales", "m": "Synovial bursae", "e": "bursae (L. bursa: purse, pouch, from Gk. byrsa: hide, leather) + synoviales (Gk./NL. synovialis: of synovial fluid)", "p": 415}, {"t": "Bursa synovialis subcutanea", "m": "Subcutaneous bursa — lies directly beneath the skin", "e": "bursa (L. bursa: purse, pouch) + synovialis (Gk./NL. synovialis: of synovial fluid) + subcutanea (L. sub: under + cutis: skin)", "p": 415}, {"t": "Bursa synovialis submuscularis", "m": "Submuscular bursa — lies beneath a muscle", "e": "bursa (L. bursa: purse, pouch) + synovialis (Gk./NL. synovialis: of synovial fluid) + submuscularis (L. sub: under + musculus: muscle)", "p": 415}, {"t": "Bursa synovialis subfascialis", "m": "Subfascial bursa — lies beneath a fascia", "e": "bursa (L. bursa: purse, pouch) + synovialis (Gk./NL. synovialis: of synovial fluid) + subfascialis (L. sub: under + fascia: band)", "p": 415}, {"t": "Bursa synovialis subtendinea", "m": "Subtendinous bursa — lies beneath a tendon", "e": "bursa (L. bursa: purse, pouch) + synovialis (Gk./NL. synovialis: of synovial fluid) + subtendinea (L. sub: under + tendo/tendinis: tendon)", "p": 415}, {"t": "Splanchnologia", "m": "Splanchnology — study of viscera", "e": "splanchno (Gk. splanchnon: viscus, internal organ) + logia (Gk. logos: study of)", "p": 415}, {"t": "Nomina generalia", "m": "General terms", "e": "nomina (L. nomen/nominis: name, term) + generalia (L. generalis: general, from genus: kind, class)", "p": 415}, {"t": "Tunica albuginea", "m": "Tunica albuginea — tough, whitish connective tissue sheath", "e": "tunica (L. tunica: coat, covering, garment) + albuginea (L. albuginea: whitish, from albus: white)", "p": 415}, {"t": "Epithelium mucosae", "m": "Epithelium mucosae — epithelial cell layer of the mucosa", "e": "epithelium (Gk. epi: upon + thele: nipple, hence surface covering) + mucosae (L. mucosus: mucous, from mucus: slime)", "p": 415}, {"t": "Lamina propria mucosae", "m": "Lamina propria mucosae — lamina propria of the mucosa; layer of reticular connective tissue extending up to the muscularis mucosae", "e": "lamina (L. lamina: thin plate, layer) + propria (L. proprius: own, proper) + mucosae (L. mucosus: mucous, from mucus: slime)", "p": 415}, {"t": "systema nervosum periphericum", "m": "Peripheral nervous system", "e": "systema (Gk. systēma: system, organized whole) + nervosum (L. nervosus: of nerves, from nervus = nerve) + periphericum (Gk. peripherikos: peripheral, from peri = around + pherein = to carry)", "p": 417}, {"t": "Nervus", "m": "Nerve", "e": "nervus (L. nervus: nerve, sinew, from Gk. neuron = nerve)", "p": 417}, {"t": "Endoneurium", "m": "Delicate connective tissue sheath attaching directly to the basal membrane of an individual nerve fiber", "e": "endo- (Gk. endon: within) + neurium (Gk. neuron: nerve)", "p": 417}, {"t": "Perineurium", "m": "Connective tissue sheath enclosing the bundles of fibers of a peripheral nerve, consisting of lamellae made of epithelioid connective tissue cells", "e": "peri- (Gk. peri: around) + neurium (Gk. neuron: nerve)", "p": 417}, {"t": "Epineurium", "m": "The connective tissue sheath covering a peripheral nerve", "e": "epi- (Gk. epi: upon, over) + neurium (Gk. neuron: nerve)", "p": 417}, {"t": "Neurofibrae afferentes", "m": "Afferent nerve fibers — nerve fibers traveling into the central nervous system", "e": "neuro- (Gk. neuron: nerve) + fibrae (L. fibra: fiber, thread) + afferentes (L. afferens: carrying toward, from ad = to + ferre = to carry)", "p": 417}, {"t": "Neurofibrae efferentes", "m": "Efferent nerve fibers — nerve fibers that conduct impulses away from the central nervous system", "e": "neuro- (Gk. neuron: nerve) + fibrae (L. fibra: fiber, thread) + efferentes (L. efferens: carrying away, from ex = out + ferre = to carry)", "p": 417}, {"t": "Neurofibrae somaticae", "m": "Somatic nerve fibers — opposing the autonomic nerves, i.e., visceral nerves", "e": "neuro- (Gk. neuron: nerve) + fibrae (L. fibra: fiber, thread) + somaticae (Gk. sōmatikos: of the body, from sōma = body)", "p": 417}, {"t": "Neurofibrae autonomicae viscerales", "m": "Autonomic (visceral) nerve fibers — fibers of the visceral nerves", "e": "neuro- (Gk. neuron: nerve) + fibrae (L. fibra: fiber, thread) + autonomicae (Gk. autonomikos: self-governing, from autos = self + nomos = law) + viscerales (L. visceralis: of the viscera, from viscera = internal organs)", "p": 417}, {"t": "Ganglion", "m": "An accumulation of nerve cell bodies and thus a macroscopic thickening of a nerve", "e": "ganglion (Gk. ganglion: knot, swelling under the skin)", "p": 417}, {"t": "Capsula ganglii", "m": "Capsule of ganglion — composed of connective tissue", "e": "capsula (L. capsula: small box, diminutive of capsa = box) + ganglii (Gk. ganglion: knot, swelling)", "p": 417}, {"t": "capsula ganglionica", "m": "Capsule of ganglion (alternative term)", "e": "capsula (L. capsula: small box, diminutive of capsa = box) + ganglionica (Gk. ganglion: knot, swelling + L. -ica suffix)", "p": 417}, {"t": "Stroma ganglii", "m": "Stroma of ganglion — internal connective tissue of a ganglion", "e": "stroma (Gk. strōma: bed, mattress, supporting framework) + ganglii (Gk. ganglion: knot, swelling)", "p": 417}, {"t": "Stroma ganglionicum", "m": "Internal connective tissue of a ganglion (alternative term)", "e": "stroma (Gk. strōma: bed, mattress, supporting framework) + ganglionicum (Gk. ganglion: knot, swelling + L. -icum suffix)", "p": 417}, {"t": "Ganglia craniospinalia", "m": "Craniospinal (sensory) ganglia — collective term for spinal and cranial nerve sensory ganglia", "e": "ganglia (Gk. ganglion: knot, swelling, plural) + cranio- (Gk. kranion: skull) + spinalia (L. spina: spine, thorn)", "p": 417}, {"t": "encephalospinalia sensoria", "m": "Craniospinal sensory ganglia (alternative term)", "e": "encephalo- (Gk. enkephalos: brain, from en = in + kephalē = head) + spinalia (L. spina: spine) + sensoria (L. sensorius: of sensation, from sentire = to feel)", "p": 417}, {"t": "Ganglia spinalia", "m": "Spinal ganglia (sensory) — dorsal root ganglia", "e": "ganglia (Gk. ganglion: knot, swelling, plural) + spinalia (L. spina: spine, thorn)", "p": 417}, {"t": "sensoria", "m": "Sensory — relating to sensation", "e": "sensoria (L. sensorius: of sensation, from sentire = to feel, perceive)", "p": 417}, {"t": "Ganglia sensoria neuricum cranialium", "m": "Sensory ganglia of cranial nerves — spinal ganglia equivalent of cranial nerves", "e": "ganglia (Gk. ganglion: knot, swelling, plural) + sensoria (L. sensorius: of sensation) + neuricum (Gk. neuron: nerve + L. -icum suffix) + cranialium (Gk. kranion: skull + L. -alis suffix)", "p": 417}, {"t": "gg. encephalica", "m": "Cranial ganglia (abbreviated form)", "e": "gg. (abbreviation of ganglia, Gk. ganglion: knot) + encephalica (Gk. enkephalos: brain, from en = in + kephalē = head)", "p": 417}, {"t": "Ganglia autonomica visceralia", "m": "Autonomic (visceral) ganglia — ganglia of visceral nerves", "e": "ganglia (Gk. ganglion: knot, swelling, plural) + autonomica (Gk. autonomikos: self-governing, from autos = self + nomos = law) + visceralia (L. visceralis: of the viscera, from viscera = internal organs)", "p": 417}, {"t": "Neurofibrae praeganglionicae", "m": "Preganglionic nerve fibers — myelinated nerve fibers passing to the ganglia of the visceral nerves", "e": "neuro- (Gk. neuron: nerve) + fibrae (L. fibra: fiber, thread) + prae- (L. prae: before) + ganglionicae (Gk. ganglion: knot, swelling)", "p": 417}, {"t": "Neurofibrae postganglionicae", "m": "Postganglionic nerve fibers — nonmyelinated nerve fibers passing from the visceral ganglia to the viscera", "e": "neuro- (Gk. neuron: nerve) + fibrae (L. fibra: fiber, thread) + post- (L. post: after, behind) + ganglionicae (Gk. ganglion: knot, swelling)", "p": 417}, {"t": "Ganglion sympatheticum", "m": "Sympathetic ganglion — represented mainly by the sympathetic trunk", "e": "ganglion (Gk. ganglion: knot, swelling) + sympatheticum (Gk. sympathetikos: sympathetic, from syn = together + pathos = feeling)", "p": 417}, {"t": "sympathicum", "m": "Sympathetic (alternative adjectival form)", "e": "sympathicum (Gk. sympathētikos: sympathetic, from syn = together + pathos = feeling, suffering)", "p": 417}, {"t": "Ramus communicans alba", "m": "White ramus communicans — connection between the spinal nerve and sympathetic trunk, appearing white due to myelinated preganglionic fibers", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating, from communicare = to share, connect) + alba (L. albus: white)", "p": 417}, {"t": "Ramus communicans griseus", "m": "Gray ramus communicans — connection between the sympathetic trunk and spinal nerve, containing postganglionic nonmyelinated fibers", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating, from communicare = to share, connect) + griseus (L. griseus: gray, from Medieval L. grīseus)", "p": 417}, {"t": "Ganglion parasympatheticum", "m": "Parasympathetic ganglion", "e": "ganglion (Gk. ganglion: knot, swelling) + parasympatheticum (Gk. para = beside + sympathetikos: sympathetic, from syn = together + pathos = feeling)", "p": 417}, {"t": "parasympathicum", "m": "Parasympathetic (alternative adjectival form)", "e": "para- (Gk. para: beside, alongside) + sympathicum (Gk. sympathētikos: sympathetic, from syn = together + pathos = feeling)", "p": 417}, {"t": "Plexus nervorum spinalium", "m": "Plexus of spinal nerves — present in the cervical, lumbar and sacral regions, giving rise to nerves for the limbs", "e": "plexus (L. plexus: braid, network, from plectere = to braid) + nervorum (L. nervus: nerve, genitive plural) + spinalium (L. spinalis: of the spine, from spina = spine, thorn, genitive plural)", "p": 417}, {"t": "encephalici", "m": "Encephalic (alternative term for cranial nerves)", "e": "encephalici (Gk. enkephalikos: of the brain, from en = in + kephalē = head)", "p": 418}, {"t": "Nuclei nervorum cranialium", "m": "Cranial nerve nuclei", "e": "nuclei (L. nucleus: kernel, core, from nux = nut) + nervorum (L. nervus: nerve, genitive plural) + cranialium (L. craniālis: of the cranium, genitive plural)", "p": 418}, {"t": "encephalicorum", "m": "Of the encephalon (alternative genitive form for cranial nerve nuclei)", "e": "encephalicorum (Gk. enkephalikos: of the brain, genitive plural, from en = in + kephalē = head)", "p": 418}, {"t": "Nuclei originis", "m": "Nuclei of origin — nuclei that give rise to the efferent, mostly motor, nerve fibers", "e": "nuclei (L. nucleus: kernel, core) + originis (L. origo: origin, source, genitive singular, from oriri = to rise)", "p": 418}, {"t": "Nuclei terminationis", "m": "Nuclei of termination — sensory nuclei where the afferent nerve fibers terminate and synapse with a second neuron", "e": "nuclei (L. nucleus: kernel, core) + terminationis (L. terminatio: termination, end, genitive singular, from terminus = boundary)", "p": 418}, {"t": "Nervus mixtus", "m": "Mixed nerve — a nerve containing both motor and sensory fibers, or a nerve with somatic and visceral components", "e": "nervus (L. nervus: nerve, sinew) + mixtus (L. mixtus: mixed, from miscere = to mix)", "p": 418}, {"t": "n. mixtarum neurofibrarum", "m": "Nerve of mixed nerve fibers (alternative Latin form for mixed nerve)", "e": "n. (abbreviation of nervus: L. nerve) + mixtarum (L. mixtus: mixed, genitive plural feminine) + neurofibrarum (Gk./L. neuro = nerve + fibra = fiber, genitive plural)", "p": 418}, {"t": "Rami cutanei", "m": "Cutaneous branches — cutaneous nerves or rami conducting impulses to the skin", "e": "rami (L. ramus: branch, plural) + cutanei (L. cutaneus: of the skin, from cutis = skin)", "p": 418}, {"t": "Rami articulares", "m": "Articular branches — nerves or nerve rami conducting impulses to joints", "e": "rami (L. ramus: branch, plural) + articulares (L. articulāris: of a joint, from articulus = joint, diminutive of artus = joint)", "p": 418}, {"t": "Nervus motorius", "m": "Motor nerve — nerve which only has fibers for muscles", "e": "nervus (L. nervus: nerve, sinew) + motorius (L. motorius: of motion, from movere = to move)", "p": 418}, {"t": "Nervus sensorius", "m": "Sensory nerve — nerve containing afferent fibers which convey impulses to the central nervous system from peripheral receptors", "e": "nervus (L. nervus: nerve, sinew) + sensorius (L. sensorius: of sensation, from sentire = to feel, sense)", "p": 418}, {"t": "Ramus communicans", "m": "Communicating branch", "e": "ramus (L. ramus: branch) + communicans (L. communicans: communicating, present participle of communicare = to share, connect)", "p": 418}, {"t": "Nervus et ramus autonomici viscerales", "m": "Autonomic (visceral) nerve and ramus — nerves and their rami that conduct impulses from the region of nerve supply to the viscera", "e": "nervus (L. nervus: nerve) + et (L.: and) + ramus (L. ramus: branch) + autonomici (Gk. autonomikos: self-governing, from autos = self + nomos = law) + viscerales (L. viscerālis: of the viscera, from viscera = internal organs)", "p": 418}, {"t": "Plexus autonomicus visceralis", "m": "Autonomic (visceral) plexus — a plexus situated within an organ", "e": "plexus (L. plexus: network, braid, from plectere = to braid) + autonomicus (Gk. autonomikos: self-governing, from autos = self + nomos = law) + visceralis (L. viscerālis: of the viscera, from viscera = internal organs)", "p": 418}, {"t": "Plexus vascularis", "m": "Vascular plexus — nerve plexus in the wall of vessels with sensory and autonomic components", "e": "plexus (L. plexus: network, braid) + vascularis (L. vasculāris: of vessels, from vasculum = small vessel, diminutive of vas = vessel)", "p": 418}, {"t": "Plexus periarteriales", "m": "Periarterial plexus — nerve plexus within the adventitia of arteries", "e": "plexus (L. plexus: network, braid) + periarteriales (Gk./L. peri = around + arteria = artery, from Gk. artēria = windpipe, artery)", "p": 418}, {"t": "Nervi vasorum", "m": "Nervi vasorum — nerves supplying blood vessels", "e": "nervi (L. nervus: nerve, plural) + vasorum (L. vas: vessel, genitive plural)", "p": 418}, {"t": "Vasa nervorum", "m": "Vasa nervorum — blood vessels supplying nerves", "e": "vasa (L. vas: vessel, plural) + nervorum (L. nervus: nerve, genitive plural)", "p": 418}, {"t": "Textus nervosus", "m": "Nervous tissue", "e": "textus (L. textus: tissue, texture, from texere = to weave) + nervosus (L. nervosus: of nerves, sinewy, from nervus = nerve)", "p": 418}, {"t": "Neuron", "m": "Neuron (nerve cell)", "e": "neuron (Gk. neuron: nerve, sinew)", "p": 418}, {"t": "neurocytus", "m": "Neurocyte (alternative Latin term for neuron/nerve cell)", "e": "neuro (Gk. neuron: nerve) + cytus (Gk. kytos: cell, hollow vessel)", "p": 418}, {"t": "Corpus neurale", "m": "Nerve cell body (perikaryon) — portion of a neuron containing the nucleus but excluding the cell processes", "e": "corpus (L. corpus: body) + neurale (Gk. neuron: nerve + L. -ale = adjectival suffix)", "p": 418}, {"t": "Axon", "m": "Axon (axis cylinder) — usually a long process of a neuron which helps to form the peripheral nerves and can be either nonmyelinated or myelinated", "e": "axon (Gk. axon: axis, axle)", "p": 418}, {"t": "neuritum", "m": "Neurite (alternative Latin term for axon/axis cylinder)", "e": "neuritum (Gk. neuron: nerve + L./Gk. -itum: diminutive/derived suffix)", "p": 418}, {"t": "Dendritum", "m": "Dendrite — one of many tree-like branched processes of a neuron that has no special sheath", "e": "dendritum (Gk. dendron: tree + -ite suffix, hence tree-like)", "p": 418}, {"t": "Rami malleolares laterales", "m": "Lateral malleolar branches — branches to the lateral malleolus, frequently from the communicating branch", "e": "rami (L. ramus: branches) + malleolares (L. malleolaris: of the malleolus, from malleus = hammer) + laterales (L. lateralis: lateral, from latus = side)", "p": 511}, {"t": "Rami calcanei", "m": "Calcanean branches — branches that pass mainly to the lateral side of the calcaneus", "e": "rami (L. ramus: branches) + calcanei (L. calcaneus: heel bone, from calx = heel)", "p": 511}, {"t": "Rete calcaneum", "m": "Calcanean network — arterial network on posterior aspect of the calcaneus", "e": "rete (L. rete: network) + calcaneum (L. calcaneum: of the heel bone, from calx = heel)", "p": 511}, {"t": "A. nutriens (nutricia) fibulae", "m": "Nutrient artery of fibula", "e": "a. (L. arteria: artery) + nutriens (L. nutriens: nourishing, from nutrire = to nourish) + nutricia (L. nutricia: nourishing, nursing) + fibulae (L. fibula: clasp/brooch, the smaller lower leg bone)", "p": 511}, {"t": "A. plantaris medialis", "m": "Medial plantar artery — generally the weaker medial terminal branch of the posterior tibial artery", "e": "a. (L. arteria: artery) + plantaris (L. plantaris: of the sole, from planta = sole of the foot) + medialis (L. medialis: medial, from medius = middle)", "p": 511}, {"t": "A. plantaris lateralis", "m": "Lateral plantar artery — larger lateral terminal branch of the posterior tibial artery", "e": "a. (L. arteria: artery) + plantaris (L. plantaris: of the sole, from planta = sole of the foot) + lateralis (L. lateralis: lateral, from latus = side)", "p": 511}, {"t": "Arcus plantaris profundus", "m": "Deep plantar arch — distal convex continuation of the lateral plantar artery between the interossei and the oblique head of the adductor hallucis", "e": "arcus (L. arcus: arch, bow) + plantaris (L. plantaris: of the sole, from planta = sole of the foot) + profundus (L. profundus: deep, from pro = forward + fundus = bottom)", "p": 511}, {"t": "Aa. metatarsales plantares", "m": "Plantar metatarsal arteries — four arterial trunks emanating from the plantar arch below the spaces between the metatarsal bones", "e": "aa. (L. arteriae: arteries) + metatarsales (Gk. meta = beyond/after + tarsos = flat of the foot) + plantares (L. plantares: of the sole, from planta = sole of the foot)", "p": 511}, {"t": "Rami perforantes", "m": "Perforating branches — usually two such branches arise from each plantar metatarsal artery and pass between the metatarsal bones to the dorsum of the foot", "e": "rami (L. ramus: branches) + perforantes (L. perforantes: perforating, from per = through + forare = to bore/pierce)", "p": 511}, {"t": "Aa. digitales plantares communes", "m": "Common plantar digital arteries — arterial stems extending from the distal perforating branch to the division into the proper plantar digital arteries", "e": "aa. (L. arteriae: arteries) + digitales (L. digitalis: of the fingers/toes, from digitus = finger/toe) + plantares (L. plantares: of the sole, from planta = sole of the foot) + communes (L. communes: common, shared)", "p": 511}, {"t": "Aa. digitales plantares propriae", "m": "Proper plantar digital arteries — arteries coursing along the plantar medial and lateral sides of the toes", "e": "aa. (L. arteriae: arteries) + digitales (L. digitalis: of the fingers/toes, from digitus = finger/toe) + plantares (L. plantares: of the sole, from planta = sole of the foot) + propriae (L. proprius: one's own, proper)", "p": 511}, {"t": "Arcus plantaris superficialis", "m": "Superficial plantar arch — occasional superficial connection between the medial and lateral plantar arteries", "e": "arcus (L. arcus: arch, bow) + plantaris (L. plantaris: of the sole, from planta = sole of the foot) + superficialis (L. superficialis: superficial, from super = above + facies = surface)", "p": 511}];

// ─────────────────────────────────────────────────────────────
// SEARCH  – combines question bank + atlas
// ─────────────────────────────────────────────────────────────
function buildSearchIndex() {
  const index = [];
  // From question bank
  Object.entries(QUESTION_BANK).forEach(([subject, meta]) => {
    meta.questions.forEach(q => {
      if (!index.find(e => e.term.toLowerCase() === q.subtopic.toLowerCase())) {
        index.push({
          term: q.subtopic,
          topic: `${subject} › ${q.topic}`,
          definition: q.explanation,
          etymology: '',
          page: 0,
          source: 'exam',
        });
      }
    });
  });
  // From atlas
  if (typeof ATLAS_TERMS !== 'undefined') {
    ATLAS_TERMS.forEach(a => {
      index.push({
        term: a.t,
        topic: a.m,
        definition: a.e,
        page: a.p,
        source: 'atlas',
      });
    });
  }
  return index;
}

const SEARCH_INDEX = buildSearchIndex();

// ─────────────────────────────────────────────────────────────
// ─────────────────────────────────────────────────────────────
// BOOK STORAGE  (IndexedDB — handles large PDFs, no size limit)
// ─────────────────────────────────────────────────────────────
const SPINE_COLORS = [
  'rgba(20,20,20,0.85)', 'rgba(30,30,30,0.80)',
  'rgba(15,15,15,0.90)', 'rgba(25,25,25,0.75)',
  'rgba(10,10,10,0.85)', 'rgba(35,35,35,0.80)',
];

function openDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open('studybuddy_books', 2);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains('meta'))  db.createObjectStore('meta',  { keyPath: 'id' });
      if (!db.objectStoreNames.contains('pdfs'))  db.createObjectStore('pdfs',  { keyPath: 'id' });
      if (!db.objectStoreNames.contains('index')) db.createObjectStore('index', { keyPath: 'id' });
    };
    req.onsuccess = e => resolve(e.target.result);
    req.onerror   = e => reject(e.target.error);
  });
}
async function dbGetAll(store) {
  const db = await openDB();
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readonly');
    const req = tx.objectStore(store).getAll();
    req.onsuccess = () => res(req.result);
    req.onerror   = () => rej(req.error);
  });
}
async function dbPut(store, val) {
  const db = await openDB();
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readwrite');
    const req = tx.objectStore(store).put(val);
    req.onsuccess = () => res();
    req.onerror   = () => rej(req.error);
  });
}
async function dbDelete(store, id) {
  const db = await openDB();
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readwrite');
    const req = tx.objectStore(store).delete(id);
    req.onsuccess = () => res();
    req.onerror   = () => rej(req.error);
  });
}
async function dbGet(store, id) {
  const db = await openDB();
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readonly');
    const req = tx.objectStore(store).get(id);
    req.onsuccess = () => res(req.result);
    req.onerror   = () => rej(req.error);
  });
}

// ─────────────────────────────────────────────────────────────
// CZECH SUBJECT EXAM — handles mixed question types
// ─────────────────────────────────────────────────────────────

/* Normalize answers for comparison */
function czNorm(s) {
  return (s || '').trim().toLowerCase().replace(/\.$/, '');
}

/* ── Order question (click-to-build) ── */
function CzOrderQ({ question, value = {placed:[], available:null}, onChange, submitted }) {
  const initAvail = () => czShuffle ? czShuffle([...question.items]) : [...question.items].sort(() => Math.random()-.5);
  const placed    = value.placed    || [];
  const available = value.available || initAvail();

  const addWord = (word, idx) => {
    const newAvail = available.filter((_, i) => i !== idx);
    onChange({ placed: [...placed, word], available: newAvail });
  };
  const removeWord = (word, idx) => {
    const newPlaced = placed.filter((_, i) => i !== idx);
    onChange({ placed: newPlaced, available: [...available, word] });
  };

  if (submitted) {
    const isCorrect = JSON.stringify(placed) === JSON.stringify(question.correct);
    return (
      <div>
        <div style={{display:'flex',flexWrap:'wrap',gap:6,marginBottom:6}}>
          {placed.map((w,i) => <span key={i} style={{padding:'4px 10px',borderRadius:7,border:'1.5px solid',
            borderColor: isCorrect ? '#1a1a1a' : '#aaa',
            background: isCorrect ? '#f0f0f0' : '#fff',
            textDecoration: isCorrect ? 'none' : 'line-through',
            color: isCorrect ? '#1a1a1a' : '#999',
            fontSize:'.88rem'}}>{w}</span>)}
          {!isCorrect && <span style={{marginLeft:6,fontSize:'.78rem',fontWeight:600}}>✗</span>}
          {isCorrect && <span style={{marginLeft:6,fontSize:'.78rem',fontWeight:700}}>✓</span>}
        </div>
        {!isCorrect && (
          <div style={{display:'flex',flexWrap:'wrap',gap:6}}>
            <span style={{fontSize:'.78rem',color:'#888',alignSelf:'center'}}>Correct:</span>
            {question.correct.map((w,i) => <span key={i} style={{padding:'4px 10px',borderRadius:7,border:'1.5px solid #1a1a1a',background:'#f0f0f0',fontSize:'.88rem',fontWeight:600}}>{w}</span>)}
          </div>
        )}
      </div>
    );
  }

  return (
    <div>
      {/* Placed words */}
      <div style={{minHeight:42,border:'1.5px dashed #ccc',borderRadius:9,padding:'6px 8px',display:'flex',flexWrap:'wrap',gap:6,marginBottom:10,background:'#fafafa'}}>
        {placed.length === 0 && <span style={{color:'#bbb',fontSize:'.85rem',alignSelf:'center'}}>Click words below to build the sentence…</span>}
        {placed.map((w,i) => (
          <span key={i} onClick={() => removeWord(w,i)}
            style={{padding:'5px 12px',borderRadius:8,border:'1.5px solid #1a1a1a',background:'#f0f0f0',cursor:'pointer',fontSize:'.88rem',fontWeight:600,userSelect:'none'}}>
            {w}
          </span>
        ))}
      </div>
      {/* Available words */}
      <div style={{display:'flex',flexWrap:'wrap',gap:6}}>
        {available.map((w,i) => (
          <span key={i} onClick={() => addWord(w,i)}
            style={{padding:'5px 12px',borderRadius:8,border:'1.5px solid #ddd',background:'#fff',cursor:'pointer',fontSize:'.88rem',userSelect:'none',transition:'border .1s'}}
            onMouseEnter={e=>e.target.style.borderColor='#555'}
            onMouseLeave={e=>e.target.style.borderColor='#ddd'}>
            {w}
          </span>
        ))}
      </div>
    </div>
  );
}

/* ── Match question — wraps CzMatchSection ── */
function CzMatchQ({ question, value = {}, onChange, submitted }) {
  // Build a section-compatible object from pairs
  const section = {
    left:  question.pairs.map(p => p[0]),
    right: question.pairs.map(p => p[1]),
  };
  return <CzMatchSection section={section} value={value} onChange={onChange} submitted={submitted} />;
}

/* ── Text input question (open, fill, translate, errorCorrection) ── */
function CzTextQ({ question, value = '', onChange, submitted }) {
  const accepted = question.acceptedAnswers || (question.answer ? [question.answer] : []);
  const isCorrect = accepted.some(a => czNorm(a) === czNorm(value));

  if (submitted) {
    return (
      <div>
        <div className="cz-fb-row" style={{borderBottom:'none',paddingBottom:0}}>
          <span className="cz-fb-q">Your answer:</span>
          {!value.trim()
            ? <span className="cz-fb-open">— not answered{accepted[0] ? ` · correct: ${accepted[0]}` : ''}</span>
            : isCorrect
              ? <span className="cz-fb-right">{value} ✓</span>
              : <><span className="cz-fb-wrong">{value}</span><span className="cz-fb-correct"> {accepted[0]}</span></>
          }
        </div>
        {!isCorrect && accepted.length > 1 && (
          <div style={{fontSize:'.78rem',color:'#888',marginTop:3}}>Also accepted: {accepted.slice(1).join(' / ')}</div>
        )}
      </div>
    );
  }

  return (
    <input className="cz-text-field" placeholder="Your answer…"
      value={value} onChange={e => onChange(e.target.value)}
      style={{maxWidth:420}}/>
  );
}

/* ── Single question card ── */
function CzSubjectQuestion({ question, qIdx, answers, setAnswer, submitted }) {
  const val = answers[qIdx];
  const upd = (v) => setAnswer(qIdx, v);

  // For MCQ — reuse existing CzMCQSection logic inline
  const renderMCQ = () => {
    const chosen = val;
    const correctOpt = question.correct !== undefined ? question.options[question.correct] : null;
    const isCorrect  = chosen === correctOpt;
    return (
      <div>
        {submitted ? (
          <div>
            <div className="cz-fb-row" style={{borderBottom:'none'}}>
              <span className="cz-fb-q">Your answer:</span>
              {!chosen
                ? <span className="cz-fb-open">— not answered{correctOpt ? ` · correct: ${correctOpt}` : ''}</span>
                : isCorrect
                  ? <span className="cz-fb-right">{chosen} ✓</span>
                  : <><span className="cz-fb-wrong">{chosen}</span><span className="cz-fb-correct"> {correctOpt}</span></>
              }
            </div>
            {!isCorrect && question.explanation && (
              <div className="cz-fb-explanation">{question.explanation}</div>
            )}
          </div>
        ) : (
          <div className="cz-mcq-opts">
            {question.options.map((opt, oi) => (
              <span key={oi} className={`cz-mcq-opt${val === opt ? ' cz-active' : ''}`}
                onClick={() => upd(opt)}>{opt}</span>
            ))}
          </div>
        )}
      </div>
    );
  };

  const typeLabel = { open:'Open', fill:'Fill in', translate:'Translate', errorCorrection:'Correct the error', match:'Match', order:'Order', mcq:'MCQ' };

  return (
    <div style={{background:'#fff',borderRadius:12,padding:'18px 20px',marginBottom:12,boxShadow:'0 1px 4px rgba(0,0,0,.07)'}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:10}}>
        <span style={{fontSize:'.72rem',fontWeight:700,color:'#aaa',textTransform:'uppercase',letterSpacing:'.06em'}}>
          {typeLabel[question.type] || question.type}
        </span>
        <span style={{fontSize:'.72rem',color:'#ccc'}}>{'●'.repeat(question.difficulty || 1)}</span>
      </div>
      <p style={{fontSize:'.92rem',fontWeight:600,marginBottom:12,lineHeight:1.45,color:'#1a1a1a'}}>{question.q}</p>

      {question.type === 'mcq'                                         && renderMCQ()}
      {['open','fill','translate','errorCorrection'].includes(question.type) &&
        <CzTextQ question={question} value={val || ''} onChange={upd} submitted={submitted}/>}
      {question.type === 'match' && <CzMatchQ question={question} value={val || {}} onChange={upd} submitted={submitted}/>}
      {question.type === 'order' && <CzOrderQ question={question} value={val || {}} onChange={upd} submitted={submitted}/>}

      {/* Explanation — only after submit, only for non-MCQ (MCQ shows it inline) */}
      {submitted && question.type !== 'mcq' && question.explanation && (
        <div className="cz-fb-explanation" style={{marginTop:10}}>{question.explanation}</div>
      )}
    </div>
  );
}

/* ── Main subject exam screen ── */
function CzechSubjectExam({ bankKey, onBack }) {
  const bank = window.czechQuestionBanks?.[bankKey];
  const [answers, setAnswers]     = useState({});
  const [submitted, setSubmitted] = useState(false);
  const [filter, setFilter]       = useState('all'); // all | 1 | 2 | 3 | 4

  if (!bank) return (
    <div style={{padding:40,textAlign:'center',color:'#888'}}>
      Question bank "{bankKey}" not loaded.
    </div>
  );

  const allQs = bank.questions || [];
  const questions = filter === 'all' ? allQs : allQs.filter(q => q.difficulty === Number(filter));
  const setAnswer = (i, v) => setAnswers(prev => ({...prev, [i]: v}));

  // Score for MCQ/text types after submit
  const score = submitted ? (() => {
    let correct = 0, gradable = 0;
    questions.forEach((q, i) => {
      if (q.type === 'mcq') {
        gradable++;
        if (q.options[q.correct] === answers[i]) correct++;
      } else if (['open','fill','translate','errorCorrection'].includes(q.type)) {
        const accepted = q.acceptedAnswers || (q.answer ? [q.answer] : []);
        gradable++;
        if (accepted.some(a => czNorm(a) === czNorm(answers[i] || ''))) correct++;
      }
    });
    return { correct, gradable };
  })() : null;

  return (
    <div style={{maxWidth:760,margin:'0 auto',padding:'16px 12px 40px'}}>
      {/* Header */}
      <div className="czech-header">
        <button className="back-btn" onClick={onBack}>← Back to Czech</button>
        <h2>{bank.title}</h2>
        <div style={{display:'flex',gap:6,marginTop:12,flexWrap:'wrap'}}>
          {['all','1','2','3','4'].map(f => (
            <button key={f}
              style={{padding:'4px 14px',borderRadius:8,border:'1.5px solid rgba(255,255,255,.35)',
                background: filter===f ? '#fff' : 'transparent',
                color: filter===f ? '#1a1a1a' : '#fff',
                cursor:'pointer',fontSize:'.82rem',fontWeight:600}}
              onClick={() => { setFilter(f); setAnswers({}); setSubmitted(false); }}>
              {f === 'all' ? 'All levels' : `Level ${f}`}
            </button>
          ))}
        </div>
        {submitted && score && (
          <div style={{marginTop:10,fontSize:'.88rem',fontWeight:600,color:'rgba(255,255,255,.9)'}}>
            Score: {score.correct}/{score.gradable} gradable questions correct
          </div>
        )}
      </div>

      {/* Questions */}
      {questions.map((q, i) => (
        <CzSubjectQuestion key={`${bankKey}-${filter}-${i}`}
          question={q} qIdx={i}
          answers={answers} setAnswer={setAnswer}
          submitted={submitted}/>
      ))}

      {/* Submit / Retake */}
      <div className="cz-submit-row">
        {!submitted
          ? <button className="cz-submit-btn"
              onClick={() => { setSubmitted(true); window.scrollTo(0,0); }}>
              Check Answers
            </button>
          : <button className="cz-submit-btn" style={{background:'#555'}}
              onClick={() => { setAnswers({}); setSubmitted(false); window.scrollTo(0,0); }}>
              Try Again
            </button>
        }
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
// BOOK READER COMPONENT
// ─────────────────────────────────────────────────────────────
function BookReader({ bookId, bookTitle, onClose }) {
  const [pdfDoc, setPdfDoc]           = useState(null);
  const [pageNum, setPageNum]         = useState(1);
  const [total, setTotal]             = useState(0);
  const [rendering, setRendering]     = useState(false);
  const [loading, setLoading]         = useState(true);
  const [indexing, setIndexing]       = useState(false);
  const [textIndex, setTextIndex]     = useState([]);
  const [toc, setToc]                 = useState([]);
  const [showToc, setShowToc]         = useState(true);
  const POCKET_ATLAS_TOC = `Bones : 12\nSutures, Joints and Ligaments : 64\nMuscles : 84\nMuscles, Synovial bursae and sheaths : 110\nDigestive system : 118\nDigestive and Respiratory system : 144\nUrogenital system : 164\nPeritoneum : 186\nEndocrine glands : 192\nHeart : 194\nArteries : 200\nVeins : 240\nLymphatic system : 264\nSpleen, meninges : 278\nSpinal cord : 282\nBrain : 288\nCranial Nerves : 330\nSpinal Nerves : 344\nAutonomic nervous system : 358\nSense organs : 364\nSkin and its appendages : 400\nGeneral terms : 406\nReferences : 419\nIndex : 422`;
  const [manualTocInput, setManualTocInput] = useState(POCKET_ATLAS_TOC);
  const [showManualToc, setShowManualToc]   = useState(false);
  const [pageInput, setPageInput]     = useState('');
  const [editingPage, setEditingPage] = useState(false);
  const [showSearch, setShowSearch]   = useState(false);
  const [searchQuery, setSearchQuery] = useState('');
  const [searchResults, setSearchResults] = useState([]);
  const canvasRef  = useRef(null);
  const renderTask = useRef(null);
  const versionRef = useRef(0);
  const searchRef  = useRef(null);

  // ── Load PDF + index + TOC ──
  useEffect(() => {
    let alive = true;
    setLoading(true);
    pdfjsLib.GlobalWorkerOptions.workerSrc =
      'vendor/pdf.worker.min.js';

    (async () => {
      const [stored, idxRecord] = await Promise.all([
        dbGet('pdfs', bookId),
        dbGet('index', bookId),
      ]);
      if (!stored || !alive) return;

      const pdf = await pdfjsLib.getDocument({ data: stored.data }).promise;
      if (!alive) return;
      setPdfDoc(pdf);
      setTotal(pdf.numPages);
      setLoading(false);

      // ── TOC: try PDF outline first, then text-based extraction ──
      try {
        let chapters = [];

        // 1. Try built-in PDF bookmarks
        const outline = await pdf.getOutline();
        if (outline && outline.length > 0) {
          const resolvePageNum = async (dest) => {
            if (!dest) return null;
            let resolved = dest;
            if (typeof dest === 'string') resolved = await pdf.getDestination(dest);
            if (!resolved) return null;
            const idx = await pdf.getPageIndex(resolved[0]);
            return idx + 1;
          };
          const flatten = async (items, level = 0) => {
            const out = [];
            for (const item of items) {
              const page = await resolvePageNum(item.dest);
              if (page) out.push({ title: item.title, page, level });
              if (item.items?.length) out.push(...await flatten(item.items, level + 1));
            }
            return out;
          };
          chapters = await flatten(outline);
        }

        // 2. Fall back to text-based TOC extraction
        if (chapters.length === 0) {
          const tocLines = [];
          const scanPages = Math.min(pdf.numPages, 30);

          for (let i = 1; i <= scanPages; i++) {
            const page = await pdf.getPage(i);
            const ct   = await page.getTextContent();

            // ── Cluster text items into visual lines ──
            // Sort top-to-bottom (PDF Y is bottom=0, so descending Y = top first)
            const items = ct.items
              .filter(it => it.str && it.str.trim().length > 0)
              .map(it => ({ str: it.str, x: it.transform[4], y: it.transform[5] }))
              .sort((a, b) => b.y - a.y || a.x - b.x);

            // Group into lines: start new line when Y gap > 6pt from previous item's Y
            const lineGroups = [];
            let curLine = [];
            let prevY = null;
            for (const it of items) {
              if (prevY === null || Math.abs(it.y - prevY) <= 6) {
                curLine.push(it);
              } else {
                if (curLine.length) lineGroups.push(curLine);
                curLine = [it];
              }
              prevY = it.y;
            }
            if (curLine.length) lineGroups.push(curLine);

            for (const grp of lineGroups) {
              // Sort left-to-right within each line
              grp.sort((a, b) => a.x - b.x);
              const rawJoined = grp.map(g => g.str).join('');

              // Only process lines that contain real dot-leaders (4+ consecutive dots)
              // This filters out normal sentences that happen to end in a number
              if (!/\.{4,}/.test(rawJoined)) continue;

              // Strip dot-leaders and clean up whitespace
              const cleaned = rawJoined
                .replace(/[.·]{4,}/g, ' ')   // replace dot leaders with space
                .replace(/\s+/g, ' ')
                .trim();

              // Now cleaned should look like "bones 2" or "sutures joints and ligaments 54"
              const m = cleaned.match(/^(.{2,80}?)\s+(\d{1,4})\s*$/);
              if (m) {
                const title = m[1].trim().replace(/[,\s]+$/, '');
                const pg    = parseInt(m[2]);
                if (title.length >= 2 && !/^\d+$/.test(title) && pg > 0 && pg <= pdf.numPages) {
                  tocLines.push({ title, page: pg, level: 0 });
                }
              }
            }
          }

          // Deduplicate + sort by page
          const seen = new Set();
          const deduped = tocLines
            .filter(e => {
              const k = e.title.toLowerCase() + '|' + e.page;
              if (seen.has(k)) return false;
              seen.add(k);
              return true;
            })
            .sort((a, b) => a.page - b.page);

          if (deduped.length >= 1) chapters = deduped;
        }

        if (alive && chapters.length > 0) {
          setToc(chapters);
        } else if (alive) {
          // Auto-extract failed — open manual entry panel so user can save in one click
          setShowManualToc(true);
        }
      } catch(e) {
        console.warn('TOC extraction failed:', e);
        if (alive) setShowManualToc(true);
      }

      // ── Text index: use stored or re-extract ──
      if (idxRecord && idxRecord.pages && idxRecord.pages.length > 0) {
        if (alive) setTextIndex(idxRecord.pages);
      } else {
        // Re-index entire book
        if (alive) setIndexing(true);
        const pages = [];
        for (let i = 1; i <= pdf.numPages; i++) {
          if (!alive) break;
          const page = await pdf.getPage(i);
          const ct   = await page.getTextContent();
          const text = ct.items.map(x => x.str).join(' ').trim();
          if (text.length > 5) pages.push({ page: i, text });
        }
        await dbPut('index', { id: bookId, pages });
        if (alive) { setTextIndex(pages); setIndexing(false); }
      }
    })();

    return () => { alive = false; };
  }, [bookId]);

  // ── Render current page ──
  useEffect(() => {
    if (!pdfDoc || !canvasRef.current) return;
    const version = ++versionRef.current;
    if (renderTask.current) { renderTask.current.cancel(); renderTask.current = null; }
    setRendering(true);
    pdfDoc.getPage(pageNum).then(page => {
      if (version !== versionRef.current) return;
      const viewport = page.getViewport({ scale: 1.5 });
      const canvas = canvasRef.current;
      if (!canvas) return;
      canvas.width  = viewport.width;
      canvas.height = viewport.height;
      const task = page.render({ canvasContext: canvas.getContext('2d'), viewport });
      renderTask.current = task;
      task.promise
        .then(() => { if (version === versionRef.current) setRendering(false); })
        .catch(() => {});
    });
  }, [pdfDoc, pageNum]);

  // ── Search ──
  function handleSearch(val) {
    setSearchQuery(val);
    if (val.trim().length < 2) { setSearchResults([]); return; }
    const q = val.toLowerCase();
    const hits = [];
    textIndex.forEach(p => {
      const lower = p.text.toLowerCase();
      if (lower.includes(q)) {
        const idx     = lower.indexOf(q);
        const snippet = p.text.slice(Math.max(0, idx - 50), idx + 120).trim();
        hits.push({ page: p.page, snippet });
      }
    });
    setSearchResults(hits.slice(0, 40));
  }

  function goTo(n) {
    if (rendering) return;
    setPageNum(Math.max(1, Math.min(total, n)));
  }
  function jumpTo(page) {
    goTo(page);
    setShowSearch(false);
    setSearchQuery('');
    setSearchResults([]);
  }

  // Keyboard navigation (left/right arrows)
  React.useEffect(() => {
    function onKey(e) {
      if (editingPage) return;           // don't navigate while typing in page input
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); goTo(pageNum + 1); }
      if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); goTo(pageNum - 1); }
    }
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [pageNum, total, rendering, editingPage]);

  return (
    <>
      <div className="book-reader-overlay" onClick={onClose} />
      <div className="book-reader">
        <div className="book-reader-inner">

          {/* Header */}
          <div className="book-reader-header">
            <button className="book-reader-toc-btn" title="Table of contents"
              onClick={() => setShowToc(s => !s)}>TOC</button>
            <span className="book-reader-title">{bookTitle}</span>
            <div className="book-reader-nav">
              <button onClick={() => goTo(pageNum - 1)} disabled={pageNum <= 1 || rendering}>‹</button>
              {editingPage ? (
                <input
                  type="number" min="1" max={total}
                  value={pageInput}
                  autoFocus
                  onChange={e => setPageInput(e.target.value)}
                  onKeyDown={e => {
                    if (e.key === 'Enter') {
                      const n = parseInt(pageInput);
                      if (!isNaN(n)) goTo(n);
                      setEditingPage(false);
                    }
                    if (e.key === 'Escape') setEditingPage(false);
                  }}
                  onBlur={() => {
                    const n = parseInt(pageInput);
                    if (!isNaN(n)) goTo(n);
                    setEditingPage(false);
                  }}
                  style={{width:52,textAlign:'center',fontSize:13,border:'1px solid #ccc',borderRadius:6,padding:'2px 4px'}}
                />
              ) : (
                <span
                  title="Click to jump to page"
                  style={{cursor:'pointer',borderBottom:'1px dashed #aaa',paddingBottom:1}}
                  onClick={() => { setPageInput(String(pageNum)); setEditingPage(true); }}
                >{pageNum} / {total}</span>
              )}
              <button onClick={() => goTo(pageNum + 1)} disabled={pageNum >= total || rendering}>›</button>
            </div>
            {indexing && <span style={{fontSize:11,color:'#aaa',fontStyle:'italic'}}>Indexing…</span>}
            <button className="book-reader-search-btn" title="Search in book"
              onClick={() => { setShowSearch(s => !s); setTimeout(() => searchRef.current?.focus(), 50); }}>⌕</button>
            <button className="book-reader-close" onClick={onClose}>Close</button>
          </div>

          {/* Search bar */}
          {showSearch && (
            <div className="book-search-bar">
              <input ref={searchRef} type="text" placeholder="Search in this book…"
                value={searchQuery} onChange={e => handleSearch(e.target.value)} />
              {searchQuery.length >= 2 && (
                <div className="book-search-count">
                  {searchResults.length > 0 ? `${searchResults.length} result${searchResults.length !== 1 ? 's' : ''}` : 'No results'}
                </div>
              )}
            </div>
          )}

          {/* Search results */}
          {showSearch && searchResults.length > 0 && (
            <div className="book-search-results">
              {searchResults.map((r, i) => (
                <div key={i} className="book-search-result" onClick={() => jumpTo(r.page)}>
                  <span className="book-search-page">p.{r.page}</span>
                  <span className="book-search-snippet">…{r.snippet}…</span>
                </div>
              ))}
            </div>
          )}

          {/* Body: TOC sidebar + canvas */}
          <div className="book-reader-body">
            {showToc && (
              <div className="book-toc-sidebar">
                <div className="book-toc-label">Contents</div>

                {toc.length > 0 ? (
                  <>
                    {toc.map((item, i) => (
                      <div key={i}
                        className={`book-toc-item${item.page === pageNum ? ' active' : ''}`}
                        style={{ paddingLeft: 12 + item.level * 14 }}
                        onClick={() => jumpTo(item.page)}
                      >
                        <span className="book-toc-title">{item.title}</span>
                        <span className="book-toc-page">{item.page}</span>
                      </div>
                    ))}
                    <div style={{marginTop:12,paddingTop:10,borderTop:'1px solid rgba(0,0,0,0.1)'}}>
                      <button
                        style={{fontSize:11,color:'#888',background:'none',border:'1px solid #ccc',borderRadius:6,padding:'3px 8px',cursor:'pointer',width:'100%'}}
                        onClick={()=>setShowManualToc(v=>!v)}
                      >{showManualToc ? 'Cancel' : 'Edit chapters manually'}</button>
                    </div>
                  </>
                ) : (
                  <div style={{padding:'8px 0'}}>
                    <div style={{fontSize:12,color:'#999',marginBottom:10,lineHeight:1.5}}>
                      Couldn't auto-detect chapters. Enter them manually:
                    </div>
                    <button
                      style={{fontSize:12,background:'#222',color:'#fff',border:'none',borderRadius:8,padding:'6px 14px',cursor:'pointer',width:'100%',marginBottom:8}}
                      onClick={()=>setShowManualToc(v=>!v)}
                    >{showManualToc ? 'Cancel' : '+ Add chapters'}</button>
                  </div>
                )}

                {showManualToc && (
                  <div style={{marginTop:8}}>
                    <div style={{fontSize:11,color:'#888',marginBottom:6,lineHeight:1.5}}>
                      One chapter per line:<br/>
                      <code style={{background:'#f5f5f5',padding:'2px 4px',borderRadius:4}}>Title : PageNumber</code>
                    </div>
                    <textarea
                      value={manualTocInput}
                      onChange={e=>setManualTocInput(e.target.value)}
                      placeholder={"bones : 2\nsutures and joints : 54\nmuscles : 80"}
                      style={{width:'100%',minHeight:140,fontSize:12,padding:8,border:'1px solid #ccc',borderRadius:8,resize:'vertical',fontFamily:'monospace'}}
                    />
                    <button
                      style={{marginTop:6,background:'#1a1a1a',color:'#fff',border:'none',borderRadius:8,padding:'7px 14px',cursor:'pointer',fontSize:13,width:'100%'}}
                      onClick={()=>{
                        const lines = manualTocInput.split('\n').map(l=>l.trim()).filter(Boolean);
                        const entries = [];
                        lines.forEach(ln => {
                          const sep = ln.lastIndexOf(':');
                          if (sep < 0) return;
                          const title = ln.slice(0, sep).trim();
                          const pg = parseInt(ln.slice(sep+1).trim());
                          if (title && !isNaN(pg) && pg > 0) entries.push({ title, page: pg, level: 0 });
                        });
                        if (entries.length > 0) {
                          setToc(entries.sort((a,b) => a.page - b.page));
                          setShowManualToc(false);
                        }
                      }}
                    >Save chapters</button>
                  </div>
                )}
              </div>
            )}
            <div className="book-canvas-wrap">
              {loading
                ? <div className="book-reader-loading">Loading book…</div>
                : <canvas ref={canvasRef} />
              }
            </div>
          </div>

        </div>
      </div>
    </>
  );
}


function BookShelf({ onBooksChange, onOpenBook }) {
  const [books, setBooks]           = useState([]);
  const [processing, setProcessing] = useState(false);
  const [progress, setProgress]     = useState('');
  const fileRef = useRef(null);

  useEffect(() => {
    dbGetAll('meta').then(list => { setBooks(list); onBooksChange(list); });
  }, []);

  async function handleFile(e) {
    const file = e.target.files[0];
    if (!file || !file.name.endsWith('.pdf')) return;
    setProcessing(true);
    setProgress('Reading PDF…');
    try {
      pdfjsLib.GlobalWorkerOptions.workerSrc =
        'vendor/pdf.worker.min.js';
      const arrayBuf = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuf.slice(0) }).promise;
      const id = Date.now();
      const maxPages = Math.min(pdf.numPages, 400);
      const pages = [];
      for (let i = 1; i <= maxPages; i++) {
        if (i % 20 === 0) setProgress(`Reading page ${i} / ${maxPages}…`);
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        const text = content.items.map(x => x.str).join(' ').trim();
        if (text.length > 20) pages.push({ page: i, text });
      }
      const meta = {
        id, title: file.name.replace(/\.pdf$/i, ''),
        pageCount: pdf.numPages,
        color: SPINE_COLORS[books.length % SPINE_COLORS.length],
      };
      await dbPut('meta',  meta);
      await dbPut('pdfs',  { id, data: arrayBuf });
      await dbPut('index', { id, pages });
      const updated = [...books, meta];
      setBooks(updated);
      onBooksChange(updated);
    } catch(err) {
      alert('Could not read PDF: ' + err.message);
    }
    setProcessing(false);
    setProgress('');
    e.target.value = '';
  }

  async function removeBook(book) {
    if (!confirm(`Remove "${book.title}"?`)) return;
    await dbDelete('meta',  book.id);
    await dbDelete('pdfs',  book.id);
    await dbDelete('index', book.id);
    const updated = books.filter(b => b.id !== book.id);
    setBooks(updated);
    onBooksChange(updated);
  }

  return (
    <div className="bookshelf-section">
      <div className="bookshelf-label">Library</div>
      <div className="bookshelf-shelf">
        {books.map(book => (
          <div
            key={book.id}
            className="book-spine"
            style={{ background: book.color, borderLeftColor: book.color?.replace('0.25','0.6') }}
            title={book.title + ' — click to open, right-click to remove'}
            onClick={() => onOpenBook(book)}
            onContextMenu={e => { e.preventDefault(); removeBook(book); }}
          >
            <span className="book-spine-title">{book.title}</span>
          </div>
        ))}
        <button className="book-add-btn" title="Add PDF book" onClick={() => fileRef.current.click()}>+</button>
        <input ref={fileRef} type="file" accept=".pdf" style={{ display:'none' }} onChange={handleFile} />
      </div>
      {processing && <div className="book-processing">{progress}</div>}
    </div>
  );
}

function SearchWidget({ books = [] }) {
  const [query, setQuery]       = useState('');
  const [results, setResults]   = useState([]);
  const [selected, setSelected] = useState(null);
  const [open, setOpen]         = useState(false);
  const wrapRef = useRef(null);

  useEffect(() => {
    function handleClick(e) {
      if (wrapRef.current && !wrapRef.current.contains(e.target)) {
        setOpen(false); setQuery(''); setResults([]); setSelected(null);
      }
    }
    document.addEventListener('mousedown', handleClick);
    return () => document.removeEventListener('mousedown', handleClick);
  }, []);

  function handleChange(e) {
    const val = e.target.value;
    setQuery(val);
    setSelected(null);
    if (val.trim().length < 2) { setResults([]); setOpen(false); return; }
    const q = val.toLowerCase();

    // Search question bank + atlas
    const staticHits = SEARCH_INDEX.filter(e =>
      e.term.toLowerCase().includes(q) ||
      e.topic.toLowerCase().includes(q) ||
      e.definition.toLowerCase().includes(q)
    ).slice(0, 6);

    // Search books
    const bookHits = [];
    books.forEach(book => {
      book.pages.forEach(p => {
        if (p.text.toLowerCase().includes(q) && bookHits.length < 4) {
          const idx = p.text.toLowerCase().indexOf(q);
          const snippet = p.text.slice(Math.max(0, idx - 60), idx + 120).trim();
          bookHits.push({
            term: val,
            topic: `${book.title} · p.${p.page}`,
            definition: snippet,
            source: 'book',
          });
        }
      });
    });

    setResults([...staticHits, ...bookHits].slice(0, 10));
    setOpen(true);
  }

  function handleSelect(item) {
    setSelected(item);
    setResults([]);
  }

  return (
    <div className="search-widget" ref={wrapRef}>
      <div className="search-input-wrap">
        <span className="search-icon">⌕</span>
        <input
          type="text"
          placeholder="Search a term…"
          value={query}
          onChange={handleChange}
          onFocus={() => results.length > 0 && setOpen(true)}
        />
      </div>

      {open && results.length > 0 && !selected && (
        <div className="search-panel">
          <div className="search-results-list">
            {results.map((item, i) => (
              <div key={i} className="search-result-item" onClick={() => handleSelect(item)}>
                <div>{item.term}</div>
                <div className="result-topic">{item.topic}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      {open && query.trim().length >= 2 && results.length === 0 && !selected && (
        <div className="search-panel">
          <div className="search-no-results">No results for "{query}"</div>
        </div>
      )}

      {selected && (
        <div className="search-panel">
          <div className="search-definition">
            <div className="def-term">{selected.term}</div>
            <div style={{ fontSize: 11, color: '#aaa', marginBottom: 8 }}>
              {selected.source === 'atlas' ? `${selected.topic}${selected.page ? ` · p.${selected.page}` : ''}` : selected.topic}
            </div>
            <div className="def-text">{selected.definition || '—'}</div>
          </div>
        </div>
      )}
    </div>
  );
}


// ─────────────────────────────────────────────────────────────
// FLIP CARD
// ─────────────────────────────────────────────────────────────
function FlipCard({ label, content }) {
  const [flipped, setFlipped] = React.useState(false);
  const backColors = {
    'Origin':      'rgba(210,60,60,0.15)',
    'Insertion':   'rgba(50,100,220,0.15)',
    'Innervation': 'rgba(210,185,40,0.15)',
    'Function':    'rgba(240,240,240,0.95)',
  };
  const backBorders = {
    'Origin':      '1px solid rgba(210,60,60,0.25)',
    'Insertion':   '1px solid rgba(50,100,220,0.25)',
    'Innervation': '1px solid rgba(210,185,40,0.30)',
    'Function':    '1px solid rgba(0,0,0,0.10)',
  };
  return (
    <div
      onClick={() => setFlipped(f => !f)}
      style={{
        perspective: '800px',
        width: '100%',
        height: '140px',
        cursor: 'pointer',
        userSelect: 'none',
      }}
    >
      <div style={{
        position: 'relative',
        width: '100%',
        height: '100%',
        transformStyle: 'preserve-3d',
        transition: 'transform 0.5s',
        transform: flipped ? 'rotateY(180deg)' : 'none',
      }}>
        {/* Front */}
        <div style={{
          position: 'absolute', inset: 0,
          backfaceVisibility: 'hidden',
          background: 'rgba(210,210,210,0.85)',
          border: '1px solid rgba(0,0,0,0.12)',
          borderRadius: '12px',
          display: 'flex', alignItems: 'center', justifyContent: 'center',
          color: '#1a1a1a', fontSize: '1rem', fontWeight: 700,
          letterSpacing: '0.02em',
          boxShadow: '0 2px 8px rgba(0,0,0,0.10)',
        }}>
          {label}
        </div>
        {/* Back */}
        <div style={{
          position: 'absolute', inset: 0,
          backfaceVisibility: 'hidden',
          transform: 'rotateY(180deg)',
          background: backColors[label] || 'rgba(240,240,240,0.95)',
          border: backBorders[label] || '1px solid rgba(0,0,0,0.10)',
          borderRadius: '12px',
          display: 'flex', alignItems: 'center', justifyContent: 'center',
          padding: '12px',
          color: '#222', fontSize: '0.88rem', lineHeight: 1.45, textAlign: 'center',
          boxShadow: '0 2px 8px rgba(0,0,0,0.10)',
        }}>
          {content}
        </div>
      </div>
    </div>
  );
}

// ─────────────────────────────────────────────────────────────
// MUSCLE LAB
// ─────────────────────────────────────────────────────────────
function MuscleLab({ onBack }) {
  const bank = window.MUSCLE_BANK || [];
  const [idx, setIdx] = React.useState(0);
  const [imageFlipped, setImageFlipped] = React.useState(false);
  const muscle = bank[idx];

  /* Reset image flip whenever the selected muscle changes */
  React.useEffect(() => { setImageFlipped(false); }, [idx]);

  /* Build two-level sidebar: { regionName: { groupName: [muscleObj,...] } } */
  const regions = React.useMemo(() => {
    const map = {};
    bank.forEach(m => {
      if (!map[m.region]) map[m.region] = {};
      if (!map[m.region][m.group]) map[m.region][m.group] = [];
      map[m.region][m.group].push(m);
    });
    return map;
  }, [bank]);

  /* Which region headers are open */
  const [openRegions, setOpenRegions] = React.useState(() => new Set([bank[0]?.region]));

  /* Auto-open the region whenever the selected muscle changes */
  React.useEffect(() => {
    if (muscle) setOpenRegions(prev => new Set([...prev, muscle.region]));
  }, [muscle?.region]);

  if (!muscle) {
    return (
      <div className="content">
        <button className="topbar-back" onClick={onBack}>← Anatomy</button>
        <p style={{ marginTop: '1rem', color: '#666' }}>No muscles in the bank yet.</p>
      </div>
    );
  }

  return (
    <div style={{ display: 'flex', minHeight: '100vh', background: '#fff' }}>

      {/* ── Sidebar ── */}
      <div style={{
        width: 200, flexShrink: 0,
        borderRight: '1px solid rgba(0,0,0,0.10)',
        padding: '24px 0',
        overflowY: 'auto',
        background: 'rgba(248,247,245,0.95)',
      }}>
        <button
          className="topbar-back"
          onClick={onBack}
          style={{ margin: '0 16px 20px', display: 'block' }}
        >← Anatomy</button>

        {Object.entries(regions).map(([regionName, groups]) => {
          const isOpen = openRegions.has(regionName);
          const toggleRegion = () => setOpenRegions(prev => {
            const next = new Set(prev);
            if (next.has(regionName)) next.delete(regionName);
            else next.add(regionName);
            return next;
          });
          return (
            <div key={regionName} style={{ marginBottom: '2px' }}>
              {/* Region header — clickable */}
              <div
                onClick={toggleRegion}
                style={{
                  padding: '8px 16px',
                  display: 'flex', alignItems: 'center', justifyContent: 'space-between',
                  fontSize: '0.75rem', fontWeight: 800,
                  color: '#1a1a1a', textTransform: 'uppercase', letterSpacing: '0.07em',
                  cursor: 'pointer',
                  background: isOpen ? 'rgba(0,0,0,0.04)' : 'transparent',
                  borderBottom: '1px solid rgba(0,0,0,0.07)',
                  userSelect: 'none',
                }}
              >
                <span>{regionName}</span>
                <span style={{ fontSize: '0.65rem', color: '#aaa', marginLeft: 4 }}>
                  {isOpen ? '▲' : '▼'}
                </span>
              </div>

              {/* Groups + muscles inside region */}
              {isOpen && Object.entries(groups).map(([groupName, muscles]) => (
                <div key={groupName} style={{ marginBottom: '4px' }}>
                  <div style={{
                    padding: '5px 16px 3px',
                    fontSize: '0.62rem', fontWeight: 700,
                    color: '#aaa', textTransform: 'uppercase', letterSpacing: '0.06em',
                  }}>
                    {groupName}
                  </div>
                  {muscles.map(m => {
                    const active = m.id === muscle.id;
                    return (
                      <div
                        key={m.id}
                        onClick={() => setIdx(bank.indexOf(m))}
                        style={{
                          padding: '7px 16px 7px 20px',
                          fontSize: '0.85rem',
                          fontWeight: active ? 700 : 400,
                          color: active ? '#1a1a1a' : '#444',
                          background: active ? 'rgba(0,0,0,0.07)' : 'transparent',
                          borderLeft: active ? '3px solid #1a1a1a' : '3px solid transparent',
                          cursor: 'pointer',
                          transition: 'background 0.15s',
                        }}
                      >
                        {m.name}
                      </div>
                    );
                  })}
                </div>
              ))}
            </div>
          );
        })}
      </div>

      {/* ── Main content ── */}
      <div style={{ flex: 1, padding: '32px 36px', overflowY: 'auto',
        display: 'flex', flexDirection: 'column', alignItems: 'center' }}>

        {/* Inner column — capped width, centred */}
        <div style={{ width: '100%', maxWidth: 700 }}>

          {/* Name / Image flip card — height driven by the image */}
          <div
            onClick={() => setImageFlipped(f => !f)}
            style={{
              perspective: '1200px',
              width: '100%',
              marginBottom: '1.6rem',
              cursor: 'pointer',
              userSelect: 'none',
            }}
          >
            <div style={{
              position: 'relative',
              width: '100%',
              transformStyle: 'preserve-3d',
              transition: 'transform 0.55s cubic-bezier(0.4,0.2,0.2,1)',
              transform: imageFlipped ? 'rotateY(180deg)' : 'none',
            }}>

              {/* Back — muscle image (position:relative → sets container height) */}
              <div style={{
                position: 'relative',
                backfaceVisibility: 'hidden',
                transform: 'rotateY(180deg)',
                borderRadius: '14px',
                overflow: 'hidden',
                border: '1px solid rgba(0,0,0,0.08)',
                background: 'rgba(0,0,0,0.03)',
              }}>
                {muscle.image
                  ? <img
                      src={muscle.image}
                      alt={muscle.name}
                      style={{ width: '100%', display: 'block', objectFit: 'contain' }}
                    />
                  : <div style={{ height: 220, display: 'flex', alignItems: 'center',
                      justifyContent: 'center', color: '#aaa', fontSize: '0.9rem' }}>
                      No image available
                    </div>
                }
              </div>

              {/* Front — muscle name (position:absolute → overlays on top, same size as image) */}
              <div style={{
                position: 'absolute', inset: 0,
                backfaceVisibility: 'hidden',
                background: 'rgba(245,244,242,0.95)',
                border: '1px solid rgba(0,0,0,0.09)',
                borderRadius: '14px',
                display: 'flex', flexDirection: 'column',
                alignItems: 'center', justifyContent: 'center',
                padding: '32px 24px',
                boxShadow: '0 2px 12px rgba(0,0,0,0.07)',
              }}>
                <div style={{ fontSize: '0.72rem', color: '#999', fontWeight: 600,
                  textTransform: 'uppercase', letterSpacing: '0.07em', marginBottom: 10 }}>
                  {muscle.region} — {muscle.group}
                </div>
                <h2 style={{ margin: 0, fontSize: '1.9rem', fontWeight: 800, color: '#1a1a1a', textAlign: 'center' }}>
                  {muscle.name}
                </h2>
                <div style={{ marginTop: 18, fontSize: '0.75rem', color: '#bbb', letterSpacing: '0.04em' }}>
                  tap to reveal image
                </div>
              </div>

            </div>
          </div>

          {/* Flip cards */}
          <div style={{
            display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '12px',
          }}>
            <FlipCard label="Origin"      content={muscle.origin} />
            <FlipCard label="Insertion"   content={muscle.insertion} />
            <FlipCard label="Innervation" content={muscle.innervation} />
            <FlipCard label="Function"    content={muscle.function} />
          </div>

        </div>
      </div>

    </div>
  );
}

/* ── Match the Organ — Peritoneal Relations ─────────────────────── */
function OrganSticker({ type, inv }) {
  const st = { width: 34, height: 34, display: 'block', flexShrink: 0 };
  const f = inv ? 'rgba(255,255,255,0.15)' : '#e8e8e8';
  const s = inv ? 'rgba(255,255,255,0.7)' : '#999';
  const sw = 1.6;
  switch (type) {
    case 'stomach':
      return <svg viewBox="0 0 32 32" style={st}><path d="M10 8 Q7 8 7 14 Q7 22 12 24 Q18 26 22 22 Q26 18 24 12 Q22 6 18 8 Q14 10 10 8Z" fill={f} stroke={s} strokeWidth={sw}/></svg>;
    case 'intestine':
      return <svg viewBox="0 0 32 32" style={st}><path d="M9 7 Q9 14 16 14 Q23 14 23 21 Q23 27 16 27 Q9 27 9 22" fill="none" stroke={s} strokeWidth={sw+0.6} strokeLinecap="round"/></svg>;
    case 'colon':
      return <svg viewBox="0 0 32 32" style={st}><path d="M8 25 L8 9 Q8 6 11 6 L21 6 Q24 6 24 9 L24 23 Q24 26 21 26 L11 26" fill="none" stroke={s} strokeWidth={sw+0.6} strokeLinecap="round" strokeLinejoin="round"/></svg>;
    case 'liver':
      return <svg viewBox="0 0 32 32" style={st}><path d="M6 17 Q5 9 14 7 Q22 5 26 12 Q29 18 22 23 Q15 27 10 24 Q6 21 6 17Z" fill={f} stroke={s} strokeWidth={sw}/></svg>;
    case 'solid':
      return <svg viewBox="0 0 32 32" style={st}><ellipse cx="16" cy="16" rx="11" ry="8" fill={f} stroke={s} strokeWidth={sw}/><path d="M10 16 Q16 13 22 16" fill="none" stroke={s} strokeWidth={0.8} opacity="0.5"/></svg>;
    case 'kidney':
      return <svg viewBox="0 0 32 32" style={st}><path d="M15 5 Q9 5 8 16 Q7 27 14 27 Q18 27 20 23 Q22 18 20 14 Q22 9 18 6 Q17 5 15 5Z" fill={f} stroke={s} strokeWidth={sw}/><path d="M14 13 Q16 16 14 20" fill="none" stroke={s} strokeWidth={1}/></svg>;
    case 'bladder':
      return <svg viewBox="0 0 32 32" style={st}><ellipse cx="16" cy="14" rx="10" ry="10" fill={f} stroke={s} strokeWidth={sw}/><path d="M13 23 Q13 28 16 28 Q19 28 19 23" fill={f} stroke={s} strokeWidth={sw}/></svg>;
    case 'tube':
      return <svg viewBox="0 0 32 32" style={st}><path d="M10 5 Q10 16 16 16 Q22 16 22 27" fill="none" stroke={s} strokeWidth={sw+0.8} strokeLinecap="round"/></svg>;
    case 'uterus':
      return <svg viewBox="0 0 32 32" style={st}><path d="M16 9 Q20 9 21 14 L21 21 Q21 26 16 26 Q11 26 11 21 L11 14 Q12 9 16 9Z" fill={f} stroke={s} strokeWidth={sw}/><path d="M11 14 Q8 10 6 12" fill="none" stroke={s} strokeWidth={sw} strokeLinecap="round"/><path d="M21 14 Q24 10 26 12" fill="none" stroke={s} strokeWidth={sw} strokeLinecap="round"/></svg>;
    case 'gland':
      return <svg viewBox="0 0 32 32" style={st}><path d="M16 7 Q23 9 24 16 Q24 23 18 25 Q12 27 9 22 Q6 17 9 11 Q12 6 16 7Z" fill={f} stroke={s} strokeWidth={sw}/></svg>;
    case 'prostate':
      return <svg viewBox="0 0 32 32" style={st}><path d="M16 8 Q23 8 24 15 Q25 22 18 25 Q16 26 14 25 Q7 22 8 15 Q9 8 16 8Z" fill={f} stroke={s} strokeWidth={sw}/><path d="M12 17 Q16 15 20 17" fill="none" stroke={s} strokeWidth={1} strokeLinecap="round"/></svg>;
    default:
      return <svg viewBox="0 0 32 32" style={st}><circle cx="16" cy="16" r="11" fill={f} stroke={s} strokeWidth={sw}/></svg>;
  }
}

function PeriotonealGame({ onBack }) {
  const CATEGORIES = [
    { id: 'intraperitoneal', title: 'Intraperitoneal', explanation: 'Organs covered almost completely by visceral peritoneum and usually suspended by a mesentery.' },
    { id: 'primary-retroperitoneal', title: 'Primary retroperitoneal', explanation: 'Organs that developed behind the peritoneum and were never suspended by a mesentery.' },
    { id: 'secondary-retroperitoneal', title: 'Secondary retroperitoneal', explanation: 'Organs that were originally intraperitoneal but became fused to the posterior abdominal wall during development.' },
    { id: 'subperitoneal', title: 'Subperitoneal / Infraperitoneal', explanation: 'Pelvic organs located below the peritoneum, only partly related to it superiorly.' },
  ];
  const ORGANS = [
    { id: 'stomach',           name: 'Stomach',                    category: 'intraperitoneal',         sticker: 'stomach'   },
    { id: 'jejunum',           name: 'Jejunum',                    category: 'intraperitoneal',         sticker: 'intestine' },
    { id: 'ileum',             name: 'Ileum',                      category: 'intraperitoneal',         sticker: 'intestine' },
    { id: 'spleen',            name: 'Spleen',                     category: 'intraperitoneal',         sticker: 'solid'     },
    { id: 'liver',             name: 'Liver',                      category: 'intraperitoneal',         sticker: 'liver'     },
    { id: 'gallbladder',       name: 'Gallbladder',                category: 'intraperitoneal',         sticker: 'bladder'   },
    { id: 'cecum-appendix',    name: 'Cecum + vermiform appendix', category: 'intraperitoneal',         sticker: 'colon'     },
    { id: 'transverse-colon',  name: 'Transverse colon',           category: 'intraperitoneal',         sticker: 'colon'     },
    { id: 'sigmoid-colon',     name: 'Sigmoid colon',              category: 'intraperitoneal',         sticker: 'colon'     },
    { id: 'uterine-tubes',     name: 'Uterine tubes',              category: 'intraperitoneal',         sticker: 'tube'      },
    { id: 'ovaries',           name: 'Ovaries',                    category: 'intraperitoneal',         sticker: 'gland'     },
    { id: 'uterus-fundus-body',name: 'Fundus/body of uterus',      category: 'intraperitoneal',         sticker: 'uterus'    },
    { id: 'kidneys',           name: 'Kidneys',                    category: 'primary-retroperitoneal', sticker: 'kidney'    },
    { id: 'suprarenal-glands', name: 'Suprarenal glands',          category: 'primary-retroperitoneal', sticker: 'gland'     },
    { id: 'ureters',           name: 'Ureters',                    category: 'primary-retroperitoneal', sticker: 'tube'      },
    { id: 'duodenum-parts-2-4',name: 'Duodenum parts 2-4',         category: 'secondary-retroperitoneal', sticker: 'intestine' },
    { id: 'pancreas',          name: 'Pancreas',                   category: 'secondary-retroperitoneal', sticker: 'solid'     },
    { id: 'ascending-colon',   name: 'Ascending colon',            category: 'secondary-retroperitoneal', sticker: 'colon'     },
    { id: 'descending-colon',  name: 'Descending colon',           category: 'secondary-retroperitoneal', sticker: 'colon'     },
    { id: 'upper-rectum',      name: 'Rectum (upper 2/3)',          category: 'secondary-retroperitoneal', sticker: 'colon'     },
    { id: 'urinary-bladder',   name: 'Urinary bladder',            category: 'subperitoneal',           sticker: 'bladder'   },
    { id: 'prostate',          name: 'Prostate',                   category: 'subperitoneal',           sticker: 'prostate'  },
    { id: 'seminal-glands',    name: 'Seminal glands',             category: 'subperitoneal',           sticker: 'gland'     },
    { id: 'uterine-cervix',    name: 'Uterine cervix',             category: 'subperitoneal',           sticker: 'uterus'    },
    { id: 'vagina',            name: 'Vagina',                     category: 'subperitoneal',           sticker: 'tube'      },
    { id: 'lower-rectum',      name: 'Rectum (lower 1/3)',          category: 'subperitoneal',           sticker: 'colon'     },
  ];

  function shuffle(arr) { const a=[...arr]; for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; }

  const [shuffled]  = useState(() => shuffle(ORGANS));
  const [placed, setPlaced] = useState({});
  const [selected, setSelected] = useState(null);
  const [checked, setChecked]   = useState(false);
  const [narrow, setNarrow]     = useState(window.innerWidth < 768);

  useEffect(() => {
    const h = () => setNarrow(window.innerWidth < 768);
    window.addEventListener('resize', h);
    return () => window.removeEventListener('resize', h);
  }, []);

  const bankOrgans   = shuffled.filter(o => !placed[o.id]);
  const inCat        = (catId) => ORGANS.filter(o => placed[o.id] === catId);
  const correctCount = ORGANS.filter(o => placed[o.id] === o.category).length;
  const totalPlaced  = Object.keys(placed).length;

  const onDragStart = (e, id) => { e.dataTransfer.setData('organId', id); e.dataTransfer.effectAllowed='move'; };
  const onDragOver  = (e) => { e.preventDefault(); e.dataTransfer.dropEffect='move'; };
  const dropIntoCat = (e, catId) => { e.preventDefault(); const id=e.dataTransfer.getData('organId'); if(id){setPlaced(p=>({...p,[id]:catId}));setChecked(false);} };
  const dropToBank  = (e) => { e.preventDefault(); const id=e.dataTransfer.getData('organId'); if(id){setPlaced(p=>{const n={...p};delete n[id];return n;});setChecked(false);} };

  const clickOrgan  = (id) => setSelected(s => s===id ? null : id);
  const clickPlaced = (e, id) => { e.stopPropagation(); setPlaced(p=>{const n={...p};delete n[id];return n;}); setSelected(null); setChecked(false); };
  const clickCat    = (catId) => { if(!selected)return; setPlaced(p=>({...p,[selected]:catId})); setSelected(null); setChecked(false); };
  const reset       = () => { setPlaced({}); setSelected(null); setChecked(false); };

  /* Organ card style (bank + inside zones) */
  const cardStyle = (o) => {
    const isSel    = selected === o.id;
    const correct  = checked && placed[o.id] === o.category;
    const wrong    = checked && placed[o.id] && placed[o.id] !== o.category;
    return {
      display: 'flex', alignItems: 'center', gap: 7,
      padding: '6px 10px 6px 7px', margin: '3px', borderRadius: 10,
      background: correct ? '#d4edda' : wrong ? '#f8d7da' : isSel ? '#1a1a1a' : '#fff',
      border: `1.5px solid ${correct ? '#b8dfc5' : wrong ? '#f0b8be' : isSel ? '#1a1a1a' : '#e0e0e0'}`,
      boxShadow: isSel ? '0 2px 8px rgba(0,0,0,0.18)' : '0 1px 3px rgba(0,0,0,0.07)',
      cursor: 'grab', userSelect: 'none', transition: 'all 0.12s',
    };
  };

  /* Zone drop-area style */
  const zoneStyle = (active) => ({
    borderRadius: 14, padding: '16px 16px 14px',
    border: `2px ${active ? 'dashed #888' : 'solid #e4e4e4'}`,
    background: active ? 'rgba(0,0,0,0.025)' : '#fafafa',
    cursor: active ? 'pointer' : 'default',
    transition: 'border 0.12s, background 0.12s',
    minHeight: 110,
    boxShadow: '0 1px 4px rgba(0,0,0,0.04)',
  });

  /* Organ card element (reused in bank and zones) */
  const OrganCard = ({ o, fromZone }) => (
    <div
      draggable
      onDragStart={e => { if(fromZone) e.stopPropagation(); onDragStart(e, o.id); }}
      onClick={e => fromZone ? clickPlaced(e, o.id) : clickOrgan(o.id)}
      style={cardStyle(o)}
      title={fromZone ? 'Click to return to bank' : 'Drag or tap to place'}
    >
      <OrganSticker type={o.sticker} inv={selected===o.id} />
      <span style={{ fontSize: 13, fontWeight: 500, color: selected===o.id ? '#fff' : '#1a1a1a', lineHeight: 1.2 }}>{o.name}</span>
    </div>
  );

  /* Zone header */
  const ZoneHeader = ({ cat }) => (
    <div style={{ marginBottom: 12, paddingBottom: 10, borderBottom: '1px solid rgba(0,0,0,0.07)' }}>
      <div style={{ fontWeight: 700, fontSize: 13, color: '#1a1a1a', letterSpacing: '.02em', textTransform: 'uppercase' }}>{cat.title}</div>
      <div style={{ fontSize: 11, color: '#b0b0b0', marginTop: 4, lineHeight: 1.5, fontWeight: 400, letterSpacing: '.01em' }}>{cat.explanation}</div>
    </div>
  );

  const refImg = (
    <img
      src="peritoneum/DAF36D83-A190-4AB5-9951-CA9DA4957481.png"
      alt="Peritoneal relations diagram"
      style={{ width: '100%', borderRadius: 12, boxShadow: '0 3px 14px rgba(0,0,0,0.12)', display: 'block' }}
    />
  );

  return (
    <div style={{ display: 'flex', flexDirection: narrow ? 'column' : 'row', alignItems: 'flex-start', gap: 24, maxWidth: 1140, margin: '0 auto', padding: '0 12px 56px' }}>

      {/* ── Game panel ── */}
      <div style={{ flex: 1, minWidth: 0 }}>

        {/* Sticky header */}
        <div style={{ position: 'sticky', top: 0, zIndex: 10, background: 'rgba(250,250,250,0.97)', paddingTop: 16, paddingBottom: 12, marginBottom: 18, borderBottom: '1px solid #e8e8e8' }}>
          <button className="topbar-back" onClick={onBack}>← Anatomy</button>
          <h2 style={{ margin: '8px 0 3px', fontSize: 18, fontWeight: 700, color: '#1a1a1a' }}>Match the Organ — Peritoneal Relations</h2>
          <div style={{ fontSize: 13, color: '#999' }}>
            {checked
              ? <span style={{ fontWeight: 600, color: correctCount === ORGANS.length ? '#2a7a4a' : '#1a1a1a' }}>Correct: {correctCount} / {ORGANS.length}</span>
              : <span>{totalPlaced} of {ORGANS.length} placed{selected ? <span style={{ color: '#555', fontWeight: 600 }}> — tap a zone to place</span> : ''}</span>}
          </div>
        </div>

        {/* Organ bank */}
        <div
          onDragOver={onDragOver}
          onDrop={dropToBank}
          style={{ background: '#f3f3f3', borderRadius: 14, padding: '12px 12px 10px', marginBottom: 20, minHeight: 60, boxShadow: 'inset 0 1px 3px rgba(0,0,0,0.05)' }}
        >
          <div style={{ fontSize: 10, fontWeight: 800, color: '#bbb', textTransform: 'uppercase', letterSpacing: '.08em', marginBottom: 8 }}>
            {bankOrgans.length > 0 ? `Organ bank — ${bankOrgans.length} remaining` : 'All organs placed — drag here to return'}
          </div>
          <div style={{ display: 'flex', flexWrap: 'wrap' }}>
            {bankOrgans.map(o => <OrganCard key={o.id} o={o} fromZone={false} />)}
          </div>
        </div>

        {/* ── Relation board ── */}
        <div style={{ background: '#f0f0f0', borderRadius: 20, padding: '20px 18px', boxShadow: '0 3px 16px rgba(0,0,0,0.08)', border: '1px solid #e0e0e0' }}>
          <div style={{ textAlign: 'center', fontSize: 10, fontWeight: 800, color: '#b8b8b8', textTransform: 'uppercase', letterSpacing: '.12em', marginBottom: 18 }}>Peritoneal Relations Board</div>

          {/* Intraperitoneal */}
          <div
            onDragOver={onDragOver}
            onDrop={e => dropIntoCat(e, 'intraperitoneal')}
            onClick={() => clickCat('intraperitoneal')}
            style={{ ...zoneStyle(!!selected), background: selected ? 'rgba(60,120,220,0.05)' : '#eef1fa', border: `2px ${selected ? 'dashed #7799dd' : 'solid #ccd5ee'}` }}
          >
            <ZoneHeader cat={CATEGORIES[0]} />
            <div style={{ display: 'flex', flexWrap: 'wrap', minHeight: 52 }}>
              {inCat('intraperitoneal').length === 0
                ? <span style={{ color: '#b8c2d8', fontSize: 12, alignSelf: 'center' }}>Drop intraperitoneal organs here</span>
                : inCat('intraperitoneal').map(o => <OrganCard key={o.id} o={o} fromZone={true} />)}
            </div>
          </div>

          {/* Peritoneum membrane divider */}
          <div style={{ position: 'relative', margin: '16px 4px', textAlign: 'center' }}>
            <div style={{ borderTop: '2px dashed #c0c0c0', position: 'absolute', top: '50%', left: 0, right: 0 }}></div>
            <span style={{ position: 'relative', background: '#f0f0f0', padding: '0 12px', fontSize: 10, fontWeight: 800, color: '#b0b0b0', textTransform: 'uppercase', letterSpacing: '.1em' }}>peritoneum</span>
          </div>

          {/* Retroperitoneal row */}
          <div style={{ display: 'flex', gap: 12, marginBottom: 0 }}>
            {/* Primary retroperitoneal */}
            <div
              onDragOver={onDragOver}
              onDrop={e => dropIntoCat(e, 'primary-retroperitoneal')}
              onClick={() => clickCat('primary-retroperitoneal')}
              style={{ ...zoneStyle(!!selected), flex: 1, background: selected ? 'rgba(0,0,0,0.02)' : '#f3f2ef', border: `2px ${selected ? 'dashed #aaa' : 'solid #dbd8d2'}` }}
            >
              <ZoneHeader cat={CATEGORIES[1]} />
              <div style={{ display: 'flex', flexWrap: 'wrap', minHeight: 52 }}>
                {inCat('primary-retroperitoneal').length === 0
                  ? <span style={{ color: '#c8c4bc', fontSize: 12, alignSelf: 'center' }}>Drop here</span>
                  : inCat('primary-retroperitoneal').map(o => <OrganCard key={o.id} o={o} fromZone={true} />)}
              </div>
            </div>
            {/* Secondary retroperitoneal */}
            <div
              onDragOver={onDragOver}
              onDrop={e => dropIntoCat(e, 'secondary-retroperitoneal')}
              onClick={() => clickCat('secondary-retroperitoneal')}
              style={{ ...zoneStyle(!!selected), flex: 1, background: selected ? 'rgba(0,0,0,0.02)' : '#f3f2ef', border: `2px ${selected ? 'dashed #aaa' : 'solid #dbd8d2'}` }}
            >
              <ZoneHeader cat={CATEGORIES[2]} />
              <div style={{ display: 'flex', flexWrap: 'wrap', minHeight: 52 }}>
                {inCat('secondary-retroperitoneal').length === 0
                  ? <span style={{ color: '#c8c4bc', fontSize: 12, alignSelf: 'center' }}>Drop here</span>
                  : inCat('secondary-retroperitoneal').map(o => <OrganCard key={o.id} o={o} fromZone={true} />)}
              </div>
            </div>
          </div>

          {/* Pelvic divider */}
          <div style={{ position: 'relative', margin: '16px 4px', textAlign: 'center' }}>
            <div style={{ borderTop: '2px dashed #c0c0c0', position: 'absolute', top: '50%', left: 0, right: 0 }}></div>
            <span style={{ position: 'relative', background: '#f0f0f0', padding: '0 12px', fontSize: 10, fontWeight: 800, color: '#b0b0b0', textTransform: 'uppercase', letterSpacing: '.1em' }}>pelvic floor</span>
          </div>

          {/* Subperitoneal */}
          <div
            onDragOver={onDragOver}
            onDrop={e => dropIntoCat(e, 'subperitoneal')}
            onClick={() => clickCat('subperitoneal')}
            style={{ ...zoneStyle(!!selected), background: selected ? 'rgba(120,60,180,0.04)' : '#f2f0f8', border: `2px ${selected ? 'dashed #aa88cc' : 'solid #d8d0ec'}` }}
          >
            <ZoneHeader cat={CATEGORIES[3]} />
            <div style={{ display: 'flex', flexWrap: 'wrap', minHeight: 52 }}>
              {inCat('subperitoneal').length === 0
                ? <span style={{ color: '#c0b8d4', fontSize: 12, alignSelf: 'center' }}>Drop subperitoneal organs here</span>
                : inCat('subperitoneal').map(o => <OrganCard key={o.id} o={o} fromZone={true} />)}
            </div>
          </div>
        </div>

        {/* Action buttons */}
        <div style={{ display: 'flex', gap: 10, marginTop: 16 }}>
          <button
            onClick={() => setChecked(true)}
            disabled={totalPlaced === 0}
            style={{ flex: 1, padding: '12px 0', borderRadius: 11, border: 'none', background: '#1a1a1a', color: '#fff', fontWeight: 700, fontSize: 14, cursor: totalPlaced===0 ? 'not-allowed' : 'pointer', opacity: totalPlaced===0 ? 0.35 : 1, boxShadow: totalPlaced===0 ? 'none' : '0 2px 8px rgba(0,0,0,0.15)' }}
          >
            Check answers
          </button>
          <button
            onClick={reset}
            style={{ padding: '12px 22px', borderRadius: 11, border: '1.5px solid #d0d0d0', background: '#fff', color: '#555', fontWeight: 600, fontSize: 14, cursor: 'pointer', boxShadow: '0 1px 4px rgba(0,0,0,0.06)' }}
          >
            Reset
          </button>
        </div>
        {checked && (
          <div style={{ marginTop: 12, padding: '12px 16px', borderRadius: 11, background: correctCount===ORGANS.length ? '#d4edda' : '#f5f5f5', border: `1.5px solid ${correctCount===ORGANS.length ? '#b8dfc5' : '#e8e8e8'}`, fontSize: 14, fontWeight: 600, color: '#1a1a1a' }}>
            {correctCount === ORGANS.length
              ? 'All organs correctly placed.'
              : `${correctCount} of ${ORGANS.length} correct — incorrect organs highlighted in red. Click them to return to the bank.`}
          </div>
        )}
      </div>

      {/* ── Reference image ── */}
      <div style={narrow ? { width: '100%', order: -1, marginBottom: 8 } : { width: 300, flexShrink: 0, position: 'sticky', top: 16 }}>
        {!narrow && <div style={{ fontSize: 10, fontWeight: 800, color: '#bbb', textTransform: 'uppercase', letterSpacing: '.08em', marginBottom: 8 }}>Reference image</div>}
        {refImg}
      </div>

    </div>
  );
}

function App() {
  const [subject, setSubject]       = useState(null);
  const [examIndex, setExamIndex]   = useState(null);
  const [specialMode, setSpecialMode] = useState(null); // {type:'anatomy_slides'} | {type:'czech_credit',testKey:'A'}
  const [books, setBooks]           = useState([]);
  const [openBook, setOpenBook]     = useState(null);

  const meta     = subject ? QUESTION_BANK[subject] : null;
  const hasExams = meta?.exams != null;

  function handleSelectSubject(name) {
    setSubject(name);
    setExamIndex(null);
    setSpecialMode(null);
  }
  function handleExamSelect(val) {
    if (val && typeof val === 'object') {
      setSpecialMode(val);
    } else {
      setExamIndex(val);
    }
  }
  function handleBack() {
    if (specialMode) {
      setSpecialMode(null);
    } else if (hasExams && examIndex !== null) {
      setExamIndex(null);
    } else {
      setSubject(null);
      setExamIndex(null);
      setSpecialMode(null);
    }
  }

  return (
    <div className="app">
      <SearchWidget books={books} />
      {specialMode?.type === 'anatomy_slides'
        ? <AnatomyTest onBack={handleBack} />
        : specialMode?.type === 'czech_credit'
          ? <CzechCreditTest testKey={specialMode.testKey} onBack={handleBack} />
          : specialMode?.type === 'czech_subject'
            ? <CzechSubjectExam bankKey={specialMode.bankKey} onBack={handleBack} />
          : specialMode?.type === 'muscle_lab'
            ? <MuscleLab onBack={handleBack} />
          : specialMode?.type === 'peritoneal_game'
            ? <PeriotonealGame onBack={handleBack} />
          : !subject
            ? <HomeScreen
                onSelectSubject={handleSelectSubject}
                onBooksChange={setBooks}
                onOpenBook={setOpenBook}
              />
            : hasExams && examIndex === null
              ? <ExamPicker subject={subject} onSelectExam={handleExamSelect} onBack={() => { setSubject(null); setExamIndex(null); setSpecialMode(null); }} />
              : <ExamScreen subject={subject} examIndex={examIndex} onBack={handleBack} />
      }
      {openBook && (
        <BookReader bookId={openBook.id} bookTitle={openBook.title} onClose={() => setOpenBook(null)} />
      )}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>

<!-- PWA: Register service worker for offline support -->
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function() {
      navigator.serviceWorker.register('/sw.js').then(function(reg) {
        console.log('Study Buddy SW registered, scope:', reg.scope);
      }).catch(function(err) {
        console.log('Study Buddy SW registration failed:', err);
      });
    });
  }
</script>
</body>
</html>
