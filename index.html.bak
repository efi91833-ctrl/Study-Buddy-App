  {id:"histo10-015",topic:"Skin",subtopic:"Cells",difficulty:"Very hard",question:"Which cell senses touch?",options:{A:"Melanocyte",B:"Merkel cell",C:"Langerhans",D:"Keratinocyte"},correct:"B",explanation:"Mechanoreceptor."},
